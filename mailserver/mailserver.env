OVERRIDE_HOSTNAME=mail.alvarezplacas.com.ar
LOG_LEVEL=info
SUPERVISOR_LOGLEVEL=warn
SSL_TYPE=manual
SSL_CERT_PATH=/etc/letsencrypt/live/alvarezplacas.com.ar/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/alvarezplacas.com.ar/privkey.pem
ENABLE_SPAMASSASSIN=1
ENABLE_CLAMAV=0
ENABLE_FAIL2BAN=1
ENABLE_POSTGREY=0
ONE_DIR=1
DMS_DEBUG=0
PERMIT_DOCKER=network
