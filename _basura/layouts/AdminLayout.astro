---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;

// Mocked admin user info for UI
const adminUser = {
    name: "Javier Alvarez",
    role: "Administrador General",
    avatar: "https://api.dicebear.com/7.x/initials/svg?seed=JA&backgroundColor=ff2800"
};
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title} | Alvarez Placas Admin</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		
		<!-- Font Awesome -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
	</head>
	<body class="bg-[#111111] text-gray-200 font-sans antialiased flex h-screen overflow-hidden">
		
        <!-- Mobile Sidebar Overlay -->
        <div id="mobile-overlay" class="fixed inset-0 bg-black/80 z-40 hidden md:hidden backdrop-blur-sm transition-opacity"></div>

        <!-- Sidebar Navigation -->
        <aside id="sidebar" class="fixed md:static inset-y-0 left-0 z-50 w-72 bg-[#1a1a1a] border-r border-gray-800 flex flex-col transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out">
            <!-- Logo Area -->
            <div class="h-20 flex items-center justify-center border-b border-gray-800 px-6 shrink-0">
                <a href="/admin" class="text-xl font-bold tracking-tight text-white flex items-center gap-2 w-full">
                    <i class="fas fa-shield-alt text-primary flex-shrink-0"></i>
                    <span class="truncate">PANEL <span class="text-primary">ADMIN</span></span>
                </a>
                <button id="close-sidebar" class="md:hidden text-gray-400 hover:text-white p-2">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>

            <!-- User Profile Area -->
            <div class="p-6 border-b border-gray-800 shrink-0">
                <div class="flex items-center gap-4">
                    <img src={adminUser.avatar} alt="Admin" class="w-12 h-12 rounded-full border-2 border-primary/50 shadow-[0_0_10px_rgba(255,40,0,0.3)]" />
                    <div class="overflow-hidden">
                        <h4 class="text-white font-bold text-sm truncate">{adminUser.name}</h4>
                        <p class="text-primary-light font-medium text-xs truncate">{adminUser.role}</p>
                    </div>
                </div>
            </div>

            <!-- Navigation Links -->
            <nav class="flex-1 overflow-y-auto py-6 px-4 space-y-2 custom-scrollbar">
                
                <p class="px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Principal</p>
                <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-all group active-nav-marker relative">
                    <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-0 bg-primary rounded-r-full transition-all group-hover:h-8 hidden marker-div"></div>
                    <i class="fas fa-chart-line w-5 text-center group-hover:text-primary transition-colors"></i>
                    <span class="font-medium">Dashboard</span>
                </a>

                <div class="h-4"></div> <!-- Spacer -->
                
                <p class="px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Gestión de Catálogo</p>
                <a href="/admin/catalogo" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-all group active-nav-marker relative">
                    <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-0 bg-primary rounded-r-full transition-all group-hover:h-8 hidden marker-div"></div>
                    <i class="fas fa-book-open w-5 text-center group-hover:text-primary transition-colors"></i>
                    <span class="font-medium">Productos y Excel</span>
                </a>

                <div class="h-4"></div> <!-- Spacer -->

                <p class="px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Usuarios y Roles</p>
                <a href="/admin/clientes" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-all group active-nav-marker relative">
                    <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-0 bg-primary rounded-r-full transition-all group-hover:h-8 hidden marker-div"></div>
                    <i class="fas fa-users w-5 text-center group-hover:text-primary transition-colors"></i>
                    <span class="font-medium">Clientes Registrados</span>
                </a>
                <a href="/admin/vendedores" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-all group active-nav-marker relative">
                    <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-0 bg-primary rounded-r-full transition-all group-hover:h-8 hidden marker-div"></div>
                    <i class="fas fa-user-tie w-5 text-center group-hover:text-primary transition-colors"></i>
                    <span class="font-medium">Gestión Vendedores</span>
                </a>

                <div class="h-4"></div> <!-- Spacer -->

                <p class="px-4 text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Configuración</p>
                <a href="/admin/settings" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-all group disabled cursor-not-allowed opacity-50 relative">
                    <i class="fas fa-cog w-5 text-center"></i>
                    <span class="font-medium">Ajustes Gloables</span>
                    <i class="fas fa-lock text-[10px] ml-auto"></i>
                </a>
            </nav>

            <!-- Bottom Actions -->
            <div class="p-4 border-t border-gray-800 shrink-0">
                <a href="/" target="_blank" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all w-full text-left mb-2">
                    <i class="fas fa-external-link-alt w-5 text-center"></i>
                    <span class="font-medium">Ver Tienda</span>
                </a>
                <button id="logout-btn" class="flex items-center gap-3 px-4 py-3 rounded-lg text-red-400 hover:text-red-300 hover:bg-red-400/10 transition-all w-full text-left">
                    <i class="fas fa-sign-out-alt w-5 text-center"></i>
                    <span class="font-medium">Cerrar Sesión</span>
                </button>
            </div>
        </aside>

        <!-- Main Content Wrapper -->
        <div class="flex-1 flex flex-col h-screen overflow-hidden relative">
            
            <!-- Top Header -->
            <header class="h-20 bg-[#1a1a1a]/80 backdrop-blur-md border-b border-gray-800 flex items-center justify-between px-4 sm:px-6 lg:px-8 z-30 shrink-0">
                <div class="flex items-center gap-4">
                    <button id="open-sidebar" class="md:hidden text-gray-400 hover:text-white p-2 focus:outline-none">
                        <i class="fas fa-bars text-xl"></i>
                    </button>
                    <!-- Título de Página Dinámico (opcional, se puede pasar via slot o props) -->
                    <h1 class="text-xl font-bold text-white hidden sm:block">{title}</h1>
                </div>

                <div class="flex items-center gap-4">
                    <!-- Notifications -->
                    <button class="relative p-2 text-gray-400 hover:text-white transition-colors focus:outline-none rounded-full hover:bg-white/5">
                        <i class="far fa-bell text-xl"></i>
                        <span class="absolute top-1 right-1 w-2.5 h-2.5 bg-primary rounded-full border-2 border-[#1a1a1a]"></span>
                    </button>
                </div>
            </header>

            <!-- Main Scrollable Area -->
            <main class="flex-1 overflow-x-hidden overflow-y-auto bg-[#111111] custom-scrollbar relative">
                <!-- Decorative Glow -->
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-lg h-32 bg-primary/5 rounded-full blur-[100px] pointer-events-none z-0"></div>
                
                <div class="relative z-10 p-4 sm:p-6 lg:p-8 max-w-7xl mx-auto w-full">
                    <slot />
                </div>
            </main>
        </div>

	</body>
</html>

<style>
    /* Estilos para el scrollbar en el panel de admin */
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
        height: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #333;
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #555;
    }

    /* Active nav marker class dynamically added */
    .nav-active {
        background-color: rgba(255, 255, 255, 0.05);
        color: white;
    }
    .nav-active .marker-div {
        display: block;
        height: 60%;
    }
    .nav-active i {
        color: var(--color-primary, #ff2800);
    }
</style>

<script>
    // Componente Client-Side para la UI básica
    document.addEventListener('astro:page-load', () => {
        const sidebar = document.getElementById('sidebar');
        const openBtn = document.getElementById('open-sidebar');
        const closeBtn = document.getElementById('close-sidebar');
        const overlay = document.getElementById('mobile-overlay');

        function openMenu() {
            if(sidebar && overlay) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                // timeout to allow display block to apply before animating opacity
                setTimeout(() => overlay.classList.remove('opacity-0'), 10);
            }
        }

        function closeMenu() {
            if(sidebar && overlay) {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        }

        if(openBtn) openBtn.addEventListener('click', openMenu);
        if(closeBtn) closeBtn.addEventListener('click', closeMenu);
        if(overlay) overlay.addEventListener('click', closeMenu);

        // Logout logic
        const logoutBtn = document.getElementById('logout-btn');
        if (logoutBtn) {
            logoutBtn.addEventListener('click', () => {
                window.location.href = '/api/auth/logout';
            });
        }

        // Lógica simple para marcar Link activo
        const currentPath = window.location.pathname;
        const navLinks = document.querySelectorAll('aside nav a.active-nav-marker');
        
        navLinks.forEach(link => {
            const href = link.getAttribute('href');
            // Exact match for /admin, or starts with for subpages (very rudimentary, improve as needed)
            if (href) {
                if (href === '/admin' && currentPath === '/admin') {
                    link.classList.add('nav-active');
                } else if (href !== '/admin' && currentPath.startsWith(href)) {
                    link.classList.add('nav-active');
                }
            }
        });
    });
</script>
