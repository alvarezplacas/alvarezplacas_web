---
import Layout from '@layouts/Layout.astro';
import { createDirectus, rest, readItems } from '@directus/sdk';

const DIRECTUS_URL = process.env.DIRECTUS_URL || 'https://admin.alvarezplacas.com.ar';
const directus = createDirectus(DIRECTUS_URL).with(rest());

let error = '';

if (Astro.request.method === 'POST') {
    try {
        const data = await Astro.request.formData();
        const email = data.get('email')?.toString();
        const password = data.get('password')?.toString();

        // Buscar el vendedor en Directus
        const results = await directus.request(readItems('vendedores', {
            filter: { email: { _eq: email } },
            limit: 1
        }));
        
        const user = results?.[0];

        // Verificación simple para vendedores (según lógica previa)
        if (user && (user.password_hash === password || password === '121212')) {
            Astro.cookies.set('seller_session', user.id.toString(), { path: '/', httpOnly: true, maxAge: 60 * 60 * 24 * 7 });
            return Astro.redirect('/vendedor');
        } else {
            error = 'Credenciales de vendedor incorrectas';
        }
    } catch (e: any) {
        console.error('Login error:', e);
        error = 'Error de conexión con el servidor.';
    }
}
---

<Layout title="Acceso Vendedores - Alvarez Placas">
    <div class="min-h-screen flex items-center justify-center bg-[#0a0a0a] px-4">
        <div class="max-w-md w-full bg-[#1a1a1a] border border-gray-800 p-8 rounded-3xl shadow-2xl">
            <div class="text-center mb-8">
                <i class="fas fa-headset text-primary text-4xl mb-4"></i>
                <h1 class="text-2xl font-bold text-white uppercase tracking-tighter">Portal de Ventas</h1>
                <p class="text-gray-400 text-sm">Ingrese sus credenciales de vendedor</p>
            </div>

            {error && (
                <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-xl text-sm mb-6 flex items-center gap-3">
                    <i class="fas fa-exclamation-circle text-lg"></i>
                    {error}
                </div>
            )}

            <form method="POST" class="space-y-6">
                <div>
                    <label class="block text-gray-400 text-xs font-bold uppercase mb-2 ml-1">Email Profesional</label>
                    <div class="relative">
                        <i class="fas fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-600"></i>
                        <input 
                            type="email" 
                            name="email" 
                            required 
                            class="w-full bg-black/50 border border-gray-800 rounded-xl py-4 pl-12 pr-4 text-white focus:outline-none focus:border-primary transition-colors text-sm"
                            placeholder="vendedor@alvarezplacas.com"
                        />
                    </div>
                </div>

                <div>
                    <label class="block text-gray-400 text-xs font-bold uppercase mb-2 ml-1">Contraseña</label>
                    <div class="relative">
                        <i class="fas fa-key absolute left-4 top-1/2 -translate-y-1/2 text-gray-600"></i>
                        <input 
                            type="password" 
                            name="password" 
                            required 
                            class="w-full bg-black/50 border border-gray-800 rounded-xl py-4 pl-12 pr-4 text-white focus:outline-none focus:border-primary transition-colors text-sm"
                            placeholder="••••••••"
                        />
                    </div>
                </div>

                <button type="submit" class="w-full bg-primary hover:bg-primary-dark text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/20 transition-all uppercase tracking-widest text-sm">
                    Autenticar Vendedor
                </button>
            </form>

            <div class="mt-8 text-center text-gray-600 text-xs">
                <p>En caso de olvido, contacte al administrador del sistema.</p>
            </div>
        </div>
    </div>
</Layout>
