---
import Layout from '@layouts/Layout.astro';
import BottomNav from '@components/BottomNav.astro';

// POC: Mock materials list
const products = [
    { id: 1, name: "Placa Egger Olmo Alpino 18mm", price: 54000 },
    { id: 2, name: "Placa Faplac Seda Giorno 18mm", price: 42000 },
    { id: 3, name: "MDF Crudo 18mm", price: 32000 },
    { id: 4, name: "Tapacanto PVC 22mm x 0.45mm (ml)", price: 850 },
];
---

<Layout title="Generador de Presupuestos PRO | Alvarez Placas">
    <main class="bg-[#0a0a0a] min-h-screen pb-24">
        <!-- Header Profesional -->
        <div class="bg-[#111111] border-b border-white/5 py-8 px-4 sm:px-8">
            <div class="max-w-5xl mx-auto flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                    <h1 class="text-3xl font-black text-white uppercase tracking-tighter">Budgeter <span class="text-primary italic">PRO</span></h1>
                    <p class="text-gray-500 font-medium text-sm mt-1">Crea presupuestos para tus clientes con tu propia marca.</p>
                </div>
                <div class="flex items-center gap-4">
                    <div class="text-right hidden sm:block">
                        <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest leading-tight">Proveedor Oficial</p>
                        <p class="text-xs text-white font-black">Alvarezplacas SRL</p>
                    </div>
                    <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center border border-primary/20">
                        <i class="fas fa-certificate text-primary"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="max-w-5xl mx-auto p-4 sm:p-8 grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- Herramientas de Configuración -->
            <div class="lg:col-span-1 space-y-6">
                <section class="bg-[#111111] border border-white/10 rounded-2xl p-6 shadow-xl">
                    <h3 class="text-white font-bold mb-6 flex items-center gap-2 text-sm uppercase tracking-wider">
                        <i class="fas fa-cog text-primary"></i> Tu Configuración
                    </h3>
                    
                    <div class="space-y-4">
                        <div>
                            <label class="block text-[10px] text-gray-500 uppercase font-black mb-2 ml-1">Tu Margen de Ganancia (%)</label>
                            <input type="number" id="profitMargin" value="30" class="w-full bg-black border border-gray-800 rounded-xl px-4 py-3 text-white font-bold outline-none focus:border-primary transition-all">
                        </div>
                        <div>
                            <label class="block text-[10px] text-gray-500 uppercase font-black mb-2 ml-1">Impuestos / Varios (%)</label>
                            <input type="number" id="taxMargin" value="0" class="w-full bg-black border border-gray-800 rounded-xl px-4 py-3 text-white font-bold outline-none focus:border-primary transition-all">
                        </div>
                    </div>
                </section>

                <section class="bg-[#111111] border border-white/10 rounded-2xl p-6 shadow-xl">
                    <h3 class="text-white font-bold mb-6 flex items-center gap-2 text-sm uppercase tracking-wider">
                        <i class="fas fa-plus-circle text-blue-500"></i> Agregar Materiales
                    </h3>
                    <div class="space-y-2 max-h-60 overflow-y-auto pr-2 custom-scrollbar">
                        {products.map(p => (
                            <button onclick={`addItem(${JSON.stringify(p)})`} class="w-full text-left p-3 rounded-xl bg-black hover:bg-white/5 border border-gray-800 transition-all group flex justify-between items-center">
                                <div>
                                    <p class="text-xs text-white font-bold line-clamp-1">{p.name}</p>
                                    <p class="text-[10px] text-gray-500">${p.price}</p>
                                </div>
                                <i class="fas fa-plus text-[10px] text-gray-700 group-hover:text-primary transition-colors"></i>
                            </button>
                        ))}
                    </div>
                    
                    <div class="mt-6 pt-6 border-t border-white/5 space-y-4">
                        <button onclick="addCustomItem()" class="w-full py-3 bg-white/5 hover:bg-white/10 text-white font-bold rounded-xl text-xs uppercase tracking-widest border border-white/10 transition-all">
                            + Item Personalizado (Mano de obra, etc)
                        </button>
                    </div>
                </section>
            </div>

            <!-- Previsualización del Presupuesto -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-[2rem] shadow-2xl overflow-hidden text-black min-h-[800px] flex flex-col" id="budgetPreview">
                    <!-- Header del Budget -->
                    <div class="p-10 border-b-2 border-gray-100 flex justify-between items-start">
                        <div>
                            <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mb-4 text-gray-400 border-2 border-dashed border-gray-200">
                                <i class="fas fa-image"></i>
                            </div>
                            <h2 class="text-2xl font-black uppercase tracking-tighter" contenteditable="true">TU NOMBRE / MARCA</h2>
                            <p class="text-gray-400 text-xs font-bold uppercase tracking-widest" contenteditable="true">Arquitecto / Carpintería de Diseño</p>
                        </div>
                        <div class="text-right">
                            <h3 class="text-4xl font-black text-gray-100 uppercase tracking-tighter leading-none mb-1">PRESUPUESTO</h3>
                            <p class="text-gray-400 text-xs font-bold">FECHA: {new Date().toLocaleDateString()}</p>
                        </div>
                    </div>

                    <!-- Items Table -->
                    <div class="p-10 flex-grow">
                        <table class="w-full mb-10">
                            <thead>
                                <tr class="border-b-2 border-black text-[10px] font-black uppercase tracking-widest">
                                    <th class="py-4 text-left">Descripción</th>
                                    <th class="py-4 text-center">Cant.</th>
                                    <th class="py-4 text-right">Precio Unit.</th>
                                    <th class="py-4 text-right">Subtotal</th>
                                    <th class="py-4"></th>
                                </tr>
                            </thead>
                            <tbody id="budgetItemsBody" class="divide-y divide-gray-100">
                                <!-- JS Populated -->
                            </tbody>
                        </table>
                    </div>

                    <!-- Footer / Totales -->
                    <div class="p-10 bg-gray-50 border-t-2 border-gray-100">
                        <div class="flex flex-col md:flex-row justify-between gap-8">
                            <div class="max-w-xs">
                                <p class="text-[10px] font-black text-black uppercase tracking-widest mb-4">Notas y Validez</p>
                                <p class="text-[10px] text-gray-500 leading-relaxed" contenteditable="true">
                                    Presupuesto válido por 5 días. Los precios están sujetos a cambios sin previo aviso según disponibilidad de stock.
                                </p>
                                <div class="mt-8 pt-8 border-t border-gray-200">
                                    <p class="text-[8px] font-bold text-gray-400 uppercase tracking-[0.2em]">Proveedor oficial de materiales</p>
                                    <p class="text-[10px] font-black text-gray-800">Alvarezplacas SRL</p>
                                </div>
                            </div>
                            <div class="flex flex-col gap-2 min-w-[200px]">
                                <div class="flex justify-between text-xs font-bold text-gray-500 uppercase">
                                    <span>Materiales</span>
                                    <span id="subtotalLabel">$0</span>
                                </div>
                                <div class="flex justify-between text-xs font-bold text-gray-500 uppercase">
                                    <span>Margen Profesional</span>
                                    <span id="marginLabel">$0</span>
                                </div>
                                <div class="flex justify-between items-end border-t-2 border-black pt-4 mt-2">
                                    <span class="text-xs font-black uppercase">Total Final</span>
                                    <span class="text-3xl font-black tracking-tighter" id="totalLabel">$0</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Botones Acción -->
                <div class="mt-8 flex gap-4">
                    <button onclick="window.print()" class="flex-1 py-5 bg-white text-black font-black rounded-2xl uppercase tracking-widest text-sm shadow-xl hover:scale-[1.02] transition-all flex items-center justify-center gap-3">
                        <i class="fas fa-file-pdf"></i> Descargar / Imprimir
                    </button>
                </div>
            </div>
        </div>
    </main>

    <style>
        @media print {
            body * { visibility: hidden; background: white !important; }
            #budgetPreview, #budgetPreview * { visibility: visible; }
            #budgetPreview { 
                position: absolute; 
                left: 0; 
                top: 0; 
                width: 100%; 
                height: auto;
                box-shadow: none !important;
                border: none !important;
            }
            .no-print { display: none !important; }
        }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }
    </style>

    <script is:inline>
        let items = [];

        window.addItem = (product) => {
            const existing = items.find(i => i.id === product.id && i.type === 'product');
            if (existing) {
                existing.quantity++;
            } else {
                items.push({ ...product, quantity: 1, type: 'product' });
            }
            renderItems();
        };

        window.addCustomItem = () => {
            const name = prompt("Descripción del item (ej: Mano de obra, Herrajes):");
            const price = parseFloat(prompt("Precio de costo:"));
            if (name && !isNaN(price)) {
                items.push({ id: Date.now(), name, price, quantity: 1, type: 'custom' });
                renderItems();
            }
        };

        window.removeItem = (id) => {
            items = items.filter(i => i.id !== id);
            renderItems();
        };

        window.renderItems = () => {
            const body = document.getElementById('budgetItemsBody');
            const margin = parseFloat(document.getElementById('profitMargin').value) / 100;
            const tax = parseFloat(document.getElementById('taxMargin').value) / 100;
            
            body.innerHTML = '';
            let rawSubtotal = 0;

            items.forEach(item => {
                const subtotal = item.price * item.quantity;
                rawSubtotal += subtotal;
                
                // Calculamos el precio para el cliente final (con el margen aplicado)
                const clientUnitPrice = item.price * (1 + margin);
                const clientSubtotal = clientUnitPrice * item.quantity;

                const row = document.createElement('tr');
                row.className = "group";
                row.innerHTML = `
                    <td class="py-6 text-sm font-bold text-gray-800">${item.name}</td>
                    <td class="py-6 text-center text-sm font-bold text-gray-500">${item.quantity}</td>
                    <td class="py-6 text-right text-sm font-bold text-gray-500">$${clientUnitPrice.toLocaleString()}</td>
                    <td class="py-6 text-right text-sm font-black">$${clientSubtotal.toLocaleString()}</td>
                    <td class="py-6 text-right no-print">
                        <button onclick="removeItem(${item.id})" class="text-gray-300 hover:text-red-500 px-2 transition-colors">
                            <i class="fas fa-trash-alt text-[10px]"></i>
                        </button>
                    </td>
                `;
                body.appendChild(row);
            });

            const marginAmount = rawSubtotal * margin;
            const subtotalWithMargin = rawSubtotal + marginAmount;
            const taxes = subtotalWithMargin * tax;
            const finalTotal = subtotalWithMargin + taxes;

            document.getElementById('subtotalLabel').textContent = `$${rawSubtotal.toLocaleString()}`;
            document.getElementById('marginLabel').textContent = `$${marginAmount.toLocaleString()}`;
            document.getElementById('totalLabel').textContent = `$${finalTotal.toLocaleString()}`;
        };

        // Listen for margin changes
        document.getElementById('profitMargin').addEventListener('input', renderItems);
        document.getElementById('taxMargin').addEventListener('input', renderItems);
    </script>
</Layout>
