---
/**
 * Componente de Notas Rápidas (Ayuda Memoria)
 * Estilo Adobe Photoshop - Panel de Notas/Capas
 */
import { directus, readItems } from '@conexiones/directus.js';

interface Props {
    vendedor_id: string;
}

const { vendedor_id } = Astro.props;

// Fetch de las últimas notas no completadas
let notas = [];
try {
    notas = await directus.request(readItems('vendedor_notas', {
        filter: {
            vendedor_id: { _eq: parseInt(vendedor_id) || vendedor_id },
            completada: { _eq: false },
            es_recordatorio: { _eq: false }
        },
        sort: ['-date_created'],
        limit: 10
    }));
} catch (e) {
    console.error("Error cargando notas rápidas:", e);
}
---

<div class="bg-[#252525] border border-[#111] rounded shadow-2xl flex flex-col h-full overflow-hidden" style="font-family: 'Inter', sans-serif;" id="quick-notes-container">
    <!-- Header -->
    <div class="h-8 bg-[#333] border-b border-[#111] flex items-center px-3 justify-between shrink-0">
        <span class="text-[10px] font-bold uppercase tracking-wider text-white"><i class="fas fa-thumbtack text-gray-400 mr-1 rotate-45"></i> Notas Rápidas</span>
        <div class="flex gap-2">
            <button id="add-note-btn" class="hover:text-white text-gray-400 transition-colors tooltip-trigger" data-tooltip="Nueva Nota">
                <i class="fas fa-plus text-[10px]"></i>
            </button>
        </div>
    </div>

    <!-- Lista de Notas -->
    <div class="flex-1 overflow-y-auto custom-scrollbar p-2 space-y-2 bg-[#1a1a1a]" id="notes-list">
        {notas.length === 0 ? (
            <div class="p-4 text-center">
                <p class="text-[11px] text-gray-500 italic">Sin notas pendientes</p>
            </div>
        ) : (
            notas.map((nota) => (
                <div class="group relative bg-[#2d2d2d] border border-[#111] p-2 hover:bg-[#3d3d3d] transition-all cursor-default select-none rounded-sm">
                    <div class="flex items-start gap-2">
                        <div class={`w-1 self-stretch rounded-full ${nota.urgencia === 'alta' ? 'bg-red-500' : nota.urgencia === 'media' ? 'bg-amber-500' : 'bg-green-500'} tooltip-trigger`} data-tooltip={`Prioridad: ${nota.urgencia || 'Baja'}`}></div>
                        <button class="mt-1 w-3 h-3 border border-white/20 rounded-full hover:border-primary transition-colors complete-note-btn tooltip-trigger" data-tooltip="Completar" data-id={nota.id}>
                        </button>
                        <div class="flex-1 min-w-0">
                            <p class="text-[11px] text-gray-200 leading-tight" style="font-family: 'Inter', sans-serif;">{nota.contenido}</p>
                            <div class="flex items-center gap-2 mt-1">
                                {nota.relacion_tipo && nota.relacion_tipo !== 'general' && (
                                    <span class="text-[8px] bg-primary/20 text-primary px-1 rounded uppercase font-bold tracking-tighter">
                                        {nota.relacion_tipo}
                                    </span>
                                )}
                                <span class="text-[8px] opacity-30 italic">
                                    {new Date(nota.date_created).toLocaleDateString()}
                                </span>
                            </div>
                        </div>
                        <button class="opacity-0 group-hover:opacity-100 text-gray-500 hover:text-red-500 transition-all delete-note-btn tooltip-trigger" data-tooltip="Eliminar Permanentemente" data-id={nota.id}>
                            <i class="fas fa-trash-alt text-[9px]"></i>
                        </button>
                    </div>
                </div>
            ))
        )}
    </div>

    <!-- Input Rápido (Oculto por defecto) -->
    <div id="new-note-form" class="hidden p-2 bg-[#333] border-t border-[#111] shrink-0">
        <textarea 
            id="note-input" 
            placeholder="Escribe una nota..." 
            class="w-full bg-[#1e1e1e] border border-[#111] rounded p-2 text-[11px] text-white focus:outline-none focus:border-primary transition-all resize-none h-16 custom-scrollbar"
        ></textarea>
        <div class="flex flex-wrap items-center justify-between gap-2 mt-2">
            <div class="flex gap-1 items-center bg-[#1e1e1e] p-1 rounded border border-[#111]">
                <button class="urgency-btn w-5 h-5 rounded flex items-center justify-center text-green-500 hover:bg-green-500/10 transition-colors tooltip-trigger" data-urgency="baja" data-tooltip="Prioridad Baja">
                    <i class="fas fa-circle text-[8px]"></i>
                </button>
                <button class="urgency-btn w-5 h-5 rounded flex items-center justify-center text-amber-500 hover:bg-amber-500/10 transition-colors tooltip-trigger" data-urgency="media" data-tooltip="Prioridad Media">
                    <i class="fas fa-exclamation-circle text-[8px]"></i>
                </button>
                <button class="urgency-btn w-5 h-5 rounded flex items-center justify-center text-red-500 hover:bg-red-500/10 transition-colors tooltip-trigger" data-urgency="alta" data-tooltip="Prioridad Alta">
                    <i class="fas fa-fire text-[8px]"></i>
                </button>
                <input type="hidden" id="note-urgencia" value="baja" />
            </div>
            
            <select id="note-rel" class="bg-[#1e1e1e] border border-[#111] text-[9px] text-white rounded px-1 h-5 outline-none">
                <option value="general">General</option>
                <option value="cliente">Cliente</option>
                <option value="pedido">Pedido</option>
            </select>
            
            <div class="flex items-center gap-2">
                <input type="checkbox" id="note-is-reminder" class="w-3 h-3 accent-primary" />
                <label for="note-is-reminder" class="text-[9px] text-gray-400">Recordatorio</label>
            </div>
            
            <input type="datetime-local" id="note-date" class="hidden bg-[#1e1e1e] border border-[#111] text-[9px] text-white rounded px-1 h-5 outline-none" />
            
            <div class="flex gap-1 ml-auto">
                <button id="cancel-note" class="text-[9px] px-2 py-1 text-gray-300 hover:bg-white/5 rounded">Cancelar</button>
                <button id="save-note" class="text-[9px] bg-primary text-white px-2 py-1 rounded font-bold transition-all flex items-center gap-1 hover:brightness-110">
                    <span id="save-note-text">Guardar</span>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Usamos el ID del vendedor que viene del servidor (inyectado vía dataset o global)
    document.addEventListener('DOMContentLoaded', () => {
        const addBtn = document.getElementById('add-note-btn');
        const form = document.getElementById('new-note-form');
        const cancelBtn = document.getElementById('cancel-note');
        const saveBtn = document.getElementById('save-note');
        const input = document.getElementById('note-input') as HTMLTextAreaElement;
        const relSelect = document.getElementById('note-rel') as HTMLSelectElement;
        const isReminder = document.getElementById('note-is-reminder') as HTMLInputElement;
        const dateInput = document.getElementById('note-date') as HTMLInputElement;
        const urgencyInput = document.getElementById('note-urgencia') as HTMLInputElement;
        const urgencyBtns = document.querySelectorAll('.urgency-btn');

        // Manejo de botones de urgencia
        urgencyBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                urgencyBtns.forEach(b => b.classList.remove('bg-white/10', 'ring-1', 'ring-white/20'));
                btn.classList.add('bg-white/10', 'ring-1', 'ring-white/20');
                if (urgencyInput) urgencyInput.value = btn.getAttribute('data-urgency') || 'baja';
                
                // Cambiar el color de fondo del textarea segun prioridad
                const u = urgencyInput.value;
                input.classList.remove('border-[#111]', 'border-red-500', 'border-amber-500', 'border-green-500', 'bg-[#1e1e1e]', 'bg-red-500/10', 'bg-amber-500/10', 'bg-green-500/10');
                if(u === 'alta') input.classList.add('border-red-500', 'bg-red-500/10');
                else if(u === 'media') input.classList.add('border-amber-500', 'bg-amber-500/10');
                else if(u === 'baja') input.classList.add('border-green-500', 'bg-green-500/10');
                else input.classList.add('border-[#111]', 'bg-[#1e1e1e]');
            });
        });

        if (isReminder && dateInput) {
            isReminder.addEventListener('change', () => {
                dateInput.classList.toggle('hidden', !isReminder.checked);
            });
        }

        if (addBtn && form) {
            addBtn.addEventListener('click', () => {
                form.classList.toggle('hidden');
                if (!form.classList.contains('hidden')) input.focus();
            });
        }

        if (cancelBtn) {
            cancelBtn.addEventListener('click', () => {
                form?.classList.add('hidden');
                if (input) input.value = '';
            });
        }

        if (saveBtn) {
            const saveText = document.getElementById('save-note-text');
            saveBtn.addEventListener('click', async () => {
                const content = input.value.trim();
                if (!content) return;

                if (saveText) saveText.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i>';
                saveBtn.setAttribute('disabled', 'true');
                saveBtn.classList.add('opacity-50', 'cursor-not-allowed');

                try {
                    const res = await fetch('/api/vendedor/notes', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            contenido: content,
                            relacion_tipo: relSelect.value,
                            es_recordatorio: isReminder.checked,
                            fecha_vencimiento: isReminder.checked ? dateInput.value : null,
                            urgencia: urgencyInput.value
                        })
                    });

                    if (res.ok) {
                        window.location.reload();
                    }
                } catch (e) {
                    console.error(e);
                } finally {
                    if (saveText) saveText.innerHTML = 'Guardar';
                    saveBtn.removeAttribute('disabled');
                    saveBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                }
            });
        }

        // Marcar como completada
        document.querySelectorAll('.complete-note-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
                const id = btn.getAttribute('data-id');
                btn.innerHTML = '<i class="fas fa-check text-white text-[8px]"></i>';
                btn.classList.add('bg-primary');
                
                try {
                    const res = await fetch(`/api/vendedor/notes?id=${id}`, {
                        method: 'PATCH'
                    });
                    if (res.ok) {
                        setTimeout(() => window.location.reload(), 500);
                    }
                } catch (e) {
                    console.error(e);
                }
            });
        });

        // Eliminar nota permanentemente
        document.querySelectorAll('.delete-note-btn').forEach(btn => {
            btn.addEventListener('click', async () => {
                if (!confirm('¿Eliminar esta nota permanentemente?')) return;
                
                const id = btn.getAttribute('data-id');
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                
                try {
                    const res = await fetch(`/api/vendedor/notes?id=${id}`, {
                        method: 'DELETE'
                    });
                    if (res.ok) {
                        window.location.reload();
                    }
                } catch (e) {
                    console.error(e);
                }
            });
        });
    });
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #444; border-radius: 2px; }
</style>
