                        fontFamily: 'Inter, sans-serif'
                    },
                    theme: { mode: 'dark' },
                    series: [
                        { name: 'Ventas Acum.', data: seriesVentas },
                        { name: 'Gastos Acum.', data: seriesGastos },
                        { name: 'Ganancia Neta Acum.', data: seriesNeto }
                    ],
                    xaxis: {
                        categories: categories,
                        labels: { style: { colors: '#888', fontSize: '10px' } }
                    },
                    yaxis: {
                        labels: {
                            style: { colors: '#888', fontSize: '10px' },
