    <!-- SECCIÓN DE TABLA COMPARATIVA TIPO HOJA EXCEL ORIGINAL -->
    <div class="bg-[#111] border border-white/5 rounded-2xl p-6 overflow-hidden">
        <h4 class="text-white font-bold uppercase tracking-wider text-xs mb-4 flex items-center gap-2">
            <i class="fas fa-table text-gray-500"></i> Desglose Detallado de Márgenes de Utilidad (Lógica Excel)
        </h4>
        <div class="overflow-x-auto">
