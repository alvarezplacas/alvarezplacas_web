                    }
                };

                this.chartInstance = new ApexCharts(document.getElementById('chart-calculadora-proyeccion'), options);
                this.chartInstance.render();
            },

            // Update ApexChart series
            updateChart() {
                if (!this.chartInstance) return;
                const data = this.runSimulation();
                
                const seriesVentas = data.map(d => parseFloat(d.ventasAcumuladas.toFixed(0)));
                const seriesGastos = data.map(d => parseFloat(d.gastosAcumulados.toFixed(0)));
                const seriesNeto = data.map(d => parseFloat(d.netoAcumulado.toFixed(0)));
                const categories = data.map(d => d.mes);

                this.chartInstance.updateOptions({
                    xaxis: { categories: categories }
                });
                
                this.chartInstance.updateSeries([
                    { name: 'Ventas Acum.', data: seriesVentas },
                    { name: 'Gastos Acum.', data: seriesGastos },
                    { name: 'Ganancia Neta Acum.', data: seriesNeto }
                ]);
            },

            // Export to CSV
            exportCSV() {
                const data = this.runSimulation();
                let csv = 'Mes,Ventas Proyectadas,Gastos Proyectados,Neto Acumulado\n';
                data.forEach(row => {
                    csv += `${row.mes},${row.ventas.toFixed(0)},${row.gastos.toFixed(0)},${row.netoAcumulado.toFixed(0)}\n`;
                });

                const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob);
                link.setAttribute('download', 'Proyecciones_AlvarezPlacas.csv');
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                this.showToast('✓ CSV descargado correctamente');
            },

            // Sincronizar automáticamente con Operación Diaria (LocalStorage + API)
            async syncFromDailyOps(silent = false, force = false) {
                if (!force && !this.isLiveSync) return;
                if (!this.fechaDesde || !this.fechaHasta) return;

                let items = [];
                try {
                    const res = await fetch(`/api/caja/movimientos?fechaDesde=${this.fechaDesde}&fechaHasta=${this.fechaHasta}&limit=5000`);
                    if (res.ok) {
                        const data = await res.json();
                        items = data.data || [];
                    }
                } catch(e) {
                    console.warn("Directus fetch failed in calculator sync:", e);
                }

                // Merge local storage
                try {
                    const localData = localStorage.getItem('caja_movimientos_local');
                    const localMovs = localData ? JSON.parse(localData) : [];
                    const filteredLocal = localMovs.filter(m => m && m.fecha && m.fecha >= this.fechaDesde && m.fecha <= this.fechaHasta);
                    filteredLocal.forEach(lm => {
                        const exists = items.some(im => (im && im.id && lm && lm.id && im.id.toString() === lm.id.toString()) || (im && lm && im.fecha === lm.fecha && parseFloat(im.monto) === parseFloat(lm.monto) && im.categoria === lm.categoria && im.tipo === lm.tipo));
                        if (!exists) {
                            items.push(lm);
                        }
                    });
                } catch(e) {
                    console.error("Local storage merge failed in calculator sync:", e);
                }

                // Now calculate totals
                let sumVentaBlanco = 0;
                let sumVentaNegro = 0;
                let sumGastos = 0;
                let sumIvaVentas = 0;
                let sumIvaCompras = 0;

                items.forEach(m => {
                    if (!m) return;
                    const monto = parseFloat(m.monto) || 0;
                    const tipo = (m.tipo || '').toLowerCase();
                    const categoria = (m.categoria || '').toLowerCase();
                    if (tipo === 'ingreso') {
                        if (categoria === 'venta_blanco') {
                            sumVentaBlanco += monto;
                        } else if (categoria === 'venta_negro') {
                            sumVentaNegro += monto;
                        }
                    } else if (tipo === 'egreso') {
                        if (categoria.startsWith('gasto_fijo') || categoria.startsWith('gasto_variable')) {
                            sumGastos += monto;
                        } else if (categoria === 'impuestos') {
                            // If they enter taxes as expenses...
                        }
                    }
                });

                // Update calculator state - reset all to synced values
                this.ventaBlanco = sumVentaBlanco;
                this.ventaNegro = sumVentaNegro;
                this.gastosTotales = sumGastos;
                this.ivaVentas = sumIvaVentas;

                // Reset corte/pegado breakdown to 0 (must be entered manually per period)
                // These cannot be derived from daily ops categories
                this.ventaCorteBlanco = 0;
                this.ventaPegadoBlanco = 0;
                this.cantPegadosBlanco = 0;
                this.ventaCorteNegro = 0;
                this.ventaPegadoNegro = 0;
                this.cantPegadosNegro = 0;

                if (!silent) {
                    const resumen = `V1: ${this.format(sumVentaBlanco)} | V2: ${this.format(sumVentaNegro)} | Gastos: ${this.format(sumGastos)}`;
                    this.showToast('✓ Sincronizado (' + items.length + ' movs) → ' + resumen);
                }
            },

            // LocalStorage helpers for projections
            getLocalProyecciones() {
                try {
                    const data = localStorage.getItem('caja_proyecciones_local');
                    return data ? JSON.parse(data) : [];
                } catch(e) {
                    return [];
                }
            },

            saveLocalProyecciones(projs) {
                try {
                    localStorage.setItem('caja_proyecciones_local', JSON.stringify(projs));
                } catch(e) {}
            },

            async loadSavedProyecciones() {
                let items = [];
                try {
                    const res = await fetch(`/api/caja/proyecciones?limit=100&sort=-date_created`);
                    if (res.ok) {
                        const data = await res.json();
                        items = data.data || [];
                    }
                } catch(e) {
                    console.warn("Directus projections fetch failed, loading local only:", e);
                }

                // Merge local
                const localProjs = this.getLocalProyecciones();
                localProjs.forEach(lp => {
                    const exists = items.some(im => im && im.id && lp && lp.id && im.id.toString() === lp.id.toString());
                    if (!exists) {
                        items.push(lp);
                    }
                });

                // Sort: newest first based on date_created (or id as fallback)
                items.sort((a, b) => {
                    const dateA = a && a.date_created ? new Date(a.date_created).getTime() : 0;
                    const dateB = b && b.date_created ? new Date(b.date_created).getTime() : 0;
                    if (dateA && dateB) return dateB - dateA;

                    // Fallback to numeric or local id timestamp
                    const idA = a && a.id ? a.id.toString() : '';
                    const idB = b && b.id ? b.id.toString() : '';
                    
                    const numA = idA.startsWith('local_proj_') ? parseInt(idA.split('_')[2]) : parseInt(idA);
                    const numB = idB.startsWith('local_proj_') ? parseInt(idB.split('_')[2]) : parseInt(idB);
                    
                    if (!isNaN(numA) && !isNaN(numB)) {
                        return numB - numA;
                    }
                    return idB.localeCompare(idA);
                });
                
                this.savedProyecciones = items;
                this.updateComparativaChart();
            },

            // Save Snapshot of projections to Directus + LocalStorage
            async saveSnapshotToCEO(overwrite = false) {
                let nombre = this.nombreProyeccion.trim();
                if (!nombre) {
                    const fDesdeStr = this.fechaDesde ? this.fechaDesde.split('-').reverse().join('/') : '';
                    const fHastaStr = this.fechaHasta ? this.fechaHasta.split('-').reverse().join('/') : '';
                    const defaultName = fDesdeStr && fHastaStr 
                        ? `Cierre Proyectado ${fDesdeStr} a ${fHastaStr}`
                        : `Cierre Proyectado ${new Date().toLocaleDateString('es-AR')}`;
                    nombre = prompt("Ingrese un nombre descriptivo para esta proyección:", defaultName);
                    if (!nombre) return;
                    this.nombreProyeccion = nombre;
                }

                const isEdit = this.activeProyeccionId !== null && overwrite;
                const tempId = isEdit ? this.activeProyeccionId : ('local_proj_' + Date.now() + '_' + Math.floor(Math.random() * 1000));

                const detalles = {
                    nombre: nombre,
                    fechaDesde: this.fechaDesde,
                    fechaHasta: this.fechaHasta,
                    periodoDias: this.periodoDias,
                    ventaBlanco: this.ventaBlanco,
                    ventaCorteBlanco: this.ventaCorteBlanco,
                    ventaPegadoBlanco: this.ventaPegadoBlanco,
                    cantPegadosBlanco: this.cantPegadosBlanco,
                    precioPegadoBlanco: this.precioPegadoBlanco,
                    ventaNegro: this.ventaNegro,
                    ventaCorteNegro: this.ventaCorteNegro,
                    ventaPegadoNegro: this.ventaPegadoNegro,
                    cantPegadosNegro: this.cantPegadosNegro,
                    precioPegadoNegro: this.precioPegadoNegro,
                    gastosTotales: this.gastosTotales,
                    ivaCompras: this.ivaCompras,
                    ivaVentas: this.ivaVentas,
                    recaudacion: this.recaudacion,
                    compraTotalReal: this.compraTotalReal,
                    mesesProyeccion: this.mesesProyeccion,
                    crecimientoVentas: this.crecimientoVentas,
                    inflacionGastos: this.inflacionGastos,
                    netaProyectadaFinal: this.pCalculated.netaUltima
                };

                const payload = {
                    id: tempId,
                    vendedor_email: 'fernando@alvarezplacas.com.ar',
                    fecha: this.fechaHasta || new Date().toISOString().split('T')[0],
                    date_created: new Date().toISOString(),
                    ventas_blanco: this.ventaBlanco,
                    ventas_negro: this.ventaNegro,
                    gastos_totales: this.gastosTotales,
                    utilidad_acumulada: this.gananciaNetaAcumulada,
                    detalles_simulacion: JSON.stringify(detalles),
                    synced: false
                };

                // Save locally first
                const localProjs = this.getLocalProyecciones();
                if (isEdit) {
                    const idx = localProjs.findIndex(p => p && p.id && tempId && p.id.toString() === tempId.toString());
                    if (idx !== -1) {
                        localProjs[idx] = payload;
                    } else {
                        localProjs.push(payload);
                    }
                } else {
                    localProjs.push(payload);
                }
                this.saveLocalProyecciones(localProjs);

                // Attempt Directus sync
                try {
                    let res;
                    const apiPayload = {
                        vendedor_email: payload.vendedor_email,
                        fecha: payload.fecha,
                        ventas_blanco: payload.ventas_blanco,
                        ventas_negro: payload.ventas_negro,
                        gastos_totales: payload.gastos_totales,
                        utilidad_acumulada: payload.utilidad_acumulada,
                        detalles_simulacion: payload.detalles_simulacion
                    };

                    if (isEdit && tempId && !tempId.toString().startsWith('local_')) {
                        // UPDATE in server-side API
                        res = await fetch(`/api/caja/proyecciones?id=${tempId}`, {
                            method: 'PATCH',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify(apiPayload)
                        });
                    } else {
                        // CREATE in server-side API
                        res = await fetch('/api/caja/proyecciones', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify(apiPayload)
                        });
                    }

                    if (res.ok) {
                        const apiRes = await res.json();
                        const realId = apiRes.data.id;

                        // Update local store with real ID and mark synced
                        const updated = this.getLocalProyecciones();
                        const idx = updated.findIndex(p => p && p.id && tempId && p.id.toString() === tempId.toString());
                        if (idx !== -1) {
                            updated[idx].id = realId;
                            updated[idx].synced = true;
                            this.saveLocalProyecciones(updated);
                        }
                        this.activeProyeccionId = realId;
                        this.showToast('✓ Proyección guardada con éxito en la base centralizada');
                    } else {
                        if (!isEdit) {
                            this.activeProyeccionId = tempId;
                        }
                        this.showToast('✓ Proyección registrada localmente (Directus fuera de línea)');
                    }
                } catch(e) {
                    if (!isEdit) {
                        this.activeProyeccionId = tempId;
                    }
                    this.showToast('✓ Proyección registrada localmente (Modo sin conexión)');
                }

                await this.loadSavedProyecciones();
            },

            // Reset active loaded state
            nuevoCierre() {
                this.activeProyeccionId = null;
                this.nombreProyeccion = '';
                this.showToast('✓ Modo nuevo cierre activado. Valores listos para nueva simulación.');
            },

            // Load projection snapshot inputs to Alpine reactive state
            loadProyeccion(proj) {
