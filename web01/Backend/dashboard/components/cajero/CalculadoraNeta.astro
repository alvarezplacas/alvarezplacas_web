                if (detalles.fechaHasta) this.fechaCarga = detalles.fechaHasta;
                
                this.ventaBlanco = detalles.ventaBlanco !== undefined ? detalles.ventaBlanco : proj.ventas_blanco;
                this.ventaCorteBlanco = detalles.ventaCorteBlanco !== undefined ? detalles.ventaCorteBlanco : 0;
                this.ventaPegadoBlanco = detalles.ventaPegadoBlanco !== undefined ? detalles.ventaPegadoBlanco : 0;
                this.cantPegadosBlanco = detalles.cantPegadosBlanco !== undefined ? detalles.cantPegadosBlanco : 0;
                this.precioPegadoBlanco = detalles.precioPegadoBlanco !== undefined ? detalles.precioPegadoBlanco : 1000;
                
                this.ventaNegro = detalles.ventaNegro !== undefined ? detalles.ventaNegro : proj.ventas_negro;
                this.ventaCorteNegro = detalles.ventaCorteNegro !== undefined ? detalles.ventaCorteNegro : 0;
                this.ventaPegadoNegro = detalles.ventaPegadoNegro !== undefined ? detalles.ventaPegadoNegro : 0;
                this.cantPegadosNegro = detalles.cantPegadosNegro !== undefined ? detalles.cantPegadosNegro : 0;
                this.precioPegadoNegro = detalles.precioPegadoNegro !== undefined ? detalles.precioPegadoNegro : 1000;
                
                this.gastosTotales = detalles.gastosTotales !== undefined ? detalles.gastosTotales : proj.gastos_totales;
                this.ivaCompras = detalles.ivaCompras !== undefined ? detalles.ivaCompras : 0;
                this.ivaVentas = detalles.ivaVentas !== undefined ? detalles.ivaVentas : 0;
                this.recaudacion = detalles.recaudacion !== undefined ? detalles.recaudacion : 0;
                this.compraTotalReal = detalles.compraTotalReal !== undefined ? detalles.compraTotalReal : 0;
                
                if (detalles.mesesProyeccion !== undefined) this.mesesProyeccion = detalles.mesesProyeccion;
                if (detalles.crecimientoVentas !== undefined) this.crecimientoVentas = detalles.crecimientoVentas;
                if (detalles.inflacionGastos !== undefined) this.inflacionGastos = detalles.inflacionGastos;

                this.showToast(`✓ Cargada proyección: ${this.nombreProyeccion}`);
                this.updateChart();
            },

            // Delete projection snapshot
            async editProyeccion(proj) {
                let currentNombre = 'Sin nombre';
                let det = {};
                try {
                    det = typeof proj.detalles_simulacion === 'string' ? JSON.parse(proj.detalles_simulacion) : proj.detalles_simulacion;
                    currentNombre = det.nombre || currentNombre;
                } catch(e) {}

                const nuevoNombre = prompt("Editar nombre de la proyección:", currentNombre);
                if (!nuevoNombre || nuevoNombre.trim() === '' || nuevoNombre === currentNombre) return;

                det.nombre = nuevoNombre.trim();
                const newDetallesStr = JSON.stringify(det);
                
                // Actualizar localmente
                const localProjs = this.getLocalProyecciones();
                const idx = localProjs.findIndex(p => p && p.id && proj.id && p.id.toString() === proj.id.toString());
                if (idx !== -1) {
                    localProjs[idx].detalles_simulacion = newDetallesStr;
                    this.saveLocalProyecciones(localProjs);
                }
                
                proj.detalles_simulacion = newDetallesStr;
                
                // Sincronizar con DB si no es solo local
                const tempId = proj.id;
                if (tempId && !tempId.toString().startsWith('local_')) {
                    try {
                        const apiPayload = {
                            vendedor_email: proj.vendedor_email,
                            fecha: proj.fecha,
                            ventas_blanco: proj.ventas_blanco || 0,
                            ventas_negro: proj.ventas_negro || 0,
                            gastos_totales: proj.gastos_totales || 0,
                            utilidad_acumulada: proj.utilidad_acumulada || 0,
                            detalles_simulacion: newDetallesStr
                        };
                        
                        await fetch('/api/proyecciones', {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id: tempId, ...apiPayload })
                        });
                        this.showToast('Nombre actualizado.');
                    } catch (e) {
                        console.error('Error updating DB:', e);
                        this.showToast('Actualizado localmente. Error de conexión.');
                    }
                } else {
                    this.showToast('Nombre actualizado (Local).');
                }
                
                await this.fetchSavedProyecciones();
                
                // Update header if this is the active projection
                if (this.activeProyeccionId && this.activeProyeccionId.toString() === tempId.toString()) {
                    this.nombreProyeccion = det.nombre;
                }
            },

            async deleteProyeccion(proj) {
                let nombre = 'Sin nombre';
                try {
                    const det = typeof proj.detalles_simulacion === 'string' ? JSON.parse(proj.detalles_simulacion) : proj.detalles_simulacion;
                    nombre = det.nombre || proj.fecha;
                } catch(e) {}

                if (!confirm(`¿Eliminar la proyección "${nombre}"?`)) return;

                const id = proj.id;
                
                // Delete locally first
                const localProjs = this.getLocalProyecciones();
                const filtered = localProjs.filter(p => p && p.id && id && p.id.toString() !== id.toString());
                this.saveLocalProyecciones(filtered);

                if (this.activeProyeccionId && id && this.activeProyeccionId.toString() === id.toString()) {
                    this.activeProyeccionId = null;
                    this.nombreProyeccion = '';
                }

                // Delete from Directus if synced/real ID
                if (id && !id.toString().startsWith('local_')) {
                    try {
                        const res = await fetch(`/api/caja/proyecciones?id=${id}`, {
                            method: 'DELETE'
                        });
                        if (res.ok) {
                            this.showToast('✓ Proyección eliminada correctamente de Directus y LocalStorage');
                        } else {
                            this.showToast('✓ Proyección eliminada localmente (Error en Directus)');
                        }
                    } catch(e) {
                        this.showToast('✓ Proyección eliminada localmente');
                    }
                } else {
                    this.showToast('✓ Proyección eliminada localmente');
                }

                await this.loadSavedProyecciones();
            },

            // Initialize Comparative Scenario Chart
            initComparativaChart() {
                const options = {
                    chart: {
                        type: 'bar',
                        height: 280,
                        background: 'transparent',
                        toolbar: { show: false },
                        fontFamily: 'Inter, sans-serif'
                    },
                    theme: { mode: 'dark' },
                    series: [{ name: 'Utilidad Neta', data: [] }],
                    xaxis: {
                        categories: [],
                        labels: { style: { colors: '#888', fontSize: '9px' } }
                    },
                    yaxis: {
                        labels: {
                            style: { colors: '#888', fontSize: '10px' },
                            formatter: (val) => this.format(val)
                        }
                    },
                    colors: ['#3b82f6'],
                    grid: { borderColor: '#222' },
                    dataLabels: {
                        enabled: true,
                        formatter: (val) => '$' + (val / 1000).toFixed(0) + 'k',
                        style: { fontSize: '9px' }
                    },
                    tooltip: {
                        y: { formatter: (val) => this.format(val) }
                    }
                };

                this.comparativaChartInstance = new ApexCharts(document.getElementById('chart-calculadora-comparativa'), options);
                this.comparativaChartInstance.render();
            },

            // Update Comparative Scenario Chart
            updateComparativaChart() {
                if (!this.comparativaChartInstance) {
                    this.$nextTick(() => {
                        const el = document.getElementById('chart-calculadora-comparativa');
                        if (el) {
                            this.initComparativaChart();
                            this.updateComparativaChart();
                        }
                    });
                    return;
                }

                // Get latest 5 projections
                const latestProjs = [...this.savedProyecciones].slice(0, 5).reverse();
                
                const categories = latestProjs.map(p => {
                    let nombre = 'Sin nombre';
                    try {
                        const det = typeof p.detalles_simulacion === 'string' ? JSON.parse(p.detalles_simulacion) : p.detalles_simulacion;
                        nombre = det.nombre || p.fecha;
                    } catch(e) {}
                    return nombre;
                });
                
                const data = latestProjs.map(p => parseFloat(p.utilidad_acumulada || 0));

                this.comparativaChartInstance.updateOptions({
                    xaxis: { categories: categories }
                });

                this.comparativaChartInstance.updateSeries([{
                    name: 'Utilidad Neta',
                    data: data
                }]);
            }
        }));
    };
    if (typeof window.Alpine !== 'undefined') {
        registerCalculadora();
    } else {
        document.addEventListener('alpine:init', registerCalculadora);
    }
</script>

