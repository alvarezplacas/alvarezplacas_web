                </thead>
                <tbody class="divide-y divide-white/5 text-gray-300">
                    <tr>
                        <td class="p-3 font-medium">Margen Base Melaminas (Placas)</td>
                        <td class="p-3 text-center text-gray-500 font-mono">Venta Sin Corte &times; % Config.</td>
                        <td class="p-3 text-right font-mono">
                            <span class="text-[9px] text-gray-500 mr-1" x-text="'(' + porcentajeMargenBlanco + '%)'"></span>
                            <span x-text="format(margenBlanco)"></span>
                        </td>
                        <td class="p-3 text-right font-mono">
                            <span class="text-[9px] text-gray-500 mr-1" x-text="'(' + porcentajeMargenNegro + '%)'"></span>
                            <span x-text="format(margenNegro)"></span>
                        </td>
                    </tr>
                    <tr>
                        <td class="p-3 font-medium">Margen Servicio de Corte</td>
                        <td class="p-3 text-center text-gray-500 font-mono">Corte × (80% / 100%)</td>
                        <td class="p-3 text-right font-mono" x-text="format(margenCorteBlanco)"></td>
                        <td class="p-3 text-right font-mono" x-text="format(margenCorteNegro)"></td>
                    </tr>
                    <tr>
                        <td class="p-3 font-medium">Costo Interno Servicio Pegado</td>
                        <td class="p-3 text-center text-gray-500 font-mono">Cant. Pegados × Valor Unit.</td>
                        <td class="p-3 text-right font-mono text-gray-400" x-text="format(costoPegadoBlanco)"></td>
                        <td class="p-3 text-right font-mono text-gray-400" x-text="format(costoPegadoNegro)"></td>
                    </tr>
                    <tr>
                        <td class="p-3 font-medium">Excedente Servicio Pegado</td>
                        <td class="p-3 text-center text-gray-500 font-mono">Servicio Total - Costo Interno</td>
                        <td class="p-3 text-right font-mono text-gray-400" x-text="format(servPegadoBlanco)"></td>
                        <td class="p-3 text-right font-mono text-gray-400" x-text="format(servPegadoNegro)"></td>
                    </tr>
                    <tr class="bg-blue-500/[0.02]">
                        <td class="p-3 font-semibold text-white">Utilidad Bruta por Canal</td>
                        <td class="p-3 text-center text-gray-500 font-mono">Suma de Utilidades Parciales</td>
                        <td class="p-3 text-right font-semibold text-blue-400 font-mono" x-text="format(gananciaVentaBlanco)"></td>
                        <td class="p-3 text-right font-semibold text-purple-400 font-mono" x-text="format(gananciaVentaNegro)"></td>
