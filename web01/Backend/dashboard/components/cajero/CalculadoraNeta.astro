                    colors: ['#10b981', '#ef4444', '#3b82f6'],
                    stroke: { curve: 'smooth', width: 2.5 },
                    fill: {
                        type: 'gradient',
                        gradient: {
                            opacityFrom: 0.25,
                            opacityTo: 0.02,
                            shadeIntensity: 0.5
                        }
                    },
                    grid: { borderColor: '#222' },
                    dataLabels: { enabled: false },
                    tooltip: {
