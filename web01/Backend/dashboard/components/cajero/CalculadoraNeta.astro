    </div>

    <!-- SECCIÓN DE HISTORIAL Y COMPARATIVAS DE CIERRES PROYECTADOS -->
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 mt-6">
        
        <!-- Lista de Proyecciones Guardadas -->
        <div class="bg-[#111] border border-white/5 rounded-2xl p-6 flex flex-col justify-between">
            <div>
                <h4 class="text-white font-bold uppercase tracking-wider text-xs mb-4 flex items-center gap-2">
                    <i class="fas fa-history text-blue-500"></i> Historial de Escenarios Guardados
                </h4>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse text-xs">
                        <thead>
                            <tr class="border-b border-white/10 bg-[#161616] text-gray-400">
                                <th class="p-3 font-semibold">Nombre del Cierre / Fecha</th>
                                <th class="p-3 font-semibold text-center">Periodo (Desde/Hasta)</th>
                                <th class="p-3 font-semibold text-right">Neto Período</th>
                                <th class="p-3 font-semibold text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5 text-gray-300">
                            <template x-if="savedProyecciones.length === 0">
                                <tr>
                                    <td colspan="4" class="p-4 text-center text-gray-500">No hay proyecciones registradas aún.</td>
                                </tr>
                            </template>
                            <template x-for="proj in savedProyecciones" :key="proj.id">
                                <tr :class="(activeProyeccionId && proj.id && activeProyeccionId.toString() === proj.id.toString()) ? 'bg-blue-600/5 font-semibold text-white' : ''">
                                    <td class="p-3">
                                        <div class="flex flex-col">
                                            <span class="font-bold text-gray-200" x-text="JSON.parse(proj.detalles_simulacion).nombre || 'Sin nombre'"></span>
                                            <span class="text-[10px] text-gray-500" x-text="'Guardado: ' + proj.fecha + ((proj.id && proj.id.toString().startsWith('local_')) ? ' (Local)' : '')"></span>
                                        </div>
                                    </td>
                                    <td class="p-3 text-center font-mono text-[10px]" x-text="((d => d ? d.split('-').reverse().join('/') : '--')(JSON.parse(proj.detalles_simulacion).fechaDesde)) + ' a ' + ((d => d ? d.split('-').reverse().join('/') : '--')(JSON.parse(proj.detalles_simulacion).fechaHasta))"></td>
                                    <td class="p-3 text-right font-mono font-bold text-emerald-400" x-text="format(proj.utilidad_acumulada)"></td>
                                    <td class="p-3 text-center">
                                        <div class="flex items-center justify-center gap-1.5">
                                            <button class="bg-blue-600/10 hover:bg-blue-600 text-blue-400 hover:text-white px-2 py-1 rounded transition text-[10px] font-bold uppercase tracking-wider" @click="loadProyeccion(proj)">
                                                Cargar
                                            </button>
                                            <button class="bg-purple-600/10 hover:bg-purple-600 text-purple-400 hover:text-white px-2 py-1 rounded transition text-[10px] font-bold uppercase tracking-wider" @click="editProyeccion(proj)" title="Editar Nombre">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="bg-red-600/10 hover:bg-red-600 text-red-400 hover:text-white px-2 py-1 rounded transition text-[10px] font-bold uppercase tracking-wider" @click="deleteProyeccion(proj)" title="Eliminar">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Gráfico Comparativo -->
        <div class="bg-[#111] border border-white/5 rounded-2xl p-6">
            <h4 class="text-white font-bold uppercase tracking-wider text-xs mb-4 flex items-center gap-2">
                <i class="fas fa-chart-bar text-purple-500"></i> Comparativa Estratégica (Utilidad Neta)
            </h4>
            <div id="chart-calculadora-comparativa" style="min-height: 280px; width: 100%;"></div>
        </div>
    </div>
</div>

 <script is:inline>
    // Ultra-Robust CDN Fallbacks to prevent Alpine initialization crashes
    if (typeof currency === 'undefined') {
        window.currency = function(val) {
            const value = parseFloat(val) || 0;
            return {
                value: value,
                add: (x) => currency(value + (parseFloat(x && x.value !== undefined ? x.value : x) || 0)),
                subtract: (x) => currency(value - (parseFloat(x && x.value !== undefined ? x.value : x) || 0)),
                multiply: (x) => currency(value * (parseFloat(x && x.value !== undefined ? x.value : x) || 0)),
                divide: (x) => currency(value / (parseFloat(x && x.value !== undefined ? x.value : x) || 1))
            };
        };
    }
    if (typeof ApexCharts === 'undefined') {
        window.ApexCharts = class {
            constructor() {}
            render() {}
            updateOptions() {}
            updateSeries() {}
            destroy() {}
        };
    }

    const registerCalculadora = () => {
        Alpine.data('calculadora', () => ({
            // State variables
            isLiveSync: false,
            ventaBlanco: 1500000,
            ventaCorteBlanco: 150000,
            ventaPegadoBlanco: 60000,
            cantPegadosBlanco: 40,
            precioPegadoBlanco: 1000,
            
            ventaNegro: 2200000,
            ventaCorteNegro: 200000,
            ventaPegadoNegro: 80000,
            cantPegadosNegro: 50,
            precioPegadoNegro: 1000,

            porcentajeMargenBlanco: 24.24,
            porcentajeMargenNegro: 24.24,
            
            gastosTotales: 680000,
            ivaCompras: 80000,
            ivaVentas: 130000,

            recaudacion: 3700000,
            compraTotalReal: 2846151,
            fechaCarga: new Date().toISOString().split('T')[0],
            get fechaDesde() {
                if (!this.fechaCarga) return '';
                const parts = this.fechaCarga.split('-');
                return `${parts[0]}-${parts[1]}-01`;
            },
            get fechaHasta() {
                return this.fechaCarga || '';
            },
            
            // Simulación variables
            mesesProyeccion: 12,
            crecimientoVentas: 10, // 10% mensual
            inflacionGastos: 5,   // 5% mensual
            
            showImporter: false,
            pasteArea: '',
            
            toast: {
                show: false,
                message: ''
            },
            
            // Projections history state
            savedProyecciones: [],
            activeProyeccionId: null,
            nombreProyeccion: '',
            
            // Apexcharts references
            chartInstance: null,
            comparativaChartInstance: null,
            
            init() {
                // Initialize charts on next tick
                this.$nextTick(() => {
                    this.initChart();
                    this.initComparativaChart();
                    this.syncFromDailyOps(true, true);
                    this.loadSavedProyecciones();
                });

                window.addEventListener('sync-calculator', () => {
                    this.syncFromDailyOps(true, true);
                });

                window.addEventListener('load-projection-by-id', (e) => {
                    const id = e.detail.id;
                    const proj = this.savedProyecciones.find(p => p.id.toString() === id.toString());
                    if (proj) {
                        this.loadProyeccion(proj);
                    }
                });

                // Polling interval (real-time sync when tab is active)
                setInterval(() => {
                    const panel = document.getElementById('panel-calculadora');
                    if (panel && !panel.classList.contains('hidden')) {
                        this.syncFromDailyOps(true);
                    }
                }, 4000);

                // Watchers to update chart
                this.$watch('ventaBlanco', () => this.updateChart());
                this.$watch('ventaCorteBlanco', () => this.updateChart());
                this.$watch('ventaPegadoBlanco', () => this.updateChart());
                this.$watch('cantPegadosBlanco', () => this.updateChart());
                this.$watch('precioPegadoBlanco', () => this.updateChart());
                this.$watch('ventaNegro', () => this.updateChart());
                this.$watch('ventaCorteNegro', () => this.updateChart());
                this.$watch('ventaPegadoNegro', () => this.updateChart());
                this.$watch('cantPegadosNegro', () => this.updateChart());
                this.$watch('precioPegadoNegro', () => this.updateChart());
                this.$watch('gastosTotales', () => this.updateChart());
                this.$watch('porcentajeMargenBlanco', () => this.updateChart());
                this.$watch('porcentajeMargenNegro', () => this.updateChart());
                this.$watch('mesesProyeccion', () => this.updateChart());
                this.$watch('crecimientoVentas', () => this.updateChart());
                this.$watch('inflacionGastos', () => this.updateChart());
                this.$watch('fechaCarga', () => { this.syncFromDailyOps(true, true); this.updateChart(); });
            },

            // Formula Getters Venta 1
            get ventaSinCorteBlanco() { return currency(this.ventaBlanco).subtract(this.ventaCorteBlanco).subtract(this.ventaPegadoBlanco).value; },
            get margenBlanco() { return currency(this.ventaSinCorteBlanco).multiply(this.porcentajeMargenBlanco / 100).value; },
            get margenCorteBlanco() { return currency(this.ventaCorteBlanco).multiply(0.80).value; },
            get costoPegadoBlanco() { return currency(this.cantPegadosBlanco).multiply(this.precioPegadoBlanco).value; },
            get servPegadoBlanco() { return currency(this.ventaPegadoBlanco).subtract(this.costoPegadoBlanco).value; },
            get margenPegadoBlanco() { return currency(this.costoPegadoBlanco).add(currency(this.servPegadoBlanco).multiply(0.285715)).value; },
            get gananciaVentaBlanco() { return currency(this.margenBlanco).add(this.margenCorteBlanco).add(this.margenPegadoBlanco).value; },

            // Formula Getters Venta 2
            get ventaSinCorteNegro() { return currency(this.ventaNegro).subtract(this.ventaCorteNegro).subtract(this.ventaPegadoNegro).value; },
            get margenNegro() { return currency(this.ventaSinCorteNegro).multiply(this.porcentajeMargenNegro / 100).value; },
            get margenCorteNegro() { return currency(this.ventaCorteNegro).multiply(1.0).value; },
            get costoPegadoNegro() { return currency(this.cantPegadosNegro).multiply(this.precioPegadoNegro).value; },
            get servPegadoNegro() { return currency(this.ventaPegadoNegro).subtract(this.costoPegadoNegro).value; },
            get margenPegadoNegro() { return currency(this.costoPegadoNegro).add(currency(this.servPegadoNegro).multiply(0.285715)).value; },
            get gananciaVentaNegro() { return currency(this.margenNegro).add(this.margenCorteNegro).add(this.margenPegadoNegro).value; },

            // Control Recaudacion y Compras Getters
            get totalVentas() { return currency(this.ventaBlanco).add(this.ventaNegro).value; },
            get porcentajeV1() { return this.totalVentas > 0 ? ((this.ventaBlanco / this.totalVentas) * 100).toFixed(1) : '0.0'; },
            get porcentajeV2() { return this.totalVentas > 0 ? ((this.ventaNegro / this.totalVentas) * 100).toFixed(1) : '0.0'; },
            get materiaPrimaBlanco() { return currency(this.ventaSinCorteBlanco).subtract(this.margenBlanco).divide(1.25).value; },
            get materiaPrimaNegro() { return currency(this.ventaSinCorteNegro).subtract(this.margenNegro).divide(1.105).value; },
            get materiaPrimaTotal() { return currency(this.materiaPrimaBlanco).add(this.materiaPrimaNegro).value; },
            get desvioDeCompra() { return currency(this.compraTotalReal).subtract(this.materiaPrimaTotal).value; },
            get recaudacionMenosVentas() { return currency(this.recaudacion).subtract(this.totalVentas).value; },

            // Period duration getter
            get periodoDias() {
                if (!this.fechaDesde || !this.fechaHasta) return 30;
                const d1 = new Date(this.fechaDesde);
                const d2 = new Date(this.fechaHasta);
                const diffTime = d2.getTime() - d1.getTime();
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                return Math.max(0, diffDays);
            },

            get periodoRangoTexto() {
                if (!this.fechaDesde || !this.fechaHasta) return '';
                const fD = this.fechaDesde.split('-').reverse().join('/');
                const fH = this.fechaHasta.split('-').reverse().join('/');
                return `de ${fD} a ${fH} (${this.periodoDias} días)`;
            },

            get gananciaTotal() { return currency(this.gananciaVentaBlanco).add(this.gananciaVentaNegro).value; },
            get gananciaNetaAcumulada() { return currency(this.gananciaTotal).subtract(this.gastosTotales).value; },
            get ivaAPagar() { return currency(this.ivaVentas).subtract(this.ivaCompras).value; },

            // Projection Calculator (Intermediate reactive stats)
            get pCalculated() {
                const results = this.runSimulation();
                const last = results[results.length - 1];
                return {
                    ventaUltima: last.ventas,
                    gastoUltimo: last.gastos,
                    netaUltima: last.netoAcumulado
                };
            },

            format(value) {
                return new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', maximumFractionDigits: 0 }).format(value);
            },

            cleanAndParseFloat(val) {
                if (val === null || val === undefined) return 0;
                let str = String(val).trim();
                if (!str) return 0;
                
                // Remove currency symbols and spaces
                str = str.replace(/[^0-9.,-]/g, '');
                
                // If it has both dot and comma, e.g. 1.234,56
                if (str.includes('.') && str.includes(',')) {
                    str = str.replace(/\./g, '').replace(/,/g, '.');
                } else if (str.includes(',')) {
                    // Single comma
                    const commaCount = (str.match(/,/g) || []).length;
                    if (commaCount === 1) {
                        str = str.replace(/,/g, '.');
                    } else {
                        str = str.replace(/,/g, '');
                    }
                } else if (str.includes('.')) {
                    // Single or multiple dots
                    const dotCount = (str.match(/\./g) || []).length;
                    if (dotCount > 1) {
                        str = str.replace(/\./g, '');
                    } else {
                        // Single dot. In Argentina, single dot in large numbers is thousands,
                        // but could be decimal. E.g. "24.24" is decimal, "1.500" is thousands.
                        // Let's check if there are 3 digits after the dot (e.g. "1.500" -> 1500)
                        const parts = str.split('.');
                        if (parts[1] && parts[1].length === 3 && parseFloat(parts[0]) > 0) {
                            str = str.replace(/\./g, '');
                        }
                    }
                }
                
                const parsed = parseFloat(str);
                return isNaN(parsed) ? 0 : parsed;
            },

            showToast(msg) {
                this.toast.message = msg;
                this.toast.show = true;
                setTimeout(() => this.toast.show = false, 4000);
            },

            toggleLiveSync() {
                this.isLiveSync = !this.isLiveSync;
                if (this.isLiveSync) {
                    this.syncFromDailyOps(false, true);
                } else {
                    this.showToast('✓ Sincronización en vivo desactivada (Modo Manual)');
                }
            },

            openCalculadoraManual() {
                const manualTabBtn = document.querySelector('.ctab[data-ctab="manual-calculadora"]');
                if (manualTabBtn) {
                    manualTabBtn.click();
                }
            },

            // Parsing Gcom Log strings or copy-paste logs
            parseGcomData() {
                if (!this.pasteArea) return;
                
                const lines = this.pasteArea.split('\n');
                let foundAny = false;
                
                lines.forEach(line => {
                    const cleanLine = line.toLowerCase().replace(/[\$\.,]/g, '');
                    const numbers = line.match(/\d+([\.,]\d+)?/g);
                    if (!numbers) return;
                    
                    const value = parseFloat(numbers[0].replace(/[\.,]/g, ''));
                    
                    if (cleanLine.includes('venta 1') || cleanLine.includes('blanco') || cleanLine.includes('v1')) {
                        if (cleanLine.includes('corte')) this.ventaCorteBlanco = value;
                        else if (cleanLine.includes('pegado')) this.ventaPegadoBlanco = value;
                        else this.ventaBlanco = value;
                        foundAny = true;
                    } 
                    else if (cleanLine.includes('venta 2') || cleanLine.includes('negro') || cleanLine.includes('v2')) {
                        if (cleanLine.includes('corte')) this.ventaCorteNegro = value;
                        else if (cleanLine.includes('pegado')) this.ventaPegadoNegro = value;
                        else this.ventaNegro = value;
                        foundAny = true;
                    }
                    else if (cleanLine.includes('gastos') || cleanLine.includes('egresos') || cleanLine.includes('fijos')) {
                        this.gastosTotales = value;
                        foundAny = true;
                    }
                    else if (cleanLine.includes('pegados') || cleanLine.includes('cant pegado')) {
                        this.cantPegadosBlanco = value;
                        foundAny = true;
                    }
                });

                if (foundAny) {
                    this.showToast('✓ Resumen Gcom Procesado Correctamente');
                    this.showImporter = false;
                    this.pasteArea = '';
                } else {
                    alert('No se reconocieron variables válidas. Compruebe los términos e intente nuevamente.');
                }
            },

            // Run math simulation month-by-month
            runSimulation() {
                const results = [];
                let currentV1 = this.ventaBlanco;
                let currentV2 = this.ventaNegro;
                let currentGastos = this.gastosTotales;
                
                let accumVentas = 0;
                let accumGastos = 0;
                let accumNeto = 0;

                for (let m = 1; m <= this.mesesProyeccion; m++) {
                    const factorV = 1 + (this.crecimientoVentas / 100);
                    const factorG = 1 + (this.inflacionGastos / 100);

                    // Grow sales & expenses
                    currentV1 = this.ventaBlanco * Math.pow(factorV, m);
                    currentV2 = this.ventaNegro * Math.pow(factorV, m);
                    currentGastos = this.gastosTotales * Math.pow(factorG, m);

                    // Re-calculate margins with exact formulas
                    const sinCorteV1 = Math.max(0, currentV1 - (this.ventaCorteBlanco * Math.pow(factorV, m)) - (this.ventaPegadoBlanco * Math.pow(factorV, m)));
                    const margBlanco = sinCorteV1 * 0.23077;
                    const margCorteBlanco = this.ventaCorteBlanco * Math.pow(factorV, m) * 0.80;
                    const cPegadosBlanco = this.cantPegadosBlanco * Math.pow(factorV, m) * this.precioPegadoBlanco;
                    const sPegadoBlanco = Math.max(0, (this.ventaPegadoBlanco * Math.pow(factorV, m)) - cPegadosBlanco);
                    const margPegadoBlanco = cPegadosBlanco + (sPegadoBlanco * 0.285715);
                    const gainV1 = margBlanco + margCorteBlanco + margPegadoBlanco;

                    const sinCorteV2 = Math.max(0, currentV2 - (this.ventaCorteNegro * Math.pow(factorV, m)) - (this.ventaPegadoNegro * Math.pow(factorV, m)));
                    const margNegro = sinCorteV2 * 0.23077;
                    const margCorteNegro = this.ventaCorteNegro * Math.pow(factorV, m) * 1.0;
                    const cPegadosNegro = this.cantPegadosNegro * Math.pow(factorV, m) * this.precioPegadoNegro;
                    const sPegadoNegro = Math.max(0, (this.ventaPegadoNegro * Math.pow(factorV, m)) - cPegadosNegro);
                    const margPegadoNegro = cPegadosNegro + (sPegadoNegro * 0.285715);
                    const gainV2 = margNegro + margCorteNegro + margPegadoNegro;

                    const monthGainTotal = gainV1 + gainV2;
                    const monthNeto = monthGainTotal - currentGastos;

                    accumVentas += (currentV1 + currentV2);
                    accumGastos += currentGastos;
                    accumNeto += monthNeto;

                    results.push({
                        mes: 'Mes ' + m,
                        ventas: currentV1 + currentV2,
                        gastos: currentGastos,
                        netoAcumulado: accumNeto,
                        ventasAcumuladas: accumVentas,
                        gastosAcumulados: accumGastos
                    });
                }
                return results;
            },

            // Initialize ApexChart
            initChart() {
                const data = this.runSimulation();
                const categories = data.map(d => d.mes);
                const seriesVentas = data.map(d => parseFloat(d.ventasAcumuladas.toFixed(0)));
                const seriesGastos = data.map(d => parseFloat(d.gastosAcumulados.toFixed(0)));
                const seriesNeto = data.map(d => parseFloat(d.netoAcumulado.toFixed(0)));

                const options = {
                    chart: {
                        type: 'area',
                        height: 280,
                        background: 'transparent',
