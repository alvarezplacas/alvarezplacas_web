    </div>

    <!-- SECCION CENTRAL DE SIMULACIÓN Y PROYECCIONES INTERACTIVAS (EL GRÁFICO PREVENTIVO) -->
    <div class="bg-[#111] border border-white/5 rounded-2xl p-6">
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 mb-6 pb-4 border-b border-white/5">
            <div>
                <h3 class="text-white font-bold uppercase tracking-wider text-sm flex items-center gap-2">
