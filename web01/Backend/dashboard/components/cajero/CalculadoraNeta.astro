---
/**
 * Calculadora Neta Proyectada - Version Centralizada e Inteligente
 * Centraliza e integra la logica compleja del Excel de Fernando.
 */
---

<div class="space-y-6" x-data="calculadora()">
    
    <!-- HEADER Y ACCIONES RAPIDAS -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 bg-[#161616] border border-white/5 p-6 rounded-2xl relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-blue-900/10 to-transparent pointer-events-none"></div>
        <div class="relative z-10">
            <h2 class="text-2xl font-black text-white uppercase tracking-tighter">Calculadora <span class="text-blue-500">Proyectada Avanzada</span></h2>
            <p class="text-gray-400 text-sm">Centro operativo financiero con proyecciones y simulador de escenarios</p>
        </div>
        <div class="relative z-10 flex flex-wrap gap-2">
            <button class="bg-blue-600/20 text-blue-400 hover:bg-blue-600 hover:text-white transition-all w-10 h-10 rounded-xl flex items-center justify-center border border-blue-500/30 tooltip-trigger" data-tooltip="Exportar CSV" @click="exportCSV()">
                <i class="fas fa-file-csv text-lg"></i>
            </button>
            <button class="bg-emerald-600/20 text-emerald-400 hover:bg-emerald-600 hover:text-white transition-all px-4 py-2.5 rounded-xl text-xs font-bold uppercase tracking-wider flex items-center gap-2 border border-emerald-500/30" @click="saveSnapshotToCEO()">
                <i class="fas fa-cloud-upload-alt"></i> Registrar Cierre Proyectado
            </button>
        </div>
    </div>

    <!-- BANNER DE EDICIÓN ACTIVA -->
    <div x-show="activeProyeccionId !== null" x-transition class="bg-blue-600/10 border border-blue-500/30 rounded-2xl p-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 relative overflow-hidden" style="display: none;">
        <div class="absolute inset-0 bg-gradient-to-r from-blue-500/5 to-transparent pointer-events-none"></div>
        <div class="flex items-center gap-3">
            <div class="bg-blue-500/20 text-blue-400 w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 animate-pulse">
                <i class="fas fa-edit text-lg"></i>
            </div>
            <div>
                <h4 class="text-white font-bold text-xs uppercase tracking-wider">Edición Activa de Cierre Proyectado</h4>
                <p class="text-gray-400 text-[11px]">
                    Modificando: <span class="text-blue-400 font-bold" x-text="nombreProyeccion"></span>. Los cambios se pueden sobrescribir con 'Guardar Cambios'.
                </p>
            </div>
        </div>
        <div class="flex gap-2 w-full sm:w-auto relative z-10">
            <button class="flex-1 sm:flex-none bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold uppercase tracking-wider px-4 py-2 rounded-lg transition" @click="saveSnapshotToCEO(true)">
                <i class="fas fa-save mr-1"></i> Guardar Cambios
            </button>
            <button class="flex-1 sm:flex-none bg-white/10 hover:bg-white/20 text-white text-xs font-bold uppercase tracking-wider px-4 py-2 rounded-lg transition" @click="nuevoCierre()">
                <i class="fas fa-plus mr-1"></i> Nuevo Cierre
            </button>
        </div>
    </div>

    <!-- IMAGEN/TOAST DE RETROALIMENTACIÓN -->
    <div x-show="toast.show" x-transition class="fixed top-4 right-4 z-50 flex items-center gap-3 bg-[#111] border border-green-500/30 text-green-400 px-5 py-3 rounded-xl shadow-2xl" style="display: none;">
        <i class="fas fa-check-circle text-lg"></i>
        <span class="text-xs font-bold uppercase tracking-wider" x-text="toast.message"></span>
    </div>

    <!-- CUADRO DE CALCULO - FORMATO INTERACTIVO DE CELDAS DE EXCEL (FONDO NEGRO) -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        
        <!-- OPERACIONES VENTA 1 -->
        <div class="bg-[#111] border border-blue-500/10 rounded-2xl p-6 relative flex flex-col justify-between">
            <div class="absolute top-0 right-0 w-24 h-24 bg-blue-500/[0.02] blur-xl pointer-events-none"></div>
            <div>
                <div class="flex items-center justify-between mb-4 pb-2 border-b border-white/5">
                    <div class="flex items-center gap-2">
                        <i class="fas fa-file-invoice text-blue-500"></i>
                        <h3 class="text-white font-bold uppercase tracking-widest text-xs">Venta 1 (Blanco)</h3>
                    </div>
                    <span class="font-mono text-blue-400 bg-blue-500/10 text-[10px] font-bold px-2 py-0.5 rounded" x-text="porcentajeV1 + '%'"></span>
                </div>
                
                <div class="space-y-4">
                    <!-- Total Venta 1 -->
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <label class="text-gray-500 text-[10px] font-black uppercase tracking-wider">Venta 1 Bruta</label>
                            <span class="text-[9px] text-blue-400/70 font-mono">Gcom V1</span>
                        </div>
                        <div class="relative flex items-center">
                            <button class="absolute left-2 text-gray-600 hover:text-white text-xs" @click="ventaBlanco = Math.max(0, ventaBlanco - 50000); isLiveSync = false">-</button>
                            <input type="text" :value="ventaBlanco" @change="ventaBlanco = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-blue-900/50 rounded-xl px-8 py-2.5 text-white text-sm focus:border-blue-500 outline-none text-right font-mono font-bold tracking-tight hover:border-blue-700/60 transition" />
                            <button class="absolute right-2 text-gray-600 hover:text-white text-xs" @click="ventaBlanco += 50000; isLiveSync = false">+</button>
                        </div>
                    </div>

                    <!-- Margen Base Venta 1 -->
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <label class="text-gray-500 text-[10px] font-black uppercase tracking-wider">Margen Base (%)</label>
                        </div>
                        <div class="relative flex items-center">
                            <input type="text" :value="porcentajeMargenBlanco" @change="porcentajeMargenBlanco = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-blue-900/50 rounded-xl px-8 py-2.5 text-white text-sm focus:border-blue-500 outline-none text-right font-mono font-bold tracking-tight hover:border-blue-700/60 transition" />
                        </div>
                    </div>

                    <!-- Corte Venta 1 -->
                    <div>
                        <label class="block text-gray-500 text-[10px] font-black uppercase tracking-wider mb-1">Servicio de Corte V1</label>
                        <div class="relative flex items-center">
                            <button class="absolute left-2 text-gray-600 hover:text-white text-xs" @click="ventaCorteBlanco = Math.max(0, ventaCorteBlanco - 10000); isLiveSync = false">-</button>
                            <input type="text" :value="ventaCorteBlanco" @change="ventaCorteBlanco = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-blue-900/50 rounded-xl px-8 py-2.5 text-white text-sm focus:border-blue-500 outline-none text-right font-mono hover:border-blue-700/60 transition" />
                            <button class="absolute right-2 text-gray-600 hover:text-white text-xs" @click="ventaCorteBlanco += 10000; isLiveSync = false">+</button>
                        </div>
                    </div>

                    <!-- Pegado Venta 1 -->
                    <div>
                        <label class="block text-gray-500 text-[10px] font-black uppercase tracking-wider mb-1">Servicio de Pegado V1</label>
                        <div class="relative flex items-center">
                            <button class="absolute left-2 text-gray-600 hover:text-white text-xs" @click="ventaPegadoBlanco = Math.max(0, ventaPegadoBlanco - 10000); isLiveSync = false">-</button>
                            <input type="text" :value="ventaPegadoBlanco" @change="ventaPegadoBlanco = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-blue-900/50 rounded-xl px-8 py-2.5 text-white text-sm focus:border-blue-500 outline-none text-right font-mono hover:border-blue-700/60 transition" />
                            <button class="absolute right-2 text-gray-600 hover:text-white text-xs" @click="ventaPegadoBlanco += 10000; isLiveSync = false">+</button>
                        </div>
                    </div>

                    <!-- Detalle Pegados -->
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-gray-500 text-[9px] font-black uppercase tracking-wider mb-1">Cant. Pegados</label>
                            <input type="text" :value="cantPegadosBlanco" @change="cantPegadosBlanco = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-blue-900/50 rounded-xl px-3 py-2 text-white text-xs focus:border-blue-500 outline-none text-right font-mono" />
                        </div>
                        <div>
                            <label class="block text-gray-500 text-[9px] font-black uppercase tracking-wider mb-1">Valor Unitario</label>
                            <input type="text" :value="precioPegadoBlanco" @change="precioPegadoBlanco = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-blue-900/30 rounded-xl px-3 py-2 text-gray-400 text-xs focus:border-blue-500 outline-none text-right font-mono" />
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="mt-6 pt-4 border-t border-white/5 space-y-2">
                <div class="flex justify-between text-xs">
                    <span class="text-gray-500">Subtotal Melaminas:</span>
                    <span class="font-mono text-gray-300" x-text="format(ventaSinCorteBlanco)"></span>
                </div>
                <div class="flex justify-between text-xs">
                    <span class="text-gray-500">Utilidad Venta 1:</span>
                    <span class="font-mono text-blue-400 font-bold" x-text="format(gananciaVentaBlanco)"></span>
                </div>
            </div>
        </div>

        <!-- OPERACIONES VENTA 2 -->
        <div class="bg-[#111] border border-purple-500/10 rounded-2xl p-6 relative flex flex-col justify-between">
            <div class="absolute top-0 right-0 w-24 h-24 bg-purple-500/[0.02] blur-xl pointer-events-none"></div>
            <div>
                <div class="flex items-center justify-between mb-4 pb-2 border-b border-white/5">
                    <div class="flex items-center gap-2">
                        <i class="fas fa-wallet text-purple-500"></i>
                        <h3 class="text-white font-bold uppercase tracking-widest text-xs">Venta 2 (Negro)</h3>
                    </div>
                    <span class="font-mono text-purple-400 bg-purple-500/10 text-[10px] font-bold px-2 py-0.5 rounded" x-text="porcentajeV2 + '%'"></span>
                </div>
                
                <div class="space-y-4">
                    <!-- Total Venta 2 -->
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <label class="text-gray-500 text-[10px] font-black uppercase tracking-wider">Venta 2 Bruta</label>
                            <span class="text-[9px] text-purple-400/70 font-mono">Gcom V2</span>
                        </div>
                        <div class="relative flex items-center">
                            <button class="absolute left-2 text-gray-600 hover:text-white text-xs" @click="ventaNegro = Math.max(0, ventaNegro - 50000); isLiveSync = false">-</button>
                            <input type="text" :value="ventaNegro" @change="ventaNegro = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-purple-900/50 rounded-xl px-8 py-2.5 text-white text-sm focus:border-purple-500 outline-none text-right font-mono font-bold tracking-tight hover:border-purple-700/60 transition" />
                            <button class="absolute right-2 text-gray-600 hover:text-white text-xs" @click="ventaNegro += 50000; isLiveSync = false">+</button>
                        </div>
                    </div>

                    <!-- Margen Base Venta 2 -->
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <label class="text-gray-500 text-[10px] font-black uppercase tracking-wider">Margen Base (%)</label>
                        </div>
                        <div class="relative flex items-center">
                            <input type="text" :value="porcentajeMargenNegro" @change="porcentajeMargenNegro = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-purple-900/50 rounded-xl px-8 py-2.5 text-white text-sm focus:border-purple-500 outline-none text-right font-mono font-bold tracking-tight hover:border-purple-700/60 transition" />
                        </div>
                    </div>

                    <!-- Servicio de Corte V2 -->
                    <div>
                        <label class="block text-gray-500 text-[10px] font-black uppercase tracking-wider mb-1">Servicio de Corte V2</label>
                        <div class="relative flex items-center">
                            <button class="absolute left-2 text-gray-600 hover:text-white text-xs" @click="ventaCorteNegro = Math.max(0, ventaCorteNegro - 10000); isLiveSync = false">-</button>
                            <input type="text" :value="ventaCorteNegro" @change="ventaCorteNegro = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-purple-900/50 rounded-xl px-8 py-2.5 text-white text-sm focus:border-purple-500 outline-none text-right font-mono hover:border-purple-700/60 transition" />
                            <button class="absolute right-2 text-gray-600 hover:text-white text-xs" @click="ventaCorteNegro += 10000; isLiveSync = false">+</button>
                        </div>
                    </div>

                    <!-- Servicio de Pegado V2 -->
                    <div>
                        <label class="block text-gray-500 text-[10px] font-black uppercase tracking-wider mb-1">Servicio de Pegado V2</label>
                        <div class="relative flex items-center">
                            <button class="absolute left-2 text-gray-600 hover:text-white text-xs" @click="ventaPegadoNegro = Math.max(0, ventaPegadoNegro - 10000); isLiveSync = false">-</button>
                            <input type="text" :value="ventaPegadoNegro" @change="ventaPegadoNegro = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-purple-900/50 rounded-xl px-8 py-2.5 text-white text-sm focus:border-purple-500 outline-none text-right font-mono hover:border-purple-700/60 transition" />
                            <button class="absolute right-2 text-gray-600 hover:text-white text-xs" @click="ventaPegadoNegro += 10000; isLiveSync = false">+</button>
                        </div>
                    </div>

                    <!-- Detalle Pegados -->
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-gray-500 text-[9px] font-black uppercase tracking-wider mb-1">Cant. Pegados</label>
                            <input type="text" :value="cantPegadosNegro" @change="cantPegadosNegro = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-purple-900/50 rounded-xl px-3 py-2 text-white text-xs focus:border-purple-500 outline-none text-right font-mono" />
                        </div>
                        <div>
                            <label class="block text-gray-500 text-[9px] font-black uppercase tracking-wider mb-1">Valor Unitario</label>
                            <input type="text" :value="precioPegadoNegro" @change="precioPegadoNegro = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-purple-900/30 rounded-xl px-3 py-2 text-gray-400 text-xs focus:border-purple-500 outline-none text-right font-mono" />
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="mt-6 pt-4 border-t border-white/5 space-y-2">
                <div class="flex justify-between text-xs">
                    <span class="text-gray-500">Subtotal Melaminas:</span>
                    <span class="font-mono text-gray-300" x-text="format(ventaSinCorteNegro)"></span>
                </div>
                <div class="flex justify-between text-xs">
                    <span class="text-gray-500">Utilidad Venta 2:</span>
                    <span class="font-mono text-purple-400 font-bold" x-text="format(gananciaVentaNegro)"></span>
                </div>
            </div>
        </div>

        <!-- DEDUCCIONES Y GASTOS (EXCEL NEGRO) -->
        <div class="bg-[#111] border border-red-500/10 rounded-2xl p-6 relative flex flex-col justify-between">
            <div class="absolute top-0 right-0 w-24 h-24 bg-red-500/[0.02] blur-xl pointer-events-none"></div>
            <div>
                <div class="flex items-center gap-2 mb-4 pb-2 border-b border-white/5">
                    <i class="fas fa-chart-pie text-red-500"></i>
                    <h3 class="text-white font-bold uppercase tracking-widest text-xs">Deducciones & Gastos</h3>
                </div>
                
                <div class="space-y-4">
                    <!-- Gastos Totales del Periodo - AUTO desde Operación Diaria -->
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <label class="text-gray-500 text-[10px] font-black uppercase tracking-wider">Gastos Operativos (Fijos + Var)</label>
                            <span class="text-[9px] font-bold px-1.5 py-0.5 rounded" :class="isLiveSync ? 'bg-emerald-500/20 text-emerald-400' : 'bg-yellow-500/20 text-yellow-400'" x-text="isLiveSync ? '⚡ AUTO' : '✎ MANUAL'"></span>
                        </div>
                        <div class="relative flex items-center">
                            <button class="absolute left-2 text-gray-600 hover:text-white text-xs" @click="gastosTotales = Math.max(0, gastosTotales - 20000); isLiveSync = false">-</button>
                            <input type="text" :value="gastosTotales" @change="gastosTotales = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border rounded-xl px-8 py-2.5 text-white text-sm outline-none text-right font-mono font-bold transition" :class="isLiveSync ? 'border-emerald-900/60 focus:border-emerald-500 hover:border-emerald-700/60' : 'border-red-900/50 focus:border-red-500 hover:border-red-700/60'" />
                            <button class="absolute right-2 text-gray-600 hover:text-white text-xs" @click="gastosTotales += 20000; isLiveSync = false">+</button>
                        </div>
                        <p class="text-[9px] text-gray-600 mt-1" x-show="isLiveSync">Suma automática de egresos del período seleccionado</p>
                    </div>

                    <!-- IVA Ventas vs IVA Compras -->
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-gray-500 text-[9px] font-black uppercase tracking-wider mb-1">IVA Ventas</label>
                            <input type="text" :value="ivaVentas" @change="ivaVentas = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-red-900/30 rounded-xl px-3 py-2.5 text-white text-xs focus:border-red-500 outline-none text-right font-mono" />
                        </div>
                        <div>
                            <label class="block text-gray-500 text-[9px] font-black uppercase tracking-wider mb-1">IVA Compras</label>
                            <input type="text" :value="ivaCompras" @change="ivaCompras = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-red-900/30 rounded-xl px-3 py-2.5 text-white text-xs focus:border-red-500 outline-none text-right font-mono" />
                        </div>
                    </div>

                    <!-- Periodo de Fecha a Fecha con Botón de Sincronización -->
                    <div class="space-y-3">
                        <!-- Sincronización Automática Toggle -->
                        <div class="flex justify-between items-center bg-[#000]/50 p-2.5 rounded-xl border border-white/5">
                            <div class="flex flex-col">
                                <span class="text-gray-300 text-[10px] font-black uppercase tracking-widest">Sincronización en Vivo</span>
                                <span class="text-[9px] text-gray-500 font-semibold" x-text="isLiveSync ? '✓ Datos vinculados en vivo' : '⚡ Modo manual / Escenario libre'"></span>
                            </div>
                            <button type="button" 
                                    class="relative inline-flex h-5 w-10 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none"
                                    :class="isLiveSync ? 'bg-blue-600' : 'bg-[#222] border border-white/10'"
                                    @click="toggleLiveSync()">
                                <span class="pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"
                                      :class="isLiveSync ? 'translate-x-5' : 'translate-x-0'"></span>
                            </button>
                        </div>

                        <div class="grid grid-cols-1 gap-2">
                            <div>
                                <label class="block text-gray-500 text-[10px] font-black uppercase tracking-wider mb-1">Fecha de Carga</label>
                                <input type="date" x-model="fechaCarga" class="w-full bg-[#000] border border-white/10 rounded-xl px-3 py-2 text-white text-xs focus:border-blue-500 outline-none font-mono text-center font-bold" />
                            </div>
                        </div>
                        <div class="flex justify-between items-center text-xs bg-[#000]/40 p-2.5 rounded-xl border border-white/5 gap-2">
                            <div class="flex flex-col">
                                <span class="text-gray-500 text-[10px] uppercase font-bold">Duración Base:</span>
                                <span class="font-mono text-blue-400 font-bold text-[11px]" x-text="periodoRangoTexto"></span>
                            </div>
                            <button type="button" class="bg-[#1a1a1a] hover:bg-[#222] text-blue-400 hover:text-blue-300 border border-blue-500/20 hover:border-blue-500/40 px-2.5 py-1.5 rounded-lg text-[9px] font-black uppercase tracking-wider flex items-center gap-1 transition" @click="syncFromDailyOps(false, true)">
                                <i class="fas fa-sync-alt"></i> Sincronizar Caja
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="mt-6 pt-4 border-t border-white/5 space-y-1">
                <div class="flex justify-between text-xs">
                    <span class="text-gray-500">Saldo IVA a Pagar:</span>
                    <span class="font-mono text-gray-300" x-text="format(ivaAPagar)"></span>
                </div>
                <div class="flex justify-between text-xs">
                    <span class="text-gray-500">Utilidad Bruta Total:</span>
                    <span class="font-mono text-gray-300 font-semibold" x-text="format(gananciaTotal)"></span>
                </div>
                <div class="flex justify-between text-xs pt-1.5 border-t border-white/5">
                    <span class="text-emerald-500 font-bold uppercase tracking-wider">NETO PERIODO ACTUAL:</span>
                    <span class="font-mono text-emerald-400 font-black text-sm" x-text="format(gananciaNetaAcumulada)"></span>
                </div>
            </div>
        </div>

        <!-- CONTROL DE RECAUDACIÓN Y COMPRAS -->
        <div class="bg-[#111] border border-amber-500/10 rounded-2xl p-6 relative flex flex-col justify-between">
            <div class="absolute top-0 right-0 w-24 h-24 bg-amber-500/[0.02] blur-xl pointer-events-none"></div>
            <div>
                <div class="flex items-center gap-2 mb-4 pb-2 border-b border-white/5">
                    <i class="fas fa-cash-register text-amber-500"></i>
                    <h3 class="text-white font-bold uppercase tracking-widest text-xs">Control de Caja & Compras</h3>
                </div>
                
                <div class="space-y-4">
                    <!-- Recaudación -->
                    <div>
                        <label class="block text-gray-500 text-[10px] font-black uppercase tracking-wider mb-1">Recaudación Real</label>
                        <div class="relative flex items-center">
                            <button class="absolute left-2 text-gray-600 hover:text-white text-xs" @click="recaudacion = Math.max(0, recaudacion - 50000); isLiveSync = false">-</button>
                            <input type="text" :value="recaudacion" @change="recaudacion = cleanAndParseFloat($event.target.value)" @input="isLiveSync = false" class="w-full bg-[#000] border border-amber-900/50 rounded-xl px-8 py-2.5 text-white text-sm focus:border-amber-500 outline-none text-right font-mono font-bold tracking-tight hover:border-amber-700/60 transition" />
                            <button class="absolute right-2 text-gray-600 hover:text-white text-xs" @click="recaudacion += 50000; isLiveSync = false">+</button>
                        </div>
                    </div>

