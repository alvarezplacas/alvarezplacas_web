---
import { gecomManualData } from '../../logic/gecom_manual.ts';
---

<div class="h-full flex flex-col md:flex-row bg-[#111] rounded-2xl border border-white/5 overflow-hidden" x-data="{ activeTopic: 0 }">
    <!-- Sidebar -->
    <div class="w-full md:w-1/3 bg-[#161616] border-r border-white/5 overflow-y-auto max-h-[600px] custom-scrollbar">
        <div class="p-4 border-b border-white/5 bg-black/20">
            <h3 class="text-white font-bold uppercase tracking-wider text-sm flex items-center gap-2">
                <i class="fas fa-book text-blue-500"></i> Procedimientos GECOM
            </h3>
            <p class="text-xs text-gray-500 mt-1">Manual de operaciones y sistema</p>
        </div>
        <div class="p-2 space-y-1">
            {gecomManualData.map((item, index) => (
                <button 
                    @click={`activeTopic = ${index}`}
                    :class={`activeTopic === ${index} ? 'bg-blue-600/20 border-blue-500/50 text-white' : 'bg-transparent border-transparent text-gray-400 hover:bg-white/5'`}
                    class="w-full text-left px-4 py-3 rounded-xl border transition-all flex items-center justify-between group"
                >
                    <span class="text-xs font-semibold tracking-wide" set:text={item.title}></span>
                    <i class="fas fa-chevron-right text-[10px] opacity-0 group-hover:opacity-100 transition-opacity"></i>
                </button>
            ))}
        </div>
    </div>

    <!-- Content Area -->
    <div class="w-full md:w-2/3 p-8 bg-gradient-to-br from-[#111] to-[#0a0a0a] overflow-y-auto max-h-[600px] custom-scrollbar relative">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-blue-900/10 via-transparent to-transparent pointer-events-none"></div>
        
        {gecomManualData.map((item, index) => (
            <div x-show={`activeTopic === ${index}`} style="display: none;" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" class="relative z-10">
                <h2 class="text-2xl font-black text-white mb-6 uppercase tracking-tight border-b border-white/10 pb-4" set:text={item.title}></h2>
                <div class="prose prose-invert prose-blue max-w-none">
                    <pre class="bg-black/40 border border-white/5 rounded-2xl p-6 text-sm text-gray-300 whitespace-pre-wrap font-mono leading-relaxed" set:html={item.content}></pre>
                </div>
            </div>
        ))}
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }
</style>
