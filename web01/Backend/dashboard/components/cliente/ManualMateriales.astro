---
/**
 * Componente: ManualMateriales.astro
 * SEO Optimizado y con Estándar UX/UI Premium 2026.
 * Explica las ventajas de nuestros materiales (Egger, Faplac, Sadepan) y enlaza al catálogo.
 */
import { directus, readItems } from '@conexiones/directus.js';
import { resolveProductImage } from '@conexiones/lib/media.js';

let melaminasSamples = [];
try {
    const rawData = await directus.request(readItems('Productos', {
        filter: { 
            rubro: { letra: { _eq: 'M' } },
            foto_principal: { _nnull: true } // Prefer items with images
        },
        limit: 6,
        fields: ['id', 'nombre', 'sku', 'marca.nombre', 'foto_principal']
    }));
    const pData = rawData?.data || rawData || [];
    melaminasSamples = pData.map(p => ({
        id: p.id,
        name: p.nombre,
        sku: p.sku,
        brand: p.marca?.nombre || 'ALVAREZ PLACAS',
        image: resolveProductImage(p.sku, p.foto_principal)
    }));
} catch (e) {
    console.error("Error fetching melaminas samples for Academia:", e);
}
---

<article class="manual-interactivo-container" x-data="{ tab: 'mdf' }" aria-label="Manual interactivo de materiales">
    <header class="mb-8 border-b border-[var(--border-card)] pb-6">
        <h1 class="text-3xl md:text-5xl font-black text-[var(--text-main)] uppercase tracking-tighter mb-4 leading-none">
            Academia de <span class="text-[var(--alvarez-blue)] italic">Materiales</span>
        </h1>
        <p class="text-sm font-medium text-[var(--text-muted)] max-w-3xl leading-relaxed">
            Descubre las características técnicas de nuestras placas, aprende sobre certificaciones ecológicas y elige el material perfecto para tu próximo proyecto. Trabajamos con marcas líderes mundiales como <strong class="text-[var(--text-main)]">Egger, Faplac y Sadepan</strong>.
        </p>
    </header>

    <!-- Pestañas Interactivas (Alpine.js) -->
    <nav class="flex overflow-x-auto gap-2 mb-8 hide-scrollbar" aria-label="Navegación de materiales">
        <button 
            class="px-6 py-3 rounded-xl font-bold uppercase text-[10px] tracking-widest transition-all whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-[var(--alvarez-blue)]"
            :class="tab === 'mdf' ? 'bg-[var(--text-main)] text-[var(--bg-main)] shadow-md' : 'bg-[var(--bg-card)] border border-[var(--border-card)] text-[var(--text-muted)] hover:opacity-85'"
            @click="tab = 'mdf'"
            aria-controls="panel-mdf"
            :aria-selected="tab === 'mdf'"
        >
            <i class="fas fa-layer-group mr-2"></i> Tableros MDF
        </button>
        <button 
            class="px-6 py-3 rounded-xl font-bold uppercase text-[10px] tracking-widest transition-all whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-[var(--alvarez-blue)]"
            :class="tab === 'melaminas' ? 'bg-[var(--text-main)] text-[var(--bg-main)] shadow-md' : 'bg-[var(--bg-card)] border border-[var(--border-card)] text-[var(--text-muted)] hover:opacity-85'"
            @click="tab = 'melaminas'"
            aria-controls="panel-melaminas"
            :aria-selected="tab === 'melaminas'"
        >
            <i class="fas fa-swatchbook mr-2"></i> Melaminas & Aglomerados
        </button>
        <button 
            class="px-6 py-3 rounded-xl font-bold uppercase text-[10px] tracking-widest transition-all whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-[var(--alvarez-blue)]"
            :class="tab === 'tapas' ? 'bg-[var(--text-main)] text-[var(--bg-main)] shadow-md' : 'bg-[var(--bg-card)] border border-[var(--border-card)] text-[var(--text-muted)] hover:opacity-85'"
            @click="tab = 'tapas'"
            aria-controls="panel-tapas"
            :aria-selected="tab === 'tapas'"
        >
            <i class="fas fa-tags mr-2 text-orange-500"></i> Tapas y Saldos
        </button>
        <button 
            class="px-6 py-3 rounded-xl font-bold uppercase text-[10px] tracking-widest transition-all whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-[var(--alvarez-blue)]"
            :class="tab === 'sostenibilidad' ? 'bg-[var(--text-main)] text-[var(--bg-main)] shadow-md' : 'bg-[var(--bg-card)] border border-[var(--border-card)] text-[var(--text-muted)] hover:opacity-85'"
            @click="tab = 'sostenibilidad'"
            aria-controls="panel-sostenibilidad"
            :aria-selected="tab === 'sostenibilidad'"
        >
            <i class="fas fa-leaf mr-2 text-emerald-500"></i> Eco-Certificaciones
        </button>
    </nav>

    <div class="relative min-h-[400px]">
        
        <!-- PANEL: MDF -->
        <section id="panel-mdf" x-show="tab === 'mdf'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;" aria-labelledby="title-mdf">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="bg-[var(--bg-card)] border border-[var(--border-card)] p-8 rounded-[2rem] shadow-sm">
                    <h2 id="title-mdf" class="text-xl font-black text-[var(--text-main)] uppercase tracking-widest mb-4 flex items-center gap-3">
                        MDF <span class="text-[10px] font-bold text-[var(--text-muted)] border border-[var(--border-card)] px-2 py-1 rounded-full">Medium Density Fiberboard</span>
                    </h2>
                    <p class="text-sm text-[var(--text-muted)] mb-6 leading-relaxed font-medium">
                        El MDF se compone de finas fibras de madera prensadas. Su densidad homogénea lo convierte en el sustrato perfecto para <strong class="text-[var(--text-main)]">lacados, moldurados profundos y mecanizados</strong>.
                    </p>
                    <ul class="space-y-4 mb-8">
                        <li class="flex items-start gap-3">
                            <i class="fas fa-weight-hanging text-blue-600 mt-1"></i>
                            <p class="text-xs text-[var(--text-main)]"><strong class="font-black">MDF vs Aglomerado (MDP):</strong> El MDF es significativamente <strong class="text-red-600 dark:text-red-400">más pesado</strong> y denso que el aglomerado tradicional, lo que le otorga mayor resistencia estructural y terminación perfecta en los cantos.</p>
                        </li>
                        <li class="flex items-start gap-3">
                            <i class="fas fa-ruler-combined text-blue-600 mt-1"></i>
                            <div class="text-xs text-[var(--text-main)] w-full">
                                <strong class="font-black">Fichas Técnicas por Marca (Placas 18mm):</strong>
                                <div x-data="{ brandTab: 'faplac' }" class="mt-3 w-full">
                                    <div class="flex p-0.5 bg-[var(--bg-main)] border border-[var(--border-card)] rounded-xl gap-1 mb-4 w-fit shadow-inner">
                                        <button @click="brandTab = 'faplac'" :class="brandTab === 'faplac' ? 'bg-[var(--text-main)] text-[var(--bg-main)] shadow-sm' : 'text-[var(--text-muted)] hover:text-[var(--text-main)] hover:bg-[var(--border-card)]/30'" class="py-1.5 px-3 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all duration-300 focus:outline-none">Faplac</button>
                                        <button @click="brandTab = 'egger'" :class="brandTab === 'egger' ? 'bg-[var(--text-main)] text-[var(--bg-main)] shadow-sm' : 'text-[var(--text-muted)] hover:text-[var(--text-main)] hover:bg-[var(--border-card)]/30'" class="py-1.5 px-3 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all duration-300 focus:outline-none">Egger</button>
                                        <button @click="brandTab = 'sadepan'" :class="brandTab === 'sadepan' ? 'bg-[var(--text-main)] text-[var(--bg-main)] shadow-sm' : 'text-[var(--text-muted)] hover:text-[var(--text-main)] hover:bg-[var(--border-card)]/30'" class="py-1.5 px-3 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all duration-300 focus:outline-none">Sadepan</button>
                                    </div>
                                    
                                    <!-- Faplac -->
                                    <ul x-show="brandTab === 'faplac'" 
                                        x-transition:enter="transition ease-out duration-300 transform"
                                        x-transition:enter-start="opacity-0 translate-y-2 scale-[0.98]"
                                        x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                                        class="space-y-2 text-[var(--text-muted)] bg-[var(--bg-main)] p-4 rounded-xl border border-[var(--border-card)]">
                                        <li class="flex justify-between items-center border-b border-[var(--border-card)] pb-2">
                                            <span>Dimensiones</span> <strong class="text-[var(--text-main)] text-right">2.75m x 1.83m<br><span class="text-[9px] font-normal">(5.03 m²)</span></strong>
                                        </li>
                                        <li class="flex justify-between items-center border-b border-[var(--border-card)] pb-2">
                                            <span>Peso Placa MDF</span> <strong class="text-[var(--text-main)]">~68 kg</strong>
                                        </li>
                                        <li class="flex justify-between items-center">
                                            <span>Peso Placa Aglomerado</span> <strong class="text-[var(--text-main)]">~59 kg</strong>
                                        </li>
                                    </ul>

                                    <!-- Egger -->
                                    <ul x-show="brandTab === 'egger'" 
                                        x-transition:enter="transition ease-out duration-300 transform"
                                        x-transition:enter-start="opacity-0 translate-y-2 scale-[0.98]"
                                        x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                                        style="display:none;" 
                                        class="space-y-2 text-[var(--text-muted)] bg-[var(--bg-main)] p-4 rounded-xl border border-[var(--border-card)]">
                                        <li class="flex justify-between items-center border-b border-[var(--border-card)] pb-2">
                                            <span>Dimensiones</span> <strong class="text-[var(--text-main)] text-right">2.60m x 1.83m<br><span class="text-[9px] font-normal">(4.75 m²)</span></strong>
                                        </li>
                                        <li class="flex justify-between items-center border-b border-[var(--border-card)] pb-2">
                                            <span>Peso Placa MDF</span> <strong class="text-[var(--text-main)]">~64 kg</strong>
                                        </li>
                                        <li class="flex justify-between items-center">
                                            <span>Peso Placa Aglomerado</span> <strong class="text-[var(--text-main)]">~56 kg</strong>
                                        </li>
                                    </ul>

                                    <!-- Sadepan -->
                                    <ul x-show="brandTab === 'sadepan'" 
                                        x-transition:enter="transition ease-out duration-300 transform"
                                        x-transition:enter-start="opacity-0 translate-y-2 scale-[0.98]"
                                        x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                                        style="display:none;" 
                                        class="space-y-2 text-[var(--text-muted)] bg-[var(--bg-main)] p-4 rounded-xl border border-[var(--border-card)]">
                                        <li class="flex justify-between items-center border-b border-[var(--border-card)] pb-2">
                                            <span>Dimensiones</span> <strong class="text-[var(--text-main)] text-right">2.82m x 1.83m<br><span class="text-[9px] font-normal">(5.16 m²)</span></strong>
                                        </li>
                                        <li class="flex justify-between items-center border-b border-[var(--border-card)] pb-2">
                                            <span>Peso Placa MDF</span> <strong class="text-[var(--text-main)]">~70 kg</strong>
                                        </li>
                                        <li class="flex justify-between items-center">
                                            <span>Peso Placa Aglomerado</span> <strong class="text-[var(--text-main)]">~60 kg</strong>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </li>
                    </ul>
                    <a href="/catalogo?categoria=mdf" class="inline-flex items-center gap-2 bg-[var(--text-main)] hover:opacity-85 text-[var(--bg-main)] font-black uppercase text-[10px] tracking-widest px-6 py-3 rounded-xl transition-all shadow-md focus:ring-2 focus:ring-[var(--text-main)] focus:ring-offset-2 focus:ring-offset-[var(--bg-main)]">
                        Ver MDF en Catálogo <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
                <div class="bg-gradient-to-br from-[var(--border-card)] to-transparent rounded-[2rem] overflow-hidden flex items-center justify-center p-8 border border-[var(--border-card)]">
                    <!-- Placeholder premium para imagen de producto -->
                    <div class="text-center opacity-40">
                        <i class="fas fa-cubes text-6xl mb-4 text-[var(--text-main)]"></i>
                        <p class="text-[10px] font-black uppercase tracking-widest text-[var(--text-main)]">Representación de Fibra MDF</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- PANEL: MELAMINAS -->
        <section id="panel-melaminas" x-show="tab === 'melaminas'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;" aria-labelledby="title-melaminas"
                 x-data={JSON.stringify({ activeSample: melaminasSamples.length > 0 ? 0 : -1, samples: melaminasSamples })}>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Columna Izquierda: Información y Proyector 3D -->
                <div class="bg-[var(--bg-card)] border border-[var(--border-card)] p-8 rounded-[2rem] shadow-sm flex flex-col relative overflow-hidden">
                    <div class="relative z-10">
                        <h2 id="title-melaminas" class="text-xl font-black text-[var(--text-main)] uppercase tracking-widest mb-4">
                            Proyector de Texturas
                        </h2>
                        <p class="text-sm text-[var(--text-muted)] mb-4 leading-relaxed font-medium">
                            Nuestras melaminas cumplen normativas internacionales y presentan texturas sincronizadas. Explora nuestro catálogo en tiempo real.
                        </p>
                    </div>
                    
                    <template x-if="activeSample !== -1">
                        <div class="mt-4 flex-1 flex flex-col items-center justify-center relative min-h-[350px]">
                            <!-- Escenario 3D (Canvas CSS) -->
                            <div class="projector-stage relative w-full h-full flex items-center justify-center perspective-[1000px]">
                                <!-- Foco de luz -->
                                <div class="absolute -top-20 left-1/2 -translate-x-1/2 w-[200%] h-[150%] bg-gradient-to-b from-blue-600/10 via-white/5 to-transparent rounded-[100%] blur-[50px] pointer-events-none transform -rotate-12 opacity-50 transition-opacity duration-500"></div>
                                
                                <!-- Tablero 3D -->
                                <div class="board-3d relative w-64 h-64 md:w-80 md:h-80 shadow-2xl transition-all duration-700 ease-in-out transform hover:scale-105"
                                     style="transform-style: preserve-3d; transform: rotateX(20deg) rotateY(-15deg) translateZ(50px);">
                                    
                                    <!-- Cara frontal (Textura Principal) -->
                                    <div class="absolute inset-0 rounded-lg border-2 border-white/10 shadow-[inset_0_0_50px_rgba(0,0,0,0.5)] bg-cover bg-center transition-all duration-700"
                                         :style="'background-image: url(' + samples[activeSample].image + ')'">
                                        <!-- Brillo interactivo (Luz) -->
                                        <div class="absolute inset-0 bg-gradient-to-tr from-black/60 via-transparent to-white/20 rounded-lg"></div>
                                    </div>
                                    
                                    <!-- Canto izquierdo (Grosor de la placa) -->
                                    <div class="absolute left-0 top-0 bottom-0 w-4 bg-[#8b6b4e] origin-left"
                                         style="transform: rotateY(-90deg);">
                                         <div class="absolute inset-0 bg-black/40"></div>
                                    </div>
                                    
                                    <!-- Canto inferior -->
                                    <div class="absolute left-0 right-0 bottom-0 h-4 bg-[#6e5138] origin-bottom"
                                         style="transform: rotateX(90deg);">
                                         <div class="absolute inset-0 bg-black/60"></div>
                                    </div>
                                    
                                    <!-- Sombra arrojada -->
                                    <div class="absolute -bottom-10 left-4 right-4 h-12 bg-black/40 blur-xl rounded-[100%]"
                                         style="transform: translateZ(-50px) rotateX(90deg);"></div>
                                </div>
                            </div>
                            
                            <!-- Información de la muestra seleccionada -->
                            <div class="w-full bg-[var(--bg-main)]/80 backdrop-blur border border-[var(--border-card)] rounded-2xl p-5 relative z-20 mt-6 shadow-xl transform translate-y-0 transition-all">
                                <div class="flex justify-between items-start mb-2">
                                    <span class="bg-blue-600 text-white text-[9px] font-black uppercase tracking-widest px-3 py-1 rounded-full shadow-lg" x-text="samples[activeSample].brand"></span>
                                    <p class="text-[10px] text-[var(--text-muted)] font-mono uppercase bg-[var(--bg-card)] px-2 py-1 rounded" x-text="'SKU: ' + samples[activeSample].sku"></p>
                                </div>
                                <h3 class="text-2xl font-black text-[var(--text-main)] italic uppercase leading-none" x-text="samples[activeSample].name"></h3>
                            </div>
                        </div>
                    </template>
                    
                    <template x-if="activeSample === -1">
                        <div class="mt-auto bg-[var(--bg-main)] border border-[var(--border-card)] rounded-2xl p-6 text-center text-[var(--text-muted)] text-xs font-medium">
                            <i class="fas fa-spinner fa-spin text-2xl mb-2"></i><br>
                            Cargando proyector 3D...
                        </div>
                    </template>
                </div>
                
                <!-- Columna Derecha: Galería Interactiva -->
                <div class="flex flex-col gap-4">
                    <div class="bg-[var(--bg-card)] border border-[var(--border-card)] rounded-[2rem] p-6 shadow-sm flex-1">
                        <h3 class="font-black uppercase tracking-widest text-[var(--text-main)] text-xs mb-4">Galería de Diseños Destacados</h3>
                        <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
                            <template x-for="(sample, index) in samples" :key="sample.id">
                                <button 
                                    @click="activeSample = index"
                                    class="relative aspect-square rounded-xl overflow-hidden border-2 transition-all duration-300 focus:outline-none"
                                    :class="activeSample === index ? 'border-blue-600 scale-[1.02] shadow-lg shadow-blue-600/20 z-10' : 'border-transparent hover:border-[var(--border-card)] opacity-80 hover:opacity-100'"
                                >
                                    <img :src="sample.image" class="absolute inset-0 w-full h-full object-cover" :alt="sample.name">
                                    <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 to-transparent p-2 text-left">
                                        <p class="text-[8px] font-black text-white uppercase truncate" x-text="sample.name"></p>
                                    </div>
                                    <div x-show="activeSample === index" class="absolute inset-0 ring-inset ring-2 ring-blue-600 rounded-xl pointer-events-none"></div>
                                </button>
                            </template>
                        </div>
                    </div>
                    
                    <a href="/catalogo?categoria=melamina" class="bg-[var(--text-main)] hover:opacity-85 text-[var(--bg-main)] font-black uppercase text-[10px] tracking-widest px-6 py-4 rounded-[1.5rem] transition-all shadow-md text-center flex items-center justify-center gap-2">
                        Explorar Catálogo Completo <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
        </section>

        <!-- PANEL: TAPAS -->
        <section id="panel-tapas" x-show="tab === 'tapas'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;" aria-labelledby="title-tapas">
            <div class="bg-gradient-to-br from-[var(--bg-card)] to-orange-50 dark:to-orange-950/20 border border-orange-500/20 p-8 md:p-12 rounded-[2rem] shadow-sm relative overflow-hidden">
                <i class="fas fa-box-open absolute -right-10 -bottom-10 text-[200px] text-orange-500/10 pointer-events-none"></i>
                
                <h2 id="title-tapas" class="text-2xl font-black text-[var(--text-main)] uppercase tracking-widest mb-6 relative z-10">
                    Oportunidades: <span class="text-orange-500">Tapas de Paquete</span>
                </h2>
                
                <p class="text-sm text-[var(--text-muted)] max-w-3xl mb-8 leading-relaxed font-medium relative z-10">
                    Muchos clientes consultan por opciones más económicas para estructuras no visibles o talleres. Las <strong class="text-[var(--text-main)]">TAPAS</strong> son tableros de segunda calidad que vienen como cubiertas protectoras en los pallets de fábrica (una arriba y otra abajo del lote).
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative z-10">
                    <article class="bg-[var(--bg-main)]/80 backdrop-blur border border-[var(--border-card)] p-6 rounded-2xl">
                        <header class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-full bg-orange-500/10 flex items-center justify-center text-orange-500"><i class="fas fa-exclamation-triangle"></i></div>
                            <h3 class="font-black uppercase tracking-widest text-[11px] text-[var(--text-main)]">Condición del Material</h3>
                        </header>
                        <p class="text-[11px] text-[var(--text-muted)] font-medium leading-relaxed">
                            Al ser cubiertas protectoras, suelen estar rayadas en al menos una de sus caras o presentar pequeños desperfectos (ej. despuntes en los bordes). Sin embargo, <strong class="text-[var(--text-main)]">estructuralmente son totalmente utilizables</strong> de todas maneras.
                        </p>
                    </article>
                    
                    <article class="bg-[var(--bg-main)]/80 backdrop-blur border border-[var(--border-card)] p-6 rounded-2xl">
                        <header class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-full bg-orange-500/10 flex items-center justify-center text-orange-500"><i class="fas fa-tags"></i></div>
                            <h3 class="font-black uppercase tracking-widest text-[11px] text-[var(--text-main)]">Precios Económicos</h3>
                        </header>
                        <p class="text-[11px] text-[var(--text-muted)] font-medium leading-relaxed">
                            Se venden como saldo a un costo mucho más barato, dependiendo exclusivamente de su estado al llegar de fábrica. Ideal consultar el stock y la disponibilidad en el momento.
                        </p>
                    </article>
                </div>
            </div>
        </section>

        <!-- PANEL: SOSTENIBILIDAD -->
        <section id="panel-sostenibilidad" x-show="tab === 'sostenibilidad'" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-y-4" x-transition:enter-end="opacity-100 translate-y-0" style="display: none;" aria-labelledby="title-sostenibilidad">
            <div class="bg-gradient-to-br from-[var(--bg-card)] to-[oklch(0.9_0.05_150)] dark:to-[oklch(0.2_0.05_150)] border border-emerald-500/20 p-8 md:p-12 rounded-[2rem] shadow-sm relative overflow-hidden">
                <i class="fas fa-globe-americas absolute -right-10 -bottom-10 text-[200px] text-emerald-500/10 pointer-events-none"></i>
                
                <h2 id="title-sostenibilidad" class="text-2xl font-black text-[var(--text-main)] uppercase tracking-widest mb-6 relative z-10">
                    Construcción Ecológica y Puntuación <span class="text-emerald-500">LEED / BREEAM</span>
                </h2>
                
                <p class="text-sm text-[var(--text-muted)] max-w-3xl mb-8 leading-relaxed font-medium relative z-10">
                    Alvarez Placas se enorgullece de proveer materiales que protegen la salud humana y forestal. Nuestros tableros cuentan con Declaraciones Ambientales de Producto (DAP) y cumplen los requisitos de bajas emisiones para certificaciones de vanguardia.
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative z-10">
                    <article class="bg-[var(--bg-main)]/80 backdrop-blur border border-[var(--border-card)] p-6 rounded-2xl">
                        <header class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-500"><i class="fas fa-wind"></i></div>
                            <h3 class="font-black uppercase tracking-widest text-[11px] text-[var(--text-main)]">Emisiones Clase E1 & NAF</h3>
                        </header>
                        <p class="text-[11px] text-[var(--text-muted)] font-medium leading-relaxed">
