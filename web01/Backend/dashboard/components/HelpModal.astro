---
export interface Props {
    role: 'vendedor' | 'ceo' | 'cajero';
}

const { role } = Astro.props;

const isVendedor = role === 'vendedor';
const isCeo = role === 'ceo';
const isCajero = role === 'cajero';
---

<!-- HELP MANUAL MODAL -->
<div id="help-modal" class="modal-overlay">
    <div class="modal-window">
        <header class="modal-header">
            <div class="modal-header-title">
                <i class="fas fa-question-circle" style="color: #e02020;"></i>
                <span>Centro de Ayuda & Documentación</span>
            </div>
            <button class="modal-close" id="btn-close-help">&times;</button>
        </header>
        <div class="modal-body">
            <!-- Navigation sidebar of the help center -->
            <aside class="modal-sidebar">
                { (isVendedor || isCeo) && (
                    <button class="help-nav-btn active" data-tab="help-dashboard">
                        <i class="fas fa-th-large"></i> Panel Principal
                    </button>
                )}
                { isCajero && (
                    <button class="help-nav-btn active" data-tab="help-caja">
                        <i class="fas fa-cash-register"></i> Panel de Caja
                    </button>
                )}
                { isVendedor && (
                    <>
                        <button class="help-nav-btn" data-tab="help-agenda">
                            <i class="fas fa-calendar-alt"></i> Agenda y Tareas
                        </button>
                        <button class="help-nav-btn" data-tab="help-clientes">
                            <i class="fas fa-users"></i> Base de Clientes
                        </button>
                        <button class="help-nav-btn" data-tab="help-mensajeria">
                            <i class="fas fa-comments"></i> Mensajería y Chat
                        </button>
                        <button class="help-nav-btn" data-tab="help-planta">
                            <i class="fas fa-industry"></i> Estado de Planta
                        </button>
                    </>
                )}
                { isCeo && (
                    <>
                        <button class="help-nav-btn" data-tab="help-finanzas">
                            <i class="fas fa-chart-line"></i> Dashboard Financiero
                        </button>
                        <button class="help-nav-btn" data-tab="help-radar">
                            <i class="fas fa-satellite-dish"></i> Radar Predictivo
                        </button>
                        <button class="help-nav-btn" data-tab="help-simulador">
                            <i class="fas fa-calculator" style="color: #10b981;"></i> Simulador Fórmulas
                        </button>
                    </>
                )}
                { (isCajero || isVendedor) && (
                    <>
                        <button class="help-nav-btn" data-tab="help-gcom-test">
                            <i class="fas fa-flask" style="color: #f59e0b;"></i> GCOM Test (Stock)
                        </button>
                        <button class="help-nav-btn" data-tab="help-gcom-import">
                            <i class="fas fa-file-import" style="color: #10b981;"></i> Importar en GCOM
                        </button>
                        <button class="help-nav-btn" data-tab="help-facturas">
                            <i class="fas fa-file-invoice"></i> Buscador OCR
                        </button>
                    </>
                )}
                { isCajero && (
                    <>
                        <button class="help-nav-btn" data-tab="help-herramientas">
                            <i class="fas fa-toolbox"></i> Herramientas
                        </button>
                        <button class="help-nav-btn" data-tab="help-email">
                            <i class="fas fa-envelope" style="color: #3b82f6;"></i> Configurar Correo
                        </button>
                    </>
                )}
                <button class="help-nav-btn" data-tab="help-estrategia">
                    <i class="fas fa-book"></i> Estrategia y Materiales
                </button>
                <a class="help-nav-btn" href="/manuales/Manual_Catalogacion_Alvarez_Placas.html" target="_blank" style="text-decoration: none;">
                    <i class="fas fa-file-pdf" style="color: #ef4444;"></i> Manual de Catalogación
                </a>
                <button class="help-nav-btn" data-tab="help-acerca">
                    <i class="fas fa-info-circle"></i> Acerca de (Beta)
                </button>
            </aside>
            <!-- Main content pane of the help center -->
            <main class="modal-content">
                
                { (isVendedor || isCeo) && (
                    <div class="help-tab-content active" id="help-tab-dashboard">
                        <h2>📊 Panel Principal (Dashboard)</h2>
                        <p class="help-intro">El centro de operaciones diario del vendedor y supervisor. Permite visualizar las métricas clave de facturación y objetivos mensuales de un vistazo.</p>
                        <h3>Funcionamiento:</h3>
                        <ul>
                            <li>Muestra la facturación del mes en curso contrastada con el objetivo asignado.</li>
                            <li>Presenta los estados de cobros pendientes y los accesos rápidos a herramientas.</li>
                        </ul>
                        <h3>Limitaciones en Fase Beta:</h3>
                        <p>Los datos del gráfico de desempeño mensual se refrescan automáticamente cada 10 minutos. Para ver actualizaciones en tiempo real, recarga la pestaña.</p>
                    </div>
                )}
                
                { isCajero && (
                    <>
                        <div class="help-tab-content active" id="help-tab-caja">
                            <h2>🧾 Panel de Caja</h2>
                            <p class="help-intro">Centro de operaciones diario para la administración de ingresos, egresos y control de operaciones.</p>
                            <h3>Funcionamiento:</h3>
                            <ul>
                                <li>Control exhaustivo de cobros diarios y movimientos de caja.</li>
                                <li>Acceso directo a herramientas de validación de comprobantes.</li>
                            </ul>
                        </div>

                        <div class="help-tab-content" id="help-tab-email">
                            <h2>📱 Configurar Correo Móvil</h2>
                            <p class="help-intro">Instrucciones para sincronizar tu cuenta corporativa (<strong style="color:#fff;">fernando@alvarezplacas.com.ar</strong>) con la aplicación de Mail de tu celular o computadora.</p>
                            
                            <table class="help-table" style="margin-top: 10px;">
                                <tr>
                                    <th style="width: 30%;">Campo</th>
                                    <th>Valor a ingresar</th>
                                </tr>
                                <tr>
                                    <td><strong>Tipo de Cuenta</strong></td>
                                    <td>IMAP</td>
                                </tr>
                                <tr>
                                    <td><strong>Dirección de Correo</strong></td>
                                    <td><code style="background:#111; padding:2px 6px; border-radius:4px; color:#10b981; font-family:monospace;">fernando@alvarezplacas.com.ar</code></td>
                                </tr>
                                <tr>
                                    <td><strong>Nombre de Usuario</strong></td>
                                    <td><code style="background:#111; padding:2px 6px; border-radius:4px; color:#10b981; font-family:monospace;">fernando@alvarezplacas.com.ar</code> <em>(Igual que el correo)</em></td>
                                </tr>
                                <tr>
                                    <td><strong>Contraseña</strong></td>
                                    <td><em>La contraseña de tu cuenta de correo.</em></td>
                                </tr>
                                <tr>
                                    <td><strong>Servidor Entrante (IMAP)</strong></td>
                                    <td><code style="background:#111; padding:2px 6px; border-radius:4px; color:#3b82f6; font-family:monospace;">mail.alvarezplacas.com.ar</code><br>Puerto: <strong>993</strong> (Requiere SSL/TLS)</td>
                                </tr>
                                <tr>
                                    <td><strong>Servidor Saliente (SMTP)</strong></td>
                                    <td><code style="background:#111; padding:2px 6px; border-radius:4px; color:#3b82f6; font-family:monospace;">mail.alvarezplacas.com.ar</code><br>Puerto: <strong>465</strong> (Requiere SSL/TLS)<br><em>* Requiere autenticación (mismo usuario/contraseña)</em></td>
                                </tr>
                            </table>
                            
                            <div style="background: rgba(59,130,246,0.1); border: 1px solid rgba(59,130,246,0.4); border-left: 4px solid #3b82f6; border-radius: 6px; padding: 12px 16px; margin: 16px 0; font-size: 12px; color: #93c5fd;">
                                <strong style="display:block; margin-bottom:4px;">💡 Tips para Android o iPhone:</strong>
                                Al agregar la cuenta, selecciona <strong>"Otra"</strong> o <strong>"IMAP"</strong>. Asegúrate de configurar la conexión segura (SSL/TLS).
                            </div>
                        </div>
                    </>
                )}

                { isVendedor && (
                    <>
                        <!-- Agenda Panel -->
                        <div class="help-tab-content" id="help-tab-agenda">
                            <h2>📅 Agenda y Tareas Diario</h2>
                            <p class="help-intro">Planifica y gestiona tus citas, llamadas y tareas operativas diarias para mantener tu flujo de trabajo organizado.</p>
                            <h3>Funcionamiento:</h3>
                            <ul>
                                <li>Visualización de tareas ordenadas cronológicamente para el día actual.</li>
                                <li>Creación rápida de recordatorios vinculados a un cliente específico.</li>
                            </ul>
                            <h3>Limitaciones en Fase Beta:</h3>
                            <p>Los recordatorios actualmente no envían notificaciones push externas; las alertas son internas y visibles únicamente dentro de la pestaña activa del Workspace.</p>
                        </div>

                        <!-- Clientes Panel -->
                        <div class="help-tab-content" id="help-tab-clientes">
                            <h2>👥 Base de Clientes</h2>
                            <p class="help-intro">Gestión completa de tu cartera de clientes asignados, sus estados de cuenta y límites de crédito.</p>
                            <h3>Funcionamiento:</h3>
                            <ul>
                                <li>Actualización de saldos, estados financieros (Al día, Vencido, Bloqueado) directamente en pantalla.</li>
                                <li>Historial de compras y contacto telefónico directo a través de WhatsApp.</li>
                            </ul>
                            <h3>Limitaciones en Fase Beta:</h3>
                            <p>El cambio de saldo y límite de crédito de clientes requiere una validación del Jefe de Ventas para impactar directamente en el sistema ERP central.</p>
                        </div>

                        <!-- Mensajeria Panel -->
                        <div class="help-tab-content" id="help-tab-mensajeria">
                            <h2>💬 Mensajería y Chat en Vivo</h2>
                            <p class="help-intro">Canal de comunicación directa entre el equipo comercial y la gerencia de planta para coordinar cortes.</p>
                            <h3>Funcionamiento:</h3>
                            <ul>
                                <li>Envío de alertas de pedidos urgentes y notificaciones instantáneas de cambios en diseños o prioridades de producción.</li>
                                <li>Marcado de notas urgentes con tags de color amarillo y rojo.</li>
                            </ul>
                            <h3>Limitaciones en Fase Beta:</h3>
                            <p>La mensajería instantánea está optimizada para mensajes cortos de texto. Los archivos adjuntos de más de 10MB están bloqueados en esta versión preliminar para preservar el ancho de banda del servidor.</p>
                        </div>

                        <!-- Estado de Planta Panel -->
                        <div class="help-tab-content" id="help-tab-planta">
                            <h2>🏭 Monitoreo: Estado de Planta</h2>
                            <p class="help-intro">Módulo exclusivo de supervisión de producción y priorización de cortes en las seccionadoras SmartCut.</p>
                            <h3>Funcionamiento:</h3>
                            <ul>
                                <li>Visualización en tiempo real del estado de cada orden de corte (En cola, Cortando, Empaquetado, Listo para Despacho).</li>
                                <li>Permite a los administradores / jefes reordenar prioridades de producción en caliente.</li>
                            </ul>
                            <h3>Limitaciones en Fase Beta:</h3>
                            <p>Los sensores físicos de las sierras reportan el avance con un retraso de 3 segundos. No manipule la cola de producción durante procesos críticos de recalibración de la máquina.</p>
                        </div>
                    </>
                )}

                { isCeo && (
                    <>
                        <div class="help-tab-content" id="help-tab-finanzas">
                            <h2>📈 Dashboard Financiero</h2>
                            <p class="help-intro">Panel ejecutivo para monitorear la salud financiera, ingresos netos y proyecciones de facturación.</p>
                            <h3>Funcionamiento:</h3>
                            <ul>
                                <li>Métricas consolidadas de todas las sucursales.</li>
                                <li>Visualización de reportes históricos de cierre.</li>
                            </ul>
                        </div>
                        <div class="help-tab-content" id="help-tab-radar">
                            <h2>📡 Radar Predictivo</h2>
                            <p class="help-intro">Análisis en tiempo real de indicadores macroeconómicos y proyecciones del mercado.</p>
                            <h3>Funcionamiento:</h3>
                            <ul>
                                <li>Monitoreo de la cotización de divisas (Dólar Blue, MEP, CCL) y riesgo país.</li>
                                <li>Proyecciones basadas en datos del mercado actual para toma de decisiones ágiles.</li>
                            </ul>
                        </div>
                        <div class="help-tab-content" id="help-tab-simulador">
                            <h2>🧮 Simulador Matemático de Fórmulas</h2>
                            <p class="help-intro">Herramienta para alinear los cálculos del Catalogador con las fórmulas nativas de GCOM.</p>
                            <h3>Funcionamiento:</h3>
                            <ul>
                                <li><strong>Precios de Lista y Descuentos:</strong> Permite probar cómo impactan los descuentos de proveedores en el costo base.</li>
                                <li><strong>Rentabilidad e IVA:</strong> Simula el precio ideal de venta antes de redondeos.</li>
                                <li><strong>Cálculo Inverso (Costo Trucado):</strong> Como GCOM obliga a usar precios redondeados, el simulador hace ingeniería inversa para enviarle a GCOM un "costo modificado" y que su cálculo termine dando el número redondo deseado.</li>
                                <li>Al guardar la fórmula, ésta afectará automáticamente a todas las exportaciones de precios TXT para GCOM.</li>
                            </ul>
                        </div>
                    </>
                )}

                { (isCajero || isVendedor) && (
                    <>
                        <div class="help-tab-content" id="help-tab-gcom-test">
                            <h2>🧪 Acceso al Entorno de Pruebas GCOM</h2>
                            <p class="help-intro">Cómo conectarse a la base de pruebas <strong style="color:#f59e0b;">AP2526_TEST</strong> para controlar el stock y probar la sincronización de SKUs sin afectar la operativa real.</p>

                            <div class="gcom-alert" style="background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.4); border-left: 4px solid #f59e0b; border-radius: 6px; padding: 12px 16px; margin: 16px 0; font-size: 12px; color: #fcd34d;">
                                <strong style="display:block; margin-bottom:4px;">⚠️ ENTORNO DE PRUEBAS — SEGURO</strong>
                                Todo lo que hagas en AP2526_TEST está aislado. La base productiva real (AP2526) NO se ve afectada.
                            </div>

                            <h3>Pasos para conectarse:</h3>
                            <ol style="margin-left: 18px; color: #ccc; line-height: 1.8; font-size: 13px;">
                                <li>Abrir el programa <strong style="color:#fff;">GCOM</strong> en tu terminal.</li>
                                <li>En el menú superior hacer clic en <strong style="color:#fff;">"Bases"</strong> y luego en <strong style="color:#fff;">"Lista"</strong>.</li>
                                <li>En el listado de bases disponibles, seleccionar: <code style="background:#111; padding:2px 8px; border-radius:4px; color:#f59e0b; font-family:monospace;">AP2526_TEST</code></li>
                                <li>Hacer clic en <strong style="color:#fff;">"Aceptar"</strong> para confirmar el ingreso.</li>
                            </ol>

                            <h3>Verificación de seguridad:</h3>
                            <p>Comprobá que en la barra de estado o cabecera de GCOM figure la ruta de pruebas:</p>
                            <pre style="background:#111; border:1px solid #333; border-radius:6px; padding:10px 14px; color:#10b981; font-family:monospace; font-size:12px; margin-top:8px; overflow-x:auto;">\\server-alvarezp\c\gecom\datos\AP2526_TEST</pre>

                            <h3>¿Qué podés hacer dentro del TEST?</h3>
                            <ul>
                                <li>Consultar y verificar el stock de productos con los nuevos códigos <code style="background:#111; padding:1px 6px; border-radius:3px; color:#3b82f6;">X-XX-XXXX</code>.</li>
                                <li>Facturar, registrar cobros y modificar precios de forma 100% aislada.</li>
                                <li>Validar que la sincronización automática con el catálogo web funciona correctamente.</li>
                            </ul>

                            <h3>Para volver al sistema productivo real:</h3>
                            <p>Repetir el proceso y seleccionar la base <code style="background:#111; padding:2px 8px; border-radius:4px; color:#10b981; font-family:monospace;">AP2526</code> (sin el sufijo _TEST).</p>

                            <div style="margin-top: 20px; background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.25); border-radius:6px; padding:12px 16px; font-size:12px; color:#93c5fd;">
                                <strong style="display:block; margin-bottom:4px;">ℹ️ Contexto técnico</strong>
                                Esta base de pruebas fue creada como copia exacta de AP2526. El motor de sincronización de stock (Python) monitorea los archivos <code style="font-family:monospace;">stock.fac</code> y actualiza el catálogo web (Directus) automáticamente cuando se producen cambios en GCOM.
                            </div>
                        </div>

                        <div class="help-tab-content" id="help-tab-gcom-import">
                            <h2>📥 Importación de Artículos y SKUs en GCOM</h2>
                            <p class="help-intro">Instrucciones paso a paso para que el operador importe el archivo de equivalencias TXT de SKUs y Rubros generado desde Directus.</p>

                            <div class="gcom-alert" style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.4); border-left: 4px solid #10b981; border-radius: 6px; padding: 12px 16px; margin: 16px 0; font-size: 12px; color: #a7f3d0;">
                                <strong style="display:block; margin-bottom:4px;">📄 ARCHIVO DE IMPORTACIÓN GENERADO</strong>
                                El archivo con los 1786 artículos y sus equivalencias de SKUs e índices jerárquicos está listo en:<br/>
                                <code style="background:#111; padding:2px 6px; border-radius:4px; color:#10b981; font-family:monospace; font-size:11px;">d:\Alvarezplacas_2026\WEB-alvarezplacas_astro\Alvarezplacas\gcom\importacion_articulos.txt</code>
                            </div>

                            <h3>Paso 1: Configurar e Importar los Artículos (`importacion_articulos.txt`)</h3>
                             <ol style="margin-left: 18px; color: #ccc; line-height: 1.8; font-size: 13px;">
                                 <li>Descarga el archivo desde el botón <strong>GCOM TXT (ARTICULOS)</strong>.</li>
                                 <li>En el menú superior de GCOM, ir a <strong style="color:#fff;">Bases</strong> ➡️ <strong style="color:#fff;">Formatos</strong> ➡️ <strong style="color:#fff;">Importación y Exportación</strong>.</li>
                                 <li>Seleccionar <strong style="color:#fff;">Importación de Artículos</strong> y configurar el formato posicional de <strong>80 caracteres</strong> así:
                                     <ul>
                                         <li><strong>CODIGO ARTICULO</strong>: Columna <code style="color:#10b981;">1</code>, Ancho <code style="color:#10b981;">12</code> (SKU sin guiones)</li>
                                         <li><strong>DESCRIPCION</strong>: Columna <code style="color:#10b981;">13</code>, Ancho <code style="color:#10b981;">47</code></li>
                                         <li><strong>RUBRO (LETRA)</strong>: Columna <code style="color:#10b981;">60</code>, Ancho <code style="color:#10b981;">11</code> (Código de rubro en una letra, ej. M o D)</li>
                                         <li><strong>PRECIO EFECTIVO</strong>: Columna <code style="color:#10b981;">71</code>, Ancho <code style="color:#10b981;">10</code></li>
                                     </ul>
                                 </li>
                             </ol>

                             <h3>Paso 2: Configurar e Importar los Precios (`importacion_precios.txt`)</h3>
                             <ol style="margin-left: 18px; color: #ccc; line-height: 1.8; font-size: 13px;">
                                 <li>Descarga el archivo desde el botón <strong>GCOM TXT (PRECIOS)</strong>.</li>
                                 <li>En el menú superior de GCOM, ir a <strong style="color:#fff;">Bases</strong> ➡️ <strong style="color:#fff;">Formatos</strong> ➡️ <strong style="color:#fff;">Importación y Exportación</strong>.</li>
                                 <li>Seleccionar el formato de tipo <strong style="color:#fff;">Importación precios</strong> (ej. "CAMBIO DE PRECIOS") y configurar las variables de <strong>32 caracteres</strong> así:
                                     <ul>
                                         <li><strong>CODIGO ARTICULO</strong>: Columna <code style="color:#10b981;">1</code>, Ancho <code style="color:#10b981;">12</code></li>
                                         <li><strong>PRECIO (Código lista/moneda)</strong>: Columna <code style="color:#10b981;">13</code>, Ancho <code style="color:#10b981;">3</code> (Por defecto `1`)</li>
                                         <li><strong>PRECIO (Importe)</strong>: Columna <code style="color:#10b981;">16</code>, Ancho <code style="color:#10b981;">17</code> (Costo inverso ajustado)</li>
                                     </ul>
                                 </li>
                             </ol>

                             <h3>Paso 3: Configurar e Importar Cuentas Redondeadas (`precios_redondeados.txt`)</h3>
                             <ol style="margin-left: 18px; color: #ccc; line-height: 1.8; font-size: 13px;">
                                 <li>Descarga el archivo desde el botón <strong>GCOM TXT (REDONDEADOS)</strong>.</li>
                                 <li>En el menú superior de GCOM, ir a <strong style="color:#fff;">Bases</strong> ➡️ <strong style="color:#fff;">Formatos</strong> ➡️ <strong style="color:#fff;">Importación y Exportación</strong>.</li>
                                 <li>Seleccionar el formato correspondiente para importar la <strong>cuenta contable de 70 caracteres</strong>:
                                     <ul>
                                         <li><strong>CODIGO ARTICULO</strong>: Columna <code style="color:#10b981;">1</code>, Ancho <code style="color:#10b981;">15</code></li>
                                         <li><strong>DESCRIPCION</strong>: Columna <code style="color:#10b981;">16</code>, Ancho <code style="color:#10b981;">40</code></li>
                                         <li><strong>GAP (Vacío)</strong>: Columna <code style="color:#10b981;">56</code>, Ancho <code style="color:#10b981;">7</code></li>
                                         <li><strong>CUENTA CONTABLE</strong>: Columna <code style="color:#10b981;">63</code>, Ancho <code style="color:#10b981;">8</code> (Código contable numérico del rubro, ej. `0001` o `0017`)</li>
                                     </ul>
                                 </li>
                             </ol>
                            <div style="margin: 15px 0 25px 18px;">
                                <span style="display:block; font-size:11px; color:#888; margin-bottom:6px; font-weight:bold; text-transform:uppercase;">📸 Vista de Configuración del Formato en GCOM:</span>
                                <img src="/images/gcom/estructura_importacion_articulos.jpg" alt="Estructura de Importación GCOM" style="max-width: 100%; height: auto; border: 1px solid #444; border-radius: 6px; box-shadow: 0 4px 10px rgba(0,0,0,0.5);" />
                            </div>

                            <h3>Paso 2: Ejecutar la Importación</h3>
                            <ol style="margin-left: 18px; color: #ccc; line-height: 1.8; font-size: 13px;">
                                <li>Ir al menú <strong style="color:#fff;">Módulos</strong> ➡️ <strong style="color:#fff;">Stock</strong> ➡️ <strong style="color:#fff;">Artículos</strong> ➡️ <strong style="color:#fff;">Rubros y Artículos</strong>.</li>
                                <li>Presionar <strong style="color:#f59e0b;">Ctrl + Clic</strong> sobre la columna **Descripción** de cualquier artículo (se pondrá azul).</li>
                                <li>En la barra de herramientas, hacer clic en el botón de **Funciones Especiales** (ícono de herramientas).</li>
                                <li>Seleccionar <strong style="color:#fff;">Importar Artículos</strong> en el menú desplegable.</li>
                                <li>Hacer clic en la carpeta para elegir el archivo de importación:
