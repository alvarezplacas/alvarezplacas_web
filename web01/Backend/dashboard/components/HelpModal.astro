<script>
    document.addEventListener('DOMContentLoaded', () => {
        // ---- Help Center Modal Engine ----
        const helpModal = document.getElementById('help-modal');
        const btnManual = document.getElementById('btn-manual');
        const btnAcerca = document.getElementById('btn-acerca');
        const btnCloseHelp = document.getElementById('btn-close-help');

        function openHelpTab(tabId) {
            // Remove active class from all buttons and tabs
            document.querySelectorAll('.help-nav-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.help-tab-content').forEach(tab => tab.classList.remove('active'));

            // Find target button and tab
            const targetBtn = document.querySelector(`.help-nav-btn[data-tab="help-${tabId}"]`);
            const targetTab = document.getElementById(`help-tab-${tabId}`);

            if (targetBtn && targetTab) {
                targetBtn.classList.add('active');
                targetTab.classList.add('active');
            }

            if (helpModal) {
                helpModal.classList.add('show');
            }
        }

        btnManual?.addEventListener('click', (e) => {
            e.preventDefault();
            // Try to open a relevant default tab
            const defaultTab = document.querySelector('.help-nav-btn')?.getAttribute('data-tab')?.replace('help-', '') || 'dashboard';
            openHelpTab(defaultTab);
        });

        btnAcerca?.addEventListener('click', (e) => {
            e.preventDefault();
            openHelpTab('acerca');
        });

        btnCloseHelp?.addEventListener('click', () => {
            helpModal?.classList.remove('show');
        });

        // Close modal when clicking on overlay
        helpModal?.addEventListener('click', (e) => {
            if (e.target === helpModal) {
                helpModal.classList.remove('show');
            }
        });

        // Toggle manual tabs
        document.querySelectorAll('.help-nav-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const tabAttr = btn.getAttribute('data-tab');
                if (tabAttr) {
                    const tabId = tabAttr.replace('help-', '');
                    openHelpTab(tabId);
                }
            });
        });

        // Search engine for estrategia
        const searchInput = document.getElementById('estrategia-search');
        if (searchInput) {
            searchInput.addEventListener('input', function(e) {
                const term = e.target.value.toLowerCase();
                const items = document.querySelectorAll('.estrategia-item');
                items.forEach(item => {
                    const text = item.getAttribute('data-term') + " " + item.innerText.toLowerCase();
                    item.style.display = text.includes(term) ? 'block' : 'none';
                });
            });
        }
    });
</script>
