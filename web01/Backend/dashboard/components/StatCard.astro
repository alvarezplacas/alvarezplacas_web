---
/**
 * StatCard - Tarjeta de estadísticas para el dashboard.
 * Propiedad del Agente 2 (Backend/Dashboard).
 */
interface Props {
    label: string;
    value: string | number;
    icon: string;
    color?: string;
    trend?: any;
}

const { label, value, icon, color = 'primary', trend } = Astro.props;
---

<div class="bg-[#1a1a1a] border border-gray-800 rounded-xl p-6 relative overflow-hidden group">
    <div class="flex items-start justify-between relative z-10">
        <div>
            <p class="text-gray-400 text-sm font-semibold uppercase tracking-wider mb-1">{label}</p>
            <h3 class="text-4xl font-bold text-white tracking-tight">{value}</h3>
        </div>
        <div class="w-12 h-12 rounded-lg bg-primary/20 text-primary flex items-center justify-center">
            <i class={`fas ${icon} text-xl`}></i>
        </div>
    </div>
</div>
