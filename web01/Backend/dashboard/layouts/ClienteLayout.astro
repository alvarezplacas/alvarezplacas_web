---
/**
 * ClienteLayout - Portal de Clientes Preferenciales.
 */
import '../../../Frontend/home/styles/global.css';
import { CommunicationService } from '../logic/communication.js';

interface Props {
	title: string;
    userName?: string;
}

const { title, userName = "Cliente Alvarez" } = Astro.props;
const clientId = Astro.cookies.get('client_session')?.value || Astro.url.searchParams.get('id');
let unreadCount = 0;
if (clientId) {
    try {
        unreadCount = await CommunicationService.getUnreadCount(clientId);
    } catch (e) {}
}
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title} | Club Alvarez Placas</title>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
        <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
	</head>
	<body class="bg-black text-gray-200 font-sans antialiased flex flex-col min-h-screen overflow-x-hidden">
        <!-- 🛡️ Inicialización inmediata del tema para evitar parpadeos (FOUC) -->
        <script is:inline>
            (function() {
                const savedTheme = localStorage.getItem('client-theme') || 'light';
                if (savedTheme === 'dark') {
                    document.body.classList.add('body-theme-dark');
                } else {
                    document.body.classList.add('body-theme-light');
                }
            })();
        </script>
        
        <!-- Luxury Navigation -->
        <header class="h-24 bg-[#111111]/80 backdrop-blur-md border-b border-white/5 flex items-center justify-between px-8 sticky top-0 z-50">
            <div class="flex items-center gap-8">
                <a href="/" class="text-2xl font-black text-white tracking-tighter">
                    ALVAREZ<span class="text-primary italic">PLACAS</span>
                </a>
                <nav class="hidden md:flex items-center gap-6">
                    <a href="/cliente" class="text-[11px] font-black uppercase tracking-widest text-primary">Mi Panel</a>
                    <a href="/cliente/pedidos" class="text-[11px] font-black uppercase tracking-widest text-gray-500 hover:text-white transition-colors">Mis Pedidos</a>
                    <a href="/cliente/creador-presupuestos" class="text-[11px] font-black uppercase tracking-widest text-gray-500 hover:text-white transition-colors">Presupuestos</a>
                    <a href={`/cliente/mensajes${clientId ? '?id=' + clientId : ''}`} class="relative text-[11px] font-black uppercase tracking-widest text-gray-500 hover:text-white transition-colors flex items-center gap-2">
                        Mensajes
                        {unreadCount > 0 && (
                            <span class="absolute -top-2 -right-3 w-4 h-4 bg-red-500 text-white rounded-full flex items-center justify-center text-[8px] font-black animate-pulse">
                                {unreadCount}
                            </span>
                        )}
                    </a>
                </nav>
            </div>

            <div class="flex items-center gap-4 md:gap-6">
                <div class="hidden sm:flex flex-col items-end">
                    <p class="text-[10px] font-black text-gray-500 uppercase tracking-widest leading-none mb-1">Bienvenido</p>
                    <p class="text-sm font-bold text-white leading-none">{userName}</p>
                </div>
                
                <a href={`/cliente/mensajes${clientId ? '?id=' + clientId : ''}`} class="relative w-10 h-10 md:w-12 md:h-12 rounded-xl md:rounded-2xl bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-primary/20 transition-all border border-white/5 shadow-lg">
                    <i class="fas fa-comment-alt text-sm md:text-base"></i>
                    {unreadCount > 0 && (
                        <span class="absolute -top-2 -right-2 md:-top-1 md:-right-1 w-4 h-4 md:w-5 md:h-5 bg-red-500 text-white rounded-full flex items-center justify-center text-[9px] font-black animate-pulse shadow-[0_0_10px_rgba(239,68,68,0.6)]">
                            {unreadCount}
                        </span>
                    )}
                </a>

                <div class="hidden md:flex w-12 h-12 rounded-2xl bg-gradient-to-br from-primary to-orange-600 items-center justify-center shadow-lg shadow-primary/20">
                    <i class="fas fa-user text-white"></i>
                </div>
                
                <a href="/api/auth/logout" class="w-10 h-10 md:w-12 md:h-12 rounded-xl bg-white/5 flex items-center justify-center text-gray-400 hover:bg-red-500 hover:text-white transition-all shadow-lg border border-white/5">
                    <i class="fas fa-sign-out-alt"></i>
                </a>
            </div>
        </header>

        <main class="flex-1 p-6 md:p-12 max-w-7xl mx-auto w-full">
            <slot />
        </main>

        <footer class="p-8 border-t border-white/5 bg-[#0a0a0a] flex flex-col items-center justify-center gap-2">
            <p class="text-[10px] font-black text-gray-700 uppercase tracking-[0.3em]">Alvarez Placas SRL &copy; 2026 | Área de Clientes</p>
            <a href="https://clientes.nuthost.com/aff.php?aff=329" target="_blank" rel="noopener noreferrer" class="text-[9px] text-gray-600 hover:text-white transition-colors flex items-center gap-1 mt-2">
                <i class="fas fa-server"></i> Plataforma impulsada por NutHost
            </a>
        </footer>
	</body>
</html>
