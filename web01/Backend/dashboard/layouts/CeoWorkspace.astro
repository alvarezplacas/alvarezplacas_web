---
import '../../../Frontend/home/styles/global.css';
import { directus, readItems } from '@conexiones/directus.js';
import { query } from '@conexiones/lib/db.js';
import QuickNotes from '../components/QuickNotes.astro';
import AgendaPanel from '../components/AgendaPanel.astro';
import BusinessHoursCounter from '../components/BusinessHoursCounter.astro';

interface Props {
    title: string;
    vendedor_id?: string;
}

const { title, vendedor_id } = Astro.props;

const resolvedSellerId = vendedor_id || Astro.cookies.get('seller_session')?.value || '5'; // default Guillermo is ID 5

let sellerName = "Guillermo";
let sellerProfile = {
    foto_personal: '',
};

if (resolvedSellerId) {
    try {
        const sellerResults = await directus.request(readItems('vendedores', {
            filter: { id: { _eq: parseInt(resolvedSellerId) } },
            limit: 1
        })) as any[];
        if (sellerResults?.[0]) {
            sellerName = sellerResults[0].name || sellerName;
        }

        const profileRes = await query('SELECT * FROM vendedor_perfiles WHERE vendedor_id = $1 LIMIT 1', [parseInt(resolvedSellerId)]);
        if (profileRes?.rows?.[0]) {
            sellerProfile = profileRes.rows[0];
            if (sellerProfile.name) sellerName = sellerProfile.name;
        }
    } catch(e) {
        console.error("[Workspace] Error fetching seller info:", e);
    }
}
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Dashboard del CEO</title>
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- Chart.js and ApexCharts -->
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <!-- Alpine.js for interactive elements -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <style>
        :root {
            /* Adobe Photoshop/Premiere CC Dark Theme Palette */
            --ps-bg: #1e1e1e;
            --ps-panel-bg: #252525;
            --ps-panel-border: #383838;
            --ps-text-main: #cccccc;
            --ps-text-muted: #888888;
            --ps-accent: #2e609c;
            --ps-accent-hover: #3d79bf;
            --ps-toolbar-bg: #333333;
            --ps-toolbar-border: #444444;
            --ps-tab-bg: #2d2d2d;
            --ps-tab-active: #1e1e1e;
            --ps-highlight: #ffffff;
            --ps-success: #10b981;
            --ps-warning: #f59e0b;
            --ps-danger: #ef4444;
            
            --scrollbar-bg: #1e1e1e;
            --scrollbar-thumb: #444444;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        
        body {
            background-color: var(--ps-bg);
            color: var(--ps-text-main);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            height: 100vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            font-size: 13px;
        }

        /* Top Menu Bar */
        .top-menubar {
            height: 28px;
            background-color: var(--ps-toolbar-bg);
            border-bottom: 1px solid var(--ps-toolbar-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 12px;
            user-select: none;
        }
        
        .menu-items { display: flex; gap: 16px; }
        .menu-item { color: var(--ps-text-main); cursor: pointer; padding: 4px 8px; border-radius: 2px; }
        .menu-item:hover { background-color: rgba(255, 255, 255, 0.1); color: var(--ps-highlight); }
        .menu-item.brand { font-weight: 700; color: #fff; }

        .macro-ticker {
            display: flex;
            gap: 15px;
            color: #10b981;
            font-family: 'Roboto Mono', monospace;
            font-size: 11px;
            align-items: center;
        }

        /* App Layout */
        .app-container {
            display: flex;
            flex: 1;
            height: calc(100vh - 28px);
            overflow: hidden;
        }

        /* Left Toolbar */
        .toolbar {
            width: 48px;
            background-color: var(--ps-toolbar-bg);
            border-right: 1px solid var(--ps-toolbar-border);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 10px 0;
            justify-content: space-between;
            z-index: 10;
        }

        .tool-btn {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--ps-text-main);
            border-radius: 4px;
            margin-bottom: 4px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s ease;
            position: relative;
        }

        .tool-btn:hover { background-color: rgba(255,255,255,0.1); color: var(--ps-highlight); }
        .tool-btn.active { background-color: var(--ps-panel-border); box-shadow: inset 0 1px 3px rgba(0,0,0,0.5); color: #3b82f6; }
        .tool-btn.disabled { opacity: 0.4; cursor: not-allowed; }
        .toolbar-sep { width: 24px; height: 1px; background-color: var(--ps-toolbar-border); margin: 8px 0; }

        /* Main Canvas */
        .canvas-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            background-color: var(--ps-bg);
            position: relative;
            min-width: 0; /* Prevents flex overflow */
        }

        .tabs-bar {
            height: 34px;
            background-color: var(--ps-panel-bg);
            border-bottom: 1px solid var(--ps-panel-border);
            display: flex;
            padding: 0 8px;
            align-items: flex-end;
        }

        .tab {
            height: 28px;
            padding: 0 15px;
            background-color: var(--ps-tab-bg);
            border-radius: 4px 4px 0 0;
            margin-right: 2px;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            border: 1px solid var(--ps-panel-border);
            border-bottom: none;
            color: var(--ps-text-muted);
            font-size: 12px;
        }

        .tab.active { background-color: var(--ps-tab-active); color: var(--ps-highlight); border-bottom: 1px solid var(--ps-tab-active); margin-bottom: -1px; z-index: 2; }
        
        .canvas-content {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            position: relative;
        }

        /* Right Panel */
        .right-panel {
            width: 280px;
            background-color: var(--ps-panel-bg);
            border-left: 1px solid var(--ps-panel-border);
            display: flex;
            flex-direction: column;
        }

        .panel-header {
            height: 34px;
            display: flex;
            align-items: center;
            padding: 0 12px;
            background-color: var(--ps-toolbar-bg);
            border-bottom: 1px solid var(--ps-toolbar-border);
            font-weight: 600;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .panel-body { padding: 12px; flex: 1; overflow-y: auto; }
        
        /* Notes widget */
        .notes-widget {
            background: var(--ps-bg);
            border: 1px solid var(--ps-panel-border);
            border-radius: 4px;
            padding: 10px;
            margin-top: 15px;
        }
        
        /* Tooltip */
        .tooltip {
            position: fixed;
            background: #111;
            color: #fff;
            padding: 4px 8px;
            border-radius: 3px;
            font-size: 11px;
            pointer-events: none;
            z-index: 1000;
            opacity: 0;
            transition: opacity 0.1s;
            border: 1px solid #333;
        }
        .tooltip.visible { opacity: 1; }

    </style>
</head>
<body>
    <div class="tooltip" id="global-tooltip"></div>

    <header class="top-menubar">
        <div class="menu-items">
            <div class="menu-item brand">
                <i class="fa-solid fa-crown text-amber-500 mr-2" style="font-size: 12px;"></i>
                Alvarez Placas
            </div>
            <div class="menu-item">Supervisión</div>
            <div class="menu-item">Personal</div>
            <div class="menu-item">Finanzas</div>
            <div class="menu-item">Reportes</div>
            <div class="menu-item" id="btn-ayuda-ceo">Ayuda <i class="fas fa-book" style="margin-left: 5px; opacity: 0.7;"></i></div>
        </div>
        
        <!-- Macro Ticker & Business Hours -->
        <div style="display: flex; align-items: center; gap: 20px;">
            <BusinessHoursCounter />
            <div class="macro-ticker" id="macro-ticker">
                <span>Dólar Blue: <span id="dolar-blue">--</span></span> |
                <span>Dólar MEP: <span id="dolar-mep">--</span></span> |
                <span style="color:#f59e0b;">Riesgo País: <span id="riesgo-pais">--</span></span>
            </div>
        </div>
    </header>

    <div class="app-container">
        <aside class="toolbar">
            <div class="toolbar-top">
                <a href="/ceo" class="tool-btn ${Astro.url.pathname === '/ceo' ? 'active' : ''}" data-tooltip="Control de Correos (IMAP)">
                    <i class="fas fa-envelope"></i>
                </a>
                
                <a href="/ceo/radar" class="tool-btn ${Astro.url.pathname === '/ceo/radar' ? 'active' : ''}" data-tooltip="Radar Global Predictivo">
                    <i class="fas fa-satellite-dish" style="color: #10b981;"></i>
                </a>

                <a href="/ceo/facturas" class="tool-btn ${Astro.url.pathname === '/ceo/facturas' ? 'active' : ''}" data-tooltip="Buscador de Facturas">
                    <i class="fas fa-file-invoice" style="color: #ef4444;"></i>
                </a>
                <div class="toolbar-sep"></div>
                
                <a href="#" class="tool-btn disabled tooltip-trigger" data-tooltip="Gestión de Cuentas (Próximamente)">
                    <i class="fas fa-sliders"></i>
                </a>
            </div>

            <div class="toolbar-bottom">
                <button id="logout-btn" class="tool-btn tooltip-trigger" data-tooltip="Cerrar Sesión" style="color:#ef4444;">
                    <i class="fas fa-power-off"></i>
                </button>
            </div>
        </aside>

        <main class="canvas-area">
            <div class="tabs-bar">
                <div class="tab active" id="active-tab">
                    <span id="active-tab-name">Supervision_General.psd</span>
                </div>
            </div>

            <div class="canvas-content">
                <slot />
            </div>
        </main>

        <aside class="right-panel">
            <div class="panel-header">
                <span class="panel-title">Propiedades del CEO</span>
            </div>
            <div class="panel-body">
                <!-- Contexto -->
                <div style="background: #1a1a1a; border: 1px solid #333; border-radius: 4px; padding: 12px; margin-bottom: 15px;">
                    <p style="font-size: 10px; font-weight: 700; color: #ef4444; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 12px;">Contexto Actual</p>
                    <div style="display: flex; flex-direction: column; gap: 8px;">
                        <div style="display: flex; justify-content: space-between; font-size: 11px;">
                            <span style="color: #888;">Directivo:</span>
                            <span style="color: #fff; font-weight: 600; text-align: right;">{sellerName} (ID: {vendedor_id || '—'})</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 11px;">
                            <span style="color: #888;">Sesión:</span>
                            <span style="color: #22c55e; font-weight: 600;">ACTIVA</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; font-size: 11px; border-top: 1px solid #333; padding-top: 8px; margin-top: 4px;">
                            <span style="color: #888;">Rango:</span>
                            <span style="color: #f59e0b; font-weight: 600;">CEO & FUNDADOR</span>
                        </div>
                    </div>
                </div>
                
                <div class="notes-widget" style="padding: 0; border: none; background: transparent;">
                    <QuickNotes vendedor_id={resolvedSellerId} />
                </div>

                <div class="agenda-widget" style="margin-top: 15px;">
                    <AgendaPanel vendedor_id={resolvedSellerId} />
                </div>
            </div>
        </aside>
    </div>

    <!-- ESTRATEGIA MODAL -->
    <div id="ceo-estrategia-modal" class="modal-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 9999; align-items: center; justify-content: center;">
        <div class="modal-window" style="background: var(--ps-panel-bg); border: 1px solid var(--ps-panel-border); border-radius: 8px; width: 600px; max-width: 90%; display: flex; flex-direction: column;">
            <header style="padding: 15px; border-bottom: 1px solid var(--ps-panel-border); display: flex; justify-content: space-between; align-items: center; background: var(--ps-toolbar-bg);">
                <h3 style="margin: 0; font-size: 14px; font-weight: 600; text-transform: uppercase;"><i class="fas fa-book" style="color: var(--ps-accent); margin-right: 8px;"></i> Estrategia y Argumentación</h3>
                <button id="close-estrategia-ceo" style="background: none; border: none; color: var(--ps-text-muted); cursor: pointer; font-size: 18px;">&times;</button>
            </header>
            <div style="padding: 20px; overflow-y: auto; max-height: 70vh;">
                <p style="color: var(--ps-text-muted); margin-bottom: 15px;">Diccionario rápido de materiales para resolver dudas técnicas.</p>
                <div style="margin-bottom: 15px;">
                    <input type="text" id="ceo-estrategia-search" placeholder="Buscar término (ej. MDF, FSC, Egger)..." style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid var(--ps-panel-border); background: var(--ps-bg); color: var(--ps-text-main);">
                </div>
                <ul id="ceo-estrategia-list" style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
                    <li class="ceo-estrategia-item" data-term="mdf medium density fiberboard trupan finsa" style="background: var(--ps-bg); padding: 10px; border-radius: 4px; border: 1px solid var(--ps-panel-border);">
                        <strong style="color: var(--ps-highlight);">MDF:</strong> Tablero de fibras de densidad media. Ideal para ruteados y lacados. Ej: Trupán (Arauco), Finsa.
                    </li>
                    <li class="ceo-estrategia-item" data-term="mdp pb aglomerado melamina faplac egger sadepan" style="background: var(--ps-bg); padding: 10px; border-radius: 4px; border: 1px solid var(--ps-panel-border);">
                        <strong style="color: var(--ps-highlight);">MDP / Aglomerado:</strong> Tablero de partículas recubierto en melamina. Excelente retención de tornillos. Marcas: Faplac, Egger, Sadepan.
                    </li>
                    <li class="ceo-estrategia-item" data-term="hb hardboard cholguan durolac fondo" style="background: var(--ps-bg); padding: 10px; border-radius: 4px; border: 1px solid var(--ps-panel-border);">
                        <strong style="color: var(--ps-highlight);">Hardboard (HB):</strong> Tablero prensado de alta densidad y bajo espesor (ej. Cholguán, Durolac). Ideal para fondos de mueble.
                    </li>
                    <li class="ceo-estrategia-item" data-term="fsc pefc certificacion bosque sostenible" style="background: var(--ps-bg); padding: 10px; border-radius: 4px; border: 1px solid var(--ps-panel-border);">
                        <strong style="color: var(--ps-highlight);">FSC / PEFC:</strong> Sellos que garantizan que la madera proviene de bosques gestionados de forma sustentable. Argumento clave para arquitectos.
                    </li>
                    <li class="ceo-estrategia-item" data-term="e1 naf carb formaldehido emisiones salud" style="background: var(--ps-bg); padding: 10px; border-radius: 4px; border: 1px solid var(--ps-panel-border);">
                        <strong style="color: var(--ps-highlight);">Emisiones E1 / NAF:</strong> Clasificación de resinas con baja o nula emisión de formaldehídos. Argumento clave para salud, escuelas y hospitales.
                    </li>
                    <li class="ceo-estrategia-item" data-term="leed breeam creditos construccion ecologica" style="background: var(--ps-bg); padding: 10px; border-radius: 4px; border: 1px solid var(--ps-panel-border);">
                        <strong style="color: var(--ps-highlight);">LEED / BREEAM:</strong> Sistemas de certificación de edificios ecológicos. Nuestros productos suman puntos para que el arquitecto certifique su obra.
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- PROFILE EDIT MODAL -->
    <div id="profile-modal" class="modal-overlay">
        <div class="modal-window modal-window--profile" style="max-width: 600px; height: auto; min-height: 480px; display: flex; flex-direction: column;">
            <header class="modal-header" style="height: 48px; background: #2d2d2d; border-bottom: 1px solid #111; display: flex; align-items: center; justify-content: space-between; padding: 0 16px; flex-shrink: 0;">
                <div class="modal-header-title" style="display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 16px; color: #fff;">
                    <i class="fas fa-user-circle" style="color: #f59e0b; font-size: 22px;"></i>
                    <span>Ficha de Configuración de CEO</span>
                </div>
                <button class="modal-close" id="btn-close-profile" style="background: transparent; border: none; color: #888; font-size: 24px; cursor: pointer; transition: color .15s;">&times;</button>
            </header>
            <div class="modal-body" style="display: block; padding: 25px; flex: 1; background: #252525; overflow-y: auto;">
                <form id="profile-edit-form" style="display: flex; flex-direction: column; gap: 20px;">
                    <!-- Cambio de Contraseña -->
                    <div style="padding-top: 5px;">
                        <label style="display: block; font-size: 12px; font-weight: 900; text-transform: uppercase; color: #888; margin-bottom: 8px; letter-spacing: .05em; display: flex; align-items: center; gap: 8px;">
                            <i class="fas fa-lock" style="color: #f59e0b;"></i> Cambiar Contraseña <span style="font-size: 10px; font-weight: 500; text-transform: none; color: #666;">(Dejar en blanco para mantener la actual)</span>
                        </label>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                            <div>
                                <input type="password" id="profile-password" style="width: 100%; border: 1px solid #333; border-radius: 8px; padding: 12px; color: #fff; font-size: 14px; outline: none; background: #1a1a1a;" placeholder="Nueva contraseña" />
                            </div>
                            <div>
                                <input type="password" id="profile-password-confirm" style="width: 100%; border: 1px solid #333; border-radius: 8px; padding: 12px; color: #fff; font-size: 14px; outline: none; background: #1a1a1a;" placeholder="Confirmar contraseña" />
                            </div>
                        </div>
                    </div>

                    <!-- Botones de Acción -->
                    <div style="display: flex; gap: 12px; margin-top: 15px; border-top: 1px solid #333; padding-top: 20px;">
                        <button type="button" id="btn-logout-profile" style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #f43f5e; padding: 12px 20px; border-radius: 8px; font-size: 13px; font-weight: 900; text-transform: uppercase; cursor: pointer; transition: all 0.2s;">
                            <i class="fas fa-power-off" style="margin-right: 5px;"></i> Cerrar Sesión
                        </button>
                        
                        <div style="margin-left: auto; display: flex; gap: 12px;">
                            <button type="button" id="btn-cancel-profile" style="background: #252525; border: 1px solid #333; color: #aaa; padding: 12px 20px; border-radius: 8px; font-size: 13px; font-weight: 700; text-transform: uppercase; cursor: pointer; transition: all 0.2s;">
                                Cancelar
                            </button>
                            <button type="submit" id="btn-save-profile" style="background: #f59e0b; border: none; color: #fff; padding: 12px 30px; border-radius: 8px; font-size: 13px; font-weight: 900; text-transform: uppercase; cursor: pointer; transition: all 0.2s; box-shadow: 0 0 15px rgba(245,158,11,0.3);">
                                Guardar Cambios <i class="fas fa-check-circle" style="margin-left: 5px;"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <style>
        .modal-overlay {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.85);
            display: none; justify-content: center; align-items: center; z-index: 9999;
            backdrop-filter: blur(4px);
        }
        .modal-overlay.show { display: flex; }
        .modal-window {
            background: var(--ps-bg); width: 90%; max-width: 800px;
            border-radius: 12px; border: 1px solid var(--ps-panel-border);
            box-shadow: 0 20px 40px rgba(0,0,0,0.5); overflow: hidden;
            animation: modalFadeIn 0.2s ease-out;
        }
        @keyframes modalFadeIn {
            from { opacity: 0; transform: translateY(10px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
    </style>

    <script>
        // Tooltip logic
        const tooltip = document.getElementById('global-tooltip');
        document.querySelectorAll('.tooltip-trigger').forEach(el => {
            el.addEventListener('mouseenter', e => {
                tooltip.textContent = (e.currentTarget as HTMLElement).dataset.tooltip;
                tooltip.classList.add('visible');
                
                const rect = (e.currentTarget as HTMLElement).getBoundingClientRect();
                tooltip.style.left = (rect.right + 10) + 'px';
                tooltip.style.top = (rect.top + (rect.height/2) - (tooltip.offsetHeight/2)) + 'px';
            });
            el.addEventListener('mouseleave', () => tooltip.classList.remove('visible'));
        });

        // Profile Modal Logic
        const profileModal = document.getElementById('profile-modal');
        const triggerProfile = document.getElementById('btn-open-profile-ceo');
        const btnCloseProfile = document.getElementById('btn-close-profile');
        const btnCancelProfile = document.getElementById('btn-cancel-profile');
        const btnLogoutProfile = document.getElementById('btn-logout-profile');
        const profileForm = document.getElementById('profile-edit-form');

        triggerProfile?.addEventListener('click', (e) => {
            e.preventDefault();
            profileModal?.classList.add('show');
            setTimeout(() => {
                (document.getElementById('profile-password') as HTMLInputElement)?.focus();
            }, 80);
        });

        const closeProfile = () => profileModal?.classList.remove('show');
        btnCloseProfile?.addEventListener('click', closeProfile);
        btnCancelProfile?.addEventListener('click', closeProfile);
        
        btnLogoutProfile?.addEventListener('click', () => {
            window.location.href = '/api/auth/logout';
        });

        profileForm?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const passwordInput = (document.getElementById('profile-password') as HTMLInputElement)?.value;
            const passwordConfirmInput = (document.getElementById('profile-password-confirm') as HTMLInputElement)?.value;

            if (passwordInput || passwordConfirmInput) {
                if (passwordInput !== passwordConfirmInput) {
                    alert('Las contraseñas no coinciden.');
                    return;
                }
                if (passwordInput.length < 6) {
                    alert('La contraseña debe tener al menos 6 caracteres.');
                    return;
                }
            }

            if (passwordInput) {
                try {
                    const resPassword = await fetch('/api/vendedor/change-password', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ password: passwordInput })
                    });
                    const dataPassword = await resPassword.json();
                    if (!dataPassword.success) {
                        alert('Ocurrió un error al actualizar la contraseña: ' + dataPassword.error);
                        return;
                    }
                    alert('¡Contraseña guardada exitosamente!');
                    closeProfile();
                } catch (err) {
                    alert('Error al procesar los cambios');
                }
            } else {
                closeProfile();
            }
        });

        // Logout
        document.getElementById('logout-btn')?.addEventListener('click', async () => {
            await fetch('/api/auth/logout', { method: 'POST' });
            window.location.href = '/login';
        });

        // Fetch Dolar & Riesgo Pais
        async function loadMacroData() {
            try {
                // Dolar Blue
                const resBlue = await fetch('https://dolarapi.com/v1/dolares/blue');
                const dataBlue = await resBlue.json();
                document.getElementById('dolar-blue')!.textContent = `$${dataBlue.venta}`;

                // Dolar MEP
                const resMep = await fetch('https://dolarapi.com/v1/dolares/mep');
                const dataMep = await resMep.json();
                document.getElementById('dolar-mep')!.textContent = `$${dataMep.venta}`;

                // Riesgo Pais
                const resRiesgo = await fetch('https://api.argentinadatos.com/v1/finanzas/indices/riesgo-pais/ultimo');
                const dataRiesgo = await resRiesgo.json();
                document.getElementById('riesgo-pais')!.textContent = `${dataRiesgo.valor} pts`;

            } catch(e) {
                console.error("Error loading macro data", e);
            }
        }
        
        loadMacroData();
        setInterval(loadMacroData, 300000);
    </script>
    <script>
        // Lógica del modal de estrategia para CEO
        const btnAyudaCeo = document.getElementById('btn-ayuda-ceo');
        const modalEstrategiaCeo = document.getElementById('ceo-estrategia-modal');
        const btnCloseEstrategiaCeo = document.getElementById('close-estrategia-ceo');
        const searchInputCeo = document.getElementById('ceo-estrategia-search');

        if (btnAyudaCeo && modalEstrategiaCeo) {
            btnAyudaCeo.addEventListener('click', () => {
                modalEstrategiaCeo.style.display = 'flex';
                searchInputCeo.focus();
            });
            btnCloseEstrategiaCeo.addEventListener('click', () => {
                modalEstrategiaCeo.style.display = 'none';
            });
            // Cerrar al hacer click afuera
            modalEstrategiaCeo.addEventListener('click', (e) => {
                if (e.target === modalEstrategiaCeo) {
                    modalEstrategiaCeo.style.display = 'none';
                }
            });
            
            // Buscador en tiempo real
            searchInputCeo.addEventListener('input', function(e) {
                const term = e.target.value.toLowerCase();
                const items = document.querySelectorAll('.ceo-estrategia-item');
                items.forEach(item => {
                    const text = item.getAttribute('data-term') + " " + item.innerText.toLowerCase();
                    item.style.display = text.includes(term) ? 'block' : 'none';
                });
            });
        }
    </script>
</body>
</html>
