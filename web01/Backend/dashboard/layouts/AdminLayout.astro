---
/**
 * AdminLayout - Estructura base para paneles administrativos.
 * Propiedad del Agente 2 (Backend/Dashboard).
 */
import '../../../Frontend/home/styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;

const adminUser = {
    name: "Javier Alvarez",
    role: "Administrador General",
    avatar: "https://api.dicebear.com/7.x/initials/svg?seed=JA&backgroundColor=ff2800"
};
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title} | Alvarez Placas Admin</title>
		<!-- Google Fonts & Font Awesome se mantienen desde CDN -->
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
	</head>
	<body class="bg-[#111111] text-gray-200 font-sans antialiased flex h-screen overflow-hidden">
        <aside id="sidebar" class="w-72 bg-[#1a1a1a] border-r border-gray-800 flex flex-col">
            <div class="h-20 flex items-center px-6 border-b border-gray-800">
                <span class="text-xl font-bold tracking-tight text-white">PANEL <span class="text-primary">ADMIN</span></span>
            </div>
            <!-- Navegación Refacturada para ser Modular -->
            <nav class="flex-1 p-4 space-y-2">
                <a href="/admin" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/5 transition-all text-sm font-bold text-gray-400 hover:text-white">
                    <i class="fas fa-home w-5 text-center"></i> Dashboard
                </a>
                <a href="/admin/clientes" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/5 transition-all text-sm font-bold text-gray-400 hover:text-white">
                    <i class="fas fa-users w-5 text-center"></i> Clientes
                </a>
                <a href="/admin/vendedores" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/5 transition-all text-sm font-bold text-gray-400 hover:text-white">
                    <i class="fas fa-user-tie w-5 text-center"></i> Vendedores
                </a>
                <a href="/admin/consultas" class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/5 transition-all text-sm font-bold text-gray-400 hover:text-white group">
                    <i class="fas fa-envelope-open-text w-5 text-center group-hover:scale-110 transition-transform"></i> Consultas Web
                </a>
            </nav>

            <div class="p-4 border-t border-gray-800 bg-black/20">
                <div class="flex items-center gap-3 mb-4 px-2">
                    <img src={adminUser.avatar} class="w-8 h-8 rounded-full border border-primary/30" alt="Avatar" />
                    <div class="overflow-hidden">
                        <p class="text-xs font-black text-white truncate uppercase italic">{adminUser.name}</p>
                        <p class="text-[9px] text-gray-500 uppercase tracking-tighter">{adminUser.role}</p>
                    </div>
                </div>
                <a href="/api/auth/logout" class="flex items-center gap-3 p-3 rounded-xl bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white transition-all text-[11px] font-black uppercase tracking-widest border border-red-500/20 shadow-lg shadow-red-500/5 group">
                    <i class="fas fa-sign-out-alt w-5 text-center group-hover:translate-x-1 transition-transform"></i> Cerrar Sesión
                </a>
            </div>
        </aside>
        <main class="flex-1 overflow-y-auto p-8">
            <slot />
        </main>
	</body>
</html>
