---
import '../../../Frontend/home/styles/global.css';

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{title} | Depósito Móvil</title>
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <!-- Alpine.js for interactive UI -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <style>
        :root {
            --bg-color: #121212;
            --panel-bg: #1e1e1e;
            --accent: #10b981; /* Green for success/actions */
            --accent-hover: #059669;
            --text-main: #ffffff;
            --text-muted: #9ca3af;
        }

        * { 
            box-sizing: border-box; 
            margin: 0; 
            padding: 0; 
            -webkit-tap-highlight-color: transparent; /* Remove tap blue box on mobile */
        }
        
        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden; /* App-like feel */
        }

        /* Top Navigation Bar */
        .mobile-header {
            height: 60px;
            background-color: var(--panel-bg);
            border-bottom: 1px solid #333;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            flex-shrink: 0;
            z-index: 100;
        }

        .header-brand {
            font-weight: 900;
            font-size: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #fff;
        }

        .header-brand i {
            color: #f59e0b; /* Amber */
        }

        .user-profile {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            background: #333;
            border-radius: 50%;
            color: #fff;
            font-weight: 700;
            font-size: 14px;
        }

        /* Main Content Area */
        .mobile-main {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            padding-bottom: 80px; /* Space for bottom nav */
            display: flex;
            flex-direction: column;
        }

        /* Bottom Navigation Bar */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 65px;
            background-color: var(--panel-bg);
            border-top: 1px solid #333;
            display: flex;
            justify-content: space-around;
            align-items: center;
            z-index: 100;
            padding-bottom: env(safe-area-inset-bottom);
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            text-decoration: none;
            flex: 1;
            height: 100%;
            gap: 4px;
            transition: color 0.2s;
        }

        .nav-item.active {
            color: var(--accent);
        }

        .nav-item i {
            font-size: 20px;
        }

        .nav-item span {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
        }

        /* Utility Classes for Mobile Apps */
        .btn-giant {
            width: 100%;
            padding: 20px;
            border-radius: 16px;
            background: var(--accent);
            color: #fff;
            border: none;
            font-size: 18px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            box-shadow: 0 8px 24px rgba(16, 185, 129, 0.3);
            transition: transform 0.1s, background 0.2s;
        }

        .btn-giant:active {
            transform: scale(0.96);
            background: var(--accent-hover);
        }
        
        /* Disable text selection */
        .no-select {
            user-select: none;
            -webkit-user-select: none;
        }
    </style>
</head>
<body class="no-select">
    <header class="mobile-header">
        <div class="header-brand">
            <i class="fas fa-boxes"></i> DEPÓSITO
        </div>
        <div class="user-profile">
            <i class="fas fa-user"></i>
        </div>
    </header>

    <main class="mobile-main">
        <slot />
    </main>

    <nav class="bottom-nav">
        <a href="/deposito" class="nav-item ${Astro.url.pathname === '/deposito' || Astro.url.pathname === '/deposito/' ? 'active' : ''}">
            <i class="fas fa-home"></i>
            <span>Inicio</span>
        </a>
        <a href="/deposito/ingreso" class="nav-item ${Astro.url.pathname.includes('/deposito/ingreso') ? 'active' : ''}">
            <i class="fas fa-plus-circle"></i>
            <span>Ingresar</span>
        </a>
        <a href="#" class="nav-item">
            <i class="fas fa-search"></i>
            <span>Buscar</span>
        </a>
    </nav>
</body>
</html>
