---
import '../../../Frontend/home/styles/global.css';
import { directus, readItems } from '@conexiones/directus.js';
import { query } from '@conexiones/lib/db.js';
import QuickNotes from '../components/QuickNotes.astro';
import AgendaPanel from '../components/AgendaPanel.astro';
import BusinessHoursCounter from '../components/BusinessHoursCounter.astro';
import HelpModal from '../components/HelpModal.astro';

interface Props {
    title: string;
    vendedor_id?: string;
}

const { title, vendedor_id } = Astro.props;

const resolvedSellerId = vendedor_id || Astro.cookies.get('seller_session')?.value || '1';

let sellerName = "Fernando (Caja)";
let sellerProfile = {
    foto_personal: '',
};

if (resolvedSellerId) {
    try {
        const sellerResults = await directus.request(readItems('vendedores', {
            filter: { id: { _eq: parseInt(resolvedSellerId) } },
            limit: 1
        })) as any[];
        if (sellerResults?.[0]) {
            sellerName = sellerResults[0].name || sellerName;
        }

        const profileRes = await query('SELECT * FROM vendedor_perfiles WHERE vendedor_id = $1 LIMIT 1', [parseInt(resolvedSellerId)]);
        if (profileRes?.rows?.[0]) {
            sellerProfile = profileRes.rows[0];
            if (sellerProfile.name) sellerName = sellerProfile.name;
        }
    } catch(e) {
        console.error("[Workspace] Error fetching seller info:", e);
    }
}
---

<!DOCTYPE html>
<html lang="es-AR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Dashboard de Caja</title>
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet">
    
    <!-- Chart.js and ApexCharts -->
    <script src="https://cdn.jsdelivr.net/npm/apexcharts" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/currency.js@2.0.4/dist/currency.min.js" crossorigin="anonymous"></script>
    <!-- Alpine.js for ManualGecom and CalculadoraNeta -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" crossorigin="anonymous"></script>

    <style>
        :root {
            /* Adobe Photoshop/Premiere CC Dark Theme Palette */
            --ps-bg: #1e1e1e;
            --ps-panel-bg: #252525;
            --ps-panel-border: #383838;
            --ps-text-main: #cccccc;
            --ps-text-muted: #888888;
            --ps-accent: #2e609c;
            --ps-accent-hover: #3d79bf;
            --ps-toolbar-bg: #333333;
            --ps-toolbar-border: #444444;
            --ps-tab-bg: #2d2d2d;
            --ps-tab-active: #1e1e1e;
            --ps-highlight: #ffffff;
            --ps-success: #10b981;
            --ps-warning: #f59e0b;
            --ps-danger: #ef4444;
            
            --scrollbar-bg: #1e1e1e;
            --scrollbar-thumb: #444444;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        
        body {
            background-color: var(--ps-bg);
            color: var(--ps-text-main);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            height: 100vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            font-size: 13px;
        }

        /* Top Menu Bar */
        .top-menubar {
            height: 28px;
            background-color: var(--ps-toolbar-bg);
            border-bottom: 1px solid var(--ps-toolbar-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 12px;
            user-select: none;
        }
        
        .menu-items { display: flex; gap: 16px; }
        .menu-item { color: var(--ps-text-main); cursor: pointer; padding: 4px 8px; border-radius: 2px; position: relative; }
        .menu-item:hover { background-color: rgba(255, 255, 255, 0.1); color: var(--ps-highlight); }

        .dropdown-content {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            background-color: var(--ps-toolbar-bg);
            min-width: 220px;
            box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.5);
            z-index: 100;
            border: 1px solid var(--ps-toolbar-border);
            border-radius: 0 0 4px 4px;
        }
        .menu-item:hover .dropdown-content { display: block; }
        .dropdown-content a {
            color: var(--ps-text-main);
            padding: 8px 12px;
            text-decoration: none;
            display: flex;
            align-items: center;
            font-size: 12px;
            border-bottom: 1px solid var(--ps-panel-border);
        }
        .dropdown-content a:last-child { border-bottom: none; }
        .dropdown-content a:hover {
            background-color: rgba(255, 255, 255, 0.1);
            color: var(--ps-highlight);
        }
        .dropdown-content a i {
            margin-right: 8px;
            width: 14px;
            text-align: center;
        }

        .macro-ticker {
            display: flex;
            gap: 15px;
            color: #10b981;
            font-family: 'Roboto Mono', monospace;
            font-size: 11px;
            align-items: center;
        }

        /* App Layout */
        .app-container {
            display: flex;
            flex: 1;
            height: calc(100vh - 28px);
            overflow: hidden;
        }

        /* Left Toolbar */
        .toolbar {
            width: 48px;
            background-color: var(--ps-toolbar-bg);
            border-right: 1px solid var(--ps-toolbar-border);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 10px 0;
            justify-content: space-between;
            z-index: 10;
        }

        .tool-btn {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--ps-text-main);
            border-radius: 4px;
            margin-bottom: 4px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s ease;
            position: relative;
        }

        .tool-btn:hover { background-color: rgba(255,255,255,0.1); color: var(--ps-highlight); }
        .tool-btn.active { background-color: var(--ps-panel-border); box-shadow: inset 0 1px 3px rgba(0,0,0,0.5); }
        .toolbar-sep { width: 24px; height: 1px; background-color: var(--ps-toolbar-border); margin: 8px 0; }

        .badge-new {
            position: absolute;
            top: -4px;
            right: -25px;
            background: #ef4444;
            color: white;
            font-size: 8px;
            font-weight: bold;
            padding: 2px 4px;
            border-radius: 4px;
            animation: pulse-badge 2s infinite;
            z-index: 20;
        }
        @keyframes pulse-badge {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }

        /* Buscador OCR Button */
        .tool-btn--buscador {
            color: #ef4444 !important;
            position: relative;
            flex-direction: column;
            gap: 2px;
            height: auto !important;
            min-height: 36px;
            padding: 5px 0;
        }
        .tool-btn--buscador i {
            font-size: 15px;
            filter: drop-shadow(0 0 5px rgba(239,68,68,0.6));
        }
        .tool-btn--buscador:hover {
            background-color: rgba(239,68,68,0.15) !important;
            color: #ef4444 !important;
        }
        .tool-btn--buscador.active {
            background-color: rgba(239,68,68,0.25) !important;
            box-shadow: inset 0 0 10px rgba(239,68,68,0.3), 0 0 8px rgba(239,68,68,0.4);
        }
        .tool-ocr-badge {
            font-size: 7px;
            font-weight: 900;
            color: #ef4444;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            line-height: 1;
        }

        /* Main Canvas */
        .canvas-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            background-color: var(--ps-bg);
            position: relative;
            min-width: 0; /* Prevents flex overflow */
        }

        .tabs-bar {
            height: 34px;
            background-color: var(--ps-panel-bg);
            border-bottom: 1px solid var(--ps-panel-border);
            display: flex;
            padding: 0 8px;
            align-items: flex-end;
        }

        .tab {
            height: 28px;
            padding: 0 15px;
            background-color: var(--ps-tab-bg);
            border-radius: 4px 4px 0 0;
            margin-right: 2px;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            border: 1px solid var(--ps-panel-border);
            border-bottom: none;
            color: var(--ps-text-muted);
            font-size: 12px;
        }

        .tab.active { background-color: var(--ps-tab-active); color: var(--ps-highlight); border-bottom: 1px solid var(--ps-tab-active); margin-bottom: -1px; z-index: 2; }
        
        .canvas-content {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            position: relative;
        }

        /* Right Panel */
        .right-panel {
            width: 280px;
            background-color: var(--ps-panel-bg);
            border-left: 1px solid var(--ps-panel-border);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), min-width 0.3s cubic-bezier(0.4, 0, 0.2, 1), border-left-color 0.3s ease;
        }

        .right-panel.collapsed {
            width: 0;
            min-width: 0;
            border-left-color: transparent;
        }

        /* Toggle trigger strip */
        .right-panel-toggle {
            width: 20px;
            background-color: var(--ps-panel-bg);
            border-left: 1px solid var(--ps-panel-border);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding-top: 15px;
            cursor: pointer;
            transition: background-color 0.2s;
            z-index: 40;
            user-select: none;
            flex-shrink: 0;
        }
        .right-panel-toggle:hover {
            background-color: var(--ps-toolbar-bg);
        }
        .right-panel-toggle i {
            color: var(--ps-text-muted);
            font-size: 10px;
        }
        .right-panel-toggle-text {
            writing-mode: vertical-rl;
            text-orientation: mixed;
            font-size: 9px !important;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #666;
            margin-top: 15px;
        }

        .panel-header {
            height: 34px;
            display: flex;
            align-items: center;
            padding: 0 12px;
            background-color: var(--ps-toolbar-bg);
            border-bottom: 1px solid var(--ps-toolbar-border);
            font-weight: 600;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .panel-body { padding: 12px; flex: 1; overflow-y: auto; }
        
        /* Notes widget */
        .notes-widget {
            background: var(--ps-bg);
            border: 1px solid var(--ps-panel-border);
            border-radius: 4px;
            padding: 10px;
            margin-top: 15px;
        }
        
        .notes-widget h4 { margin-bottom: 10px; font-size: 12px; color: var(--ps-highlight); }
        .notes-widget textarea {
            width: 100%;
            height: 150px;
            background: var(--ps-toolbar-bg);
            border: 1px solid var(--ps-panel-border);
            color: var(--ps-text-main);
            padding: 8px;
            border-radius: 4px;
            resize: vertical;
            font-family: inherit;
        }
        
        /* Tooltip */
        .tooltip {
            position: fixed;
            background: #111;
            color: #fff;
            padding: 4px 8px;
            border-radius: 3px;
            font-size: 11px;
            pointer-events: none;
            z-index: 1000;
            opacity: 0;
            transition: opacity 0.1s;
            border: 1px solid #333;
        }
        .tooltip.visible { opacity: 1; }

        /* RESPONSIVE LAYOUT MOBILE */
        @media (max-width: 768px) {
            .app-container { flex-direction: column-reverse; }
            .toolbar { width: 100%; height: 60px; flex-direction: row; border-right: none; border-top: 1px solid var(--ps-toolbar-border); padding: 0 8px; justify-content: space-around; }
            .toolbar-top { flex-direction: row; gap: 8px; flex: 1; align-items: center; justify-content: center; }
            .toolbar-bottom { padding-bottom: 0; padding-left: 8px; flex-direction: row; align-items: center; justify-content: center; }
            .toolbar-sep { width: 1px; height: 24px; margin: 0 4px; }
            .right-panel, .right-panel-toggle { display: none !important; }
        }

    </style>
</head>
<body>
    <div class="tooltip" id="global-tooltip"></div>

    <header class="top-menubar">
        <div class="menu-items">
            <div class="menu-item" style="display:flex; align-items:center; gap:6px;">
                <i class="fa-solid fa-gem text-blue-400" style="font-size: 12px;"></i>
                Alvarez Placas <span style="background:rgba(59,130,246,0.15); color:#3b82f6; padding:2px 6px; border-radius:4px; font-size:9px; font-weight:bold; letter-spacing:0.5px;">v2.2.0</span>
            </div>
            <div class="menu-item">Archivo</div>
            <div class="menu-item">Finanzas</div>
            <div class="menu-item">Reportes</div>
            <div class="menu-item">
                Ayuda <i class="fas fa-chevron-down" style="font-size: 9px; margin-left: 4px; opacity: 0.7;"></i>
                <div class="dropdown-content">
                    <a href="javascript:void(0)" id="btn-manual"><i class="fas fa-book text-blue-400"></i> Manual de Usuario</a>
                    <a href="javascript:void(0)" id="btn-acerca"><i class="fas fa-info-circle text-purple-400"></i> Acerca del Sistema</a>
                </div>
            </div>
        </div>
        
        <!-- Macro Ticker & Business Hours -->
        <div style="display: flex; align-items: center; gap: 20px;">
            <BusinessHoursCounter />
            <div class="macro-ticker" id="macro-ticker">
                <!-- Carga dinámica para evitar ceros y CORS -->
            </div>
            
            <div style="width: 1px; height: 24px; background: #333;"></div>
            
            <div class="live-badge" style="display: flex; items-center; gap: 6px; font-size: 11px; font-weight: 800; color: #fff; background: #2d2d2d; padding: 4px 10px; border-radius: 12px; border: 1px solid #444;">
                <i class="fas fa-circle" style="color: #22c55e; font-size: 8px;"></i>
                LIVE: {sellerName}
            </div>
            
            <div style="width: 1px; height: 24px; background: #333;"></div>
            
            <i class="fas fa-search" style="color: #888; font-size: 14px; cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#888'"></i>
            <i class="fa-solid fa-user-tie" id="profile-trigger-icon" style="color: #888; font-size: 16px; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.color='#fff'; this.style.transform='scale(1.15) rotate(5deg)'" onmouseout="this.style.color='#888'; this.style.transform='scale(1)'"></i>
        </div>
    </header>

    <div class="app-container">
        <!-- Left Toolbar -->
        <aside class="toolbar">
            <div class="toolbar-top">
                <a href={title === 'Caja' ? 'javascript:void(0)' : '/vendedor/caja'} class={`tool-btn tooltip-trigger ${title === 'Caja' ? 'active' : ''}`} data-tab="tab-diario" data-tooltip="Panel General de Caja">
                    <i class="fas fa-columns"></i>
                </a>
                <a href="/vendedor/ejecutivo" class={`tool-btn tooltip-trigger ${title === 'Dashboard Ejecutivo' ? 'active' : ''}`} data-tooltip="Dashboard Ejecutivo">
                    <i class="fas fa-chart-pie" style={title === 'Dashboard Ejecutivo' ? 'color:#3b82f6;' : ''}></i>
                </a>
                <a href="/vendedor/facturas" class={`tool-btn tooltip-trigger tool-btn--buscador ${title === 'Buscador Inteligente de Facturas' ? 'active' : ''}`} data-tooltip="Nuevo: Buscador Inteligente de Facturas (OCR)" id="tool-buscador-btn">
                    <i class="fas fa-search"></i>
                    <span class="tool-ocr-badge">OCR</span>
                    <span class="badge-new">NUEVO</span>
                </a>
                <div class="toolbar-sep"></div>
                <a href="/vendedor/herramientas" class={`tool-btn tooltip-trigger ${title === 'Herramientas Financieras' ? 'active' : ''}`} data-tooltip="Herramientas Financieras">
                    <i class="fas fa-toolbox"></i>
                </a>
                <a href="/vendedor/radar" class={`tool-btn tooltip-trigger ${title === 'Radar Global de Mercado' ? 'active' : ''}`} data-tooltip="Radar Predictivo de Mercado">
                    <i class="fas fa-satellite-dish"></i>
                </a>
            </div>

            <div class="toolbar-bottom">
                <a href="/vendedor" class="tool-btn tooltip-trigger" data-tooltip="Volver al Portal Vendedor" style="color:#3b82f6;">
                    <i class="fas fa-arrow-left"></i>
                </a>
                <button id="logout-btn" class="tool-btn tooltip-trigger" data-tooltip="Cerrar Sesión" style="color:#ef4444;">
                    <i class="fas fa-power-off"></i>
                </button>
            </div>
        </aside>

        <main class="canvas-area">
            <div class="tabs-bar">
                <div class="tab active" id="active-tab">
                    <span id="active-tab-name">Operacion_Diaria.xls</span>
                </div>
            </div>

            <div class="canvas-content">
                <slot />
            </div>
        </main>

        <aside class="right-panel">
            <div class="panel-header">
                <span class="panel-title">Propiedades de Caja</span>
            </div>
            <div class="panel-body">
                <!-- Removed Contexto Actual -->
                
                <div class="notes-widget" style="padding: 0; border: none; background: transparent;">
                    <QuickNotes vendedor_id={resolvedSellerId} />
                </div>

                <div class="agenda-widget" style="margin-top: 15px;">
                    <AgendaPanel vendedor_id={resolvedSellerId} />
                </div>
            </div>
        </aside>
        <div class="right-panel-toggle" id="btn-toggle-right-panel" title="Expandir Panel Derecho">
            <i class="fas fa-chevron-left"></i>
            <span class="right-panel-toggle-text">Notas y Agenda</span>
        </div>
    </div>

    <!-- HELP MANUAL MODAL -->
    <HelpModal role="cajero" />

    <!-- SELLER PROFILE EDIT MODAL -->
    <div id="profile-modal" class="modal-overlay">
        <div class="modal-window modal-window--profile" style="max-width: 600px; height: auto; min-height: 480px; display: flex; flex-direction: column;">
            <header class="modal-header" style="height: 48px; background: #2d2d2d; border-bottom: 1px solid #111; display: flex; align-items: center; justify-content: space-between; padding: 0 16px; flex-shrink: 0;">
                <div class="modal-header-title" style="display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 16px; color: #fff;">
                    <i class="fas fa-user-circle" style="color: #e02020; font-size: 22px;"></i>
                    <span>Personalización de Ficha de Cajero</span>
                </div>
                <button class="modal-close" id="btn-close-profile" style="background: transparent; border: none; color: #888; font-size: 24px; cursor: pointer; transition: color .15s;">&times;</button>
            </header>
            <div class="modal-body" style="display: block; padding: 25px; flex: 1; background: #252525; overflow-y: auto;">
                <form id="profile-edit-form" style="display: flex; flex-direction: column; gap: 20px;">
                    <!-- Cambio de Contraseña -->
                    <div style="padding-top: 5px;">
                        <label style="display: block; font-size: 12px; font-weight: 900; text-transform: uppercase; color: #888; margin-bottom: 8px; letter-spacing: .05em; display: flex; align-items: center; gap: 8px;">
                            <i class="fas fa-lock" style="color: #e02020;"></i> Cambiar Contraseña <span style="font-size: 10px; font-weight: 500; text-transform: none; color: #666;">(Dejar en blanco para mantener la actual)</span>
                        </label>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                            <div>
                                <input type="password" id="profile-password" style="width: 100%; border: 1px solid #333; border-radius: 8px; padding: 12px; color: #fff; font-size: 14px; outline: none; background: #1a1a1a;" placeholder="Nueva contraseña" />
                            </div>
                            <div>
                                <input type="password" id="profile-password-confirm" style="width: 100%; border: 1px solid #333; border-radius: 8px; padding: 12px; color: #fff; font-size: 14px; outline: none; background: #1a1a1a;" placeholder="Confirmar contraseña" />
                            </div>
                        </div>
                    </div>

                    <!-- Botones de Acción -->
                    <div style="display: flex; gap: 12px; margin-top: 15px; border-top: 1px solid #333; padding-top: 20px;">
                        <button type="button" id="btn-logout-profile" style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #f43f5e; padding: 12px 20px; border-radius: 8px; font-size: 13px; font-weight: 900; text-transform: uppercase; cursor: pointer; transition: all 0.2s;">
                            <i class="fas fa-power-off" style="margin-right: 5px;"></i> Cerrar Sesión
                        </button>
                        
                        <div style="margin-left: auto; display: flex; gap: 12px;">
                            <button type="button" id="btn-cancel-profile" style="background: #252525; border: 1px solid #333; color: #aaa; padding: 12px 20px; border-radius: 8px; font-size: 13px; font-weight: 700; text-transform: uppercase; cursor: pointer; transition: all 0.2s;">
                                Cancelar
                            </button>
                            <button type="submit" id="btn-save-profile" style="background: #e02020; border: none; color: #fff; padding: 12px 30px; border-radius: 8px; font-size: 13px; font-weight: 900; text-transform: uppercase; cursor: pointer; transition: all 0.2s; box-shadow: 0 0 15px rgba(224,32,32,0.3);">
                                Guardar Cambios <i class="fas fa-check-circle" style="margin-left: 5px;"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <style>
        .modal-overlay {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.85);
            display: none; justify-content: center; align-items: center; z-index: 9999;
            backdrop-filter: blur(4px);
        }
        .modal-overlay.show { display: flex; }
        .modal-window {
            background: var(--ps-bg); width: 90%; max-width: 800px;
            border-radius: 12px; border: 1px solid var(--ps-panel-border);
            box-shadow: 0 20px 40px rgba(0,0,0,0.5); overflow: hidden;
            animation: modalFadeIn 0.2s ease-out;
        }
        @keyframes modalFadeIn {
            from { opacity: 0; transform: translateY(10px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
    </style>

    <script>
        // Tooltip logic
        const tooltip = document.getElementById('global-tooltip');
        document.querySelectorAll('.tooltip-trigger').forEach(el => {
            el.addEventListener('mouseenter', e => {
                tooltip.textContent = (e.currentTarget as HTMLElement).dataset.tooltip;
                tooltip.classList.add('visible');
                
                const rect = (e.currentTarget as HTMLElement).getBoundingClientRect();
                tooltip.style.left = (rect.right + 10) + 'px';
                tooltip.style.top = (rect.top + (rect.height/2) - (tooltip.offsetHeight/2)) + 'px';
            });
            el.addEventListener('mouseleave', () => tooltip.classList.remove('visible'));
        });

        // Profile Modal Logic
        const profileModal = document.getElementById('profile-modal');
        const triggerProfile = document.getElementById('profile-trigger-icon');
        const btnCloseProfile = document.getElementById('btn-close-profile');
        const btnCancelProfile = document.getElementById('btn-cancel-profile');
        const btnLogoutProfile = document.getElementById('btn-logout-profile');
        const profileForm = document.getElementById('profile-edit-form');

        triggerProfile?.addEventListener('click', (e) => {
            e.preventDefault();
            profileModal?.classList.add('show');
        });

        const closeProfile = () => profileModal?.classList.remove('show');
        btnCloseProfile?.addEventListener('click', closeProfile);
        btnCancelProfile?.addEventListener('click', closeProfile);
        
        btnLogoutProfile?.addEventListener('click', () => {
            window.location.href = '/api/auth/logout';
        });

        profileForm?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const passwordInput = (document.getElementById('profile-password') as HTMLInputElement)?.value;
            const passwordConfirmInput = (document.getElementById('profile-password-confirm') as HTMLInputElement)?.value;

            if (passwordInput || passwordConfirmInput) {
                if (passwordInput !== passwordConfirmInput) {
                    alert('Las contraseñas no coinciden.');
                    return;
                }
                if (passwordInput.length < 6) {
                    alert('La contraseña debe tener al menos 6 caracteres.');
                    return;
                }
            }

            if (passwordInput) {
                try {
                    const resPassword = await fetch('/api/vendedor/change-password', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ password: passwordInput })
                    });
                    const dataPassword = await resPassword.json();
                    if (!dataPassword.success) {
                        alert('Ocurrió un error al actualizar la contraseña: ' + dataPassword.error);
                        return;
                    }
                    alert('¡Contraseña guardada exitosamente!');
                    closeProfile();
                } catch (err) {
                    alert('Error al procesar los cambios');
                }
            } else {
                closeProfile();
            }
        });

        // Logout from sidebar
        document.getElementById('logout-btn')?.addEventListener('click', async () => {
            await fetch('/api/auth/logout', { method: 'POST' });
            window.location.href = '/vendedor/login';
        });

        // Fetch Dolar & Riesgo Pais dynamically from internal API (CORS-free)
        async function loadMacroData() {
            try {
                const res = await fetch('/api/vendedor/market-radar');
                const json = await res.json();
                if (json.success && json.data) {
                    const data = json.data;
                    const items = [];

                    if (data.dolar?.blue?.val && data.dolar.blue.val > 0) {
                        items.push(`<span>Dólar Blue: <span style="color: #10b981; font-weight: bold;">$${data.dolar.blue.val}</span></span>`);
                    }
                    if (data.dolar?.mep?.val && data.dolar.mep.val > 0) {
                        items.push(`<span>Dólar MEP: <span style="color: #10b981; font-weight: bold;">$${data.dolar.mep.val}</span></span>`);
                    }
                    if (data.dolar?.ccl?.val && data.dolar.ccl.val > 0) {
                        items.push(`<span>Dólar CCL: <span style="color: #10b981; font-weight: bold;">$${data.dolar.ccl.val}</span></span>`);
                    }
                    if (data.riesgoPais && data.riesgoPais > 0) {
                        items.push(`<span style="color:#f59e0b;">Riesgo País: <span style="font-weight: bold;">${data.riesgoPais} pts</span></span>`);
                    }

                    const tickerEl = document.getElementById('macro-ticker');
                    if (tickerEl) {
                        tickerEl.innerHTML = items.join('<span style="color: #444; margin: 0 8px;">|</span>');
                    }
                }
            } catch(e) {
                console.error("Error loading macro data", e);
            }
        }
        
        loadMacroData();
        // Auto refresh every 5 mins
        setInterval(loadMacroData, 300000);

        // ---- Right Panel Toggle Logic (Auto collapsed on load) ----
        const rightPanel = document.querySelector('.right-panel');
        const toggleBtn = document.getElementById('btn-toggle-right-panel');
        const toggleIcon = toggleBtn?.querySelector('i');

        if (rightPanel && toggleBtn && toggleIcon) {
            rightPanel.classList.add('collapsed');
            toggleIcon.className = 'fas fa-chevron-left';
            toggleBtn.title = 'Expandir Panel Derecho';

            toggleBtn.addEventListener('click', () => {
                const isCollapsed = rightPanel.classList.toggle('collapsed');
                toggleIcon.className = isCollapsed ? 'fas fa-chevron-left' : 'fas fa-chevron-right';
                toggleBtn.title = isCollapsed ? 'Expandir Panel Derecho' : 'Colapsar Panel Derecho';
            });
        }
    </script>
</body>
</html>
