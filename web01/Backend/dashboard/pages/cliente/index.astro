---
/**
 * Cliente Dashboard - Portal de Fidelización.
 */
import ClienteLayout from '../../layouts/ClienteLayout.astro';
import StatCard from '@dashboard/components/StatCard.astro';
import { directus, readItems, readItem } from '@conexiones/directus.js';

// 1. Obtención de Identidad
const clientId = Astro.cookies.get('client_session')?.value;
if (!clientId) return Astro.redirect('/login');

let clientData = { name: '...', scoring: 0, client_number: '...', vendedor_id: null };
let assignedSeller = { name: 'Asignando...', whatsapp: '' };
let recentOrders = [];

try {
    // 2. Cargar Datos del Cliente
    clientData = await directus.request(readItem('clientes', clientId, {
        fields: ['*', { vendedor_id: ['id', 'name', 'whatsapp'] }]
    })) as any;

    if (clientData.vendedor_id) {
        assignedSeller = clientData.vendedor_id;
    }

    // 3. Cargar Pedidos Recientes
    recentOrders = await directus.request(readItems('pedidos', {
        filter: { cliente_id: { _eq: clientId } },
        sort: ['-fecha_pedido'],
        limit: 3,
        fields: ['id', 'status', 'fecha_pedido', 'total', 'datos_optimizacion']
    })) as any;

} catch (e) {
    console.error("[Client Dashboard Error]:", e);
}

const formatCurrency = (val) => new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS' }).format(val);
---

<ClienteLayout title="Centro de Control | Mi Club Alvarez" userName={clientData.name}>
    <!-- GLASS HERO SECTION -->
    <div class="relative mb-10 p-12 rounded-[3rem] overflow-hidden bg-gradient-to-br from-primary/20 via-black to-primary/5 border border-white/5 shadow-2xl">
        <div class="absolute top-0 right-0 p-12 opacity-10 scale-150 rotate-12">
            <i class="fas fa-rocket text-[120px] text-white"></i>
        </div>
        
        <div class="relative z-10">
            <div class="flex items-center gap-3 mb-6">
                <span class="px-3 py-1 bg-primary text-white text-[9px] font-black uppercase tracking-widest rounded-full">Pro Member</span>
                <span class="px-3 py-1 bg-white/5 text-gray-400 text-[9px] font-black uppercase tracking-widest rounded-full border border-white/10">ID: {clientData.client_number}</span>
            </div>
            
            <h1 class="text-5xl md:text-7xl font-black text-white tracking-tighter uppercase mb-6 leading-none">
                CENTRO DE <span class="text-primary italic">CONTROL</span>
            </h1>
            
            <p class="text-gray-400 max-w-xl text-sm font-medium leading-relaxed mb-8">
                Bienvenido a tu suite profesional de Alvarez Placas. Desde aquí puedes gestionar tus proyectos, optimizar cortes y realizar un seguimiento preciso de tus pedidos industriales.
            </p>

            <div class="flex flex-wrap gap-4">
                <div class="bg-black/60 backdrop-blur-xl border border-white/10 px-8 py-4 rounded-2xl">
                    <p class="text-[9px] font-black text-gray-500 uppercase tracking-widest mb-1">Puntos Acumulados</p>
                    <p class="text-3xl font-black text-primary leading-none">{clientData.scoring || 0}</p>
                </div>
                <div class="bg-black/60 backdrop-blur-xl border border-white/10 px-8 py-4 rounded-2xl">
                    <p class="text-[9px] font-black text-gray-500 uppercase tracking-widest mb-1">Pedidos Activos</p>
                    <p class="text-3xl font-black text-white leading-none">{recentOrders.filter(o => o.status !== 'entregado').length}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- MAIN TOOLS GRID - 1-CLICK ACCESS -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <a href="/herramientas/presupuestador" class="group bg-[#111] border border-white/5 p-8 rounded-[2.5rem] hover:bg-primary/10 hover:border-primary/30 transition-all flex flex-col justify-between min-h-[220px]">
            <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                <i class="fas fa-cut text-2xl"></i>
            </div>
            <div>
                <h3 class="text-sm font-black text-white uppercase tracking-widest mb-2">SmartCut PRO</h3>
                <p class="text-[10px] text-gray-500 font-bold uppercase">Optimizador de Placas</p>
            </div>
        </a>

        <a href="/herramientas/cubical" class="group bg-[#111] border border-white/5 p-8 rounded-[2.5rem] hover:bg-blue-500/10 hover:border-blue-500/30 transition-all flex flex-col justify-between min-h-[220px]">
            <div class="w-14 h-14 bg-blue-500/10 rounded-2xl flex items-center justify-center text-blue-500 group-hover:scale-110 transition-transform">
                <i class="fas fa-cube text-2xl"></i>
            </div>
            <div>
                <h3 class="text-sm font-black text-white uppercase tracking-widest mb-2">CubiCal PRO</h3>
                <p class="text-[10px] text-gray-500 font-bold uppercase">Calculador de Muebles</p>
            </div>
        </a>

        <a href="/catalogo" class="group bg-[#111] border border-white/5 p-8 rounded-[2.5rem] hover:bg-green-500/10 hover:border-green-500/30 transition-all flex flex-col justify-between min-h-[220px]">
            <div class="w-14 h-14 bg-green-500/10 rounded-2xl flex items-center justify-center text-green-500 group-hover:scale-110 transition-transform">
                <i class="fas fa-shopping-bag text-2xl"></i>
            </div>
            <div>
                <h3 class="text-sm font-black text-white uppercase tracking-widest mb-2">Catálogo</h3>
                <p class="text-[10px] text-gray-500 font-bold uppercase">Precios y Stock</p>
            </div>
        </a>

        <a href="/cliente/pedidos" class="group bg-[#111] border border-white/5 p-8 rounded-[2.5rem] hover:bg-orange-500/10 hover:border-orange-500/30 transition-all flex flex-col justify-between min-h-[220px]">
            <div class="w-14 h-14 bg-orange-500/10 rounded-2xl flex items-center justify-center text-orange-500 group-hover:scale-110 transition-transform">
                <i class="fas fa-history text-2xl"></i>
            </div>
            <div>
                <h3 class="text-sm font-black text-white uppercase tracking-widest mb-2">Mis Pedidos</h3>
                <p class="text-[10px] text-gray-500 font-bold uppercase">Historial y Tracking</p>
            </div>
        </a>
    </div>

    <!-- RECENT ACTIVITY & ASISTENCIA -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
        
        <!-- ACTIVITY -->
        <div class="xl:col-span-2 bg-[#0a0a0a] border border-white/5 rounded-[3rem] p-10">
            <div class="flex justify-between items-center mb-10">
                <h3 class="text-xs font-black text-white uppercase tracking-[0.4em]">Actividad Reciente</h3>
                <a href="/cliente/pedidos" class="text-[9px] font-black text-gray-600 uppercase border-b border-gray-800 pb-1 hover:text-white hover:border-white transition-all">Ver Historial</a>
            </div>

            <div class="space-y-4">
                {recentOrders.length === 0 ? (
                    <div class="py-20 text-center opacity-30">
                        <i class="fas fa-ghost text-5xl mb-4"></i>
                        <p class="text-[10px] font-black uppercase">Sin actividad reciente</p>
                    </div>
                ) : (
                    recentOrders.map(order => (
                        <div class="flex items-center justify-between p-6 bg-white/5 border border-white/5 rounded-3xl hover:bg-white/10 transition-all group cursor-pointer" onclick={`window.location.href='/cliente/pedidos?id=${order.id}'`}>
                            <div class="flex items-center gap-6">
                                <div class="w-14 h-14 bg-black border border-white/10 rounded-2xl flex items-center justify-center text-primary group-hover:rotate-12 transition-all">
                                    <i class="fas fa-file-invoice"></i>
                                </div>
                                <div>
                                    <p class="text-xs font-black text-white uppercase">Pedido #{order.id}</p>
                                    <div class="flex items-center gap-3 mt-1">
                                        <span class="text-[10px] text-gray-600 font-bold">{new Date(order.fecha_pedido).toLocaleDateString('es-AR')}</span>
                                        <span class="w-1 h-1 bg-gray-800 rounded-full"></span>
                                        <span class={`text-[9px] font-black uppercase ${order.status === 'entregado' ? 'text-green-500' : 'text-primary'}`}>
                                            {order.status.replace('_', ' ')}
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-black text-white">{formatCurrency(order.total)}</p>
                                <p class="text-[9px] text-gray-700 font-black uppercase mt-1">Ver Detalle</p>
                            </div>
                        </div>
                    ))
                )}
            </div>
        </div>

        <!-- CONTACT -->
        <div class="space-y-6">
            <div class="bg-gradient-to-br from-primary to-orange-700 p-10 rounded-[3rem] text-white relative overflow-hidden group">
                <div class="absolute -right-6 -bottom-6 opacity-20 group-hover:scale-110 transition-transform">
                    <i class="fab fa-whatsapp text-9xl"></i>
                </div>
                
                <p class="text-[10px] font-black uppercase tracking-widest mb-8">Asesoría Técnica</p>
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-16 h-16 bg-white/20 backdrop-blur-md rounded-2xl flex items-center justify-center border border-white/30 shadow-xl">
                        <i class="fas fa-user-tie text-2xl"></i>
                    </div>
                    <div>
                        <p class="text-[9px] font-black opacity-60 uppercase">Tu Vendedor</p>
                        <p class="text-xl font-black italic uppercase leading-none">{assignedSeller.name}</p>
                    </div>
                </div>
                
                <a href={`https://wa.me/${assignedSeller.whatsapp}`} target="_blank" class="w-full bg-white text-black font-black py-4 rounded-2xl flex items-center justify-center gap-3 transition-all hover:bg-black hover:text-white uppercase tracking-widest text-[11px] shadow-2xl">
                    <i class="fab fa-whatsapp text-lg"></i> Iniciar Chat
                </a>
            </div>

            <div class="bg-[#111] border border-white/5 p-10 rounded-[3rem]">
                <h4 class="text-[10px] font-black text-gray-500 uppercase tracking-widest mb-6">Configuración</h4>
                <div class="space-y-2">
                    <a href="/cliente/perfil" class="flex items-center justify-between p-4 bg-white/5 rounded-2xl hover:bg-white/10 transition-all group">
                        <span class="text-[10px] font-black uppercase tracking-widest text-gray-400 group-hover:text-white">Perfil Profesional</span>
                        <i class="fas fa-cog text-[10px] text-gray-800"></i>
                    </a>
                    <a href="/api/auth/logout" class="flex items-center justify-between p-4 bg-red-500/5 rounded-2xl hover:bg-red-500/10 transition-all group border border-red-500/10">
                        <span class="text-[10px] font-black uppercase tracking-widest text-red-500">Desconectar</span>
                        <i class="fas fa-power-off text-[10px] text-red-500/50"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

            <!-- ESTADO DE CUENTA / ACCESO RÁPIDO -->
            <div class="bg-[#111] border border-white/5 rounded-[2.5rem] p-8">
                <h3 class="text-xs font-black text-gray-600 uppercase tracking-[0.3em] mb-6">Mi Cuenta</h3>
                <div class="space-y-2">
                    <button onclick="window.location.href='/cliente/perfil'" class="w-full p-4 bg-white/5 rounded-2xl border border-white/5 hover:bg-white/10 transition-all flex items-center justify-between group">
                        <span class="text-[10px] font-black uppercase tracking-widest text-gray-400 group-hover:text-white">Mis Datos</span>
                        <i class="fas fa-chevron-right text-[8px] text-gray-700"></i>
                    </button>
                    <button onclick="window.location.href='/api/auth/logout'" class="w-full p-4 bg-red-500/5 rounded-2xl border border-red-500/10 hover:bg-red-500/10 transition-all flex items-center justify-between group">
                        <span class="text-[10px] font-black uppercase tracking-widest text-red-500/70">Cerrar Sesión</span>
                        <i class="fas fa-power-off text-[10px] text-red-500/50"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <!-- Client-side Logic for Messaging -->
    <script is:inline>
        const modal = document.getElementById('message-modal');
        const openBtn = document.getElementById('open-message-modal');
        const closeBtn = document.getElementById('close-message-modal');
        const form = document.getElementById('internal-message-form');
        const sendBtn = document.getElementById('send-btn');

        if (openBtn) {
            openBtn.onclick = () => modal.classList.remove('hidden');
        }

        if (closeBtn) {
            closeBtn.onclick = () => modal.classList.add('hidden');
        }

        if (form) {
            form.onsubmit = async (e) => {
                e.preventDefault();
                const originalBtn = sendBtn.innerHTML;
                sendBtn.disabled = true;
                sendBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';

                const formData = new FormData(form);
                const data = {
                    toId: formData.get('toId'),
                    content: formData.get('content'),
                    prioridad: formData.get('prioridad')
                };

                try {
                    const res = await fetch('/api/messages', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });

                    if (res.ok) {
                        alert('Mensaje enviado correctamente');
                        modal.classList.add('hidden');
                        form.reset();
                    } else {
                        alert('Error al enviar el mensaje');
                    }
                } catch (err) {
                    alert('Error de conexión');
                } finally {
                    sendBtn.disabled = false;
                    sendBtn.innerHTML = originalBtn;
                }
            };
        }
    </script>
</ClienteLayout>
