---
/**
 * Cliente Dashboard - Portal de Fidelización.
 * Refactorizado bajo estándares de Vanguardia Web 2026:
 * - Semántica HTML5 estricta (<main>, <aside>, <section>, <article>, <header>).
 * - Espacio de color OKLCH para gradientes uniformes e hiper-realistas.
 * - CSS Nesting nativo y soporte nativo de variables CSS con transiciones fluidas.
 * - Accesibilidad ARIA robusta (A11y/WCAG 3.0).
 */
import ClienteLayout from '../../layouts/ClienteLayout.astro';
import { directus, readItems, readItem } from '@conexiones/directus.js';
import { query } from '@conexiones/lib/db.js';

// 1. Obtención de Identidad (Soporta Cliente, Vendedor y Admin de forma polimórfica)
let clientId = Astro.cookies.get('client_session')?.value;
const isSeller = Astro.cookies.has('seller_session');
const isAdmin = Astro.cookies.has('admin_session');

const url = new URL(Astro.request.url);
const queryClientId = url.searchParams.get('id') || url.searchParams.get('clientId');
if (queryClientId && (isSeller || isAdmin)) {
    clientId = queryClientId;
}

if (!clientId) {
    if (isSeller || isAdmin) {
        try {
            const tempClients = await directus.request(readItems('clientes', { limit: 1, fields: ['id'] }));
            if (tempClients && tempClients.length > 0) {
                clientId = tempClients[0].id.toString();
            }
        } catch (e) {
            console.error("Error al buscar cliente temporal de soporte:", e);
        }
    }
}

if (!clientId) return Astro.redirect('/login');

let clientData = { name: '...', scoring: 0, client_number: '...', vendedor_id: null };
let assignedSeller = { id: null, name: 'Asignando...', whatsapp: '' };
let recentOrders = [];
let sellerProfile = null;

try {
    // 2. Cargar Datos del Cliente
    clientData = await directus.request(readItem('clientes', clientId, {
        fields: ['*', { vendedor_id: ['id', 'name', 'whatsapp'] }]
    })) as any;

    if (clientData.vendedor_id) {
        assignedSeller = clientData.vendedor_id;
        
        // Cargar datos del perfil de vendedor personalizado desde PostgreSQL
        if (assignedSeller.id) {
            try {
                await query(`
                    CREATE TABLE IF NOT EXISTS vendedor_perfiles (
                        vendedor_id INTEGER PRIMARY KEY,
                        name VARCHAR(255),
                        foto_personal TEXT,
                        foto_oferta TEXT,
                        nombre_oferta VARCHAR(255),
                        mensaje_oferta TEXT,
                        updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                    );
                `);
                const profileRes = await query('SELECT * FROM vendedor_perfiles WHERE vendedor_id = $1 LIMIT 1', [parseInt(assignedSeller.id)]);
                if (profileRes?.rows?.[0]) {
                    sellerProfile = profileRes.rows[0];
                    if (sellerProfile.name) {
                        assignedSeller.name = sellerProfile.name;
                    }
                }
            } catch (pgErr) {
                console.error("[Client Dashboard] Error loading seller profile from postgres:", pgErr);
            }
        }
    }

    // 3. Cargar Pedidos Recientes
    recentOrders = await directus.request(readItems('pedidos', {
        filter: { cliente_id: { _eq: clientId } },
        sort: ['-fecha_pedido'],
        limit: 3,
        fields: ['id', 'status', 'fecha_pedido', 'total', 'datos_optimizacion']
    })) as any;

} catch (e) {
    console.error("[Client Dashboard Error]:", e);
}

// 4. Avisos Generales (Requiere colección "avisos_generales" en Directus con campos: titulo, mensaje)
let generalNotices = [];
try {
    const allNotices = await directus.request(readItems('avisos_generales')) as any[];
    // Filtramos manualmente para soportar si status es un array (checkbox) o string (dropdown)
    generalNotices = allNotices.filter(n => {
        if (!n.status) return false;
        return Array.isArray(n.status) ? n.status.includes('published') : n.status === 'published';
    });
} catch (e) {
    console.warn("[Avisos] Falló la carga de avisos:", e.message);
}

// 5. Lógica de Rango de Fidelidad (Gamificación)
const score = clientData.scoring || 0;
let memberLevel = { 
    name: 'NIVEL BRONCE', 
    badgeClass: 'bg-[oklch(0.2_0.04_80_/_0.2)] text-[oklch(0.7_0.15_80)] border-[oklch(0.4_0.08_80_/_0.3)]', 
    heroGradient: 'from-[oklch(0.3_0.08_80_/_0.1)] via-[oklch(0.2_0.04_80_/_0.05)] to-transparent',
    scoringText: 'text-[oklch(0.7_0.15_80)]'
};

if (score > 1000 && score <= 5000) {
    memberLevel = { 
        name: 'NIVEL PLATA', 
        badgeClass: 'bg-[oklch(0.2_0.01_200_/_0.6)] text-[oklch(0.8_0.02_200)] border-[oklch(0.4_0.02_200_/_0.4)]', 
        heroGradient: 'from-[oklch(0.3_0.02_200_/_0.1)] via-[oklch(0.2_0.01_200_/_0.05)] to-transparent',
        scoringText: 'text-[oklch(0.8_0.02_200)]' 
    };
} else if (score > 5000) {
    memberLevel = { 
        name: 'NIVEL MÁSTER ORO', 
        badgeClass: 'bg-[oklch(0.2_0.12_85_/_0.2)] text-[oklch(0.75_0.18_85)] border-[oklch(0.5_0.12_85_/_0.3)] font-black animate-pulse', 
        heroGradient: 'from-[oklch(0.4_0.12_85_/_0.15)] via-[oklch(0.2_0.06_85_/_0.05)] to-transparent',
        scoringText: 'text-[oklch(0.75_0.18_85)]'
    };
}

const getOrderStatusConfig = (status: string) => {
    const s = status.toLowerCase();
    if (s === 'entregado') {
        return { label: 'ENTREGADO', class: 'bg-[oklch(0.25_0.14_140_/_0.1)] text-[oklch(0.75_0.16_140)] border-[oklch(0.4_0.1_140_/_0.2)]' };
    }
    if (['procesando', 'sierra', 'cortando'].includes(s)) {
        return { label: 'EN PRODUCCIÓN', class: 'bg-[oklch(0.25_0.15_200_/_0.1)] text-[oklch(0.7_0.18_200)] border-[oklch(0.4_0.12_200_/_0.2)] animate-pulse' };
    }
    if (s === 'cancelado') {
        return { label: 'CANCELADO', class: 'bg-[oklch(0.25_0.16_20_/_0.1)] text-[oklch(0.65_0.18_20)] border-[oklch(0.4_0.12_20_/_0.2)]' };
    }
    return { label: 'PENDIENTE', class: 'bg-[oklch(0.25_0.15_80_/_0.1)] text-[oklch(0.7_0.15_80)] border-[oklch(0.4_0.1_80_/_0.2)]' };
};

const formatCurrency = (val) => new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS' }).format(val);
---

<ClienteLayout title="Centro de Control | Mi Club Alvarez" userName={clientData.name}>
    
    <!-- 🎨 CONTENEDOR MAESTRO DE TEMA CON VARIABLES CSS AVANZADAS -->
    <div id="theme-wrapper" class="theme-light transition-colors duration-300 w-full min-h-screen text-[var(--text-main)]" aria-live="polite">
        
        <!-- 🧭 ACCESIBILIDAD Y CABECERA DEL SISTEMA -->
        <header class="flex flex-col md:flex-row justify-between items-center gap-4 mb-6 px-6 py-4 rounded-2xl bg-[var(--bg-card)] border border-[var(--border-card)] shadow-sm transition-colors duration-300" aria-label="Barra de herramientas superior">
            <div class="hidden md:flex items-center gap-2 text-xs font-mono text-[var(--text-muted)]">
                <span class="w-2.5 h-2.5 rounded-full bg-[oklch(0.7_0.2_140)] animate-pulse" aria-hidden="true"></span>
                SISTEMA EN LÍNEA | MODALIDAD: CLIENTE PROFESIONAL
            </div>
            
            <div class="flex items-center justify-between w-full md:w-auto gap-4">
                <div class="flex items-center gap-2">
                    <!-- Pedidos Activos -->
                    <div class="flex items-center gap-2 px-3 py-1.5 bg-[var(--bg-main)] border border-[var(--border-card)] rounded-full shadow-sm" title="Pedidos Activos">
                        <span class="text-[9px] font-black text-[var(--text-muted)] uppercase tracking-widest hidden sm:inline">Pedidos:</span>
                        <i class="fas fa-box-open text-[var(--text-muted)] text-[10px] sm:hidden"></i>
                        <span class="text-[12px] font-black text-[var(--text-main)]">{recentOrders.filter(o => o.status !== 'entregado').length}</span>
                    </div>

                    <!-- Puntos (Moneda de Oro) -->
                    <div class="flex items-center gap-2 px-3 py-1.5 bg-[var(--bg-main)] border border-[var(--border-card)] rounded-full shadow-sm" title="Puntos Acumulados">
                        <div class="w-5 h-5 rounded-full bg-gradient-to-br from-yellow-300 via-yellow-500 to-yellow-600 border border-yellow-200 shadow-[inset_0_-1px_1px_rgba(0,0,0,0.4),0_1px_2px_rgba(0,0,0,0.2)] flex items-center justify-center relative overflow-hidden">
                            <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/50 to-transparent"></div>
                            <i class="fas fa-star text-[9px] text-yellow-50 drop-shadow-md z-10"></i>
                        </div>
                        <span class="text-[12px] font-black text-[var(--text-main)]">{score} <span class="text-[9px] font-bold text-[var(--text-muted)] uppercase tracking-wider hidden sm:inline">Pts</span></span>
                    </div>
                </div>

                <!-- Botón de Alternancia de Tema (☀️/🌙) con Etiquetas ARIA -->
                <button 
                    id="theme-toggle-btn" 
                    class="flex items-center gap-2 px-3 py-1.5 rounded-full border border-[var(--border-card)] bg-[var(--bg-main)] hover:opacity-85 text-xs font-mono font-bold cursor-pointer transition-all shadow-sm focus:outline-none focus:ring-2 focus:ring-[var(--alvarez-blue)]"
                    aria-label="Cambiar tema de pantalla"
                    aria-pressed="false"
                >
                    <span id="theme-icon" aria-hidden="true">☀️</span>
                    <span id="theme-text" class="hidden sm:inline">MODO CLARO</span>
                </button>
            </div>
        </header>

        <!-- 🚀 CONTENIDO PRINCIPAL -->
        <main class="w-full">
            
            <!-- ⚠️ AVISOS GENERALES -->
            {generalNotices && generalNotices.length > 0 && (
                <div class="mb-6 space-y-4">
                    {generalNotices.map((notice: any) => (
                        <div class="bg-[oklch(0.85_0.18_90)] text-[oklch(0.25_0.1_90)] border-2 border-[oklch(0.75_0.15_90)] rounded-[2rem] p-6 shadow-md flex items-start gap-4 transition-all">
                            <div class="text-3xl mt-0.5 opacity-80" aria-hidden="true">
                                <i class="fas fa-bullhorn"></i>
                            </div>
                            <div>
                                {notice.titulo && <h4 class="font-black uppercase text-[12px] tracking-[0.2em] mb-1">{notice.titulo}</h4>}
                                <div class="text-[13px] font-bold leading-relaxed opacity-90 [&>p]:mb-2 [&>strong]:text-[var(--text-main)]" set:html={notice.mensaje} />
                            </div>
                        </div>
                    ))}
                </div>
            )}

            <!-- GLASS HERO SECTION - FIDELIDAD DEL CLIENTE -->
            <section class={`relative mb-10 p-10 md:p-12 rounded-[2.5rem] overflow-hidden bg-gradient-to-br ${memberLevel.heroGradient} bg-[var(--bg-card)] border border-[var(--border-card)] shadow-md transition-all duration-300`} aria-labelledby="hero-title">
                <div class="absolute top-0 right-0 p-12 opacity-5 scale-150 rotate-12 pointer-events-none" aria-hidden="true">
                    <i class="fas fa-rocket text-[120px] text-[var(--text-main)]"></i>
                </div>
                
                <div class="relative z-10">
                    <div class="flex items-center gap-3 mb-6">
                        <span class={`px-3 py-1 text-[9px] font-black uppercase tracking-widest rounded-full border ${memberLevel.badgeClass}`} role="status">
                            🏆 {memberLevel.name}
                        </span>
                        <span class="px-3 py-1 bg-black/5 dark:bg-white/5 text-[var(--text-muted)] text-[9px] font-black uppercase tracking-widest rounded-full border border-[var(--border-card)]">
                            ID CLIENTE: {clientData.client_number}
                        </span>
                    </div>
                    
                    <h1 id="hero-title" class="text-4xl md:text-6xl font-black text-[var(--text-main)] tracking-tighter uppercase mb-6 leading-none">
                        CENTRO DE <span class="text-[var(--alvarez-blue)] italic">CONTROL</span>
                    </h1>
                    
                    <p class="text-[var(--text-muted)] max-w-xl text-sm font-medium leading-relaxed mb-8">
                        Bienvenido a tu suite profesional de Alvarez Placas. Desde aquí puedes gestionar tus proyectos, optimizar cortes y realizar un seguimiento preciso de tus pedidos industriales.
                    </p>

                </div>
            </section>

            <!-- GRID PRINCIPAL DE HERRAMIENTAS - SOPORTE DE COMPONENTES FLEXIBLES -->
            <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-12" aria-label="Herramientas y servicios profesionales">
                
                <!-- SmartCut PRO -->
                <a href="/herramientas/presupuestador" class="group bg-[var(--bg-card)] border border-[var(--border-card)] p-8 rounded-[2rem] hover:bg-[oklch(0.65_0.2_40_/_0.06)] hover:border-[oklch(0.65_0.2_40_/_0.3)] transition-all flex flex-col justify-between min-h-[220px] shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-[oklch(0.65_0.2_40)]" aria-label="Abrir SmartCut PRO, Optimizador de placas">
                    <div class="w-14 h-14 bg-[oklch(0.65_0.2_40_/_0.1)] rounded-2xl flex items-center justify-center text-[oklch(0.65_0.2_40)] group-hover:scale-110 transition-transform" aria-hidden="true">
                        <i class="fas fa-cut text-2xl"></i>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-[var(--text-main)] uppercase tracking-widest mb-2">SmartCut PRO</h3>
                        <p class="text-[10px] text-[var(--text-muted)] font-bold uppercase">Optimizador de Placas</p>
                    </div>
                </a>

                <!-- CubiCal PRO -->
                <a href="/herramientas/cubical" class="group bg-[var(--bg-card)] border border-[var(--border-card)] p-8 rounded-[2rem] hover:bg-[oklch(0.65_0.18_200_/_0.06)] hover:border-[oklch(0.65_0.18_200_/_0.3)] transition-all flex flex-col justify-between min-h-[220px] shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-[oklch(0.65_0.18_200)]" aria-label="Abrir CubiCal PRO, Calculador de muebles de precisión">
                    <div class="w-14 h-14 bg-[oklch(0.65_0.18_200_/_0.1)] rounded-2xl flex items-center justify-center text-[oklch(0.6_0.18_200)] group-hover:scale-110 transition-transform" aria-hidden="true">
                        <i class="fas fa-cube text-2xl"></i>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-[var(--text-main)] uppercase tracking-widest mb-2">CubiCal PRO</h3>
                        <p class="text-[10px] text-[var(--text-muted)] font-bold uppercase">Calculador de Muebles</p>
                    </div>
                </a>

                <!-- Catálogo -->
                <a href="/catalogo" class="group bg-[var(--bg-card)] border border-[var(--border-card)] p-8 rounded-[2rem] hover:bg-[oklch(0.65_0.15_140_/_0.06)] hover:border-[oklch(0.65_0.15_140_/_0.3)] transition-all flex flex-col justify-between min-h-[220px] shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-[oklch(0.65_0.15_140)]" aria-label="Ver Catálogo de materiales, precios y stock en línea">
                    <div class="w-14 h-14 bg-[oklch(0.65_0.15_140_/_0.1)] rounded-2xl flex items-center justify-center text-[oklch(0.6_0.15_140)] group-hover:scale-110 transition-transform" aria-hidden="true">
                        <i class="fas fa-shopping-bag text-2xl"></i>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-[var(--text-main)] uppercase tracking-widest mb-2">Catálogo</h3>
                        <p class="text-[10px] text-[var(--text-muted)] font-bold uppercase">Precios y Stock</p>
                    </div>
                </a>

                <!-- Pedidos -->
                <a href="/cliente/pedidos" class="group bg-[var(--bg-card)] border border-[var(--border-card)] p-8 rounded-[2rem] hover:bg-[oklch(0.6_0.18_270_/_0.06)] hover:border-[oklch(0.6_0.18_270_/_0.3)] transition-all flex flex-col justify-between min-h-[220px] shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-[oklch(0.6_0.18_270)]" aria-label="Ver Mis Pedidos, historial y tracking de fabricación">
                    <div class="w-14 h-14 bg-[oklch(0.6_0.18_270_/_0.1)] rounded-2xl flex items-center justify-center text-[oklch(0.55_0.18_270)] group-hover:scale-110 transition-transform" aria-hidden="true">
                        <i class="fas fa-history text-2xl"></i>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-[var(--text-main)] uppercase tracking-widest mb-2">Mis Pedidos</h3>
                        <p class="text-[10px] text-[var(--text-muted)] font-bold uppercase">Historial y Tracking</p>
                    </div>
                </a>

                <!-- Academia de Materiales -->
                <a href="/cliente/academia" class="group bg-[var(--bg-card)] border border-[var(--border-card)] p-8 rounded-[2rem] hover:bg-[oklch(0.55_0.15_140_/_0.06)] hover:border-[oklch(0.55_0.15_140_/_0.3)] transition-all flex flex-col justify-between min-h-[220px] shadow-sm hover:shadow-md focus:outline-none focus:ring-2 focus:ring-[oklch(0.55_0.15_140)]" aria-label="Abrir Academia de Materiales, guía interactiva de tableros">
                    <div class="w-14 h-14 bg-emerald-500/10 rounded-2xl flex items-center justify-center text-emerald-500 group-hover:scale-110 transition-transform" aria-hidden="true">
                        <i class="fas fa-graduation-cap text-2xl"></i>
                    </div>
                    <div>
                        <h3 class="text-sm font-black text-[var(--text-main)] uppercase tracking-widest mb-2">Academia</h3>
                        <p class="text-[10px] text-[var(--text-muted)] font-bold uppercase">Manual de Materiales</p>
                    </div>
                </a>
            </section>

            <!-- DETALLES ADICIONALES Y ASISTENCIA -->
            <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
                
                <!-- 📰 SECCIÓN: ACTIVIDAD RECIENTE (COLUMNAS 1 & 2) -->
                <section class="xl:col-span-2 bg-[var(--bg-card)] border border-[var(--border-card)] rounded-[2.5rem] p-8 md:p-10 flex flex-col justify-between shadow-sm transition-colors duration-300" aria-labelledby="activity-title">
                    <div>
                        <div class="flex justify-between items-center mb-10">
                            <h3 id="activity-title" class="text-xs font-black text-[var(--text-main)] uppercase tracking-[0.4em]">Actividad Reciente</h3>
                            <a href="/cliente/pedidos" class="text-[9px] font-black text-[var(--text-muted)] uppercase border-b border-[var(--border-card)] pb-1 hover:text-[var(--text-main)] transition-all">Ver Historial</a>
                        </div>

                        <div class="space-y-4">
                            {recentOrders.length === 0 ? (
                                <div class="py-20 text-center opacity-30">
                                    <i class="fas fa-ghost text-5xl mb-4" aria-hidden="true"></i>
                                    <p class="text-[10px] font-black uppercase">Sin actividad reciente</p>
                                </div>
                            ) : (
                                recentOrders.map(order => {
                                    const statusCfg = getOrderStatusConfig(order.status);
                                    return (
                                        <article class="relative">
                                            <a href={`/cliente/pedidos?id=${order.id}`} class="flex items-center justify-between p-6 bg-[var(--bg-main)] border border-[var(--border-card)] rounded-3xl hover:opacity-85 transition-all group shadow-sm focus:outline-none focus:ring-2 focus:ring-[var(--alvarez-blue)]">
                                                <div class="flex items-center gap-6">
                                                    <div class="w-14 h-14 bg-[var(--bg-card)] border border-[var(--border-card)] rounded-2xl flex items-center justify-center text-[var(--alvarez-blue)] group-hover:rotate-12 transition-all" aria-hidden="true">
                                                        <i class="fas fa-file-invoice text-xl"></i>
                                                    </div>
                                                    <div>
                                                        <h4 class="text-xs font-black text-[var(--text-main)] uppercase">Pedido #{order.id}</h4>
                                                        <div class="flex flex-wrap items-center gap-3 mt-1.5">
                                                            <time datetime={order.fecha_pedido} class="text-[10px] text-[var(--text-muted)] font-mono font-bold">
                                                                {new Date(order.fecha_pedido).toLocaleDateString('es-AR')}
                                                            </time>
                                                            <span class="w-1.5 h-1.5 bg-[var(--border-card)] rounded-full" aria-hidden="true"></span>
                                                            <span class={`px-2 py-0.5 rounded font-mono text-[8px] font-black border ${statusCfg.class}`}>
                                                                {statusCfg.label}
                                                            </span>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="text-right">
                                                    <p class="text-sm font-black text-[var(--text-main)] font-mono">{formatCurrency(order.total)}</p>
                                                    <span class="text-[9px] text-[var(--text-muted)] font-black uppercase mt-1 font-mono block">Ver Detalle →</span>
                                                </div>
                                            </a>
                                        </article>
                                    );
                                })
                            )}
                        </div>
                    </div>
                </section>

                <!-- 📞 SECCIÓN: ASESORÍA Y CONTROL DE CUENTA (COLUMNA 3) -->
                <aside class="space-y-6" aria-label="Asistencia y administración de cuenta">
                    
                    <!-- WhatsApp Asesor Directo -->
                    <section class="bg-gradient-to-br from-[var(--alvarez-blue)] to-[oklch(0.3_0.1_220)] p-10 rounded-[2.5rem] text-white relative overflow-hidden group shadow-md" aria-labelledby="seller-title">
                        <div class="absolute -right-6 -bottom-6 opacity-10 group-hover:scale-110 transition-transform pointer-events-none" aria-hidden="true">
                            <i class="fab fa-whatsapp text-9xl"></i>
                        </div>
                        
                        <p class="text-[10px] font-black uppercase tracking-widest mb-8">Asesoría Técnica</p>
                        <div class="flex items-center gap-4 mb-8">
                            <div class="w-16 h-16 bg-white/20 backdrop-blur-md rounded-2xl flex items-center justify-center border border-white/30 shadow-xl overflow-hidden" aria-hidden="true">
                                {sellerProfile?.foto_personal ? (
                                    <img src={sellerProfile.foto_personal} alt={assignedSeller.name} class="w-full h-full object-cover" />
                                ) : (
                                    <i class="fas fa-user-tie text-2xl"></i>
                                )}
                            </div>
                            <div>
                                <p class="text-[9px] font-black opacity-60 uppercase">Tu Vendedor</p>
                                <h3 id="seller-title" class="text-xl font-black italic uppercase leading-none">{assignedSeller.name}</h3>
                            </div>
                        </div>
                        
                        <a href={`https://wa.me/${assignedSeller.whatsapp}`} target="_blank" rel="noopener noreferrer" class="w-full bg-white text-black font-black py-4 rounded-2xl flex items-center justify-center gap-3 transition-all hover:bg-black hover:text-white uppercase tracking-widest text-[11px] shadow-2xl focus:outline-none focus:ring-2 focus:ring-white">
                            <i class="fab fa-whatsapp text-lg" aria-hidden="true"></i> Iniciar Chat
                        </a>
                    </section>

                    <!-- Promociones Especiales de tu Vendedor -->
                    {sellerProfile && (
                        (sellerProfile.promo1_titulo && sellerProfile.promo1_imagen) || 
