    <!-- ALPINJS STATE AND IMAP WORKFLOW -->
    <script is:inline>
        function mailSupervisor() {
            return {
                activeAccount: 'info@alvarezplacas.com.ar',
                emails: [],
                selectedEmail: null,
                loadingEmails: false,
                loadingDetail: false,
                searchQuery: '',
                unreadCount: 0,
                alertCount: 0,
                hideSpam: true,

                init() {
                    this.fetchEmails();
                    // Refrescar cada 2 minutos automáticamente
                    setInterval(() => {
                        this.fetchEmails(true);
                    }, 120000);
                },

                async fetchEmails(silent = false) {
                    if (!silent) this.loadingEmails = true;
                    try {
                        const res = await fetch(`/api/ceo/mails?account=${encodeURIComponent(this.activeAccount)}`);
                        const data = await res.json();
                        if (data.success) {
                            this.emails = data.emails;
                            this.calculateStats();
                        } else {
                            console.error("Error al obtener correos:", data.error);
                        }
                    } catch (e) {
                        console.error("Error de conexión:", e);
                    } finally {
                        this.loadingEmails = false;
                    }
                },

                async selectEmail(email) {
                    this.loadingDetail = true;
                    this.selectedEmail = null;
                    try {
                        const res = await fetch(`/api/ceo/mail-detail?account=${encodeURIComponent(this.activeAccount)}&uid=${email.uid}`);
                        const data = await res.json();
                        if (data.success) {
                            this.selectedEmail = data.email;
                            
                            // Actualizar estado de visto localmente
                            const localMail = this.emails.find(m => m.uid === email.uid);
                            if (localMail && !localMail.seen) {
                                localMail.seen = true;
                                this.calculateStats();
                            }
                        } else {
                            alert("No se pudo cargar el detalle del mail: " + data.error);
                        }
                    } catch (e) {
                        alert("Error de red al cargar el mail");
                    } finally {
                        this.loadingDetail = false;
                    }
                },

                async markAsUnread() {
                    if (!this.selectedEmail) return;
                    alert("Función administrativa de marcar como no leído guardada en VPS.");
                },

                assignToOperator() {
                    alert("Función disponible en la siguiente fase de Matriz de Personal.");
                },

                filteredEmails() {
                    let list = this.emails;
                    if (this.hideSpam) {
                        list = list.filter(email => !email.spam);
                    }
                    if (!this.searchQuery) return list;
                    const query = this.searchQuery.toLowerCase().trim();
                    return list.filter(email => {
                        return email.subject.toLowerCase().includes(query) || 
                               email.from.toLowerCase().includes(query);
                    });
                },

                calculateStats() {
                    this.unreadCount = this.emails.filter(m => !m.seen).length;
                    
                    // Cuenta los correos de más de 24 horas desatendidos (no leídos)
                    const limitTime = Date.now() - (24 * 60 * 60 * 1000);
                    this.alertCount = this.emails.filter(m => {
                        return !m.seen && new Date(m.date).getTime() < limitTime;
                    }).length;
                },

                isAlertMail(email) {
                    if (!email) return false;
                    // Retorna verdadero si no está visto y lleva más de 24 horas
                    const limitTime = Date.now() - (24 * 60 * 60 * 1000);
                    return !email.seen && new Date(email.date).getTime() < limitTime;
                },

                cleanSender(fromStr) {
                    if (!fromStr) return 'Desconocido';
                    // Extrae la parte antes del menor que (<)
                    const index = fromStr.indexOf('<');
                    if (index !== -1) {
                        return fromStr.substring(0, index).trim() || fromStr.substring(index + 1, fromStr.length - 1);
                    }
                    return fromStr;
                },

                formatDate(dateStr) {
                    if (!dateStr) return '';
                    const date = new Date(dateStr);
                    const now = new Date();
                    
                    // Si es hoy, retorna la hora
                    if (date.toDateString() === now.toDateString()) {
                        return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                    }
                    
                    // Si es ayer, retorna "Ayer"
                    const yesterday = new Date(now);
                    yesterday.setDate(now.getDate() - 1);
                    if (date.toDateString() === yesterday.toDateString()) {
                        return "Ayer";
                    }
                    
                    // Sino retorna fecha corta
                    return date.toLocaleDateString([], { day: '2-digit', month: '2-digit' });
                },

                formatDateFull(dateStr) {
                    if (!dateStr) return '';
                    const date = new Date(dateStr);
                    return date.toLocaleString([], { 
                        weekday: 'long', 
                        year: 'numeric', 
                        month: 'long', 
                        day: 'numeric', 
                        hour: '2-digit', 
                        minute: '2-digit' 
                    });
                },

                formatBytes(bytes) {
                    if (bytes === 0) return '0 Bytes';
                    const k = 1024;
                    const sizes = ['Bytes', 'KB', 'MB'];
                    const i = Math.floor(Math.log(bytes) / Math.log(k));
                    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
                }
            };
        }
    </script>
</CeoWorkspace>
