            box-shadow: 0 4px 12px rgba(16,185,129,0.15);
            z-index: 99999 !important;
        }
        /* Raise parent row/cell stacking context on hover to prevent header clipping */
        #nomina-table tbody tr:hover {
            position: relative;
            z-index: 100;
        }
        #nomina-table tbody td:hover {
            position: relative;
            z-index: 101;
