        /* Tooltip Preview - Larger & Stacks Above Everything */
        .doc-hover-preview {
            display: none;
            position: absolute;
            top: 130%;
            left: 50%;
            transform: translateX(-50%);
            background: #111827;
            border: 1px solid #374151;
            border-radius: 8px;
            padding: 6px;
            z-index: 999999 !important;
            box-shadow: 0 16px 36px rgba(0,0,0,0.9);
            pointer-events: none;
            width: 320px;
            animation: fadeInTooltip 0.15s ease-out;
        }
        .doc-hover-preview img {
