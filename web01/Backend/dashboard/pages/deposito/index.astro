---
import DepositoMobile from '../../layouts/DepositoMobile.astro';
---

<DepositoMobile title="Inicio">
    <div style="display: flex; flex-direction: column; gap: 20px;">
        
        <div style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); border-radius: 20px; padding: 24px; color: white; box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);">
            <h2 style="font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; opacity: 0.9;">Turno Actual</h2>
            <p style="font-size: 28px; font-weight: 900; margin-bottom: 4px;">¡Hola, Operador!</p>
            <p style="font-size: 14px; opacity: 0.8;">Galpón Principal - Alvarez Placas</p>
        </div>

        <a href="/deposito/ingreso" style="text-decoration: none;">
            <button class="btn-giant">
                <i class="fas fa-barcode"></i> Cargar Stock
            </button>
        </a>

        <div style="margin-top: 10px;">
            <h3 style="font-size: 16px; color: #fff; margin-bottom: 12px; display: flex; align-items: center; gap: 8px;">
                <i class="fas fa-history" style="color: #f59e0b;"></i> Últimos Movimientos
            </h3>
            
            <div style="background: #1e1e1e; border: 1px solid #333; border-radius: 16px; overflow: hidden;">
                <!-- Placeholder items for now, will be dynamic later -->
                <div style="padding: 16px; border-bottom: 1px solid #333; display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <p style="color: #fff; font-weight: 700; font-size: 14px; margin-bottom: 4px;">Melamina Roble 18mm</p>
                        <p style="color: #888; font-size: 12px;"><i class="fas fa-layer-group text-blue-400"></i> Torre A1</p>
                    </div>
                    <div style="background: rgba(16, 185, 129, 0.1); color: #10b981; padding: 4px 10px; border-radius: 8px; font-weight: 900; font-size: 16px;">
                        +5
                    </div>
                </div>

                <div style="padding: 16px; display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <p style="color: #fff; font-weight: 700; font-size: 14px; margin-bottom: 4px;">MDF Crudo 15mm</p>
                        <p style="color: #888; font-size: 12px;"><i class="fas fa-th-large text-orange-400"></i> Plaquero 3</p>
                    </div>
                    <div style="background: rgba(16, 185, 129, 0.1); color: #10b981; padding: 4px 10px; border-radius: 8px; font-weight: 900; font-size: 16px;">
                        +1.5
                    </div>
                </div>
            </div>
            <p style="text-align: center; margin-top: 12px;">
                <a href="#" style="color: #10b981; font-size: 12px; text-decoration: none; font-weight: 700;">Ver historial completo</a>
            </p>
        </div>
    </div>
</DepositoMobile>
