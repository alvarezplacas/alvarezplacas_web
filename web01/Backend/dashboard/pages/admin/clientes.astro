---
/**
 * Gestión de Clientes.
 * Propiedad del Agente 2 (Backend/Dashboard).
 */
import AdminLayout from '../../layouts/AdminLayout.astro';
import { directus, readItems } from '../../../conexiones/directus.js';

let clientes = [];
try {
    const res = await directus.request(readItems('clientes', {
        sort: ['-registration_date', '-id'],
        fields: ['*', { pedidos: ['id'] }]
    }));
    clientes = (res || []).map((row) => ({
        ...row,
        nombre: row.name || row.nombre_empresa || row.nombre || 'Sin nombre',
        puntos: row.scoring || row.puntaje || 0,
        email: row.email || 'Sin email'
    }));
} catch (e) {
    const errorString = (e && typeof e === 'object' && 'errors' in e) ? JSON.stringify((e as any).errors) : (e instanceof Error ? e.message : 'Error desconocido');
    console.error("[Backend Clients Error]:", errorString);
}
---

<AdminLayout title="Gestión de Clientes">
    <div class="mb-8 flex justify-between items-center">
        <div>
            <h2 class="text-3xl font-black text-white mb-2 uppercase tracking-tight">Cartera de <span class="text-primary italic">Clientes</span></h2>
            <p class="text-gray-400 font-medium">Listado de profesionales y empresas registrados.</p>
        </div>
        <button class="bg-primary hover:bg-red-600 text-white font-bold py-2 px-6 rounded-lg transition-all flex items-center gap-2">
            <i class="fas fa-plus"></i> Nuevo Cliente
        </button>
    </div>

    <div class="bg-[#1a1a1a] border border-gray-800 rounded-xl overflow-hidden shadow-2xl">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-white/2 text-[10px] font-black text-gray-500 uppercase tracking-widest border-b border-gray-800">
                    <th class="px-6 py-4">ID</th>
                    <th class="px-6 py-4">Nombre / Empresa</th>
                    <th class="px-6 py-4">Puntos</th>
                    <th class="px-6 py-4">Pedidos</th>
                    <th class="px-6 py-4">Estado</th>
                    <th class="px-6 py-4 text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                {clientes.map(c => (
                    <tr class="hover:bg-white/2 transition-colors group">
                        <td class="px-6 py-4 text-sm font-mono text-gray-500">{c.id}</td>
                        <td class="px-6 py-4">
                            <p class="text-white font-bold text-sm">{c.nombre}</p>
                            <p class="text-[10px] text-gray-500">{c.email}</p>
                        </td>
                        <td class="px-6 py-4">
                            <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-xs font-bold">{c.puntos} pts</span>
                        </td>
                        <td class="px-6 py-4 text-sm font-medium text-gray-400">
                            {c.pedidos?.length || 0}
                        </td>
                        <td class="px-6 py-4">
                            <span class="bg-green-500/10 text-green-500 px-2 py-0.5 rounded text-[10px] font-black uppercase">Activo</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button class="p-2 hover:text-primary transition-colors"><i class="fas fa-edit"></i></button>
                            <button class="p-2 hover:text-red-500 transition-colors"><i class="fas fa-trash-alt"></i></button>
                        </td>
                    </tr>
                ))}
            </tbody>
        </table>
    </div>
</AdminLayout>
