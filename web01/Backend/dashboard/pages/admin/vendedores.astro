---
/**
 * Gestión de Vendedores.
 * Propiedad del Agente Antigravity (Google Deepmind).
 */
import AdminLayout from '../../layouts/AdminLayout.astro';
import { directus, readItems } from '../../../conexiones/directus.js';

let vendedores = [];
let errorMsg = null;

try {
    const res = await directus.request(readItems('vendedores', {
        sort: ['id'],
        fields: ['*']
    }));
    vendedores = (res || []).map((v) => ({
        ...v,
        // CORRECCIÓN: El campo en Directus es 'nombre', no 'name'
        nombre: v.nombre || v.name || v.Nombre || 'Sin nombre',
        whatsapp: v.whatsapp || v.Whatsapp || 'N/A',
        estado: 'Activo'
    }));
} catch (e: any) {
    errorMsg = (e && typeof e === 'object' && 'errors' in e) ? JSON.stringify(e.errors) : (e instanceof Error ? e.message : 'Error de conexión');
    console.error("[Backend Sellers Error]:", errorMsg);
}
---

<AdminLayout title="Gestión de Vendedores">
    <div class="mb-8 flex justify-between items-center">
        <div>
            <h2 class="text-3xl font-black text-white mb-2 uppercase tracking-tight">Equipo de <span class="text-primary italic">Ventas</span></h2>
            <p class="text-gray-400 font-medium">Gestión de ventanillas y atención al cliente.</p>
        </div>
        <button id="open-modal-btn" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg transition-all flex items-center gap-2">
            <i class="fas fa-plus"></i> Nuevo Vendedor
        </button>
    </div>

    <div class="bg-[#1a1a1a] border border-gray-800 rounded-xl overflow-hidden shadow-2xl">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-white/2 text-[10px] font-black text-gray-500 uppercase tracking-widest border-b border-gray-800">
                    <th class="px-6 py-4">ID</th>
                    <th class="px-6 py-4">Nombre</th>
                    <th class="px-6 py-4 text-center">WhatsApp</th>
                    <th class="px-6 py-4">Estado</th>
                    <th class="px-6 py-4 text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800">
                {vendedores.length === 0 ? (
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-gray-500 italic">
                            <i class="fas fa-plug mb-2 block text-xl"></i>
                            No se detectaron vendedores. Verifica la conexión con Directus.
                        </td>
                    </tr>
                ) : vendedores.map(v => (
                    <tr class="hover:bg-white/2 transition-colors group">
                        <td class="px-6 py-4 text-sm font-mono text-gray-500">{v.id}</td>
                        <td class="px-6 py-4">
                            <p class="text-white font-bold text-sm">{v.nombre}</p>
                            <p class="text-[10px] text-gray-500">{v.email || 'Sin Correo'}</p>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class={`text-sm font-medium ${v.whatsapp === 'N/A' ? 'text-gray-600' : 'text-green-500'}`}>
                                {v.whatsapp}
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="bg-blue-500/10 text-blue-500 px-2 py-0.5 rounded text-[10px] font-black uppercase">Activo</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <a href={`https://wa.me/${v.whatsapp?.replace(/\D/g, '')}`} target="_blank" class="p-2 hover:text-green-500 transition-colors"><i class="fab fa-whatsapp"></i></a>
                            <button class="p-2 hover:text-red-500 transition-colors"><i class="fas fa-trash-alt"></i></button>
                        </td>
                    </tr>
                ))}
            </tbody>
        </table>
    </div>

    <!-- Modal Nuevo Vendedor -->
    <div id="seller-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4">
        <div class="bg-[#1a1a1a] border border-gray-800 w-full max-w-md rounded-2xl p-8 shadow-2xl transform scale-95 transition-all" id="modal-content">
            <h3 class="text-2xl font-black text-white mb-2 uppercase italic tracking-tight">Nuevo <span class="text-primary">Vendedor</span></h3>
            <p class="text-gray-500 text-sm mb-6">Registra un nuevo integrante en el equipo comercial.</p>

            <form id="seller-form" class="space-y-4">
                <div>
                    <label class="block text-[10px] font-black text-gray-400 uppercase mb-1 tracking-widest">Nombre Completo</label>
                    <input type="text" name="nombre" required class="w-full bg-black/40 border border-gray-800 rounded-xl px-4 py-3 text-white text-sm focus:border-primary transition-all outline-none" placeholder="Ariel Santivañez" />
                </div>
                <div>
                    <label class="block text-[10px] font-black text-gray-400 uppercase mb-1 tracking-widest">Correo Electrónico</label>
                    <input type="email" name="email" required class="w-full bg-black/40 border border-gray-800 rounded-xl px-4 py-3 text-white text-sm focus:border-primary transition-all outline-none" placeholder="ariel@alvarezplacas.com.ar" />
                </div>
                <div>
                    <label class="block text-[10px] font-black text-gray-400 uppercase mb-1 tracking-widest">WhatsApp (Con código de país)</label>
                    <input type="text" name="whatsapp" required class="w-full bg-black/40 border border-gray-800 rounded-xl px-4 py-3 text-white text-sm focus:border-primary transition-all outline-none" placeholder="54911..." />
                </div>

                <div class="pt-4 flex gap-3">
                    <button type="button" id="close-modal-btn" class="flex-1 py-3 bg-white/5 hover:bg-white/10 text-gray-400 rounded-xl font-bold transition-all text-sm uppercase">Cancelar</button>
                    <button type="submit" class="flex-1 py-3 bg-primary hover:bg-white text-white hover:text-black rounded-xl font-black transition-all text-sm uppercase shadow-lg shadow-primary/20">Registrar</button>
                </div>
            </form>
        </div>
    </div>

    <script is:inline>
        const modal = document.getElementById('seller-modal');
        const openBtn = document.getElementById('open-modal-btn');
        const closeBtn = document.getElementById('close-modal-btn');
        const modalContent = document.getElementById('modal-content');
        const form = document.getElementById('seller-form');

        openBtn.onclick = () => {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => modalContent.classList.remove('scale-95'), 10);
        };

        const closeModal = () => {
            modalContent.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.remove('flex');
                modal.classList.add('hidden');
            }, 200);
        };

        closeBtn.onclick = closeModal;
        modal.onclick = (e) => { if(e.target === modal) closeModal(); };

        form.onsubmit = async (e) => {
            e.preventDefault();
            const btn = form.querySelector('button[type="submit"]');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            const formData = new FormData(form);
            const data = Object.fromEntries(formData);

            try {
                const res = await fetch('/api/admin/create-seller', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if(result.success) {
                    window.location.reload();
                } else {
                    alert('Error: ' + result.error);
                    btn.disabled = false;
                    btn.innerHTML = 'Registrar';
                }
            } catch (err) {
                console.error(err);
                btn.disabled = false;
                btn.innerHTML = 'Registrar';
            }
        };
    </script>
</AdminLayout>
