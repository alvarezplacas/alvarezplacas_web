<script>
    // Robust ApexCharts CDN Fallback
    if (typeof window !== 'undefined' && typeof (window as any).ApexCharts === 'undefined') {
        (window as any).ApexCharts = class {
            constructor() {}
            render() {}
            updateOptions() {}
            updateSeries() {}
            destroy() {}
        };
    }

    // ========================
    // Tab switching logic
    // ========================
    function syncToolbarActive(ctabName: string) {
        document.querySelectorAll('[data-tab]').forEach(b => b.classList.remove('active'));
        const reverseMap: Record<string, string> = {
            'diario': 'tab-diario', 'ejecutivo': 'tab-ejecutivo',
            'historico': 'tab-historico', 'buscador': 'tab-buscador'
        };
        const tabId = reverseMap[ctabName];
        if (tabId) {
            const toolBtn = document.querySelector(`[data-tab="${tabId}"]`);
            if (toolBtn) toolBtn.classList.add('active');
        }
    }

    function activateCajaTab(tabName: string) {
        document.querySelectorAll('.ctab').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.ctab-panel').forEach(p => p.classList.add('hidden'));
        const btn = document.querySelector(`.ctab[data-ctab="${tabName}"]`);
        if (btn) btn.classList.add('active');
        const panel = document.getElementById(`panel-${tabName}`);
        if (panel) panel.classList.remove('hidden');
        
        // Sync toolbar active state
        syncToolbarActive(tabName);
        
        // Update tab name in tabs bar
        const tabLabel: Record<string, string> = { 
            diario: 'Operacion_Diaria.xls', 
            ejecutivo: 'Dashboard_Ejecutivo.psd', 
            historico: 'Reportes_Historicos.xls', 
            calculadora: 'Calculadora_Neta.xls', 
            manual: 'Manual_Gecom.pdf',
            'manual-calculadora': 'Manual_Calculadora.pdf',
            buscador: 'Buscador_Facturas.psd'
        };
        const tabEl = document.getElementById('active-tab-name');
        if (tabEl) tabEl.textContent = tabLabel[tabName] || '';

        // Init charts when executive tab opens
        if (tabName === 'ejecutivo') window.dispatchEvent(new CustomEvent('init-charts'));
        if (tabName === 'historico') window.dispatchEvent(new CustomEvent('init-historico'));
        if (tabName === 'calculadora') {
            window.dispatchEvent(new CustomEvent('sync-calculator'));
        }
    }

    document.querySelectorAll('.ctab').forEach(btn => {
        btn.addEventListener('click', () => {
            const tabName = (btn as HTMLElement).dataset.ctab;
            if (tabName) activateCajaTab(tabName);
        });
    });

    // ========================
    // Toolbar tab links
    // ========================
    document.querySelectorAll('[data-tab]').forEach(btn => {
        btn.addEventListener('click', () => {
            const tabName = (btn as HTMLElement).dataset.tab;
            const ctabMap: Record<string, string> = { 
                'tab-diario': 'diario', 
                'tab-ejecutivo': 'ejecutivo', 
                'tab-historico': 'historico',
                'tab-buscador': 'buscador'
            };
            const ctabName = ctabMap[tabName || ''];
            if (ctabName) {
                activateCajaTab(ctabName);
            }
        });
    });

    // Check URL parameters for tab
    const urlParams = new URLSearchParams(window.location.search);
    const tabParam = urlParams.get('tab');
    if (tabParam) {
        activateCajaTab(tabParam);
    }

    // Mark diario as active in toolbar on load
    syncToolbarActive('diario');

    // ========================
    // Directus API
    // ========================
    const DIRECTUS_URL = 'https://admin.alvarezplacas.com.ar';
    
    function fmt(num: any): string {
        const val = parseFloat(num) || 0;
        return '$ ' + val.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
    function fmtFecha(fechaStr: string): string {
        if (!fechaStr) return '--';
        const parts = fechaStr.split('-');
        if (parts.length === 3) return `${parts[2]}/${parts[1]}/${parts[0]}`;
        return fechaStr;
    }
    function toARDate(d: Date): string {
        return d.toISOString().split('T')[0];
    }
    function today(): string {
        return toARDate(new Date());
    }

    function generateUUID(): string {
        try {
            if (typeof crypto !== 'undefined' && crypto.randomUUID) {
                return crypto.randomUUID();
            }
        } catch (e) {}
        return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
            const r = Math.random() * 16 | 0;
            const v = c === 'x' ? r : (r & 0x3 | 0x8);
            return v.toString(16);
        });
    }

    // ========================
    // LOCALSTORAGE FALLBACK HELPERS
    // ========================
    function getLocalMovimientos(): any[] {
        try {
            const data = localStorage.getItem('caja_movimientos_local');
            return data ? JSON.parse(data) : [];
        } catch (e) {
            return [];
        }
    }

    function saveLocalMovimientos(movs: any[]) {
        try {
            localStorage.setItem('caja_movimientos_local', JSON.stringify(movs));
        } catch (e) {}
    }

    // ========================
    // FORM: Guardar movimiento
    // ========================
    const form = document.getElementById('form-movimiento') as HTMLFormElement;
    const feedback = document.getElementById('form-feedback');

    // Set today as default date
    (document.getElementById('mov-fecha') as HTMLInputElement).value = today();
    (document.getElementById('filter-fecha') as HTMLInputElement).value = today();

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('btn-guardar') as HTMLButtonElement;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';

        const payload = {
            id: generateUUID(),
            date_created: new Date().toISOString(),
            fecha: (document.getElementById('mov-fecha') as HTMLInputElement).value,
            tipo: (document.getElementById('mov-tipo') as HTMLInputElement).value,
            categoria: (document.getElementById('mov-categoria') as HTMLSelectElement).value,
            monto: parseFloat((document.getElementById('mov-monto') as HTMLInputElement).value),
            detalle: (document.getElementById('mov-detalle') as HTMLInputElement).value,
            observaciones: (document.getElementById('mov-obs') as HTMLTextAreaElement).value,
            synced: false
        };

        // 1. Save locally first (immediate feedback & safety)
        const localMovs = getLocalMovimientos();
        localMovs.push(payload);
        saveLocalMovimientos(localMovs);

        // 2. Try POSTing to Directus
        try {
            const res = await fetch(`/api/caja/movimientos`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    id: payload.id,
                    fecha: payload.fecha,
                    tipo: payload.tipo,
                    categoria: payload.categoria,
                    monto: payload.monto,
                    detalle: payload.detalle,
                    observaciones: payload.observaciones
                })
            });

            if (res.ok) {
                // Update local storage to mark synced
                const updatedMovs = getLocalMovimientos();
                const idx = updatedMovs.findIndex(m => m.id === payload.id);
                if (idx !== -1) {
                    updatedMovs[idx].synced = true;
                    saveLocalMovimientos(updatedMovs);
                }

                showFeedback('success', '✓ Movimiento guardado correctamente en Directus y base local');
                form.reset();
                (document.getElementById('mov-fecha') as HTMLInputElement).value = today();
                const currentFilter = (document.getElementById('filter-fecha') as HTMLInputElement).value || today();
                loadMovimientos(currentFilter);
                loadKPIs(currentFilter);
                window.dispatchEvent(new CustomEvent('sync-calculator'));
            } else {
                showFeedback('success', '✓ Movimiento guardado localmente (Directus fuera de línea)');
                form.reset();
                (document.getElementById('mov-fecha') as HTMLInputElement).value = today();
                const currentFilter = (document.getElementById('filter-fecha') as HTMLInputElement).value || today();
                loadMovimientos(currentFilter);
                loadKPIs(currentFilter);
                window.dispatchEvent(new CustomEvent('sync-calculator'));
            }
        } catch(err) {
            showFeedback('success', '✓ Movimiento guardado localmente (Modo sin conexión)');
            form.reset();
            (document.getElementById('mov-fecha') as HTMLInputElement).value = today();
            const currentFilter = (document.getElementById('filter-fecha') as HTMLInputElement).value || today();
            loadMovimientos(currentFilter);
            loadKPIs(currentFilter);
            window.dispatchEvent(new CustomEvent('sync-calculator'));
        }

        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Guardar Movimiento';
    });

    function showFeedback(type: string, msg: string) {
        feedback!.className = `form-feedback ${type}`;
        feedback!.textContent = msg;
        feedback!.classList.remove('hidden');
        setTimeout(() => feedback!.classList.add('hidden'), 4000);
    }

    // ========================
    // LOAD: Movimientos del día
    // ========================
    async function loadMovimientos(fecha: string) {
        const tbody = document.getElementById('tbody-movimientos')!;
        tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">Cargando movimientos...</td></tr>';

        let items: any[] = [];

        // Try getting from Directus first
        try {
            const res = await fetch(`/api/caja/movimientos?fecha=${fecha}&sort=-date_created&limit=50`);
            if (res.ok) {
                const data = await res.json();
                items = data.data || [];
            }
        } catch(e) {
            console.warn("Directus fetch failed, loading local items only:", e);
        }

        // Merge from local storage
        const localItems = getLocalMovimientos().filter(m => m.fecha === fecha);
        localItems.forEach(lm => {
            const exists = items.some(im => (im && im.id && lm && lm.id && im.id.toString() === lm.id.toString()) || (im && lm && im.fecha === lm.fecha && parseFloat(im.monto) === parseFloat(lm.monto) && im.categoria === lm.categoria && im.tipo === lm.tipo));
            if (!exists) {
                items.push(lm);
            }
        });

        if (!items.length) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">No hay movimientos para esta fecha.</td></tr>';
            return;
        }

        // Sort items by date_created descending, newly created first
        items.sort((a, b) => {
            const timeA = a.date_created ? new Date(a.date_created).getTime() : 0;
            const timeB = b.date_created ? new Date(b.date_created).getTime() : 0;
            return timeB - timeA;
        });

        const catLabel: Record<string, string> = {
            venta_blanco: 'Venta 1',
            venta_negro: 'Venta 2',
            gasto_fijo: 'Gasto Fijo',
            gasto_variable: 'Gasto Variable',
            impuestos: 'Impuestos'
        };

        tbody.innerHTML = items.map((m: any) => {
            const isLocalOnly = !m.synced;
            return `
                <tr>
                    <td>${fmtFecha(m.fecha)}</td>
                    <td>
                        <span class="badge badge-${m.tipo}">${m.tipo === 'ingreso' ? '▲ Ingreso' : '▼ Egreso'}</span>
                        ${isLocalOnly ? '<span class="badge" style="background:rgba(245,158,11,0.15); color:#f59e0b; margin-left:4px;">Local</span>' : ''}
                    </td>
                    <td>${catLabel[m.categoria] || m.categoria}</td>
                    <td>${m.detalle || '--'}</td>
                    <td class="text-right" style="color:${m.tipo === 'ingreso' ? '#10b981' : '#ef4444'}; font-family:'Roboto Mono',monospace; font-weight:bold;">
                        ${m.tipo === 'egreso' ? '-' : '+'}${fmt(m.monto)}
                    </td>
                    <td>
                        <button onclick="deleteMov('${m.id}')" style="background:none;border:none;color:#888;cursor:pointer;padding:2px 6px;" title="Eliminar">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </td>
                </tr>
            `;
        }).join('');
    }

    // ========================
    // KPIs Diarios
    // ========================
    async function loadKPIs(fecha: string) {
        let items: any[] = [];

        try {
            const res = await fetch(`/api/caja/movimientos?fecha=${fecha}&limit=1000`);
            if (res.ok) {
                const data = await res.json();
                items = data.data || [];
            }
        } catch(e) {
            console.error("Error loading KPIs from Directus:", e);
        }

        // Merge from local storage
        const localItems = getLocalMovimientos().filter(m => m.fecha === fecha);
        localItems.forEach(lm => {
            const exists = items.some(im => (im && im.id && lm && lm.id && im.id.toString() === lm.id.toString()) || (im && lm && im.fecha === lm.fecha && parseFloat(im.monto) === parseFloat(lm.monto) && im.categoria === lm.categoria && im.tipo === lm.tipo));
            if (!exists) {
                items.push(lm);
            }
        });

        let ingresos = 0, egresos = 0;
        items.forEach(m => {
            if (m.tipo === 'ingreso') ingresos += parseFloat(m.monto);
            else egresos += parseFloat(m.monto);
        });

        const neto = ingresos - egresos;

        const elIngresos = document.getElementById('val-ingresos');
        if (elIngresos) elIngresos.textContent = fmt(ingresos);
        document.getElementById('val-egresos')!.textContent = fmt(egresos);
        document.getElementById('val-neto')!.textContent = fmt(neto);
        document.getElementById('val-neto')!.style.color = neto >= 0 ? '#10b981' : '#ef4444';
        document.getElementById('val-movs')!.textContent = items.length.toString();

        // === KPI: Facturado Hoy (OCR) via /api/documentos/stats ===
        try {
            const statsRes = await fetch(`/api/documentos/stats?fecha=${fecha}`);
            if (statsRes.ok) {
                const statsData = await statsRes.json();
                if (statsData.success) {
                    const totalFmt = '$ ' + (statsData.total || 0).toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                    const countFmt = `${statsData.count || 0} factura${statsData.count !== 1 ? 's' : ''} (FA)`;
                    const valEl = document.getElementById('val-facturado');
                    const cntEl = document.getElementById('cnt-facturado');
                    if (valEl) valEl.textContent = totalFmt;
                    if (cntEl) cntEl.textContent = countFmt;
                }
            }
        } catch(e) {
            console.warn('Error loading invoice stats:', e);
        }
    }

    // Delete movement
    (window as any).deleteMov = async (id: string) => {
        if (!confirm('¿Eliminar este movimiento?')) return;

        // Delete from local storage
        const localMovs = getLocalMovimientos();
        const localItem = localMovs.find(m => m && m.id && id && m.id.toString() === id.toString());
        const isLocalOnly = localItem && !localItem.synced;
        const filtered = localMovs.filter(m => m && m.id && id && m.id.toString() !== id.toString());
        saveLocalMovimientos(filtered);

        // Delete from Directus if synced/real ID
        if (!isLocalOnly) {
            try {
                await fetch(`/api/caja/movimientos?id=${id}`, {
                    method: 'DELETE'
                });
            } catch(e) {
                console.warn("Directus delete failed, item deleted locally only:", e);
            }
        }

        const filterFecha = (document.getElementById('filter-fecha') as HTMLInputElement).value || today();
        loadMovimientos(filterFecha);
        loadKPIs(filterFecha);
        window.dispatchEvent(new CustomEvent('sync-calculator'));
    };

    // Filter by date
    document.getElementById('filter-fecha')?.addEventListener('change', (e) => {
        const fecha = (e.target as HTMLInputElement).value;
        loadMovimientos(fecha);
        loadKPIs(fecha);
    });

    // Initial load
    loadMovimientos(today());
    loadKPIs(today());

    // ========================
    // EJECUTIVO: Charts
    // ========================
    let currentPeriod = 30;
    let chartsInitialized = false;
    let barChart: any = null, tortaFijosChart: any = null, tortaVariablesChart: any = null, ingresosChart: any = null;

    document.querySelectorAll('.period-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentPeriod = parseInt((btn as HTMLElement).dataset.period!);
            initCharts(currentPeriod);
        });
    });

    function getFriendlyCategoryName(catId: string): string {
        const mapping: Record<string, string> = {
            gasto_fijo_agua_calle: 'Agua de Calle',
            gasto_fijo_alquiler: 'Alquiler',
            gasto_fijo_arca: 'ARCA',
            gasto_fijo_arba_iibb: 'ARBA IIBB',
            gasto_fijo_comisiones_bancarias: 'Comisiones Bancarias',
            gasto_fijo_contadora: 'Contadora',
            gasto_fijo_faecys: 'FAECYS',
            gasto_fijo_gecom: 'GECOM',
            gasto_fijo_luz: 'Luz',
            gasto_fijo_monitoreo_alarmas: 'Monitoreo Alarmas',
            gasto_fijo_municipalidad: 'Municipalidad',
            gasto_fijo_sec: 'SEC',
            gasto_fijo_seguridad_higiene: 'Seguridad e Higiene',
            gasto_fijo_seguro_camion: 'Seguro Camión',
            gasto_fijo_seguros_galpon: 'Seguros Galpón',
            gasto_fijo_servidor: 'Servidor',
            gasto_fijo_sueldos_2026: 'Sueldos 2026',
            gasto_fijo_telefonos_internet: 'Teléfonos / Internet',
            gasto_variable_agua_ivess_dani: 'Agua Ivess/Dani',
            gasto_variable_arreglos_maquinaria_camion: 'Arreglos Maquinaria/Camión',
            gasto_variable_bomberos: 'Bomberos',
            gasto_variable_combustible_guille_facu_agus: 'Combustible Guille/Facu/Agus',
            gasto_variable_combustible_maquinaria: 'Combustible Maquinaria',
            gasto_variable_consumibles: 'Consumibles',
            gasto_variable_devoluciones_clientes_sf_caja: 'Devoluciones / SF Caja',
            gasto_variable_electricidad_ezequiel: 'Electricidad Ezequiel',
            gasto_variable_gastos_administrativos_prestamos: 'Gastos Adm. Préstamos',
            gasto_variable_gastos_varios_administracion: 'Gastos Varios Adm.',
            gasto_variable_gastos_varios_produccion: 'Gastos Varios Prod.',
            gasto_variable_libreria: 'Librería',
            gasto_variable_limpieza: 'Limpieza',
            gasto_variable_merma_mercaderia: 'Merma Mercadería',
            gasto_variable_pegamento_maquina: 'Pegamento Máquina',
            gasto_variable_plan_arca: 'Plan ARCA',
            gasto_variable_publicidad: 'Publicidad',
            gasto_variable_refrigerios: 'Refrigerios',
            gasto_variable_refrigerios_facu_agus_guille: 'Refrigerios Facu/Agus/Guille',
            gasto_variable_viaticos: 'Viáticos',
            gasto_variable_volquete: 'Volquete',
            impuestos: 'Impuestos / IVA'
        };
        return mapping[catId] || catId.replace('gasto_fijo_', '').replace('gasto_variable_', '').replace(/_/g, ' ').toUpperCase();
    }

    async function initCharts(days: number) {
        try {
            const desde = new Date();
            desde.setDate(desde.getDate() - days);
            const desdeStr = toARDate(desde);

            let items: any[] = [];

            try {
                const res = await fetch(`/api/caja/movimientos?fechaDesde=${desdeStr}&limit=1000&sort=fecha`);
                if (res.ok) {
                    const data = await res.json();
                    items = data.data || [];
                }
            } catch(e) {
                console.error("Directus charts fetch failed, falling back to local:", e);
            }

            // Merge local
            const localItems = getLocalMovimientos().filter(m => m.fecha >= desdeStr);
            localItems.forEach(lm => {
                const exists = items.some(im => (im && im.id && lm && lm.id && im.id.toString() === lm.id.toString()) || (im && lm && im.fecha === lm.fecha && parseFloat(im.monto) === parseFloat(lm.monto) && im.categoria === lm.categoria && im.tipo === lm.tipo));
                if (!exists) {
                    items.push(lm);
                }
            });

            // Sort items by date
            items.sort((a, b) => a.fecha.localeCompare(b.fecha));

            const agrupacion = (document.getElementById('ejec-gasto-agrupacion') as HTMLSelectElement)?.value || 'diario';

            let totalIngresos = 0, totalEgresos = 0;
            let gastoFijo = 0, gastoVar = 0, impuestos = 0;
            let ventaBlanco = 0, ventaNegro = 0;

            const egresosByCat: Record<string, Record<string, number>> = {};
            const fijosBreakdown: Record<string, number> = {};
            const variablesBreakdown: Record<string, number> = {};
            const intervalsSet = new Set<string>();

            items.forEach(m => {
                const monto = parseFloat(m.monto) || 0;
                const dateStr = m.fecha;

                if (m.tipo === 'ingreso') {
                    totalIngresos += monto;
                    if (m.categoria === 'venta_blanco') ventaBlanco += monto;
                    else if (m.categoria === 'venta_negro') ventaNegro += monto;
                } else {
                    totalEgresos += monto;
                    const friendlyName = getFriendlyCategoryName(m.categoria);
                    if (m.categoria.startsWith('gasto_fijo')) {
                        gastoFijo += monto;
                        fijosBreakdown[friendlyName] = (fijosBreakdown[friendlyName] || 0) + monto;
                    } else if (m.categoria.startsWith('gasto_variable')) {
                        gastoVar += monto;
                        variablesBreakdown[friendlyName] = (variablesBreakdown[friendlyName] || 0) + monto;
                    } else if (m.categoria === 'impuestos') {
                        impuestos += monto;
                    }
                    
                    // Grouping for line chart
                    let interval = dateStr;
                    if (agrupacion === 'mensual') {
                        interval = dateStr.substring(0, 7); // YYYY-MM
                    } else if (agrupacion === 'semestral') {
                        const parts = dateStr.split('-');
                        const month = parseInt(parts[1] || '1');
                        const semester = month <= 6 ? 'Semestre 1' : 'Semestre 2';
                        interval = `${parts[0]} - ${semester}`;
                    } else if (agrupacion === 'anual') {
                        interval = dateStr.substring(0, 4); // YYYY
                    }
                    intervalsSet.add(interval);

                    if (!egresosByCat[friendlyName]) {
                        egresosByCat[friendlyName] = {};
                    }
                    egresosByCat[friendlyName][interval] = (egresosByCat[friendlyName][interval] || 0) + monto;
                }
            });

            document.getElementById('ejec-egresos')!.textContent = fmt(totalEgresos);
            document.getElementById('ejec-fijos')!.textContent = fmt(gastoFijo);
            document.getElementById('ejec-variables')!.textContent = fmt(gastoVar);
            document.getElementById('ejec-impuestos')!.textContent = fmt(impuestos);

            const dates = Array.from(intervalsSet).sort();
            if (dates.length === 0) {
                dates.push(today());
            }

            const series: any[] = [];
            const activeCategories = Object.keys(egresosByCat);

            activeCategories.forEach(cat => {
                const data = dates.map(d => {
                    return parseFloat((egresosByCat[cat][d] || 0).toFixed(2));
                });
                if (data.some(v => v > 0)) {
                    series.push({
                        name: cat,
                        data: data
                    });
                }
            });

            if (series.length === 0) {
                series.push({
                    name: 'Sin Gastos',
                    data: dates.map(() => 0)
                });
            }

            const apexOpts = {
                chart: { background: 'transparent', toolbar: { show: false }, fontFamily: 'Inter, sans-serif' },
                theme: { mode: 'dark' },
                dataLabels: { enabled: false },
                grid: { borderColor: '#383838' }
            };

            // Egresos Line Chart
            if (barChart) barChart.destroy();
            barChart = new ApexCharts(document.getElementById('chart-barras'), {
                ...apexOpts,
                chart: { ...apexOpts.chart, type: 'line', height: 280 },
                series: series,
                xaxis: { 
                    categories: dates, 
                    labels: { 
                        rotate: -45, 
                        style: { colors: '#888', fontSize: '10px' } 
                    } 
                },
                yaxis: { 
                    labels: { 
                        style: { colors: '#888' }, 
                        formatter: (v: number) => `$${v.toLocaleString('es-AR')}` 
                    } 
                },
                stroke: { curve: 'smooth', width: 3 },
                markers: { size: 5, hover: { size: 7 } },
                legend: { 
                    show: true,
                    position: 'bottom',
                    labels: { colors: '#888' }
                },
                colors: [
                    '#ef4444', '#f59e0b', '#3b82f6', '#8b5cf6', '#10b981', 
                    '#ec4899', '#06b6d4', '#14b8a6', '#f97316', '#84cc16'
                ],
                tooltip: { y: { formatter: (v: number) => fmt(v) } }
            });
            barChart.render();

            // Torta Fijos (Composición de Gastos Fijos)
            const fijosLabels = Object.keys(fijosBreakdown);
            const fijosSeries = Object.values(fijosBreakdown);

            if (tortaFijosChart) tortaFijosChart.destroy();
            tortaFijosChart = new ApexCharts(document.getElementById('chart-torta'), {
                ...apexOpts,
                chart: { ...apexOpts.chart, type: 'donut', height: 280 },
                series: fijosSeries.length > 0 ? fijosSeries : [0],
                labels: fijosLabels.length > 0 ? fijosLabels : ['Sin Datos'],
                colors: [
                    '#3b82f6', '#10b981', '#8b5cf6', '#f59e0b', '#f43f5e', 
                    '#06b6d4', '#6366f1', '#ec4899', '#14b8a6', '#84cc16', 
                    '#f97316', '#a78bfa', '#38bdf8', '#34d399', '#e11d48'
                ],
                legend: { 
                    show: true,
                    position: 'bottom',
                    labels: { colors: '#888' }
                },
                tooltip: { y: { formatter: (v: number) => fmt(v) } }
            });
            tortaFijosChart.render();

            // Torta Variables (Composición de Gastos Variables)
            const variablesLabels = Object.keys(variablesBreakdown);
            const variablesSeries = Object.values(variablesBreakdown);

            if (tortaVariablesChart) tortaVariablesChart.destroy();
            tortaVariablesChart = new ApexCharts(document.getElementById('chart-torta-variables'), {
                ...apexOpts,
                chart: { ...apexOpts.chart, type: 'donut', height: 280 },
                series: variablesSeries.length > 0 ? variablesSeries : [0],
                labels: variablesLabels.length > 0 ? variablesLabels : ['Sin Datos'],
                colors: [
                    '#f97316', '#06b6d4', '#84cc16', '#7c3aed', '#10b981', 
                    '#d946ef', '#f59e0b', '#2563eb', '#f43f5e', '#0d9488', 
                    '#0ea5e9', '#dc2626', '#ca8a04', '#db2777', '#4f46e5'
                ],
                legend: { 
                    show: true,
                    position: 'bottom',
                    labels: { colors: '#888' }
                },
                tooltip: { y: { formatter: (v: number) => fmt(v) } }
            });
            tortaVariablesChart.render();

            // Fetch e inicialización del Gráfico de Ingresos (Facturación PDF)
            try {
                const resIng = await fetch(`/api/documentos/ingresos-chart`);
                if (resIng.ok) {
                    const dataIng = await resIng.json();
                    if (dataIng.success && dataIng.data) {
                        const agrupacionIngresos = (document.getElementById('ejec-ingreso-agrupacion') as HTMLSelectElement)?.value || 'diario';
                        let ingresosMap: Record<string, number> = {};
                        
                        dataIng.data.forEach((row: any) => {
                            const dateStr = (row.fecha || '').split('T')[0]; // YYYY-MM-DD
                            let interval = dateStr;
                            if (agrupacionIngresos === 'mensual') {
                                interval = dateStr.substring(0, 7);
                            } else if (agrupacionIngresos === 'semestral') {
                                const parts = dateStr.split('-');
                                const month = parseInt(parts[1] || '1');
                                const semester = month <= 6 ? 'Semestre 1' : 'Semestre 2';
                                interval = `${parts[0]} - ${semester}`;
                            } else if (agrupacionIngresos === 'anual') {
                                interval = dateStr.substring(0, 4);
                            } else {
                                // diario
                                const parts = dateStr.split('-');
                                if (parts.length >= 3) {
                                    interval = `${parts[2]}/${parts[1]}`;
                                }
                            }
                            ingresosMap[interval] = (ingresosMap[interval] || 0) + parseFloat(row.ingresos || 0);
                        });

                        const ingresosDates = Object.keys(ingresosMap).sort();
                        const ingresosSeriesData = ingresosDates.map(d => parseFloat(ingresosMap[d].toFixed(2)));

                        if (ingresosChart) ingresosChart.destroy();
                        ingresosChart = new ApexCharts(document.getElementById('chart-ingresos'), {
                            ...apexOpts,
                            chart: { ...apexOpts.chart, type: 'area', height: 280 },
                            series: [{ name: 'Ingresos (OCR)', data: ingresosSeriesData }],
                            xaxis: { 
                                categories: ingresosDates, 
                                labels: { rotate: -45, style: { colors: '#888', fontSize: '10px' } } 
                            },
                            yaxis: { 
                                labels: { style: { colors: '#888' }, formatter: (v: number) => `$${v.toLocaleString('es-AR')}` } 
                            },
                            stroke: { curve: 'smooth', width: 3 },
                            colors: ['#10b981'],
                            fill: { 
                                type: 'gradient', 
                                gradient: { shadeIntensity: 0.5, opacityFrom: 0.25, opacityTo: 0.02 } 
                            },
                            tooltip: { y: { formatter: (v: number) => fmt(v) } }
                        });
                        ingresosChart.render();
                    }
                }
            } catch (e) {
                console.error("Error loading ingresos chart:", e);
            }

        } catch(e) {
            console.error("Error initializing charts:", e);
        }
    }

    // Temporal aggregation change listener
    document.getElementById('ejec-gasto-agrupacion')?.addEventListener('change', () => {
        initCharts(currentPeriod);
    });

    document.getElementById('ejec-ingreso-agrupacion')?.addEventListener('change', () => {
        initCharts(currentPeriod);
    });

    // ========================
    // HISTORICO
    // ========================
    let histChart: any = null;

    function initHistoricoDefaults() {
        const el = document.getElementById('hist-fecha-carga') as HTMLInputElement;
        if (el && !el.value) el.value = today();
    }

    (window as any).loadProjectionToCalculator = (id: string) => {
        window.dispatchEvent(new CustomEvent('load-projection-by-id', { detail: { id: id } }));
        const tabBtn = document.querySelector(`.ctab[data-ctab="calculadora"]`);
        if (tabBtn) {
            (tabBtn as HTMLElement).click();
        }
    };

    document.getElementById('btn-generar-reporte')?.addEventListener('click', async () => {
        try {
            const fechaCarga = (document.getElementById('hist-fecha-carga') as HTMLInputElement).value;
            if (!fechaCarga) return;

            const agrupacion = (document.getElementById('hist-agrupacion') as HTMLSelectElement).value;

            const parts = fechaCarga.split('-');
            const year = parts[0];
            const month = parts[1];

            document.getElementById('hist-empty')!.style.display = 'none';
            document.getElementById('hist-kpis')!.style.display = 'grid';

            let projs: any[] = [];
            try {
                const res = await fetch(`/api/caja/proyecciones?limit=500&sort=fecha`);
                if (res.ok) {
                    const data = await res.json();
                    projs = data.data || [];
                }
            } catch(e) {
                console.warn("Directus fetch failed for historical reports:", e);
            }

            // Merge local storage proyecciones
            try {
                const localData = localStorage.getItem('caja_proyecciones_local');
                const localProjs = localData ? JSON.parse(localData) : [];
                localProjs.forEach((lp: any) => {
                    if (lp) {
                        const exists = projs.some(im => im && im.id && lp && lp.id && im.id.toString() === lp.id.toString());
                        if (!exists) {
                            projs.push(lp);
                        }
                    }
                });
            } catch(e) {}

            let filteredProjs: any[] = [];

            if (agrupacion === 'diario') {
                filteredProjs = projs.filter(p => p && p.fecha && p.fecha.startsWith(`${year}-${month}`));
            } else if (agrupacion === 'mensual' || agrupacion === 'semestral') {
                filteredProjs = projs.filter(p => p && p.fecha && p.fecha.startsWith(year));
            } else {
                filteredProjs = [...projs].filter(p => p && p.fecha);
            }

            // Sort chronologically
            filteredProjs.sort((a, b) => a.fecha.localeCompare(b.fecha));

            // Temporal aggregations
            let displayProjs: any[] = [];
            if (agrupacion === 'diario') {
                displayProjs = filteredProjs;
            } else if (agrupacion === 'mensual') {
                const byMonth: Record<string, any> = {};
                filteredProjs.forEach(p => {
                    const mMonth = p.fecha.substring(0, 7);
                    byMonth[mMonth] = p; // latest
                });
                displayProjs = Object.values(byMonth);
            } else if (agrupacion === 'semestral') {
                const bySemester: Record<string, any> = {};
                filteredProjs.forEach(p => {
                    const parts = p.fecha.split('-');
                    const m = parseInt(parts[1]);
                    const sem = m <= 6 ? 'S1' : 'S2';
                    const key = `${parts[0]}-${sem}`;
                    bySemester[key] = p; // latest
                });
                displayProjs = Object.values(bySemester);
            } else {
                const byYear: Record<string, any> = {};
                filteredProjs.forEach(p => {
                    const y = p.fecha.substring(0, 4);
                    byYear[y] = p; // latest
                });
                displayProjs = Object.values(byYear);
            }

            // Render KPIs
            if (displayProjs.length === 0) {
                document.getElementById('hist-val-ingresos')!.textContent = fmt(0);
                document.getElementById('hist-val-egresos')!.textContent = fmt(0);
                document.getElementById('hist-val-neto')!.textContent = fmt(0);
                document.getElementById('hist-val-neto')!.style.color = '#fff';
                document.getElementById('hist-val-movs')!.textContent = '0';
            } else {
                const latestProj = displayProjs[displayProjs.length - 1];
                const totalVentas = parseFloat(latestProj.ventas_blanco || 0) + parseFloat(latestProj.ventas_negro || 0);
                const totalGastos = parseFloat(latestProj.gastos_totales || 0);
                const neto = parseFloat(latestProj.utilidad_acumulada || 0);

                document.getElementById('hist-val-ingresos')!.textContent = fmt(totalVentas);
                document.getElementById('hist-val-egresos')!.textContent = fmt(totalGastos);
                document.getElementById('hist-val-neto')!.textContent = fmt(neto);
                document.getElementById('hist-val-neto')!.style.color = neto >= 0 ? '#10b981' : '#ef4444';
                document.getElementById('hist-val-movs')!.textContent = displayProjs.length.toString();
            }

            // Render Chart
            const titleEl = document.getElementById('hist-chart-title')!;
            
            const chartLabels = displayProjs.map(p => {
                if (agrupacion === 'diario') {
                    return fmtFecha(p.fecha);
                } else if (agrupacion === 'mensual') {
                    const [y, mNum] = p.fecha.substring(0, 7).split('-');
                    const monthsNames = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
                    return `${monthsNames[parseInt(mNum, 10) - 1]} ${y}`;
                } else if (agrupacion === 'semestral') {
                    const parts = p.fecha.split('-');
                    const m = parseInt(parts[1]);
                    return m <= 6 ? `1º Semestre ${parts[0]}` : `2º Semestre ${parts[0]}`;
                } else {
                    return p.fecha.substring(0, 4);
                }
            });

            const seriesVentas = displayProjs.map(p => parseFloat((parseFloat(p.ventas_blanco || 0) + parseFloat(p.ventas_negro || 0)).toFixed(0)));
            const seriesGastos = displayProjs.map(p => parseFloat(parseFloat(p.gastos_totales || 0).toFixed(0)));
            const seriesNeto = displayProjs.map(p => parseFloat(parseFloat(p.utilidad_acumulada || 0).toFixed(0)));

            if (agrupacion === 'diario') {
                titleEl.textContent = `Progreso Diario de Proyecciones Netas (${month}/${year})`;
            } else if (agrupacion === 'mensual') {
                titleEl.textContent = `Progreso Mensual de Proyecciones Netas (${year})`;
            } else if (agrupacion === 'semestral') {
                titleEl.textContent = `Evolución Semestral de Proyecciones (${year})`;
            } else {
                titleEl.textContent = `Trayectoria Histórica de Proyecciones Anuales`;
            }

            if (histChart) histChart.destroy();

            if (displayProjs.length === 0) {
                document.getElementById('hist-chart-card')!.style.display = 'none';
            } else {
                document.getElementById('hist-chart-card')!.style.display = 'block';
                histChart = new ApexCharts(document.getElementById('chart-historico'), {
                    chart: { 
                        background: 'transparent', 
                        type: 'area', 
                        height: 300, 
                        toolbar: { show: false }, 
                        fontFamily: 'Inter, sans-serif' 
                    },
                    theme: { mode: 'dark' },
                    series: [
                        { name: 'Ventas Totales', data: seriesVentas },
                        { name: 'Egresos Totales', data: seriesGastos },
                        { name: 'Ganancia Neta', data: seriesNeto }
                    ],
                    xaxis: { categories: chartLabels, labels: { style: { colors: '#888' } } },
                    yaxis: { labels: { style: { colors: '#888' }, formatter: (v: number) => `$${v.toLocaleString('es-AR')}` } },
                    colors: ['#10b981', '#ef4444', '#3b82f6'], 
                    fill: { 
                        type: 'gradient', 
                        gradient: { 
                            shadeIntensity: 0.5, 
                            opacityFrom: 0.25, 
                            opacityTo: 0.02 
                        } 
                    },
                    stroke: { curve: 'smooth', width: 2.5 },
                    dataLabels: { enabled: false },
                    grid: { borderColor: '#222' },
                    tooltip: { y: { formatter: (v: number) => fmt(v) } }
                });
                histChart.render();
            }

            // Render Detailed Snapshots Breakdown
            const container = document.getElementById('hist-egresos-container')!;
            
            if (displayProjs.length === 0) {
                container.innerHTML = `<div style="text-align:center; color:#888; padding: 20px;">No se registraron proyecciones guardadas en el período seleccionado.</div>`;
            } else {
                let html = '';
                const listProjs = [...displayProjs].reverse();
                
                listProjs.forEach((p, idx) => {
                    let det: any = {};
                    try {
                        det = typeof p.detalles_simulacion === 'string' ? JSON.parse(p.detalles_simulacion) : p.detalles_simulacion;
                    } catch(e) {
                        det = {};
                    }

                    const projId = p.id;
                    const nombre = det.nombre || p.fecha;
                    const fechaStr = fmtFecha(p.fecha);
                    const isSynced = p.synced !== false;

                    const v1 = parseFloat(det.ventaBlanco || p.ventas_blanco || 0);
                    const v1Corte = parseFloat(det.ventaCorteBlanco || 0);
                    const v1Pegado = parseFloat(det.ventaPegadoBlanco || 0);
                    const v1SinCorte = v1 - v1Corte - v1Pegado;
                    const marg1 = v1SinCorte * 0.23077;
                    const gain1 = marg1 + (v1Corte * 0.8) + (parseFloat(det.cantPegadosBlanco || 0) * parseFloat(det.precioPegadoBlanco || 1000)) + (Math.max(0, v1Pegado - parseFloat(det.cantPegadosBlanco || 0) * parseFloat(det.precioPegadoBlanco || 1000)) * 0.285715);

                    const v2 = parseFloat(det.ventaNegro || p.ventas_negro || 0);
                    const v2Corte = parseFloat(det.ventaCorteNegro || 0);
                    const v2Pegado = parseFloat(det.ventaPegadoNegro || 0);
                    const v2SinCorte = v2 - v2Corte - v2Pegado;
                    const marg2 = v2SinCorte * 0.23077;
                    const gain2 = marg2 + v2Corte + (parseFloat(det.cantPegadosNegro || 0) * parseFloat(det.precioPegadoNegro || 1000)) + (Math.max(0, v2Pegado - parseFloat(det.cantPegadosNegro || 0) * parseFloat(det.precioPegadoNegro || 1000)) * 0.285715);

                    const ganTotal = gain1 + gain2;
                    const gastos = parseFloat(det.gastosTotales || p.gastos_totales || 0);
                    const neto = parseFloat(p.utilidad_acumulada || 0);

                    const mpBlanco = v1SinCorte * 0.76923 / 1.25;
                    const mpNegro = v2SinCorte * 0.76923 / 1.105;
                    const mpTotal = mpBlanco + mpNegro;
                    const compraReal = parseFloat(det.compraTotalReal || 0);
                    const desvioCompra = compraReal - mpTotal;

                    const recaudacion = parseFloat(det.recaudacion || 0);
                    const desvioRecaudacion = recaudacion - (v1 + v2);

                    const ivaV = parseFloat(det.ivaVentas || 0);
                    const ivaC = parseFloat(det.ivaCompras || 0);
                    const ivaPagar = ivaV - ivaC;

                    const collapseId = `proj-collapse-${idx}`;

                    html += `
                        <div class="proj-card" style="background:#1e1e1e; border:1px solid #333; border-radius:10px; margin-bottom:14px; overflow:hidden; transition:all 0.2s;">
                            <div onclick="document.getElementById('${collapseId}').classList.toggle('hidden')" style="padding:14px 18px; display:flex; justify-content:space-between; align-items:center; cursor:pointer; background:#252525; user-select:none;">
                                <div style="display:flex; flex-direction:column; gap:4px;">
                                    <span style="font-weight:bold; color:#fff; font-size:13px; display:flex; align-items:center; gap:8px;">
                                        <i class="fas fa-calculator" style="color:#10b981;"></i>
                                        ${nombre}
                                        ${!isSynced ? '<span class="badge" style="background:rgba(245,158,11,0.15); color:#f59e0b;">Local</span>' : ''}
                                    </span>
                                    <span style="font-size:10px; color:#888;">Fecha de Carga: ${fechaStr} | Periodo: ${det.periodoDias || 30} días</span>
                                </div>
                                <div style="display:flex; align-items:center; gap:16px;">
                                    <div style="text-align:right;">
                                        <span style="font-size:9px; color:#888; text-transform:uppercase; font-weight:bold;">Neto Periodo</span>
                                        <div style="font-family:'Roboto Mono', monospace; font-weight:900; font-size:15px; color:${neto >= 0 ? '#10b981' : '#ef4444'};">${fmt(neto)}</div>
                                    </div>
                                    <i class="fas fa-chevron-down" style="color:#666; font-size:12px;"></i>
                                </div>
                            </div>

                            <div id="${collapseId}" class="hidden" style="border-top:1px solid #2e2e2e; padding:18px; background:#181818; transition:all 0.2s;">
                                <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:20px; margin-bottom:18px;">
                                    <div style="background:#222; padding:12px; border-radius:8px; border-left:3px solid #3b82f6;">
                                        <h5 style="color:#3b82f6; font-size:11px; text-transform:uppercase; font-weight:bold; margin-bottom:8px; display:flex; align-items:center; gap:6px;">
                                            <i class="fas fa-check-circle"></i> Venta 1 (Blanco)
                                        </h5>
                                        <div style="display:flex; flex-direction:column; gap:4px; font-size:11px; color:#aaa;">
                                            <div style="display:flex; justify-content:space-between;"><span>Venta Bruta:</span><span style="font-family:monospace; color:#fff;">${fmt(v1)}</span></div>
