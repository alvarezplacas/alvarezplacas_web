    (window as any).imprimirInforme = async (id: string) => {
        const originalText = "Imprimir Informe A4";
        const buttons = document.querySelectorAll(`button[onclick^="imprimirInforme('${id}')"]`);
        buttons.forEach(btn => {
            btn.setAttribute('disabled', 'true');
            btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Cargando Radar...`;
        });

        try {
            const list = (window as any).lastGeneratedProjections || [];
            const proj = list.find((p: any) => p && p.id && p.id.toString() === id.toString());
            if (!proj) {
                alert('No se pudo encontrar la proyección seleccionada.');
                return;
            }

            let det: any = {};
            try {
                det = typeof proj.detalles_simulacion === 'string' ? JSON.parse(proj.detalles_simulacion) : proj.detalles_simulacion;
            } catch(e) {
                det = {};
            }
            if (!det) det = {};

            // Fetch live market-radar
            let radar: any = null;
            try {
                const res = await fetch('/api/vendedor/market-radar');
                if (res.ok) {
                    const json = await res.json();
                    if (json.success) radar = json.data;
                }
            } catch(e) {
                console.warn("No se pudo obtener el radar de mercado en vivo:", e);
            }

            const v1 = parseFloat(det.ventaBlanco || proj.ventas_blanco || 0);
            const v1Corte = parseFloat(det.ventaCorteBlanco || 0);
            const v1Pegado = parseFloat(det.ventaPegadoBlanco || 0);
            const v1SinCorte = v1 - v1Corte - v1Pegado;
            const marg1 = v1SinCorte * 0.23077;
            const gain1 = marg1 + (v1Corte * 0.8) + (parseFloat(det.cantPegadosBlanco || 0) * parseFloat(det.precioPegadoBlanco || 1000)) + (Math.max(0, v1Pegado - parseFloat(det.cantPegadosBlanco || 0) * parseFloat(det.precioPegadoBlanco || 1000)) * 0.285715);

            const v2 = parseFloat(det.ventaNegro || proj.ventas_negro || 0);
            const v2Corte = parseFloat(det.ventaCorteNegro || 0);
            const v2Pegado = parseFloat(det.ventaPegadoNegro || 0);
            const v2SinCorte = v2 - v2Corte - v2Pegado;
            const marg2 = v2SinCorte * 0.23077;
            const gain2 = marg2 + v2Corte + (parseFloat(det.cantPegadosNegro || 0) * parseFloat(det.precioPegadoNegro || 1000)) + (Math.max(0, v2Pegado - parseFloat(det.cantPegadosNegro || 0) * parseFloat(det.precioPegadoNegro || 1000)) * 0.285715);

            const totalVts = v1 + v2;
            const pctV1 = totalVts > 0 ? ((v1 / totalVts) * 100).toFixed(1) : '0.0';
            const pctV2 = totalVts > 0 ? ((v2 / totalVts) * 100).toFixed(1) : '0.0';

            const ganTotal = gain1 + gain2;
            const gastos = parseFloat(det.gastosTotales || proj.gastos_totales || 0);
            const neto = parseFloat(proj.utilidad_acumulada || 0);

            const mpBlanco = v1SinCorte * 0.76923 / 1.25;
            const mpNegro = v2SinCorte * 0.76923 / 1.105;
            const mpTotal = mpBlanco + mpNegro;
            const compraReal = parseFloat(det.compraTotalReal || 0);
            const desvioCompra = compraReal - mpTotal;

            const recaudacion = parseFloat(det.recaudacion || 0);
            const desvioRecaudacion = recaudacion - totalVts;

            const ivaV = parseFloat(det.ivaVentas || 0);
            const ivaC = parseFloat(det.ivaCompras || 0);
            const ivaPagar = ivaV - ivaC;
            let riskScore = radar ? (radar.riesgoPuntaje || 0) : 0;
            let riskText = radar ? (radar.riesgoTexto || 'RIESGO BAJO: Los mercados proveedores operan con normalidad.') : 'RIESGO BAJO: Los mercados proveedores operan con normalidad.';
            let riskColor = '#10b981';
            let riskBg = 'rgba(16, 185, 129, 0.08)';

