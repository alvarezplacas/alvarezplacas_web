        margin-bottom: 20px;
    }
</style>

<script>
    // Robust ApexCharts CDN Fallback
    if (typeof window !== 'undefined' && typeof (window as any).ApexCharts === 'undefined') {
        (window as any).ApexCharts = class {
            constructor() {}
            render() {}
            updateOptions() {}
            updateSeries() {}
            destroy() {}
        };
    }

    // ========================
    // Tab switching logic
    // ========================
    function syncToolbarActive(ctabName: string) {
        document.querySelectorAll('[data-tab]').forEach(b => b.classList.remove('active'));
        const reverseMap: Record<string, string> = {
            'diario': 'tab-diario', 'ejecutivo': 'tab-ejecutivo',
            'historico': 'tab-historico', 'buscador': 'tab-buscador'
        };
        const tabId = reverseMap[ctabName];
        if (tabId) {
            const toolBtn = document.querySelector(`[data-tab="${tabId}"]`);
            if (toolBtn) toolBtn.classList.add('active');
        }
    }

    function activateCajaTab(tabName: string) {
        document.querySelectorAll('.ctab').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.ctab-panel').forEach(p => p.classList.add('hidden'));
        const btn = document.querySelector(`.ctab[data-ctab="${tabName}"]`);
        if (btn) btn.classList.add('active');
        const panel = document.getElementById(`panel-${tabName}`);
        if (panel) panel.classList.remove('hidden');
        
        // Sync toolbar active state
        syncToolbarActive(tabName);
        
        // Update tab name in tabs bar
        const tabLabel: Record<string, string> = { 
            diario: 'Operacion_Diaria.xls', 
            historico: 'Reportes_Historicos.xls', 
            calculadora: 'Calculadora_Neta.xls', 
            manual: 'Manual_Gecom.pdf',
            'manual-calculadora': 'Manual_Calculadora.pdf',
            buscador: 'Buscador_Facturas.psd'
        };
        const tabEl = document.getElementById('active-tab-name');
        if (tabEl) tabEl.textContent = tabLabel[tabName] || '';

        // Init charts when executive tab opens
        if (tabName === 'historico') window.dispatchEvent(new CustomEvent('init-historico'));
        if (tabName === 'calculadora') {
            window.dispatchEvent(new CustomEvent('sync-calculator'));
        }
    }

    document.querySelectorAll('.ctab').forEach(btn => {
        btn.addEventListener('click', () => {
            const tabName = (btn as HTMLElement).dataset.ctab;
            if (tabName) activateCajaTab(tabName);
        });
    });

    // ========================
    // Toolbar tab links
    // ========================
    document.querySelectorAll('[data-tab]').forEach(btn => {
        btn.addEventListener('click', () => {
            const tabName = (btn as HTMLElement).dataset.tab;
            const ctabMap: Record<string, string> = { 
                'tab-diario': 'diario', 
                'tab-historico': 'historico',
                'tab-buscador': 'buscador'
            };
            const ctabName = ctabMap[tabName || ''];
            if (ctabName) {
                activateCajaTab(ctabName);
            }
        });
    });

    // Check URL parameters for tab
    const urlParams = new URLSearchParams(window.location.search);
    const tabParam = urlParams.get('tab');
    if (tabParam) {
        activateCajaTab(tabParam);
    }

    // Mark diario as active in toolbar on load
    syncToolbarActive('diario');

    // ========================
    // Directus API
    // ========================
    const DIRECTUS_URL = 'https://admin.alvarezplacas.com.ar';
    
    function fmt(num: any): string {
        const val = parseFloat(num) || 0;
        return '$ ' + val.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
    function fmtFecha(fechaStr: string): string {
        if (!fechaStr) return '--';
        const parts = fechaStr.split('-');
        if (parts.length === 3) return `${parts[2]}/${parts[1]}/${parts[0]}`;
        return fechaStr;
    }
    function toARDate(d: Date): string {
        return d.toISOString().split('T')[0];
    }
    function today(): string {
        return toARDate(new Date());
    }

    function generateUUID(): string {
        try {
            if (typeof crypto !== 'undefined' && crypto.randomUUID) {
                return crypto.randomUUID();
            }
        } catch (e) {}
        return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
            const r = Math.random() * 16 | 0;
            const v = c === 'x' ? r : (r & 0x3 | 0x8);
            return v.toString(16);
        });
    }

    // ========================
    // LOCALSTORAGE FALLBACK HELPERS
    // ========================
    function getLocalMovimientos(): any[] {
        try {
            const data = localStorage.getItem('caja_movimientos_local');
            return data ? JSON.parse(data) : [];
        } catch (e) {
            return [];
        }
    }

    function saveLocalMovimientos(movs: any[]) {
        try {
            localStorage.setItem('caja_movimientos_local', JSON.stringify(movs));
        } catch (e) {}
    }

    // ========================
    // FORM: Guardar movimiento
    // ========================
    const form = document.getElementById('form-movimiento') as HTMLFormElement;
    const feedback = document.getElementById('form-feedback');

    // Set today as default date
    (document.getElementById('mov-fecha') as HTMLInputElement).value = today();
    (document.getElementById('filter-fecha') as HTMLInputElement).value = today();

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('btn-guardar') as HTMLButtonElement;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Guardando...';

        const payload = {
            id: generateUUID(),
            date_created: new Date().toISOString(),
            fecha: (document.getElementById('mov-fecha') as HTMLInputElement).value,
            tipo: (document.getElementById('mov-tipo') as HTMLInputElement).value,
            categoria: (document.getElementById('mov-categoria') as HTMLSelectElement).value,
            monto: parseFloat((document.getElementById('mov-monto') as HTMLInputElement).value),
            detalle: (document.getElementById('mov-detalle') as HTMLInputElement).value,
            observaciones: (document.getElementById('mov-obs') as HTMLTextAreaElement).value,
            synced: false
        };

        // 1. Save locally first (immediate feedback & safety)
        const localMovs = getLocalMovimientos();
        localMovs.push(payload);
        saveLocalMovimientos(localMovs);

        // 2. Try POSTing to Directus
        try {
            const res = await fetch(`/api/caja/movimientos`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    id: payload.id,
                    fecha: payload.fecha,
                    tipo: payload.tipo,
                    categoria: payload.categoria,
                    monto: payload.monto,
                    detalle: payload.detalle,
                    observaciones: payload.observaciones
                })
            });

            if (res.ok) {
                // Update local storage to mark synced
                const updatedMovs = getLocalMovimientos();
                const idx = updatedMovs.findIndex(m => m.id === payload.id);
                if (idx !== -1) {
                    updatedMovs[idx].synced = true;
                    saveLocalMovimientos(updatedMovs);
                }

                showFeedback('success', '✓ Movimiento guardado correctamente en Directus y base local');
                form.reset();
                (document.getElementById('mov-fecha') as HTMLInputElement).value = today();
                const currentFilter = (document.getElementById('filter-fecha') as HTMLInputElement).value || today();
                loadMovimientos(currentFilter);
                loadKPIs(currentFilter);
                window.dispatchEvent(new CustomEvent('sync-calculator'));
            } else {
                showFeedback('success', '✓ Movimiento guardado localmente (Directus fuera de línea)');
                form.reset();
                (document.getElementById('mov-fecha') as HTMLInputElement).value = today();
                const currentFilter = (document.getElementById('filter-fecha') as HTMLInputElement).value || today();
                loadMovimientos(currentFilter);
                loadKPIs(currentFilter);
                window.dispatchEvent(new CustomEvent('sync-calculator'));
            }
        } catch(err) {
            showFeedback('success', '✓ Movimiento guardado localmente (Modo sin conexión)');
            form.reset();
            (document.getElementById('mov-fecha') as HTMLInputElement).value = today();
            const currentFilter = (document.getElementById('filter-fecha') as HTMLInputElement).value || today();
            loadMovimientos(currentFilter);
            loadKPIs(currentFilter);
            window.dispatchEvent(new CustomEvent('sync-calculator'));
        }

        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save"></i> Guardar Movimiento';
    });

    function showFeedback(type: string, msg: string) {
        feedback!.className = `form-feedback ${type}`;
        feedback!.textContent = msg;
        feedback!.classList.remove('hidden');
        setTimeout(() => feedback!.classList.add('hidden'), 4000);
    }

    // ========================
    // LOAD: Movimientos del día
    // ========================
    let showAllMovements = false;

    // ========================
    // LOAD: Movimientos del día
    // ========================
    async function loadMovimientos(fecha: string) {
        const tbody = document.getElementById('tbody-movimientos')!;
        tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">Cargando movimientos...</td></tr>';

        let items: any[] = [];
        const tableTitle = document.getElementById('table-title')!;

        if (showAllMovements) {
            tableTitle.textContent = "Todos los Movimientos (Últimos 100)";
            try {
                const res = await fetch(`/api/caja/movimientos?sort=-date_created&limit=100`);
                if (res.ok) {
                    const data = await res.json();
                    items = data.data || [];
                }
            } catch(e) {
                console.warn("Directus fetch failed, loading local items only:", e);
            }
            // Merge all local storage items
            const localItems = getLocalMovimientos();
            localItems.forEach(lm => {
                const exists = items.some(im => (im && im.id && lm && lm.id && im.id.toString() === lm.id.toString()) || (im && lm && im.fecha === lm.fecha && parseFloat(im.monto) === parseFloat(lm.monto) && im.categoria === lm.categoria && im.tipo === lm.tipo));
                if (!exists) {
                    items.push(lm);
                }
            });
        } else {
            tableTitle.textContent = "Movimientos del Día";
            try {
                const res = await fetch(`/api/caja/movimientos?fecha=${fecha}&sort=-date_created&limit=50`);
                if (res.ok) {
                    const data = await res.json();
                    items = data.data || [];
                }
            } catch(e) {
                console.warn("Directus fetch failed, loading local items only:", e);
            }

            // Merge from local storage
            const localItems = getLocalMovimientos().filter(m => m.fecha === fecha);
            localItems.forEach(lm => {
                const exists = items.some(im => (im && im.id && lm && lm.id && im.id.toString() === lm.id.toString()) || (im && lm && im.fecha === lm.fecha && parseFloat(im.monto) === parseFloat(lm.monto) && im.categoria === lm.categoria && im.tipo === lm.tipo));
                if (!exists) {
                    items.push(lm);
                }
            });
        }

        if (!items.length) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">No hay movimientos para mostrar.</td></tr>';
            return;
        }

        // Sort items by date_created descending, newly created first
        items.sort((a, b) => {
            const timeA = a.date_created ? new Date(a.date_created).getTime() : 0;
            const timeB = b.date_created ? new Date(b.date_created).getTime() : 0;
            return timeB - timeA;
        });

        const catLabel: Record<string, string> = {
            venta_blanco: 'Venta 1',
            venta_negro: 'Venta 2',
            gasto_fijo: 'Gasto Fijo',
            gasto_variable: 'Gasto Variable',
            impuestos: 'Impuestos',
            // Gastos Fijos
            gasto_fijo_agua_calle: 'Agua de Calle',
            gasto_fijo_alquiler: 'Alquiler',
            gasto_fijo_arca: 'ARCA',
            gasto_fijo_arba_iibb: 'ARBA IIBB',
            gasto_fijo_comisiones_bancarias: 'Comisiones Bancarias',
            gasto_fijo_contadora: 'Contadora',
            gasto_fijo_faecys: 'FAECYS',
            gasto_fijo_gecom: 'GECOM',
            gasto_fijo_luz: 'Luz',
            gasto_fijo_monitoreo_alarmas: 'Monitoreo de Alarmas',
            gasto_fijo_municipalidad: 'Municipalidad',
            gasto_fijo_sec: 'SEC',
            gasto_fijo_seguridad_higiene: 'Seguridad e Higiene',
            gasto_fijo_seguro_camion: 'Seguro Camión',
            gasto_fijo_seguros_galpon: 'Seguros Galpón',
            gasto_fijo_servidor: 'Servidor',
            gasto_fijo_sueldos_2026: 'Sueldos 2026',
            gasto_fijo_telefonos_internet: 'Teléfonos Internet',
            // Gastos Variables
            gasto_variable_agua_ivess_dani: 'Agua Ivess y Dani',
            gasto_variable_arreglos_maquinaria_camion: 'Arreglos Maquinaria y Camión',
            gasto_variable_bomberos: 'Bomberos',
            gasto_variable_combustible_guille_facu_agus: 'Combustible G/F/A',
            gasto_variable_combustible_maquinaria: 'Combustible Maquinaria',
            gasto_variable_consumibles: 'Consumibles',
            gasto_variable_devoluciones_clientes_sf_caja: 'Devoluciones / SF de Caja',
            gasto_variable_electricidad_ezequiel: 'Electricidad Ezequiel',
            gasto_variable_gastos_administrativos_prestamos: 'Gastos Adm. Préstamos',
            gasto_variable_gastos_varios_administracion: 'Gastos Varios Adm.',
            gasto_variable_gastos_varios_produccion: 'Gastos Varios Prod.',
            gasto_variable_libreria: 'Librería',
            gasto_variable_limpieza: 'Limpieza',
            gasto_variable_merma_mercaderia: 'Merma Mercadería',
            gasto_variable_pegamento_maquina: 'Pegamento Máquina',
            gasto_variable_plan_arca: 'Plan ARCA',
            gasto_variable_publicidad: 'Publicidad',
            gasto_variable_refrigerios: 'Refrigerios',
            gasto_variable_refrigerios_facu_agus_guille: 'Refrigerios F/A/G',
            gasto_variable_viaticos: 'Viáticos',
            gasto_variable_volquete: 'Volquete'
        };

        tbody.innerHTML = items.map((m: any) => {
            const isLocalOnly = !m.synced;
            return `
                <tr>
                    <td>${fmtFecha(m.fecha)}</td>
                    <td>
                        <span class="badge badge-${m.tipo}">${m.tipo === 'ingreso' ? '▲ Ingreso' : '▼ Egreso'}</span>
                        ${isLocalOnly ? '<span class="badge" style="background:rgba(245,158,11,0.15); color:#f59e0b; margin-left:4px;">Local</span>' : ''}
                    </td>
                    <td>${catLabel[m.categoria] || m.categoria}</td>
                    <td>${m.detalle || '--'}</td>
                    <td class="text-right" style="color:${m.tipo === 'ingreso' ? '#10b981' : '#ef4444'}; font-family:'Roboto Mono',monospace; font-weight:bold;">
                        ${m.tipo === 'egreso' ? '-' : '+'}${fmt(m.monto)}
                    </td>
                    <td>
                        <button onclick="deleteMov('${m.id}')" style="background:none;border:none;color:#888;cursor:pointer;padding:2px 6px;" title="Eliminar">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </td>
                </tr>
            `;
        }).join('');
    }

    // ========================
    // KPIs Diarios
    // ========================
    async function loadKPIs(fecha: string) {
        let items: any[] = [];

        try {
            const res = await fetch(`/api/caja/movimientos?fecha=${fecha}&limit=1000`);
            if (res.ok) {
                const data = await res.json();
                items = data.data || [];
            }
        } catch(e) {
            console.error("Error loading KPIs from Directus:", e);
        }

        // Merge from local storage
        const localItems = getLocalMovimientos().filter(m => m.fecha === fecha);
        localItems.forEach(lm => {
            const exists = items.some(im => (im && im.id && lm && lm.id && im.id.toString() === lm.id.toString()) || (im && lm && im.fecha === lm.fecha && parseFloat(im.monto) === parseFloat(lm.monto) && im.categoria === lm.categoria && im.tipo === lm.tipo));
            if (!exists) {
                items.push(lm);
            }
        });

        let ingresos = 0, egresos = 0;
        items.forEach(m => {
            if (m.tipo === 'ingreso') ingresos += parseFloat(m.monto);
            else egresos += parseFloat(m.monto);
        });

        const neto = ingresos - egresos;

        const elIngresos = document.getElementById('val-ingresos');
        if (elIngresos) elIngresos.textContent = fmt(ingresos);
        document.getElementById('val-egresos')!.textContent = fmt(egresos);
        document.getElementById('val-neto')!.textContent = fmt(neto);
        document.getElementById('val-neto')!.style.color = neto >= 0 ? '#10b981' : '#ef4444';
        document.getElementById('val-movs')!.textContent = items.length.toString();

        // === KPI: Facturado Hoy (OCR) via /api/documentos/stats ===
        try {
            const statsRes = await fetch(`/api/documentos/stats?fecha=${fecha}`);
            if (statsRes.ok) {
                const statsData = await statsRes.json();
                if (statsData.success) {
                    const totalFmt = '$ ' + (statsData.total || 0).toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                    const countFmt = `${statsData.count || 0} factura${statsData.count !== 1 ? 's' : ''} (FA)`;
                    const valEl = document.getElementById('val-facturado');
                    const cntEl = document.getElementById('cnt-facturado');
                    if (valEl) valEl.textContent = totalFmt;
                    if (cntEl) cntEl.textContent = countFmt;
                }
            }
        } catch(e) {
            console.warn('Error loading invoice stats:', e);
        }
    }

