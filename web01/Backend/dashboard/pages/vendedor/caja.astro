                    </style>
                </head>
                <body>
                    <div class="header">
                        <div class="header-logo">Alvarez<span>Placas</span></div>
                        <div class="header-meta">
                            <strong>Fecha Emisión:</strong> ${new Date().toLocaleDateString('es-AR')} ${new Date().toLocaleTimeString('es-AR')}<br>
