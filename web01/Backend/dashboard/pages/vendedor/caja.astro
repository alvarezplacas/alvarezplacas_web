        } catch (e) {
            console.error("Error al imprimir el informe:", e);
            alert("Ocurrió un error inesperado al intentar imprimir el informe.");
        } finally {
            buttons.forEach(btn => {
                btn.removeAttribute('disabled');
                btn.innerHTML = `<i class="fas fa-print"></i> ${originalText}`;
            });
        }
    };

    document.getElementById('btn-generar-reporte')?.addEventListener('click', async () => {
        try {
            const fechaCarga = (document.getElementById('hist-fecha-carga') as HTMLInputElement).value;
            if (!fechaCarga) return;

            const agrupacion = (document.getElementById('hist-agrupacion') as HTMLSelectElement).value;

            const parts = fechaCarga.split('-');
            const year = parts[0];
            const month = parts[1];

            document.getElementById('hist-empty')!.style.display = 'none';
            document.getElementById('hist-kpis')!.style.display = 'grid';

            let projs: any[] = [];
            try {
                const res = await fetch(`/api/caja/proyecciones?limit=500&sort=fecha`);
                if (res.ok) {
                    const data = await res.json();
                    projs = data.data || [];
                }
            } catch(e) {
                console.warn("Directus fetch failed for historical reports:", e);
            }

            // Merge local storage proyecciones
            try {
                const localData = localStorage.getItem('caja_proyecciones_local');
                const localProjs = localData ? JSON.parse(localData) : [];
                localProjs.forEach((lp: any) => {
                    if (lp) {
                        const exists = projs.some(im => im && im.id && lp && lp.id && im.id.toString() === lp.id.toString());
                        if (!exists) {
                            projs.push(lp);
                        }
                    }
                });
            } catch(e) {}

            let filteredProjs: any[] = [];

            if (agrupacion === 'diario') {
                filteredProjs = projs.filter(p => p && p.fecha && p.fecha.startsWith(`${year}-${month}`));
            } else if (agrupacion === 'mensual' || agrupacion === 'semestral') {
                filteredProjs = projs.filter(p => p && p.fecha && p.fecha.startsWith(year));
            } else {
                filteredProjs = [...projs].filter(p => p && p.fecha);
            }

            // Sort chronologically
            filteredProjs.sort((a, b) => a.fecha.localeCompare(b.fecha));

            // Temporal aggregations
            let displayProjs: any[] = [];
            if (agrupacion === 'diario') {
                displayProjs = filteredProjs;
            } else if (agrupacion === 'mensual') {
                const byMonth: Record<string, any> = {};
                filteredProjs.forEach(p => {
                    const mMonth = p.fecha.substring(0, 7);
                    byMonth[mMonth] = p; // latest
                });
                displayProjs = Object.values(byMonth);
            } else if (agrupacion === 'semestral') {
                const bySemester: Record<string, any> = {};
                filteredProjs.forEach(p => {
                    const parts = p.fecha.split('-');
                    const m = parseInt(parts[1]);
                    const sem = m <= 6 ? 'S1' : 'S2';
                    const key = `${parts[0]}-${sem}`;
                    bySemester[key] = p; // latest
                });
                displayProjs = Object.values(bySemester);
            } else {
                const byYear: Record<string, any> = {};
                filteredProjs.forEach(p => {
                    const y = p.fecha.substring(0, 4);
                    byYear[y] = p; // latest
                });
                displayProjs = Object.values(byYear);
            }

            (window as any).lastGeneratedProjections = displayProjs;

            // Render KPIs
            if (displayProjs.length === 0) {
                document.getElementById('hist-val-ingresos')!.textContent = fmt(0);
                document.getElementById('hist-val-egresos')!.textContent = fmt(0);
                document.getElementById('hist-val-neto')!.textContent = fmt(0);
                document.getElementById('hist-val-neto')!.style.color = '#fff';
                document.getElementById('hist-val-movs')!.textContent = '0';
            } else {
                const latestProj = displayProjs[displayProjs.length - 1];
                const totalVentas = parseFloat(latestProj.ventas_blanco || 0) + parseFloat(latestProj.ventas_negro || 0);
                const totalGastos = parseFloat(latestProj.gastos_totales || 0);
                const neto = parseFloat(latestProj.utilidad_acumulada || 0);

                document.getElementById('hist-val-ingresos')!.textContent = fmt(totalVentas);
                document.getElementById('hist-val-egresos')!.textContent = fmt(totalGastos);
                document.getElementById('hist-val-neto')!.textContent = fmt(neto);
                document.getElementById('hist-val-neto')!.style.color = neto >= 0 ? '#10b981' : '#ef4444';
                document.getElementById('hist-val-movs')!.textContent = displayProjs.length.toString();
            }

            // Render Chart
            const titleEl = document.getElementById('hist-chart-title')!;
            
            const chartLabels = displayProjs.map(p => {
                if (agrupacion === 'diario') {
                    return fmtFecha(p.fecha);
                } else if (agrupacion === 'mensual') {
                    const [y, mNum] = p.fecha.substring(0, 7).split('-');
                    const monthsNames = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
                    return `${monthsNames[parseInt(mNum, 10) - 1]} ${y}`;
                } else if (agrupacion === 'semestral') {
                    const parts = p.fecha.split('-');
                    const m = parseInt(parts[1]);
                    return m <= 6 ? `1º Semestre ${parts[0]}` : `2º Semestre ${parts[0]}`;
                } else {
                    return p.fecha.substring(0, 4);
                }
            });

            const seriesVentas = displayProjs.map(p => parseFloat((parseFloat(p.ventas_blanco || 0) + parseFloat(p.ventas_negro || 0)).toFixed(0)));
            const seriesGastos = displayProjs.map(p => parseFloat(parseFloat(p.gastos_totales || 0).toFixed(0)));
            const seriesNeto = displayProjs.map(p => parseFloat(parseFloat(p.utilidad_acumulada || 0).toFixed(0)));

            if (agrupacion === 'diario') {
                titleEl.textContent = `Progreso Diario de Proyecciones Netas (${month}/${year})`;
            } else if (agrupacion === 'mensual') {
                titleEl.textContent = `Progreso Mensual de Proyecciones Netas (${year})`;
            } else if (agrupacion === 'semestral') {
                titleEl.textContent = `Evolución Semestral de Proyecciones (${year})`;
            } else {
                titleEl.textContent = `Trayectoria Histórica de Proyecciones Anuales`;
            }

            if (histChart) histChart.destroy();

            if (displayProjs.length === 0) {
                document.getElementById('hist-chart-card')!.style.display = 'none';
            } else {
                document.getElementById('hist-chart-card')!.style.display = 'block';
                histChart = new ApexCharts(document.getElementById('chart-historico'), {
                    chart: { 
                        background: 'transparent', 
                        type: 'area', 
                        height: 300, 
                        toolbar: { show: false }, 
                        fontFamily: 'Inter, sans-serif' 
                    },
                    theme: { mode: 'dark' },
                    series: [
                        { name: 'Ventas Totales', data: seriesVentas },
                        { name: 'Egresos Totales', data: seriesGastos },
                        { name: 'Ganancia Neta', data: seriesNeto }
                    ],
                    xaxis: { categories: chartLabels, labels: { style: { colors: '#888' } } },
                    yaxis: { labels: { style: { colors: '#888' }, formatter: (v: number) => `$${v.toLocaleString('es-AR')}` } },
                    colors: ['#10b981', '#ef4444', '#3b82f6'], 
                    fill: { 
                        type: 'gradient', 
                        gradient: { 
                            shadeIntensity: 0.5, 
                            opacityFrom: 0.25, 
                            opacityTo: 0.02 
                        } 
                    },
                    stroke: { curve: 'smooth', width: 2.5 },
                    dataLabels: { enabled: false },
                    grid: { borderColor: '#222' },
                    tooltip: { y: { formatter: (v: number) => fmt(v) } }
                });
                histChart.render();
            }

            // Render Detailed Snapshots Breakdown
            const container = document.getElementById('hist-egresos-container')!;
            
            if (displayProjs.length === 0) {
                container.innerHTML = `<div style="text-align:center; color:#888; padding: 20px;">No se registraron proyecciones guardadas en el período seleccionado.</div>`;
            } else {
                let html = '';
                const listProjs = [...displayProjs].reverse();
                
                listProjs.forEach((p, idx) => {
                    let det: any = {};
                    try {
                        det = typeof p.detalles_simulacion === 'string' ? JSON.parse(p.detalles_simulacion) : p.detalles_simulacion;
                    } catch(e) {
                        det = {};
                    }

                    const projId = p.id;
                    const nombre = det.nombre || p.fecha;
                    const fechaStr = fmtFecha(p.fecha);
                    const isSynced = p.synced !== false;

                    const v1 = parseFloat(det.ventaBlanco || p.ventas_blanco || 0);
                    const v1Corte = parseFloat(det.ventaCorteBlanco || 0);
                    const v1Pegado = parseFloat(det.ventaPegadoBlanco || 0);
                    const v1SinCorte = v1 - v1Corte - v1Pegado;
                    const marg1 = v1SinCorte * 0.23077;
                    const gain1 = marg1 + (v1Corte * 0.8) + (parseFloat(det.cantPegadosBlanco || 0) * parseFloat(det.precioPegadoBlanco || 1000)) + (Math.max(0, v1Pegado - parseFloat(det.cantPegadosBlanco || 0) * parseFloat(det.precioPegadoBlanco || 1000)) * 0.285715);

                    const v2 = parseFloat(det.ventaNegro || p.ventas_negro || 0);
                    const v2Corte = parseFloat(det.ventaCorteNegro || 0);
                    const v2Pegado = parseFloat(det.ventaPegadoNegro || 0);
                    const v2SinCorte = v2 - v2Corte - v2Pegado;
                    const marg2 = v2SinCorte * 0.23077;
                    const gain2 = marg2 + v2Corte + (parseFloat(det.cantPegadosNegro || 0) * parseFloat(det.precioPegadoNegro || 1000)) + (Math.max(0, v2Pegado - parseFloat(det.cantPegadosNegro || 0) * parseFloat(det.precioPegadoNegro || 1000)) * 0.285715);

                    const totalVts = v1 + v2;
                    const pctV1 = totalVts > 0 ? ((v1 / totalVts) * 100).toFixed(1) : '0.0';
                    const pctV2 = totalVts > 0 ? ((v2 / totalVts) * 100).toFixed(1) : '0.0';

                    const ganTotal = gain1 + gain2;
                    const gastos = parseFloat(det.gastosTotales || p.gastos_totales || 0);
                    const neto = parseFloat(p.utilidad_acumulada || 0);

                    const mpBlanco = v1SinCorte * 0.76923 / 1.25;
                    const mpNegro = v2SinCorte * 0.76923 / 1.105;
                    const mpTotal = mpBlanco + mpNegro;
                    const compraReal = parseFloat(det.compraTotalReal || 0);
                    const desvioCompra = compraReal - mpTotal;

                    const recaudacion = parseFloat(det.recaudacion || 0);
                    const desvioRecaudacion = recaudacion - (v1 + v2);

                    const ivaV = parseFloat(det.ivaVentas || 0);
                    const ivaC = parseFloat(det.ivaCompras || 0);
                    const ivaPagar = ivaV - ivaC;

                    const collapseId = `proj-collapse-${idx}`;

                    html += `
                        <div class="proj-card" style="background:#1e1e1e; border:1px solid #333; border-radius:10px; margin-bottom:14px; overflow:hidden; transition:all 0.2s;">
                            <div onclick="document.getElementById('${collapseId}').classList.toggle('hidden')" style="padding:14px 18px; display:flex; justify-content:space-between; align-items:center; cursor:pointer; background:#252525; user-select:none;">
                                <div style="display:flex; flex-direction:column; gap:4px;">
                                    <span style="font-weight:bold; color:#fff; font-size:13px; display:flex; align-items:center; gap:8px;">
                                        <i class="fas fa-calculator" style="color:#10b981;"></i>
                                        ${nombre}
                                        ${!isSynced ? '<span class="badge" style="background:rgba(245,158,11,0.15); color:#f59e0b;">Local</span>' : ''}
                                    </span>
                                    <span style="font-size:10px; color:#888;">Fecha de Carga: ${fechaStr} | Periodo: ${det.periodoDias || 30} días</span>
                                </div>
                                <div style="display:flex; align-items:center; gap:16px;">
                                    <div style="text-align:right;">
                                        <span style="font-size:9px; color:#888; text-transform:uppercase; font-weight:bold;">Neto Periodo</span>
                                        <div style="font-family:'Roboto Mono', monospace; font-weight:900; font-size:15px; color:${neto >= 0 ? '#10b981' : '#ef4444'};">${fmt(neto)}</div>
                                    </div>
                                    <i class="fas fa-chevron-down" style="color:#666; font-size:12px;"></i>
                                </div>
                            </div>

                            <div id="${collapseId}" class="hidden" style="border-top:1px solid #2e2e2e; padding:18px; background:#181818; transition:all 0.2s;">
                                <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 200px), 1fr)); gap:15px; margin-bottom:18px;">
                                    <div style="background:#222; padding:12px; border-radius:8px; border-left:3px solid #3b82f6;">
                                        <h5 style="color:#3b82f6; font-size:11px; text-transform:uppercase; font-weight:bold; margin-bottom:8px; display:flex; justify-content:space-between; align-items:center;">
                                            <span><i class="fas fa-check-circle"></i> Venta 1 (Blanco)</span>
                                            <span style="font-family:monospace; background:rgba(59,130,246,0.15); padding:2px 6px; border-radius:4px; font-size:10px;">${pctV1}%</span>
                                        </h5>
                                        <div style="display:flex; flex-direction:column; gap:4px; font-size:11px; color:#aaa;">
                                            <div style="display:flex; justify-content:space-between;"><span>Venta Bruta:</span><span style="font-family:monospace; color:#fff;">${fmt(v1)}</span></div>
                                            <div style="display:flex; justify-content:space-between;"><span>Servicio Corte:</span><span style="font-family:monospace;">${fmt(v1Corte)}</span></div>
                                            <div style="display:flex; justify-content:space-between;"><span>Servicio Pegado:</span><span style="font-family:monospace;">${fmt(v1Pegado)}</span></div>
                                            <div style="display:flex; justify-content:space-between;"><span>Melaminas Base:</span><span style="font-family:monospace;">${fmt(v1SinCorte)}</span></div>
                                            <div style="display:flex; justify-content:space-between; margin-top:4px; border-top:1px solid #333; padding-top:4px; font-weight:bold;">
                                                <span style="color:#3b82f6;">Utilidad Canal:</span>
                                                <span style="font-family:monospace; color:#3b82f6;">${fmt(gain1)}</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div style="background:#222; padding:12px; border-radius:8px; border-left:3px solid #a855f7;">
                                        <h5 style="color:#a855f7; font-size:11px; text-transform:uppercase; font-weight:bold; margin-bottom:8px; display:flex; justify-content:space-between; align-items:center;">
                                            <span><i class="fas fa-check-circle"></i> Venta 2 (Negro)</span>
                                            <span style="font-family:monospace; background:rgba(168,85,247,0.15); padding:2px 6px; border-radius:4px; font-size:10px;">${pctV2}%</span>
                                        </h5>
                                        <div style="display:flex; flex-direction:column; gap:4px; font-size:11px; color:#aaa;">
                                            <div style="display:flex; justify-content:space-between;"><span>Venta Bruta:</span><span style="font-family:monospace; color:#fff;">${fmt(v2)}</span></div>
                                            <div style="display:flex; justify-content:space-between;"><span>Servicio Corte:</span><span style="font-family:monospace;">${fmt(v2Corte)}</span></div>
                                            <div style="display:flex; justify-content:space-between;"><span>Servicio Pegado:</span><span style="font-family:monospace;">${fmt(v2Pegado)}</span></div>
                                            <div style="display:flex; justify-content:space-between;"><span>Melaminas Base:</span><span style="font-family:monospace;">${fmt(v2SinCorte)}</span></div>
                                            <div style="display:flex; justify-content:space-between; margin-top:4px; border-top:1px solid #333; padding-top:4px; font-weight:bold;">
                                                <span style="color:#a855f7;">Utilidad Canal:</span>
                                                <span style="font-family:monospace; color:#a855f7;">${fmt(gain2)}</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div style="background:#222; padding:12px; border-radius:8px; border-left:3px solid #f59e0b;">
                                        <h5 style="color:#f59e0b; font-size:11px; text-transform:uppercase; font-weight:bold; margin-bottom:8px; display:flex; align-items:center; gap:6px;">
                                            <i class="fas fa-shield-alt"></i> Caja & Compras
                                        </h5>
                                        <div style="display:flex; flex-direction:column; gap:4px; font-size:11px; color:#aaa;">
                                            <div style="display:flex; justify-content:space-between;"><span>Recaudación Real:</span><span style="font-family:monospace; color:#fff;">${fmt(recaudacion)}</span></div>
                                            <div style="display:flex; justify-content:space-between;"><span>Recaudación - Vtas:</span><span style="font-family:monospace; color:${desvioRecaudacion >= 0 ? '#10b981' : '#ef4444'};">${fmt(desvioRecaudacion)}</span></div>
                                            <div style="display:flex; justify-content:space-between;"><span>Compra Total Real:</span><span style="font-family:monospace; color:#fff;">${fmt(compraReal)}</span></div>
                                            <div style="display:flex; justify-content:space-between;"><span>Materia Prima Total:</span><span style="font-family:monospace;">${fmt(mpTotal)}</span></div>
                                            <div style="display:flex; justify-content:space-between; margin-top:4px; border-top:1px solid #333; padding-top:4px; font-weight:bold;">
                                                <span style="color:#f59e0b;">Desvío Compra:</span>
                                                <span style="font-family:monospace; color:${desvioCompra > 0 ? '#ef4444' : '#10b981'};">${fmt(desvioCompra)}</span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div style="background:#222; padding:12px; border-radius:8px; border-left:3px solid #10b981;">
                                        <h5 style="color:#10b981; font-size:11px; text-transform:uppercase; font-weight:bold; margin-bottom:8px; display:flex; align-items:center; gap:6px;">
                                            <i class="fas fa-percentage"></i> Deducciones & Gastos
                                        </h5>
                                        <div style="display:flex; flex-direction:column; gap:4px; font-size:11px; color:#aaa;">
                                            <div style="display:flex; justify-content:space-between;"><span>Gastos Operativos:</span><span style="font-family:monospace; color:#fff;">${fmt(gastos)}</span></div>
                                            <div style="display:flex; justify-content:space-between;"><span>IVA Ventas:</span><span style="font-family:monospace;">${fmt(ivaV)}</span></div>
                                            <div style="display:flex; justify-content:space-between;"><span>IVA Compras:</span><span style="font-family:monospace;">${fmt(ivaC)}</span></div>
                                            <div style="display:flex; justify-content:space-between; margin-top:4px; border-top:1px solid #333; padding-top:4px; font-weight:bold;">
                                                <span style="color:#10b981;">IVA Neto a Pagar:</span>
                                                <span style="font-family:monospace; color:#10b981;">${fmt(ivaPagar)}</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div style="display:flex; justify-content:flex-end; flex-wrap: wrap; gap:8px; border-top:1px solid #2a2a2a; padding-top:12px; margin-top:4px;">
                                    <button onclick="imprimirInforme('${projId}')" class="btn-primary" style="padding:6px 12px; font-size:11px; border-radius:4px; height:auto; background:#10b981; color:#fff; display:flex; align-items:center; gap:4px; border:none; cursor:pointer; font-weight:bold;">
                                        <i class="fas fa-print"></i> Imprimir Informe A4
                                    </button>
                                    <button onclick="loadProjectionToCalculator('${projId}')" class="btn-primary" style="padding:6px 12px; font-size:11px; border-radius:4px; height:auto; background:#1d4ed8; color:#fff; display:flex; align-items:center; gap:4px; border:none; cursor:pointer; font-weight:bold;">
                                        <i class="fas fa-edit mr-1"></i> ⚡ Cargar / Editar
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
                });
                
                container.innerHTML = html;
            }

            document.getElementById('hist-egresos-card')!.style.display = 'block';

        } catch(e) {
            console.error("Error generating historical report:", e);
        }
    });
</script>

















