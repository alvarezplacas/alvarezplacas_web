                if (radar.riesgoClase === 'risk-high') {
                    riskColor = '#ef4444';
                    riskBg = 'rgba(239, 68, 68, 0.08)';
                } else if (radar.riesgoClase === 'risk-med') {
                    riskColor = '#f59e0b';
                    riskBg = 'rgba(245, 158, 11, 0.08)';
                }
            }

            const pWin = window.open('', '_blank');
            if (!pWin) {
                alert('Por favor, permite ventanas emergentes para poder imprimir el informe.');
                return;
            }

            const nombreSim = det.nombre || `Cierre Proyectado ${proj.fecha}`;
            const fechaDesdeStr = det.fechaDesde ? det.fechaDesde.split('-').reverse().join('/') : '--/--/----';
            const fechaHastaStr = det.fechaHasta ? det.fechaHasta.split('-').reverse().join('/') : '--/--/----';
