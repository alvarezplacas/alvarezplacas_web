---
import CajeroWorkspace from '../../layouts/CajeroWorkspace.astro';
import { directus, readItems } from '@conexiones/directus.js';
import CalculadoraNeta from '../../components/cajero/CalculadoraNeta.astro';
import ManualGecom from '../../components/cajero/ManualGecom.astro';
import ManualCalculadora from '../../components/cajero/ManualCalculadora.astro';

let sellerId = Astro.cookies.get('seller_session')?.value;

// Verificar que el usuario es realmente el Cajero
if (!sellerId) {
    return Astro.redirect('/vendedor/login');
}

let sellerEmail = '';
try {
    const sellerInfo = await directus.request(readItems('vendedores', {
        filter: { id: { _eq: parseInt(sellerId) } },
        fields: ['email', 'role']
    })) as any[];
    if (sellerInfo?.[0]) {
        sellerEmail = sellerInfo[0].email;
        const role = sellerInfo[0].role;
        if (sellerEmail !== 'fernando@alvarezplacas.com.ar' && role !== 'cajero') {
            return Astro.redirect('/vendedor');
        }
    }
} catch(e) {
    console.error("[Caja] Error verifying user:", e);
}
---

<CajeroWorkspace title="Caja" vendedor_id={sellerId}>
    


    
    <!-- TABS NAV (dentro del canvas) -->
    <nav class="caja-tab-nav">
        <button class="ctab active" data-ctab="diario">
            <i class="fas fa-file-invoice-dollar"></i> Operación Diaria
        </button>
        <button class="ctab" data-ctab="historico">
            <i class="fas fa-chart-line"></i> Reportes Históricos
        </button>
        <button class="ctab" data-ctab="calculadora">
            <i class="fas fa-calculator"></i> Calculadora Neta
        </button>
    </nav>

    <!-- ========================= -->
    <!-- SOLAPA 1: OPERACIÓN DIARIA -->
    <!-- ========================= -->
    <section class="ctab-panel active" id="panel-diario">

        <!-- KPIs del día -->
        <div class="kpi-row" id="kpi-row">
            <div class="kpi-card" id="kpi-egresos">
                <div class="kpi-icon" style="background:rgba(239,68,68,0.15); color:#ef4444;">
                    <i class="fas fa-arrow-down"></i>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">Egresos Hoy</span>
                    <span class="kpi-value" id="val-egresos">$ --</span>
                </div>
            </div>
            <div class="kpi-card" id="kpi-neto">
                <div class="kpi-icon" style="background:rgba(59,130,246,0.15); color:#3b82f6;">
                    <i class="fas fa-balance-scale"></i>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">Neto del Día</span>
                    <span class="kpi-value" id="val-neto">$ --</span>
                </div>
            </div>
            <div class="kpi-card" id="kpi-movs">
                <div class="kpi-icon" style="background:rgba(245,158,11,0.15); color:#f59e0b;">
                    <i class="fas fa-receipt"></i>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">Movimientos</span>
                    <span class="kpi-value" id="val-movs">--</span>
                </div>
            </div>
            <div class="kpi-card" id="kpi-facturado" style="border-color: #ef4444; background: rgba(239, 68, 68, 0.03);">
                <div class="kpi-icon" style="background:rgba(239, 68, 68, 0.15); color:#ef4444;">
                    <i class="fas fa-file-invoice"></i>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">Facturado Hoy (OCR)</span>
                    <span class="kpi-value" id="val-facturado" style="font-size: 13px; font-weight: 900; color: #fff;">$ --</span>
                    <span class="kpi-subtext" id="cnt-facturado" style="font-size: 9px; color: #888; font-weight: 500;">0 facturas (FA)</span>
                </div>
            </div>
        </div>

        <!-- Form + Table layout -->
        <div class="diario-layout">

            <!-- Form de ingreso rápido -->
            <div class="quick-form-card">
                <div class="card-header">
                    <i class="fas fa-plus-circle" style="color:#10b981;"></i>
                    <h3>Asentar Movimiento</h3>
                </div>

                <form id="form-movimiento" autocomplete="off">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Fecha</label>
                            <input type="date" id="mov-fecha" class="ps-input" required />
                        </div>
                        <div class="form-group">
                            <label>Tipo</label>
                            <div style="background: #1e1e1e; border: 1px solid #444; color: #ccc; padding: 7px 10px; border-radius: 4px; font-size: 13px; display: flex; align-items: center; gap: 6px;">
                                <span style="color: #ef4444;">🔴</span> Egreso (Gasto)
                            </div>
                            <input type="hidden" id="mov-tipo" value="egreso" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Categoría</label>
                        <select id="mov-categoria" class="ps-input" required>
                            <option value="">Seleccionar...</option>
                            <optgroup label="Gastos Fijos">
                                <option value="gasto_fijo_agua_calle">AGUA DE CALLE</option>
                                <option value="gasto_fijo_alquiler">ALQUILER</option>
                                <option value="gasto_fijo_arca">ARCA</option>
                                <option value="gasto_fijo_arba_iibb">ARBA IIBB</option>
                                <option value="gasto_fijo_comisiones_bancarias">COMISIONES BANCARIAS</option>
                                <option value="gasto_fijo_contadora">CONTADORA</option>
                                <option value="gasto_fijo_faecys">FAECYS</option>
                                <option value="gasto_fijo_gecom">GECOM</option>
                                <option value="gasto_fijo_luz">LUZ</option>
                                <option value="gasto_fijo_monitoreo_alarmas">MONITOREO DE ALARMAS</option>
                                <option value="gasto_fijo_municipalidad">MUNICIPALIDAD</option>
                                <option value="gasto_fijo_sec">SEC</option>
                                <option value="gasto_fijo_seguridad_higiene">SEGURIDAD E HIGIENE</option>
                                <option value="gasto_fijo_seguro_camion">SEGURO CAMION</option>
                                <option value="gasto_fijo_seguros_galpon">SEGUROS GALPON</option>
                                <option value="gasto_fijo_servidor">SERVIDOR</option>
                                <option value="gasto_fijo_sueldos_2026">SUELDOS 2026</option>
                                <option value="gasto_fijo_telefonos_internet">TELEFONOS INTERNET</option>
                            </optgroup>
                            <optgroup label="Gastos Variables">
                                <option value="gasto_variable_agua_ivess_dani">AGUA IVESS y DANI</option>
                                <option value="gasto_variable_arreglos_maquinaria_camion">ARREGLOS MAQUINARIA Y CAMION</option>
                                <option value="gasto_variable_bomberos">BOMBEROS</option>
                                <option value="gasto_variable_combustible_guille_facu_agus">COMBUSTIBLE GUILLE, FACU Y AGUS</option>
                                <option value="gasto_variable_combustible_maquinaria">COMBUSTIBLE MAQUINARIA</option>
                                <option value="gasto_variable_consumibles">CONSUMIBLES</option>
                                <option value="gasto_variable_devoluciones_clientes_sf_caja">DEVOLUCIONES A CLIENTES Y SF DE CAJA</option>
                                <option value="gasto_variable_electricidad_ezequiel">ELECTRICIDAD EZEQUIEL</option>
                                <option value="gasto_variable_gastos_administrativos_prestamos">GASTOS ADMINISTRATIVOS PRESTAMOS</option>
                                <option value="gasto_variable_gastos_varios_administracion">GASTOS VARIOS DE ADMINISTRACION</option>
                                <option value="gasto_variable_gastos_varios_produccion">GASTOS VARIOS DE PRODUCCION</option>
                                <option value="gasto_variable_libreria">LIBRERÍA</option>
                                <option value="gasto_variable_limpieza">LIMPIEZA</option>
                                <option value="gasto_variable_merma_mercaderia">MERMA MERCADERIA</option>
                                <option value="gasto_variable_pegamento_maquina">PEGAMENTO MAQUINA</option>
                                <option value="gasto_variable_plan_arca">PLAN ARCA</option>
                                <option value="gasto_variable_publicidad">PUBLICIDAD</option>
                                <option value="gasto_variable_refrigerios">REFRIGERIOS</option>
                                <option value="gasto_variable_refrigerios_facu_agus_guille">REFRIGERIOS FACU, AGUS Y GUILLE</option>
                                <option value="gasto_variable_viaticos">VIATICOS</option>
                                <option value="gasto_variable_volquete">VOLQUETE</option>
                            </optgroup>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Monto ($)</label>
                        <input type="number" id="mov-monto" class="ps-input" placeholder="0.00" step="0.01" required />
                    </div>

                    <div class="form-group">
                        <label>Detalle</label>
                        <input type="text" id="mov-detalle" class="ps-input" placeholder="Ej: Cobranza cliente García" />
                    </div>

                    <div class="form-group">
                        <label>Observaciones</label>
                        <textarea id="mov-obs" class="ps-input" rows="2" placeholder="Notas adicionales..."></textarea>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn-primary" id="btn-guardar">
                            <i class="fas fa-save"></i> Guardar Movimiento
                        </button>
                    </div>
                    
                    <div id="form-feedback" class="form-feedback hidden"></div>
                </form>
            </div>

            <!-- Tabla de movimientos del día -->
            <div class="table-card">
                <div class="card-header">
                    <i class="fas fa-list" style="color:#3b82f6;"></i>
                    <h3 id="table-title">Movimientos del Día</h3>
                    <div class="filter-controls" style="display: flex; gap: 8px; align-items: center;">
                        <button type="button" id="btn-control-categorias" class="btn-primary" style="padding: 4px 10px; font-size: 11px; height: 28px; background: #1b365d; border: 1px solid #2e609c; color: #8ab4f8; font-weight: 500;" title="Control de categorías e impuestos a pagar del mes">
                            <i class="fas fa-tasks"></i> Control de Categorías
                        </button>
                        <button type="button" id="btn-todos-movimientos" class="btn-primary" style="padding: 4px 10px; font-size: 11px; height: 28px; background: #222; border: 1px solid #444; color: #aaa; font-weight: normal;" title="Ver todos los movimientos cargados">
                            <i class="fas fa-history"></i> Todos
                        </button>
                        <input type="date" id="filter-fecha" class="ps-input-sm" />
                    </div>
                </div>

                <div class="table-scroll">
                    <table class="caja-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th>Categoría</th>
                                <th>Detalle</th>
                                <th class="text-right">Monto</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="tbody-movimientos">
                            <tr>
                                <td colspan="6" class="text-center text-muted">Cargando movimientos...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================ -->
    <!-- SOLAPA 3: REPORTES HISTÓRICOS -->
    <!-- ============================ -->
    <section class="ctab-panel hidden" id="panel-historico">

        <div class="historico-controls">
            <div class="form-row" style="grid-template-columns: 1fr 1fr auto; gap: 16px; align-items: flex-end;">
                <div class="form-group">
                    <label>Fecha de Carga</label>
                    <input type="date" id="hist-fecha-carga" class="ps-input" />
                </div>
                <div class="form-group">
                    <label>Frecuencia de Gastos</label>
                    <select id="hist-agrupacion" class="ps-input">
                        <option value="diario" selected>Diario (Mes Seleccionado)</option>
                        <option value="mensual">Mensual (Año Seleccionado)</option>
                        <option value="semestral">Semestral (Año Seleccionado)</option>
                        <option value="anual">Anual (Histórico)</option>
                    </select>
                </div>
                <div class="form-group">
                    <button class="btn-primary" id="btn-generar-reporte" style="height: 38px;">
                        <i class="fas fa-search"></i> Generar Reporte
                    </button>
                </div>
            </div>
        </div>

        <!-- KPIs del período histórico -->
        <div class="kpi-row" id="hist-kpis" style="display:none;">
            <div class="kpi-card">
                <div class="kpi-icon" style="background:rgba(16,185,129,0.15); color:#10b981;">
                    <i class="fas fa-arrow-up"></i>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">Ingresos Totales</span>
                    <span class="kpi-value" id="hist-val-ingresos">$ --</span>
                </div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon" style="background:rgba(239,68,68,0.15); color:#ef4444;">
                    <i class="fas fa-arrow-down"></i>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">Egresos Totales</span>
                    <span class="kpi-value" id="hist-val-egresos">$ --</span>
                </div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon" style="background:rgba(59,130,246,0.15); color:#3b82f6;">
                    <i class="fas fa-balance-scale"></i>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">Ganancia Neta</span>
                    <span class="kpi-value" id="hist-val-neto">$ --</span>
                </div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon" style="background:rgba(245,158,11,0.15); color:#f59e0b;">
                    <i class="fas fa-receipt"></i>
                </div>
                <div class="kpi-info">
                    <span class="kpi-label">Reportes Guardados</span>
                    <span class="kpi-value" id="hist-val-movs">--</span>
                </div>
            </div>
        </div>

        <div class="chart-card" id="hist-chart-card" style="display:none; margin-top:20px;">
            <div class="card-header">
                <i class="fas fa-chart-line" style="color:#10b981;"></i>
                <h3 id="hist-chart-title">Evolución de Balance Proyectado</h3>
            </div>
            <div id="chart-historico"></div>
        </div>
        
        <div class="chart-card" id="hist-egresos-card" style="display:none; margin-top:20px;">
            <div class="card-header">
                <i class="fas fa-calculator" style="color:#10b981;"></i>
                <h3>Desglose de Balances Guardados (Calculadora Neta)</h3>
            </div>
            <div id="hist-egresos-container" style="padding: 20px; display: flex; flex-direction: column; gap: 16px;">
                <!-- Cargando balances... -->
            </div>
        </div>
        
        <div id="hist-empty" style="display:flex; align-items:center; justify-content:center; height:300px; color:#888; flex-direction:column; gap:10px;">
            <i class="fas fa-filter" style="font-size:2rem; opacity:0.3;"></i>
            <p>Selecciona una fecha de carga y presiona "Generar Reporte"</p>
        </div>
    </section>

    <!-- ============================ -->
    <!-- SOLAPA 4: CALCULADORA NETA -->
    <!-- ============================ -->
    <section class="ctab-panel hidden" id="panel-calculadora">
        <CalculadoraNeta />
    </section>

    <!-- ============================ -->
    <!-- SOLAPA 5: MANUAL GECOM -->
    <!-- ============================ -->
    <section class="ctab-panel hidden" id="panel-manual">
        <ManualGecom />
    </section>

    <!-- ============================ -->
    <!-- SOLAPA 6: MANUAL CALCULADORA NETA -->
    <!-- ============================ -->
    <section class="ctab-panel hidden" id="panel-manual-calculadora">
        <ManualCalculadora />
    </section>

    <!-- ========================= -->
    <!-- FIN SOLAPAS -->
    <!-- ========================= -->

    <!-- MODAL: CONTROL DE CATEGORÍAS MENSUAL -->
    <div id="modal-categorias" class="caja-modal hidden">
        <div class="caja-modal-content">
            <div class="caja-modal-header">
                <div style="display:flex; align-items:center; gap:10px;">
                    <i class="fas fa-tasks" style="color:#8ab4f8; font-size:1.5rem;"></i>
                    <div>
                        <h3 style="margin:0; color:#fff; font-size:16px;">Control Mensual de Categorías</h3>
                        <span id="modal-subtitle" style="font-size:11px; color:#888;">Cargando período...</span>
                    </div>
                </div>
                <button type="button" id="btn-close-modal" class="modal-close-btn">&times;</button>
            </div>
            
            <!-- Modal KPIs / stats -->
            <div class="modal-stats-bar">
                <div class="modal-stat-pill" style="border-left:3px solid #3b82f6;">
                    <span class="pill-label">Total de Categorías</span>
                    <span class="pill-val" id="lbl-total-cats">--</span>
                </div>
                <div class="modal-stat-pill" style="border-left:3px solid #10b981;">
                    <span class="pill-label">Abonadas</span>
                    <span class="pill-val" id="lbl-total-abonadas" style="color:#10b981;">--</span>
                </div>
                <div class="modal-stat-pill" style="border-left:3px solid #ef4444;">
                    <span class="pill-label">Falta Abonar</span>
                    <span class="pill-val" id="lbl-total-faltantes" style="color:#ef4444;">--</span>
                </div>
            </div>

            <!-- Control de Búsqueda y Filtros -->
            <div class="modal-filter-row">
                <div class="search-box">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" id="cat-search-input" placeholder="Buscar categoría..." class="modal-search-input" />
                </div>
                <div class="modal-tabs">
                    <button type="button" class="m-tab active" data-filter="all">Todas</button>
                    <button type="button" class="m-tab" data-filter="pending">Falta Abonar</button>
                    <button type="button" class="m-tab" data-filter="paid">Abonadas</button>
                </div>
            </div>

            <!-- Listado de Categorías -->
            <div class="modal-categories-scroll">
                <div class="modal-categories-grid">
                    <div class="cat-group-section">
                        <h4 class="cat-group-title">Gastos Fijos</h4>
                        <div id="grid-fijos" class="grid-container"></div>
                    </div>
                    <div class="cat-group-section" style="margin-top: 15px;">
                        <h4 class="cat-group-title">Gastos Variables</h4>
                        <div id="grid-variables" class="grid-container"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</CajeroWorkspace>

<style>
    /* === DYNAMIC CATEGORY MODAL === */
    .caja-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0,0,0,0.85);
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10000;
        transition: opacity 0.3s ease;
    }
    
    .caja-modal.hidden {
        display: none !important;
    }

    .caja-modal-content {
        background: #181818;
        border: 1px solid #333;
        width: 90%;
        max-width: 960px;
        height: 85vh;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.6);
        animation: modalSlideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes modalSlideUp {
        from { transform: translateY(30px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    .caja-modal-header {
        padding: 16px 24px;
        border-bottom: 1px solid #2e2e2e;
        background: #202020;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-close-btn {
        background: none;
        border: none;
        color: #888;
        font-size: 28px;
        cursor: pointer;
        transition: color 0.2s;
        line-height: 1;
    }
    .modal-close-btn:hover { color: #fff; }

    /* Stats row inside modal */
    .modal-stats-bar {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        padding: 20px 24px;
        background: #1c1c1c;
        border-bottom: 1px solid #282828;
    }

    .modal-stat-pill {
        background: #252525;
        padding: 12px 16px;
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .pill-label { font-size: 11px; color: #888; text-transform: uppercase; font-weight: bold; }
    .pill-val { font-size: 20px; font-weight: 700; color: #fff; font-family: 'Roboto Mono', monospace; }

    /* Search & Filters row */
    .modal-filter-row {
        padding: 16px 24px;
        background: #202020;
        border-bottom: 1px solid #282828;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .search-box {
        position: relative;
        flex: 1;
        min-width: 250px;
    }
    .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #666;
        font-size: 13px;
    }
    .modal-search-input {
        width: 100%;
        background: #181818;
        border: 1px solid #444;
        color: #fff;
        padding: 8px 12px 8px 36px;
        border-radius: 6px;
        font-size: 13px;
        outline: none;
        transition: border-color 0.2s;
    }
    .modal-search-input:focus { border-color: #8ab4f8; }

    .modal-tabs {
        display: flex;
        gap: 4px;
        background: #181818;
        padding: 4px;
        border-radius: 6px;
        border: 1px solid #333;
    }
    .m-tab {
        background: transparent;
        border: none;
        color: #888;
        padding: 6px 14px;
        border-radius: 4px;
        font-size: 12px;
        cursor: pointer;
        transition: all 0.2s;
        font-weight: 500;
    }
    .m-tab:hover { color: #ccc; }
    .m-tab.active {
        background: #2e609c;
        color: #fff;
    }

    /* Categories scrollable body */
    .modal-categories-scroll {
        padding: 24px;
        overflow-y: auto;
        flex: 1;
        background: #151515;
    }

    .modal-categories-grid {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .cat-group-section {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .cat-group-title {
        color: #8ab4f8;
        font-size: 13px;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.5px;
        margin: 0 0 4px 0;
        border-left: 3px solid #8ab4f8;
        padding-left: 8px;
    }

    .grid-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 12px;
    }

    .cat-card-item {
        background: #202020;
        border: 1px solid #333;
        border-radius: 8px;
        padding: 12px 16px;
