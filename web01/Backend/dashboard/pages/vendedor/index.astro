---
import VendedorLayout from '../../layouts/VendedorLayout.astro';
import StatCard from '@dashboard/components/StatCard.astro';
import { directus, readItems } from '@conexiones/directus.js';
import { aggregate } from '@directus/sdk';

let sellerId = Astro.cookies.get('seller_session')?.value || '1'; // Default for UI demo if needed
let pendingOrdersCount = 0;
let myClientsCount = 0;

try {
    const ordersStats = await directus.request(aggregate('pedidos', {
        aggregate: { count: '*' },
        query: { filter: { vendedor_id: { _eq: sellerId }, status: { _eq: 'pending' } } }
    }));
    pendingOrdersCount = parseInt(ordersStats[0]?.count || '0');

    const clientsStats = await directus.request(aggregate('clientes', {
        aggregate: { count: '*' },
        query: { filter: { vendedor_asignado: { _eq: sellerId } } }
    }));
    myClientsCount = parseInt(clientsStats[0]?.count || '0');
} catch (e) {
    console.error("Error loading seller stats:", e.message);
}
---

<VendedorLayout title="Operaciones Diarias">
    <div class="mb-8">
        <h2 class="text-3xl font-black text-white mb-2 uppercase tracking-tight">Panel de <span class="text-blue-500 italic">Ventas</span></h2>
        <p class="text-gray-400 font-medium">Gestión de atención y seguimiento de pedidos.</p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <StatCard 
            label="Pedidos Pendientes" 
            value={pendingOrdersCount} 
            icon="fa-clock" 
            color="blue"
        />
        <StatCard 
            label="Mis Clientes" 
            value={myClientsCount} 
            icon="fa-address-book" 
            color="primary"
        />
        <StatCard 
            label="Mensajes Nuevos" 
            value="3" 
            icon="fa-comment-dots" 
            color="green"
        />
    </div>

    <!-- Quick Actions -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="bg-[#1a1a1a] border border-gray-800 rounded-[2rem] p-8 relative overflow-hidden group">
            <div class="absolute -top-12 -right-12 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl"></div>
            <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-3">
                <i class="fas fa-shipping-fast text-blue-500"></i> Seguimiento Rápido
            </h3>
            <p class="text-gray-400 text-sm mb-6 leading-relaxed">Accede directamente a los pedidos que requieren tu atención inmediata para avanzar en el proceso de venta.</p>
            <a href="/vendedor/pedidos" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-white text-white hover:text-black px-6 py-3 rounded-xl font-black text-xs uppercase tracking-widest transition-all">
                Ver Pedidos <i class="fas fa-arrow-right"></i>
            </a>
        </div>

        <div class="bg-[#1a1a1a] border border-gray-800 rounded-[2rem] p-8 relative overflow-hidden group">
            <div class="absolute -top-12 -right-12 w-32 h-32 bg-green-500/10 rounded-full blur-3xl"></div>
            <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-3">
                <i class="fas fa-comments text-green-500"></i> Comunicación Interna
            </h3>
            <p class="text-gray-400 text-sm mb-6 leading-relaxed">Mantente en contacto con tus clientes. Responde consultas y envía presupuestos actualizados de forma fluida.</p>
            <a href="/vendedor/mensajes" class="inline-flex items-center gap-2 bg-green-600 hover:bg-white text-white hover:text-black px-6 py-3 rounded-xl font-black text-xs uppercase tracking-widest transition-all">
                Ir a Mensajería <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </div>
</VendedorLayout>
