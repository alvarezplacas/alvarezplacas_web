---
import VendedorWorkspace from '../../layouts/VendedorWorkspace.astro';
import { directus, readItems } from '@conexiones/directus.js';
import { aggregate } from '@directus/sdk';
import { CommunicationService } from '../../logic/communication.js';

let sellerId = Astro.cookies.get('seller_session')?.value || '1';
let pendingOrdersCount = 0;
let myClientsCount = 0;
let unreadMessages = 0;

let isCajero = false;
let isCeo = false;

try {
    const sellerInfo = await directus.request(readItems('vendedores', {
        filter: { id: { _eq: parseInt(sellerId) } },
        fields: ['email', 'role']
    }));
    if (sellerInfo && sellerInfo[0]) {
        if (sellerInfo[0].email === 'fernando@alvarezplacas.com.ar' || sellerInfo[0].role === 'cajero') {
            isCajero = true;
        } else if (sellerInfo[0].email === 'guillermo@alvarezplacas.com.ar' || sellerInfo[0].role === 'ceo') {
            isCeo = true;
        }
    }

    if (!isCajero) {
        const [ordersRes, clientsRes] = await Promise.all([
            directus.request(aggregate('pedidos', {
                aggregate: { count: '*' },
                query: { filter: { vendedor_id: { _eq: sellerId }, status: { _neq: 'entregado' } } }
            })),
            directus.request(aggregate('clientes', {
                aggregate: { count: '*' },
                query: { filter: { vendedor_id: { _eq: sellerId } } }
            }))
        ]);
        pendingOrdersCount = parseInt((ordersRes as any)[0]?.count || '0');
        myClientsCount = parseInt((clientsRes as any)[0]?.count || '0');
    }
    unreadMessages = await CommunicationService.getUnreadCount(sellerId);
} catch (e: any) {
    console.error("Error loading seller stats:", e.message);
}

const now = new Date();
const hour = now.getHours();
const greeting = hour < 12 ? 'Buenos días' : hour < 18 ? 'Buenas tardes' : 'Buenas noches';
---

{isCajero && (
    <div style="position:fixed; top:0; left:0; width:100vw; height:100vh; background:#111; z-index:99999; display:flex; justify-content:center; align-items:center; color:white; font-family:sans-serif;">
        Cargando entorno de Caja...
    </div>
    <script is:inline>window.location.replace('/vendedor/caja');</script>
)}

{isCeo && (
    <div style="position:fixed; top:0; left:0; width:100vw; height:100vh; background:#111; z-index:99999; display:flex; justify-content:center; align-items:center; color:white; font-family:sans-serif;">
        Cargando entorno de CEO...
    </div>
    <script is:inline>window.location.replace('/ceo');</script>
)}

<VendedorWorkspace title="Operaciones Diarias" vendedor_id={sellerId}>
    <!-- GREETING -->
    <div class="dash-greeting">
        <div>
            <p class="greeting-sub">{greeting} —</p>
            <h2 class="dash-title">Panel de <span class="title-accent">Ventas</span></h2>
            <p class="dash-desc">Centro de operaciones del vendedor. Usá el panel izquierdo para navegar.</p>
        </div>
        <div class="dash-date">
            <p class="date-day">{now.toLocaleDateString('es-AR', { weekday: 'long' })}</p>
            <p class="date-full">{now.toLocaleDateString('es-AR', { day: '2-digit', month: 'long', year: 'numeric' })}</p>
        </div>
    </div>

    <!-- STAT CARDS -->
    <div class="stats-grid">
        <button class="stat-card stat-card--blue" onclick="workspaceLoadView('pedidos')">
            <div class="stat-icon-wrap stat-icon-wrap--blue">
                <i class="fas fa-clipboard-list"></i>
            </div>
            <div class="stat-body">
                <p class="stat-label">Pedidos Activos</p>
                <p class="stat-value">{pendingOrdersCount}</p>
            </div>
            <i class="fas fa-arrow-right stat-arrow"></i>
        </button>

        <button class="stat-card stat-card--green" onclick="workspaceLoadView('clientes')">
            <div class="stat-icon-wrap stat-icon-wrap--green">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-body">
                <p class="stat-label">Mis Clientes</p>
                <p class="stat-value">{myClientsCount}</p>
            </div>
            <i class="fas fa-arrow-right stat-arrow"></i>
        </button>

        <button class={`stat-card ${unreadMessages > 0 ? 'stat-card--red' : 'stat-card--gray'}`} onclick="workspaceLoadView('mensajes')">
            <div class={`stat-icon-wrap ${unreadMessages > 0 ? 'stat-icon-wrap--red' : 'stat-icon-wrap--gray'}`}>
                <i class={`fas fa-comments ${unreadMessages > 0 ? 'fa-beat' : ''}`}></i>
            </div>
            <div class="stat-body">
                <p class="stat-label">Mensajes Nuevos</p>
                <p class="stat-value">{unreadMessages}</p>
            </div>
            <i class="fas fa-arrow-right stat-arrow"></i>
        </button>
    </div>

    <!-- QUICK ACCESS TOOLS -->
    <div class="tools-section">
        <p class="tools-label">Acceso Rápido a Herramientas</p>
        <div class="app-grid">
            <button class="app-btn" onclick="workspaceLoadView('pedidos')">
                <div class="app-icon" style="background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff; box-shadow: 0 4px 12px rgba(37,99,235,0.3);"><i class="fas fa-shipping-fast"></i></div>
                <div class="app-label">Pedidos</div>
            </button>

            <button class="app-btn" onclick="workspaceLoadView('clientes')">
                <div class="app-icon" style="background: linear-gradient(135deg, #16a34a, #15803d); color: #fff; box-shadow: 0 4px 12px rgba(22,163,74,0.3);"><i class="fas fa-id-card"></i></div>
                <div class="app-label">Cartera</div>
            </button>

            <button class="app-btn" onclick="workspaceLoadView('mensajes')">
                <div class="app-icon" style="background: linear-gradient(135deg, #9333ea, #7e22ce); color: #fff; box-shadow: 0 4px 12px rgba(147,51,234,0.3);"><i class="fas fa-comments"></i></div>
                <div class="app-label">Chat Planta</div>
            </button>

            <button class="app-btn" onclick="workspaceLoadView('buscador')">
                <div class="app-icon" style="background: linear-gradient(135deg, #dc2626, #b91c1c); color: #fff; box-shadow: 0 4px 12px rgba(220,38,38,0.3);"><i class="fas fa-file-invoice"></i></div>
                <div class="app-label">Facturas</div>
            </button>

            <button class="app-btn" onclick="window.location.href='/vendedor/monitoreo'">
                <div class="app-icon" style="background: linear-gradient(135deg, #059669, #047857); color: #fff; box-shadow: 0 4px 12px rgba(5,150,105,0.3);"><i class="fas fa-industry"></i></div>
                <div class="app-label">Planta</div>
            </button>

            <button class="app-btn" onclick="workspaceLoadView('agenda')">
                <div class="app-icon" style="background: linear-gradient(135deg, #ea580c, #c2410c); color: #fff; box-shadow: 0 4px 12px rgba(234,88,12,0.3);"><i class="fas fa-calendar-alt"></i></div>
                <div class="app-label">Agenda</div>
            </button>
        </div>
    </div>
</VendedorWorkspace>

<style>
    /* GREETING */
    .dash-greeting { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 24px; }
    .greeting-sub { font-size: 11px; color: #555; text-transform: uppercase; letter-spacing: .1em; margin-bottom: 4px; }
    .dash-title { font-size: 26px; font-weight: 900; color: #fff; text-transform: uppercase; letter-spacing: -.5px; }
    .title-accent { color: #3b82f6; font-style: italic; }
    .dash-desc { font-size: 12px; color: #555; margin-top: 6px; }
    .dash-date { text-align: right; }
    .date-day { font-size: 11px; color: #555; text-transform: capitalize; }
    .date-full { font-size: 12px; color: #777; font-weight: 500; margin-top: 2px; }

    /* STATS */
    .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 24px; }
    .stat-card {
        background: #1a1a1a; border: 1px solid #2a2a2a;
        border-radius: 14px; padding: 16px 18px;
        display: flex; align-items: center; gap: 14px;
        cursor: pointer; transition: all .2s;
        text-align: left; width: 100%;
    }
    .stat-card:hover { border-color: #3a3a3a; transform: translateY(-1px); box-shadow: 0 4px 20px rgba(0,0,0,.4); }
    .stat-card--blue:hover { border-color: rgba(59,130,246,.3); }
    .stat-card--green:hover { border-color: rgba(34,197,94,.3); }
    .stat-card--red:hover { border-color: rgba(239,68,68,.3); }
    .stat-icon-wrap { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
    .stat-icon-wrap--blue { background: rgba(59,130,246,.1); color: #3b82f6; }
    .stat-icon-wrap--green { background: rgba(34,197,94,.1); color: #22c55e; }
    .stat-icon-wrap--red { background: rgba(239,68,68,.1); color: #ef4444; }
    .stat-icon-wrap--gray { background: rgba(255,255,255,.05); color: #555; }
    .stat-body { flex: 1; }
    .stat-label { font-size: 10px; color: #555; text-transform: uppercase; letter-spacing: .08em; font-weight: 700; }
    .stat-value { font-size: 28px; font-weight: 900; color: #fff; line-height: 1.1; }
    .stat-arrow { color: #333; font-size: 11px; transition: transform .2s, color .2s; }
    .stat-card:hover .stat-arrow { transform: translateX(3px); color: #666; }

    /* TOOLS (Android App Style) */
    .tools-section { margin-top: 4px; }
    .tools-label { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; color: #444; margin-bottom: 12px; }
    
    .app-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(85px, 1fr)); gap: 20px 10px; justify-items: center; margin-top: 15px; }
    .app-btn {
        background: transparent; border: none; padding: 0;
        display: flex; flex-direction: column; align-items: center; gap: 8px;
        cursor: pointer; transition: all .2s cubic-bezier(0.4, 0, 0.2, 1);
        width: 100%;
    }
    .app-btn:hover { transform: translateY(-4px) scale(1.05); }
    .app-btn:active { transform: scale(0.95); }
    
    .app-icon { 
        width: 60px; height: 60px; border-radius: 16px; /* Squircle effect */
        display: flex; align-items: center; justify-content: center; 
        font-size: 24px; 
        border: 1px solid rgba(255,255,255,0.1);
        transition: all .3s ease;
        position: relative;
    }
    .app-icon::after {
        content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
        border-radius: inherit;
        background: linear-gradient(180deg, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 100%);
        pointer-events: none;
    }
    .app-btn:hover .app-icon {
        box-shadow: 0 8px 25px rgba(0,0,0,0.5);
    }
    .app-label { 
        font-size: 11px; font-weight: 500; color: #ccc; line-height: 1.2; text-align: center;
        text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    }
</style>
