---
/**
 * CatalogGrid.astro - Estructura de Alto Nivel para Catálogo Modular.
 * Diseño: Agente 4 (Frontend/Arquitectura).
 */
import fs from 'node:fs';
import path from 'node:path';
import CatalogItem from './components/CatalogItem.astro';
import CatalogFilters from './components/CatalogFilters.astro';
import { directus, readItems } from '@conexiones/directus.js';

// --- CONFIGURACIÓN DE IDENTIDAD ---
const LOGO_ID = "76aefcd2-775b-48c7-a64c-4ebd5627557c";
const FALLBACK_URL = `https://admin.alvarezplacas.com.ar/assets/${LOGO_ID}?access_token=alvarez-api-token-v16-2026`;

// --- GESTIÓN DE ESTADO ---
let catalogItems = [];
let officialBrands = [];
let showPrices = true;

/**
 * SERVICIO DE MEDIA (SSR):
 * Determina la mejor fuente para la imagen de un producto.
 * Prioridad: 1. Disco Local (si es válido) -> 2. Directus por SKU -> 3. Logo Fallback
 */
const resolveProductImage = (sku) => {
    if (!sku || sku === "-") return FALLBACK_URL;

    const fileName = `${sku}.avif`;
    const localRelativePath = `/images/catalog/Processed/${fileName}`;
    const localAbsolutePath = path.join(process.cwd(), 'public', 'images', 'catalog', 'Processed', fileName);

    try {
        if (fs.existsSync(localAbsolutePath)) {
            const stats = fs.statSync(localAbsolutePath);
            // Si el archivo pesa menos de 1KB, es un error (corrupción detectada en auditoría)
            if (stats.size > 1024) {
                return localRelativePath;
            }
        }
    } catch (e) {
        console.error(`[MediaService] Error validando ${sku}:`, e.message);
    }

    // Fallback: Si no está en disco o está corrupto, usamos el logo por ahora.
    // Nota: En el futuro aquí se podría buscar dinámicamente en el bucket de S3 de Directus.
    return FALLBACK_URL;
};

/**
 * NORMALIZACIÓN DE MARCAS
 */
const normalizeBrand = (brand) => {
    if (!brand) return "GENÉRICA";
    return brand.toString().trim().toUpperCase();
};

try {
    // CARGA DE DATOS MAESTROS
    const [settings, materials, brands] = await Promise.all([
        directus.request(readItems('site_settings', { filter: { key: { _eq: 'show_prices' } }, limit: 1 })).catch(() => []),
        directus.request(readItems('Productos', { 
            limit: 1000, 
            fields: ['id','nombre','sku','modelo','espesor','soporte','marca.nombre','rubro.letra','rubro.nombre'] 
        })).catch(() => []),
        directus.request(readItems('marcas', { limit: 100, fields: ['id', 'nombre'], sort: ['nombre'] })).catch(() => [])
    ]);

    officialBrands = (brands?.data || brands || []).map(b => normalizeBrand(b.nombre));
    if (settings?.length > 0) showPrices = settings[0].value !== 'false';

    const rawProducts = materials?.data || materials || [];
    
    if (rawProducts.length > 0) {
        const grouped = new Map();
        const standalone = [];

        rawProducts.forEach((p) => {
            const brand = normalizeBrand(p.marca?.nombre);
            const category = p.rubro?.nombre || "Varios";
            const letra = p.rubro?.letra || "X";
            
            // Clasificación por Bucket
            let bucket = "Herrajes";
            if (letra === 'R') bucket = "Herramientas";
            else if (letra === 'M') bucket = "Tableros";
            else if (letra === 'I') bucket = "Química";

            // Lógica de Agrupación para Placas (M)
            if (bucket === "Tableros" && p.modelo) {
                const key = `${brand}_${p.modelo}`.toLowerCase();
                if (!grouped.has(key)) {
                    // Limpieza de nombre (quitar espesor si está en el título)
                    let cleanName = p.nombre;
                    if (p.espesor) {
                        const esp = parseFloat(p.espesor).toString();
                        cleanName = p.nombre.replace(new RegExp(esp + "\\s*mm.*", "i"), "").trim();
                    }

                    grouped.set(key, {
                        id: p.id,
                        name: cleanName,
                        code: p.sku || "-",
                        brand: brand,
                        category: category,
                        bucket: bucket,
                        imagen: resolveProductImage(p.sku),
                        variants: [],
                        price: "Consultar"
                    });
                }
                const item = grouped.get(key);
                item.variants.push({
                    sku: p.sku,
                    espesor: p.espesor ? `${parseFloat(p.espesor)}mm` : "S/E",
                    soporte: p.soporte || "Estandar"
                });
            } else {
                standalone.push({
                    id: p.id,
                    name: p.nombre,
                    code: p.sku || "-",
                    brand: brand,
                    category: category,
                    bucket: bucket,
                    imagen: resolveProductImage(p.sku),
                    specs: [p.espesor ? `${parseFloat(p.espesor)}mm` : null, p.soporte].filter(Boolean)
                });
            }
        });

        // Ordenar variantes por espesor
        grouped.forEach(item => {
            item.variants.sort((a,b) => parseFloat(a.espesor) - parseFloat(b.espesor));
            item.specs = [`${item.variants.length} variantes disponibles`];
        });

        catalogItems = [...grouped.values(), ...standalone];
    }
} catch (error) {
    console.error("[CatalogGrid] Error Crítico de Carga:", error);
}

// FILTROS
const buckets = ["Tableros", "Herrajes", "Herramientas", "Química", "Todo"];
const uniqueBrands = [...new Set(officialBrands)].sort();
const brandsByBucket = {};
buckets.forEach(b => {
    if (b === "Todo") brandsByBucket[b] = uniqueBrands;
    else {
        const activeBrands = catalogItems.filter(i => i.bucket === b).map(i => i.brand);
        brandsByBucket[b] = uniqueBrands.filter(ub => activeBrands.includes(ub));
    }
});
---

<section class="max-w-7xl mx-auto px-4 py-12">
  <div class="text-center mb-12">
    <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">Catálogo <span class="text-primary">Alvarez Placas</span></h1>
    <p class="text-gray-400">Encontrá entre <span class="text-white font-bold">{catalogItems.length}</span> diseños y productos exclusivos.</p>
  </div>

  <CatalogFilters 
    buckets={buckets} 
    brandsByBucket={brandsByBucket} 
    allUniqueBrands={uniqueBrands} 
    totalProducts={catalogItems.length} 
  />

  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6 mt-10" id="catalogGrid">
    {catalogItems.map(item => (
      <CatalogItem placa={item} showPrices={showPrices} />
    ))}
  </div>

  {catalogItems.length === 0 && (
    <div class="text-center py-20 bg-[#151515] rounded-3xl border border-dashed border-gray-800">
      <i class="fas fa-box-open text-5xl text-gray-700 mb-4"></i>
      <h3 class="text-xl text-white">Sincronizando productos... por favor reintentá en un momento.</h3>
    </div>
  )}

  <!-- Modal Estructural -->
  <div id="productModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 opacity-0 transition-all duration-300">
    <div class="absolute inset-0 bg-black/90 backdrop-blur-md modal-backdrop close-modal"></div>
    <div class="bg-[#1a1a1a] rounded-2xl overflow-hidden shadow-2xl w-full max-w-5xl relative z-10 flex flex-col md:row max-h-[90vh] transform scale-95 transition-all duration-300" id="modalCard">
      <button class="absolute top-4 right-4 z-30 p-2 bg-black/50 hover:bg-primary text-white rounded-full close-modal">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M6 18L18 6M6 6l12 12" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      
      <div class="w-full md:w-3/5 bg-[#0a0a0a] relative min-h-[300px]">
        <img id="modalImage" src="" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute top-4 left-4"><span id="modalMarcaBadge" class="bg-primary text-black text-[10px] font-bold px-3 py-1 rounded uppercase tracking-tighter"></span></div>
      </div>

      <div class="w-full md:w-2/5 p-8 flex flex-col bg-[#1a1a1a] border-l border-gray-800 overflow-y-auto">
        <div class="mb-8">
            <h2 id="modalNombre" class="text-2xl font-bold text-white mb-1"></h2>
            <p id="modalCategory" class="text-primary text-[10px] font-bold uppercase tracking-widest"></p>
        </div>
        <div id="modalSpecsContainer" class="space-y-4 mb-8"></div>
        <div class="mt-auto">
            <a id="modalWhatsAppBtn" href="#" target="_blank" class="w-full bg-[#25D366] text-white font-bold py-4 rounded-xl flex items-center justify-center gap-2 hover:bg-[#1ebd5a] transition-colors">
                <i class="fab fa-whatsapp"></i> Consultar Disponibilidad
            </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initCatalog } from './logic/catalog-logic.js';
  document.addEventListener('astro:page-load', initCatalog);
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initCatalog);
  else initCatalog();
</script>
