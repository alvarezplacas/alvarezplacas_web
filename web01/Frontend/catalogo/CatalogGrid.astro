---
/**
 * CatalogGrid.astro - Estructura de Alto Nivel para Catálogo Modular.
 * Diseño: Agente 4 (Frontend/Arquitectura).
 */
import fs from 'node:fs';
import path from 'node:path';
import CatalogItem from './components/CatalogItem.astro';
import CatalogFilters from './components/CatalogFilters.astro';
import { directus, readItems } from '@conexiones/directus.js';

// --- CONFIGURACIÓN DE IDENTIDAD ---
const LOGO_ID = "209a486b-8623-4c3e-8f8e-2a3288f1f0fd";
const FALLBACK_URL = `https://admin.alvarezplacas.com.ar/assets/${LOGO_ID}`;

// --- GESTIÓN DE ESTADO ---
let catalogItems = [];
let officialBrands = [];
let showPrices = true;

/**
 * SERVICIO DE MEDIA (SSR):
 * Determina la mejor fuente para la imagen de un producto.
 * Prioridad: 1. Disco Local -> 2. Directus Assets -> 3. Logo Fallback
 */
const resolveProductImage = (sku, directusFileId) => {
    if (directusFileId) {
        return `https://admin.alvarezplacas.com.ar/assets/${directusFileId}?width=400&height=400&fit=cover&format=avif`;
    }

    if (!sku || sku === "-") return FALLBACK_URL;

    const fileName = `${sku}.avif`;
    const localRelativePath = `/images/catalog/Processed/${fileName}`;
    const localAbsolutePath = path.join(process.cwd(), 'public', 'images', 'catalog', 'Processed', fileName);

    try {
        if (fs.existsSync(localAbsolutePath)) {
            const stats = fs.statSync(localAbsolutePath);
            if (stats.size > 1024) return localRelativePath;
        }
    } catch (e) {}

    return FALLBACK_URL;
};

/**
 * NORMALIZACIÓN DE MARCAS
 */
const normalizeBrand = (brand) => {
    if (!brand) return "GENÉRICA";
    return brand.toString().trim().toUpperCase();
};

try {
    // CARGA DE DATOS MAESTROS
    const [settings, materials, brands] = await Promise.all([
        directus.request(readItems('site_settings', { filter: { key: { _eq: 'show_prices' } }, limit: 1 })).catch(() => []),
        directus.request(readItems('Productos', { 
            limit: 1000, 
            fields: ['id','nombre','sku','modelo','espesor','soporte','marca.nombre','rubro.letra','rubro.nombre','foto_principal'] 
        })).catch(() => []),
        directus.request(readItems('marcas', { limit: 100, fields: ['id', 'nombre'], sort: ['nombre'] })).catch(() => [])
    ]);

    officialBrands = (brands?.data || brands || []).map(b => normalizeBrand(b.nombre));
    if (settings?.length > 0) showPrices = settings[0].value !== 'false';

    const rawProducts = materials?.data || materials || [];
    
    if (rawProducts.length > 0) {
        const grouped = new Map();
        const standalone = [];

        rawProducts.forEach((p) => {
            const brand = normalizeBrand(p.marca?.nombre);
            const category = p.rubro?.nombre || "Varios";
            const letra = p.rubro?.letra || "X";
            
            // Clasificación por Bucket (Categoría Principal)
            let bucket = "Varios";
            if (letra === 'M') bucket = "Tableros";
            else if (letra === 'H') bucket = "Herrajes";
            else if (letra === 'I') bucket = "Química";
            else if (letra === 'S') bucket = "Servicios";
            else if (letra === 'T') bucket = "Tapacantos";
            else if (letra === 'R') bucket = "Herramientas";
            else if (letra === 'D') bucket = "Molduras";

            // Lógica de Agrupación para Placas (M)
            if (bucket === "Tableros" && p.modelo) {
                const key = `${brand}_${p.modelo}`.toLowerCase();
                if (!grouped.has(key)) {
                    // Limpieza de nombre (quitar espesor si está en el título)
                    let cleanName = p.nombre;
                    if (p.espesor) {
                        const esp = parseFloat(p.espesor).toString();
                        cleanName = p.nombre.replace(new RegExp(esp + "\\s*mm.*", "i"), "").trim();
                    }

                    const itemSku = (p.sku || "").toUpperCase();
                    let directusId = p.foto_principal;

                    grouped.set(key, {
                        id: p.id,
                        name: cleanName,
                        code: p.sku || "-",
                        brand: brand,
                        category: category,
                        bucket: bucket,
                        imagen: resolveProductImage(p.sku, directusId),
                        variants: [],
                        price: "Consultar"
                    });
                }
                const item = grouped.get(key);
                item.variants.push({
                    sku: p.sku,
                    espesor: p.espesor ? `${parseFloat(p.espesor)}mm` : "S/E",
                    soporte: p.soporte || "Estandar"
                });
            } else {
                const itemSku = (p.sku || "").toUpperCase();
                let directusId = p.foto_principal;

                standalone.push({
                    id: p.id,
                    name: p.nombre,
                    code: p.sku || "-",
                    brand: brand,
                    category: category,
                    bucket: bucket,
                    imagen: resolveProductImage(p.sku, directusId),
                    specs: [p.espesor ? `${parseFloat(p.espesor)}mm` : null, p.soporte].filter(Boolean)
                });
            }
        });

        // Ordenar variantes por espesor
        grouped.forEach(item => {
            item.variants.sort((a,b) => parseFloat(a.espesor) - parseFloat(b.espesor));
            item.specs = [`${item.variants.length} variantes disponibles`];
        });

        catalogItems = [...grouped.values(), ...standalone];
    }
} catch (error) {
    console.error("[CatalogGrid] Error Crítico de Carga:", error);
}

// FILTROS
const buckets = ["Tableros", "Herrajes", "Herramientas", "Química", "Todo"];
const uniqueBrands = [...new Set(officialBrands)].sort();
const brandsByBucket = {};
buckets.forEach(b => {
    if (b === "Todo") brandsByBucket[b] = uniqueBrands;
    else {
        const activeBrands = catalogItems.filter(i => i.bucket === b).map(i => i.brand);
        brandsByBucket[b] = uniqueBrands.filter(ub => activeBrands.includes(ub));
    }
});
---

<section class="max-w-7xl mx-auto px-4 py-12">
  <div class="text-center mb-12">
    <h1 class="text-3xl md:text-5xl font-bold text-white mb-4">Catálogo <span class="text-primary">Alvarez Placas</span></h1>
    <p class="text-gray-400">Encontrá entre <span class="text-white font-bold">{catalogItems.length}</span> diseños y productos exclusivos.</p>
  </div>

  <CatalogFilters 
    buckets={buckets} 
    brandsByBucket={brandsByBucket} 
    allUniqueBrands={uniqueBrands} 
    totalProducts={catalogItems.length}
  />

  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6 mt-10" id="catalogGrid">
    {catalogItems.map(item => (
      <CatalogItem placa={item} showPrices={showPrices} />
    ))}
  </div>

  {catalogItems.length === 0 && (
    <div class="text-center py-20 bg-[#151515] rounded-3xl border border-dashed border-gray-800">
      <i class="fas fa-box-open text-5xl text-gray-700 mb-4"></i>
      <h3 class="text-xl text-white">Sincronizando productos... por favor reintentá en un momento.</h3>
    </div>
  )}

  <!-- Modal Estructural Rediseñado -->
  <div id="productModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 opacity-0 transition-all duration-300">
    <div class="absolute inset-0 bg-black/95 backdrop-blur-xl modal-backdrop close-modal"></div>
    
    <div class="bg-[#111111] rounded-3xl overflow-hidden shadow-[0_0_50px_rgba(0,0,0,0.5)] w-full max-w-5xl relative z-10 flex flex-col md:flex-row max-h-[90vh] md:h-[600px] transform scale-95 transition-all duration-300 border border-white/5" id="modalCard">
      
      <!-- Botón Cerrar Flotante -->
      <button class="absolute top-6 right-6 z-50 p-2.5 bg-black/40 hover:bg-primary text-white rounded-full close-modal transition-all border border-white/10 group">
        <svg class="w-5 h-5 group-hover:rotate-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M6 18L18 6M6 6l12 12" stroke-width="2.5" stroke-linecap="round"/></svg>
      </button>
      
      <!-- LADO IZQUIERDO: IMAGEN FULL -->
      <div class="w-full md:w-1/2 bg-[#0a0a0a] relative overflow-hidden group/img">
        <img id="modalImage" src="" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover/img:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
        <div class="absolute bottom-8 left-8">
            <span id="modalMarcaBadge" class="bg-primary text-black text-[9px] font-black px-3 py-1 rounded-full uppercase tracking-widest shadow-2xl mb-2 inline-block"></span>
            <h2 id="modalNombre" class="text-3xl font-black text-white leading-tight uppercase italic"></h2>
        </div>
      </div>

      <!-- LADO DERECHO: DETALLES Y SELECTORES -->
      <div class="w-full md:w-1/2 p-10 flex flex-col bg-[#111111] overflow-y-auto custom-scrollbar">
        <div class="mb-8">
            <p id="modalCategory" class="text-primary text-[10px] font-black uppercase tracking-[0.2em] mb-6 border-b border-primary/20 pb-2 inline-block"></p>
            
            <!-- Contenedor Dinámico -->
            <div id="modalSpecsContainer" class="space-y-8">
                <!-- Aquí se inyectan los selectores por JS -->
            </div>
        </div>

        <div class="mt-auto pt-8 border-t border-white/5 flex flex-col gap-3">
            <!-- Smart Match Button -->
            <button id="modalSmartMatchBtn" class="w-full bg-white/5 hover:bg-white/10 text-white border border-white/10 font-black text-sm uppercase py-5 rounded-2xl hidden items-center justify-center gap-3 transition-all hover:border-primary/40 group">
                <svg class="w-5 h-5 text-primary group-hover:animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                Ver Combinación Smart Match
            </button>

            <!-- WhatsApp Button -->
            <a id="modalWhatsAppBtn" href="#" target="_blank" class="w-full bg-[#25D366] text-white font-black text-sm uppercase py-5 rounded-2xl flex items-center justify-center gap-3 hover:bg-[#1ebd5a] transition-all hover:shadow-[0_10px_20px_rgba(37,211,102,0.2)]">
                <i class="fab fa-whatsapp text-lg"></i> Consultar Disponibilidad
            </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .custom-scrollbar::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #FF4D00; }
</style>

<script>
  import { initCatalog } from './logic/catalog-logic.js';
  document.addEventListener('astro:page-load', initCatalog);
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initCatalog);
  else initCatalog();
</script>
