---
/**
 * CatalogItem.astro - Tarjeta de producto individual.
 * Optimizado: Recibe la imagen ya verificada desde el servidor.
 */
const { placa, fallbackUrl } = Astro.props;
const isFallback = placa.imagen === fallbackUrl;
---

<div 
  class="catalog-item group flex flex-col bg-[#111111] rounded-2xl overflow-hidden border border-gray-800/50 transition-all duration-500 hover:border-primary/50 hover:shadow-2xl hover:shadow-primary/10 cursor-pointer h-full relative"
  data-bucket={placa.bucket}
  data-brand={placa.brand}
  data-search={`${placa.name} ${placa.brand} ${placa.category} ${placa.code}`.toLowerCase()}
  data-full={JSON.stringify(placa)}
>
  <div class="absolute top-4 left-4 z-10">
    <span class={`text-[10px] font-bold px-2.5 py-1 rounded uppercase tracking-wider shadow-lg backdrop-blur-md ${
      placa.bucket === "Tableros" ? 'bg-primary/90 text-black' : 
      (placa.bucket === "Herramientas" ? 'bg-red-500/90 text-white' : 'bg-blue-500/90 text-white')
    }`}>
      {placa.bucket}
    </span>
  </div>

  <div class="aspect-square overflow-hidden bg-[#0a0a0a] relative">
    <img 
      src={placa.imagen} 
      alt={placa.name}
      class={`w-full h-full transition-transform duration-700 group-hover:scale-110 ${isFallback ? 'object-contain p-12 bg-[#1a1a1a]' : 'object-cover'}`}
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-40"></div>
  </div>

  <div class="p-5 flex flex-col flex-grow">
    <div class="mb-3">
      <p class="text-primary text-[10px] font-bold uppercase tracking-widest mb-1">{placa.brand}</p>
      <h3 class="text-white font-bold text-sm leading-tight group-hover:text-primary transition-colors line-clamp-2 min-h-[2.5rem]" title={placa.name}>
        {placa.name}
      </h3>
    </div>

    <div class="mt-auto pt-4 border-t border-gray-800/50">
      <div class="flex flex-wrap gap-1.5 mb-4">
        {placa.specs && placa.specs.map(spec => (
          <span class="bg-gray-800/80 text-gray-400 text-[9px] px-2 py-0.5 rounded border border-gray-700 uppercase tracking-tighter font-medium">
            {spec}
          </span>
        ))}
      </div>

      <div class="flex items-center justify-between">
        <span class="text-xs text-gray-500 font-mono tracking-tighter">{placa.code}</span>
        <button class="bg-primary/10 text-primary hover:bg-primary hover:text-black p-2 rounded-lg transition-all duration-300">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        </button>
      </div>
    </div>
  </div>
</div>
