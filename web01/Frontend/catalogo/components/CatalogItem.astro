---
/**
 * CatalogItem.astro - Componente Atómico de Producto.
 */
const { placa } = Astro.props;

// Identificamos si estamos usando el logo de fallback (para ajustar el estilo)
const isFallback = placa.imagen.includes('assets/76aefcd2');
---

<div 
  class="catalog-item group flex flex-col bg-[#111111] rounded-2xl overflow-hidden border border-gray-800/50 transition-all duration-500 hover:border-primary/50 hover:shadow-2xl hover:shadow-primary/10 cursor-pointer h-full relative"
  data-bucket={placa.bucket}
  data-brand={placa.brand}
  data-search={`${placa.name} ${placa.brand} ${placa.category} ${placa.code}`.toLowerCase()}
  data-full={JSON.stringify(placa)}
>
  <!-- Categoría Badge -->
  <div class="absolute top-4 left-4 z-10">
    <span class={`text-[9px] font-bold px-2 py-0.5 rounded uppercase tracking-tighter shadow-lg ${
      placa.bucket === "Tableros" ? 'bg-primary text-black' : 'bg-gray-700 text-white'
    }`}>
      {placa.bucket}
    </span>
  </div>

  <!-- Contenedor de Imagen -->
  <div class="aspect-square overflow-hidden bg-[#0a0a0a] relative">
    <img 
      src={placa.imagen} 
      alt={placa.name}
      loading="lazy"
      class={`w-full h-full transition-transform duration-700 group-hover:scale-105 ${
        isFallback ? 'object-contain p-12 bg-[#1a1a1a]' : 'object-cover'
      }`}
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-40"></div>
  </div>

  <!-- Detalles -->
  <div class="p-5 flex flex-col flex-grow">
    <div class="mb-4">
      <p class="text-primary text-[10px] font-bold uppercase tracking-widest mb-1">{placa.brand}</p>
      <h3 class="text-white font-bold text-sm leading-snug group-hover:text-primary transition-colors line-clamp-2 min-h-[2.5rem]">
        {placa.name}
      </h3>
    </div>

    <div class="mt-auto pt-4 border-t border-gray-800/40">
      <div class="flex flex-wrap gap-1.5 mb-4">
        {placa.specs && placa.specs.map(spec => (
          <span class="bg-gray-900 text-gray-500 text-[8px] px-1.5 py-0.5 rounded uppercase font-medium">
            {spec}
          </span>
        ))}
      </div>

      <div class="flex items-center justify-between">
        <span class="text-[10px] text-gray-600 font-mono">{placa.code}</span>
        <div class="flex gap-2">
            <button class="bg-[#25D366]/10 text-[#25D366] p-2 rounded-lg hover:bg-[#25D366] hover:text-white transition-all">
                <i class="fab fa-whatsapp text-xs"></i>
            </button>
        </div>
      </div>
    </div>
  </div>
</div>
