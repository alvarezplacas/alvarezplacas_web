---
/**
 * CatalogFilters - Barra de búsqueda y selectores de filtros.
 * Propiedad del Agente 4 (Frontend/Catalogo).
 */
const { buckets, brandsByBucket, allUniqueBrands = [], totalProducts = 0, backgrounds = {} } = Astro.props;
---

<div class="mb-10 flex flex-col items-center gap-6 relative">
  <p class="text-gray-400 text-sm relative z-10">
    Buscá entre <span class="text-white font-bold text-lg">{totalProducts}</span> productos específicos
  </p>
  
  <!-- Filtros de Grupos (Buckets) -->
  <div class="flex flex-wrap justify-center gap-3 mb-2 relative z-10" id="bucketFilters">
    {buckets.map((bucket) => (
      <button
        class={`px-6 py-3 rounded-xl border text-sm font-bold uppercase tracking-wider transition-all duration-300 ${
          bucket === "Todo" 
            ? 'bg-primary text-black border-primary bucket-btn active' 
            : 'bg-[#151515] text-gray-400 border-gray-800 hover:border-primary/50 hover:text-white bucket-btn'
        }`}
        data-bucket={bucket}
      >
        {bucket === "Todo" ? "🌐 Todos" : bucket}
      </button>
    ))}
  </div>

  <div class="relative w-full max-w-2xl z-10">
    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
      <i class="fas fa-search text-primary"></i>
    </div>
    <input
      type="search"
      id="catalogSearch"
      placeholder="Buscar en esta categoría (Ej: Gola, Egger Blanco, Einhell...)"
      class="w-full bg-[#151515] border border-gray-800/50 text-white rounded-2xl py-5 pl-12 pr-6 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all duration-300 placeholder-gray-600 shadow-2xl text-lg"
    />
  </div>

  <!-- Filtros de Marca Secundarios (Dinámicos) -->
  <div class="flex flex-wrap justify-center gap-2 max-w-4xl py-2" id="brandFilters">
    <button
      class="px-5 py-2 rounded-xl border text-xs font-bold uppercase tracking-wider transition-all duration-300 bg-gray-800 text-white border-gray-600 shadow-lg brand-btn active"
      data-filter="Todos"
    >
      Todas las Marcas
    </button>
    {allUniqueBrands.map(marca => (
      <button
        class="px-5 py-2 rounded-xl border text-xs font-bold uppercase tracking-wider transition-all duration-300 bg-[#151515] text-gray-500 border-gray-800 hover:border-primary/50 hover:text-white brand-btn hidden"
        data-filter={marca}
      >
        {marca}
      </button>
    ))}
  </div>
</div>

<script define:vars={{ brandsByBucket }}>
  window.BRANDS_BY_BUCKET = brandsByBucket;

  // Mejora de UX Móvil: Cerrar teclado al presionar Enter (Reforzado para Android)
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('catalogSearch');
    if (searchInput) {
      searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.keyCode === 13) {
          searchInput.blur(); // Esto oculta el teclado en móviles
          window.scrollTo({ top: searchInput.offsetTop - 20, behavior: 'smooth' });
        }
      });
    }
  });
</script>
