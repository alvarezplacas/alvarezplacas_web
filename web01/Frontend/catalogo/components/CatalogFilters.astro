---
/**
 * CatalogFilters - Barra de búsqueda y selectores de filtros.
 * Propiedad del Agente 4 (Frontend/Catalogo).
 */
const { buckets, brandsByBucket, totalProducts = 0 } = Astro.props;
---

<div class="mb-10 flex flex-col items-center gap-6">
  <p class="text-gray-400 text-sm">Buscá entre más de <span class="text-white font-bold text-lg">{totalProducts || 2200}</span> productos específicos</p>
  
  <!-- Filtros de Grupos (Buckets) -->
  <div class="flex flex-wrap justify-center gap-3 mb-2" id="bucketFilters">
    {buckets.map((bucket) => (
      <button
        class={`px-6 py-3 rounded-xl border text-sm font-bold uppercase tracking-wider transition-all duration-300 ${
          bucket === "Todo" 
            ? 'bg-primary text-black border-primary bucket-btn active' 
            : 'bg-[#151515] text-gray-400 border-gray-800 hover:border-primary/50 hover:text-white bucket-btn'
        }`}
        data-bucket={bucket}
      >
        {bucket === "Todo" ? "🌐 Todos" : bucket}
      </button>
    ))}
  </div>

  <div class="relative w-full max-w-2xl">
    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
      <i class="fas fa-search text-primary"></i>
    </div>
    <input
      type="text"
      id="catalogSearch"
      placeholder="Buscar en esta categoría (Ej: Gola, Egger Blanco, Einhell...)"
      class="w-full bg-[#151515] border border-gray-800 text-white rounded-2xl py-5 pl-12 pr-6 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all duration-300 placeholder-gray-600 shadow-2xl text-lg"
    />
  </div>

  <!-- Filtros de Marca Secundarios (Dinámicos por Bucket) -->
  <div class="flex flex-wrap justify-center gap-2 overflow-x-auto max-w-full py-2 opacity-60 hover:opacity-100 transition-opacity" id="brandFilters">
    <button
      class="px-4 py-1.5 rounded-lg border text-xs font-medium whitespace-nowrap transition-all duration-300 bg-gray-800 text-white border-gray-600 brand-btn active"
      data-filter="Todos"
    >
      Todas las Marcas
    </button>
    {Object.keys(brandsByBucket).map(bucket => (
      brandsByBucket[bucket].map(marca => (
        <button
          class="px-4 py-1.5 rounded-lg border text-xs font-medium whitespace-nowrap transition-all duration-300 bg-transparent text-gray-500 border-gray-800 hover:border-gray-600 hover:text-white brand-btn hidden"
          data-filter={marca}
          data-parent-bucket={bucket}
        >
          {marca}
        </button>
      ))
    ))}
  </div>
</div>

<script define:vars={{ brandsByBucket }}>
  window.BRANDS_BY_BUCKET = brandsByBucket;
</script>
