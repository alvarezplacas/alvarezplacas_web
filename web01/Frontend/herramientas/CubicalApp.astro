---
/**
 * CubiCal PRO - El Corazón de la Herramienta
 * Versión 1.1 - Industrialización Industrial (Modo Hueso)
 */
const { clientId } = Astro.props;
const isLoggedIn = !!clientId;
---

<div id="cubical-app-root" class="cubical-container mx-auto max-w-[1600px] px-4 py-8" data-is-logged-in={isLoggedIn} data-client-id={clientId}>
    <!-- BARRA SUPERIOR -->
    <header class="flex justify-between items-center mb-12 bg-[var(--sc-surface)] border border-[var(--sc-border)] p-6 rounded-lg shadow-sm">
        <div class="flex items-center gap-6">
             <a href="/cliente" class="nav-link-sc">
                <i class="fas fa-arrow-left"></i> VOLVER AL PANEL
            </a>
            <div style="width: 1px; height: 20px; background: var(--sc-border);"></div>
            <div>
                <div class="text-[0.6rem] font-black text-[var(--alvarez-red)] tracking-[0.2em] uppercase mb-1">CubiCal PRO v1.1</div>
                <h1 class="text-3xl font-black tracking-tighter uppercase italic text-[var(--sc-text)]">CALCULADOR <span class="text-[var(--alvarez-red)]">INDUSTRIAL</span></h1>
            </div>
        </div>
        <div class="flex gap-4 items-center">
             <div id="theme-toggle" onclick="window.cubical.toggleTheme()" class="nav-link-sc" style="cursor:pointer; color: var(--sc-text-dim);">
                <i id="theme-icon" class="fas fa-moon"></i> <span id="theme-text">MODO OSCURO</span>
            </div>
            <div style="width: 1px; height: 20px; background: var(--sc-border);"></div>
            <button id="btn-save-project" class="hidden px-6 py-2 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] rounded text-xs font-black uppercase text-[var(--sc-text)] hover:bg-[var(--sc-border)] transition-all">Guardar Proyecto</button>
            <button id="btn-goto-dashboard" onclick="window.cubical.showDashboard()" class="px-6 py-2 bg-[var(--alvarez-red)] text-white rounded text-xs font-black uppercase hover:scale-105 transition-all shadow-lg">Mis Proyectos</button>
        </div>
    </header>

    <!-- PANTALLA 1: DASHBOARD -->
    <section id="screen-dashboard" class="animate-fade-in">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="md:col-span-2">
                <h2 class="text-5xl font-black mb-4 tracking-tighter text-[var(--sc-text)]">ESTACIÓN DE TRABAJO</h2>
                <div class="w-20 h-1 bg-[var(--alvarez-red)] mb-8"></div>
                <p class="text-[var(--sc-text-dim)] mb-12 max-w-xl text-lg font-medium">Gestiona tus proyectos de mobiliario a medida y obtén el despiece optimizado para producción.</p>
                
                <div id="projects-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <!-- Dinámico -->
                    <div class="bg-[var(--sc-surface-alt)] h-40 rounded-lg animate-pulse"></div>
                    <div class="bg-[var(--sc-surface-alt)] h-40 rounded-lg animate-pulse"></div>
                </div>
            </div>
            
            <div class="bg-[var(--sc-surface)] border-2 border-dashed border-[var(--sc-border)] p-12 rounded-xl flex flex-col items-center justify-center text-center">
                <div class="w-24 h-24 bg-[var(--alvarez-red)] text-white rounded-xl flex items-center justify-center mb-8 rotate-3 shadow-xl">
                    <i class="fas fa-plus text-4xl"></i>
                </div>
                <h3 class="text-2xl font-black mb-4 text-[var(--sc-text)] uppercase tracking-tighter">¿Nuevo Mueble?</h3>
                <p class="text-[var(--sc-text-dim)] text-sm mb-10 font-medium">Calcula materiales y herrajes en segundos para tu próximo cliente.</p>
                <button onclick="window.cubical.showSetup()" class="w-full py-5 bg-[var(--alvarez-red)] text-white font-black rounded-lg hover:scale-105 transition-all uppercase tracking-widest shadow-xl">NUEVO CÁLCULO</button>
            </div>
        </div>

        <!-- CATÁLOGO DE PLANTILLAS RÁPIDAS -->
        <div class="mt-16 border-t border-[var(--sc-border)] pt-12">
            <h3 class="text-3xl font-black mb-2 tracking-tighter text-[var(--sc-text)] uppercase italic">CATÁLOGO DE PLANTILLAS</h3>
            <p class="text-[var(--sc-text-dim)] mb-8 max-w-xl text-sm font-medium">Inicia tu diseño al instante seleccionando un módulo estándar preconfigurado de nuestro catálogo.</p>
            
            <div class="relative group mt-8 px-4">
                <!-- Botón Izquierda -->
                <button id="carousel-btn-left" class="absolute left-0 top-1/2 translate-y-[-50%] w-10 h-10 rounded-full bg-[var(--sc-surface)] border border-[var(--sc-border)] text-[var(--sc-text)] flex items-center justify-center hover:bg-[var(--sc-surface-alt)] hover:border-[var(--alvarez-red)] hover:text-[var(--alvarez-red)] transition-all z-10 shadow-md cursor-pointer opacity-0 group-hover:opacity-100 focus:opacity-100 transition-opacity duration-300">
                    <i class="fas fa-chevron-left"></i>
                </button>
                
                <!-- Contenedor del Carrusel -->
                <!-- Carrusel renderizado dinámicamente desde /herramientas/logic/cubical/templates/templates.js -->
                <div id="templates-carousel" class="flex overflow-x-auto gap-6 pb-6 scroll-smooth snap-x snap-mandatory scrollbar-none [&::-webkit-scrollbar]:hidden" style="scrollbar-width: none; -ms-overflow-style: none;">
                    <!-- Las tarjetas de plantillas se insertan aquí por window.cubical.renderTemplateCarousel() -->
                </div>
                
                <!-- Botón Derecha -->
                <button id="carousel-btn-right" class="absolute right-0 top-1/2 translate-y-[-50%] w-10 h-10 rounded-full bg-[var(--sc-surface)] border border-[var(--sc-border)] text-[var(--sc-text)] flex items-center justify-center hover:bg-[var(--sc-surface-alt)] hover:border-[var(--alvarez-red)] hover:text-[var(--alvarez-red)] transition-all z-10 shadow-md cursor-pointer opacity-0 group-hover:opacity-100 focus:opacity-100 transition-opacity duration-300">
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </section>

    <!-- PANTALLA 2: SETUP -->
    <section id="screen-setup" class="hidden max-w-2xl mx-auto animate-fade-in">
        <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-12 rounded-xl shadow-2xl">
            <h2 class="text-3xl font-black mb-10 tracking-tight text-center uppercase text-[var(--sc-text)]">Configuración del Proyecto</h2>
            
            <div class="space-y-8">
                <div>
                    <label class="block text-[0.65rem] font-black text-[var(--sc-text-dim)] uppercase tracking-[0.2em] mb-3">Nombre del Proyecto o Cliente</label>
                    <input type="text" id="setup-name" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-5 rounded text-[var(--sc-text)] focus:border-[var(--alvarez-red)] outline-none font-bold text-lg" placeholder="Ej: Cocina Moderna - Juan Pérez">
                </div>
                
                <div>
                    <label class="block text-[0.65rem] font-black text-[var(--sc-text-dim)] uppercase tracking-[0.2em] mb-3">Tipo de Ambiente</label>
                    <select id="setup-env" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-5 rounded text-[var(--sc-text)] focus:border-[var(--alvarez-red)] outline-none font-bold">
                        <option value="cocina">🍳 Cocina / Bajo Mesada</option>
                        <option value="dormitorio">🛏️ Dormitorio / Vestidor</option>
                        <option value="oficina">🖥️ Oficina / Estudio</option>
                        <option value="living">🛋️ Living / Comedor</option>
                        <option value="baño">🚿 Baño / Vanitory</option>
                    </select>
                </div>

                <div class="pt-8 grid grid-cols-2 gap-4">
                    <button onclick="window.cubical.startConstructor()" class="py-5 bg-[var(--alvarez-red)] text-white font-black rounded-lg hover:scale-105 transition-all uppercase tracking-widest shadow-lg">CONTINUAR</button>
                    <button onclick="window.cubical.showDashboard()" class="py-5 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] text-[var(--sc-text-dim)] font-black rounded-lg hover:text-[var(--sc-text)] transition-all uppercase tracking-widest">CANCELAR</button>
                </div>
            </div>
        </div>
    </section>

    <!-- PANTALLA 3: CONSTRUCTOR -->
    <section id="screen-constructor" class="hidden animate-fade-in">
        <!-- CARTEL INFORMATIVO BETA DE ALVAREZ PLACAS -->
        <div class="w-full mb-6 bg-amber-500/10 border border-amber-500/30 rounded-xl p-5 flex items-start gap-4 shadow-sm backdrop-blur-md">
            <div class="w-10 h-10 rounded-lg bg-amber-500/20 flex items-center justify-center text-amber-500 flex-shrink-0">
                <i class="fas fa-exclamation-triangle text-lg"></i>
            </div>
            <div class="flex-grow space-y-1">
                <div class="flex items-center gap-3 flex-wrap">
                    <span class="text-[0.6rem] font-black uppercase bg-amber-500 text-black px-2 py-0.5 rounded tracking-widest">CUBICAL 3D PRO — v1.2 BETA</span>
                    <span class="text-[0.55rem] font-black text-amber-500/90 tracking-widest uppercase">Desarrollo Exclusivo de Alvarez Placas</span>
                </div>
                <p class="text-xs text-[var(--sc-text-dim)] font-medium leading-relaxed">
                    Este software se encuentra en fase de <strong>Prueba y Desarrollo</strong>. Las comprobaciones de despieces, optimizaciones de placas y cómputos de herrajes aún pueden tener variaciones o ser estimativos. Se aconseja revisar físicamente antes del corte industrial.
                </p>
            </div>
        </div>

        <!-- VISTA DE ESCRITORIO (PHOTOSHOP 3-COLUMN WORKSPACE) & MÓVIL DUAL -->
        <div class="hidden lg:grid grid-cols-12 gap-8">
            <!-- 1. COLUMNA IZQUIERDA: HERRAMIENTAS Y CAPAS (3 COLS) -->
            <div class="col-span-3 space-y-6">
                <!-- PREAJUSTES RÁPIDOS / TOOLBOX -->
                <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-6 rounded-xl shadow-sm">
                    <h3 class="text-xs font-black text-[var(--alvarez-red)] uppercase tracking-[0.2em] mb-6 flex items-center gap-3">
                        <i class="fas fa-tools"></i> CAJA DE HERRAMIENTAS
                    </h3>
                    <div class="space-y-3">
                        <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-1">Nombre del Módulo</label>
                        <input type="text" id="mod-name" oninput="window.cubical.updateActiveModule()" placeholder="Ej: Modulo A1" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-4 rounded text-sm font-bold mb-2" value="Modulo A1" />

                        <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-1">Elegir Módulo Base</label>
                        <select id="mod-type" onchange="window.cubical.autoSetPresets(); window.cubical.updateActiveModule()" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-4 rounded text-sm font-bold">
                            <option value="CAJONERA">🗄️ Cajonera Estándar</option>
                            <option value="PLACARD">🚪 Ropero / Vestidor</option>
                            <option value="ALACENA">🪜 Alacena Superior</option>
                            <option value="BAJO_MESADA">🍽️ Bajo Mesada Cocina</option>
                            <option value="BIBLIOTECA">📚 Biblioteca Divisoria</option>
                            <option value="CUSTOM">⚙️ Módulo a Medida Libre</option>
                        </select>
                    </div>
                </div>

                <!-- CAPAS DEL PROYECTO (LISTADO DE MÓDULOS) -->
                <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-6 rounded-xl shadow-sm">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-xs font-black text-[var(--sc-text-dim)] uppercase tracking-widest flex items-center gap-3">
                            <i class="fas fa-layer-group"></i> CAPAS / MÓDULOS
                        </h3>
                        <span id="stat-total-mods" class="text-xs font-black bg-[var(--sc-surface-alt)] px-2 py-1 rounded text-[var(--alvarez-red)] border border-[var(--sc-border)]">0</span>
                    </div>
                    <div id="module-list" class="space-y-3 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
                        <!-- Dinámico -->
                    </div>
                </div>
            </div>

            <!-- 2. COLUMNA CENTRAL: CANVAS BLUEPRINT 3D (6 COLS) -->
            <div class="col-span-6 flex flex-col gap-6">
                <div class="bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] rounded-xl min-h-[500px] flex items-center justify-center relative overflow-hidden shadow-inner flex-grow">
                    <div class="absolute top-8 left-10 text-[0.65rem] font-black text-[var(--sc-text-dim)] uppercase tracking-[0.5em] opacity-30">PROYECCIÓN TÉCNICA 3D (CAD BLUEPRINT)</div>
                    
                    <!-- TOOLBAR 3D INTERACTIVA CON TOOLTIPS -->
                    <div class="absolute top-6 right-6 flex items-center gap-2 bg-[var(--sc-surface)]/85 border border-[var(--sc-border)] px-3 py-2 rounded-lg shadow-lg backdrop-blur-md z-10">
                        <div class="relative group">
                            <button onclick="window.cubical.reset3DView()" class="w-8 h-8 rounded bg-[var(--sc-surface-alt)] hover:bg-[var(--alvarez-red)] hover:text-white text-[var(--sc-text-dim)] flex items-center justify-center transition-all shadow-sm">
                                <i class="fas fa-sync-alt text-xs"></i>
                            </button>
                            <div class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] text-[0.55rem] font-black uppercase text-[var(--sc-text)] py-1.5 px-3 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all shadow-md tracking-wider">Restaurar Vista 3D</div>
                        </div>
                        <div class="relative group">
                            <button onclick="window.cubical.set3DView('front')" class="w-8 h-8 rounded bg-[var(--sc-surface-alt)] hover:bg-[var(--alvarez-red)] hover:text-white text-[var(--sc-text-dim)] flex items-center justify-center transition-all shadow-sm">
                                <i class="fas fa-square text-xs"></i>
                            </button>
                            <div class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] text-[0.55rem] font-black uppercase text-[var(--sc-text)] py-1.5 px-3 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all shadow-md tracking-wider">Vista Frontal</div>
                        </div>
                        <div class="relative group">
                            <button onclick="window.cubical.set3DView('top')" class="w-8 h-8 rounded bg-[var(--sc-surface-alt)] hover:bg-[var(--alvarez-red)] hover:text-white text-[var(--sc-text-dim)] flex items-center justify-center transition-all shadow-sm">
                                <i class="fas fa-border-all text-xs"></i>
                            </button>
                            <div class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] text-[0.55rem] font-black uppercase text-[var(--sc-text)] py-1.5 px-3 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all shadow-md tracking-wider">Vista Superior</div>
                        </div>
                        <div class="w-[1px] h-6 bg-[var(--sc-border)] mx-1"></div>
                        <div class="relative group">
                            <button onclick="window.cubical.zoom3D(1.15)" class="w-8 h-8 rounded bg-[var(--sc-surface-alt)] hover:bg-[var(--alvarez-red)] hover:text-white text-[var(--sc-text-dim)] flex items-center justify-center transition-all shadow-sm">
                                <i class="fas fa-search-plus text-xs"></i>
                            </button>
                            <div class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] text-[0.55rem] font-black uppercase text-[var(--sc-text)] py-1.5 px-3 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all shadow-md tracking-wider">Acercar (+)</div>
                        </div>
                        <div class="relative group">
                            <button onclick="window.cubical.zoom3D(0.85)" class="w-8 h-8 rounded bg-[var(--sc-surface-alt)] hover:bg-[var(--alvarez-red)] hover:text-white text-[var(--sc-text-dim)] flex items-center justify-center transition-all shadow-sm">
                                <i class="fas fa-search-minus text-xs"></i>
                            </button>
                            <div class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] text-[0.55rem] font-black uppercase text-[var(--sc-text)] py-1.5 px-3 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all shadow-md tracking-wider">Alejar (-)</div>
                        </div>
                    </div>

                    <canvas id="canvas-preview" class="w-full h-full max-h-[600px] cursor-grab active:cursor-grabbing" style="min-height:500px; display:block;"></canvas>
                </div>

                <div class="flex justify-between items-center bg-[var(--sc-surface)] p-6 rounded-xl border border-[var(--sc-border)]">
                    <button onclick="window.cubical.generateResults()" class="w-full py-5 bg-[var(--alvarez-red)] text-white font-black rounded hover:scale-105 transition-all uppercase tracking-[0.2em] flex items-center justify-center gap-4 shadow-lg">
                        OPTIMIZAR CÁLCULO <i class="fas fa-microchip"></i>
                    </button>
                </div>
            </div>

            <!-- 3. COLUMNA DERECHA: PARAMETROS DE PRECISIÓN Y EDUCACIÓN (3 COLS) -->
            <div class="col-span-3 space-y-6">
                <!-- PARÁMETROS -->
                <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-6 rounded-xl shadow-sm">
                    <h3 class="text-xs font-black text-[var(--sc-text-dim)] uppercase tracking-widest mb-6 flex items-center gap-3">
                        <i class="fas fa-sliders-h"></i> PROPIEDADES DE MÓDULO
                    </h3>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-1">Alto (mm)</label>
                            <input type="number" id="mod-h" oninput="window.cubical.updateActiveModule()" value="800" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-3 rounded text-xs font-mono font-bold">
                        </div>
                        <div>
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-1">Ancho (mm)</label>
                            <input type="number" id="mod-w" oninput="window.cubical.updateActiveModule()" value="600" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-3 rounded text-xs font-mono font-bold">
                        </div>
                        <div>
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-1">Prof. (mm)</label>
                            <input type="number" id="mod-p" oninput="window.cubical.updateActiveModule()" value="500" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-3 rounded text-xs font-mono font-bold">
                        </div>
                        <div>
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-1">Estantes</label>
                            <input type="number" id="mod-shelves" oninput="window.cubical.updateActiveModule()" value="0" min="0" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-3 rounded text-xs font-mono font-bold">
                        </div>
                        <div>
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-1">Cajones</label>
                            <input type="number" id="mod-drawers" value="3" min="0" oninput="window.cubical.updateDrawerEducation(); window.cubical.updateActiveModule()" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-3 rounded text-xs font-mono font-bold">
                        </div>
                        <div>
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-1">Puertas</label>
                            <input type="number" id="mod-doors" value="0" min="0" oninput="window.cubical.updateHingeVisibility(); window.cubical.updateActiveModule()" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-3 rounded text-xs font-mono font-bold">
                        </div>
                        
                        <!-- Dynamic Hinge Selector -->
                        <div id="group-hinge-type" class="col-span-2 hidden">
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-1 flex justify-between items-center">
                                Bisagra (Codo)
                                <span class="text-[0.55rem] text-[var(--alvarez-blue)] cursor-pointer hover:underline" onclick="window.cubical.openMobileSheet('guide')"><i class="fas fa-info-circle"></i> ¿Cuál?</span>
                            </label>
                            <select id="mod-hinge-type" onchange="window.cubical.updateHingeEducation(); window.cubical.updateActiveModule()" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-3 rounded text-xs font-bold">
                                <option value="codo_0">Bisagra Codo 0 (Superpuesta)</option>
                                <option value="codo_9">Bisagra Codo 9 (Semi-superpuesta)</option>
                                <option value="codo_18">Bisagra Codo 18 (Embutida)</option>
                            </select>
                        </div>
                        
                        <div class="col-span-2">
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-1">Diseño de Melamina (Faplac/Egger/Sadepan)</label>
                            <select id="mod-melamina" onchange="window.cubical.changeMelamina()" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-3 rounded text-xs font-bold text-[var(--sc-text)]">
                                <optgroup label="FAPLAC (Premium)">
                                    <option value="faplac_roble" selected>🌳 Faplac Roble Americano</option>
                                    <option value="faplac_seda">🧵 Faplac Seda Giorno</option>
                                    <option value="faplac_nogal">🪵 Faplac Nogal Habano</option>
                                    <option value="faplac_gris">🪨 Faplac Gris Humo</option>
                                </optgroup>
                                <optgroup label="EGGER (Scandi Style)">
                                    <option value="egger_helsinki">🌲 Egger Helsinki Birch</option>
                                    <option value="egger_arcilla">🏺 Egger Gris Arcilla</option>
                                    <option value="egger_ceniza">💨 Egger Ceniza Egger</option>
                                </optgroup>
                                <optgroup label="SADEPAN (Classic)">
                                    <option value="sadepan_cerezo">🍒 Sadepan Cerezo</option>
                                    <option value="sadepan_haya">🌾 Sadepan Haya</option>
                                    <option value="sadepan_grafito">🕶️ Sadepan Grafito Sadepan</option>
                                </optgroup>
                            </select>
                        </div>
                    </div>
                    
                    <button onclick="window.cubical.addModule()" class="w-full mt-6 py-4 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] rounded text-xs font-black uppercase hover:bg-[var(--alvarez-red)] hover:text-white transition-all shadow-sm">AÑADIR A LA LISTA</button>
                </div>

                <!-- PANEL DIDÁCTICO / INTERACTIVO -->
                <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-6 rounded-xl shadow-sm text-xs space-y-4">
                    <h3 class="text-xs font-black text-[var(--sc-text)] uppercase tracking-wider flex items-center gap-2">
                        <i class="fas fa-graduation-cap text-[var(--alvarez-red)]"></i> ASISTENTE DIDÁCTICO
                    </h3>
                    
                    <div id="edu-drawer-tip" class="p-3 bg-[var(--sc-surface-alt)] border-l-2 border-[var(--alvarez-blue)] rounded">
                        <strong class="uppercase text-[0.6rem] block mb-1">💡 Holgura de Correderas</strong>
