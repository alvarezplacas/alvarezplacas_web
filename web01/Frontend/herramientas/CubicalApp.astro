            drawerColor: "oklch(23% 0.02 260)",
            doorColor: "oklch(33% 0.02 260)"
        }
    };

    class Cabinet3DRenderer {
        constructor(canvasId) {
            this.canvas = document.getElementById(canvasId);
            this.ctx = this.canvas.getContext('2d');
            this.angleY = -0.6; // Ángulo de rotación por defecto
            this.angleX = 0.3;  // Ángulo de inclinación por defecto
            this.scale = 0.35;
            this.panX = 0;      // Desplazamiento X para Paneo (Barra espaciadora + Mouse)
            this.panY = 0;      // Desplazamiento Y para Paneo
            this.spacePressed = false;   // Estado de la barra espaciadora
            this.autoScalePending = true;  // Auto-ajustar escala al primer render
            this.setupInteraction();
        }
        
        setupInteraction() {
            let isDragging = false;
            let lastX = 0, lastY = 0;
            
            const startDrag = (x, y) => {
                isDragging = true;
                lastX = x;
                lastY = y;
                if (this.spacePressed) {
                    this.canvas.style.cursor = 'grabbing';
                }
            };
            
            const dragMove = (x, y) => {
                if (!isDragging) return;
                const dx = x - lastX;
                const dy = y - lastY;
                
                if (this.spacePressed) {
                    // Mover/Panear el mueble por el plano
                    this.panX += dx;
                    this.panY += dy;
                    this.canvas.style.cursor = 'grabbing';
                } else {
                    // Rotar el mueble sobre sus ejes
                    this.angleY += dx * 0.007;
                    this.angleX += dy * 0.007;
                    this.angleX = Math.max(-Math.PI/3, Math.min(Math.PI/3, this.angleX)); // Evitar dar la vuelta
                }
                
                lastX = x;
                lastY = y;
                if (window.cubical && typeof window.cubical.renderPreview === 'function') {
                    window.cubical.renderPreview();
                }
            };
            
            const stopDrag = () => { 
                isDragging = false; 
                if (this.spacePressed) {
                    this.canvas.style.cursor = 'grab';
                } else {
                    this.canvas.style.cursor = 'default';
                }
            };
            
            this.canvas.addEventListener('mousedown', (e) => startDrag(e.clientX, e.clientY));
            this.canvas.addEventListener('mousemove', (e) => dragMove(e.clientX, e.clientY));
            window.addEventListener('mouseup', stopDrag);
            
            // Listeners de Teclado Globales para barra espaciadora (evitando conflicto si escribe en inputs)
            window.addEventListener('keydown', (e) => {
                const activeTag = document.activeElement ? document.activeElement.tagName.toLowerCase() : '';
                if (activeTag === 'input' || activeTag === 'textarea' || activeTag === 'select') {
                    return; // Ignorar si el usuario está tipeando en un formulario
                }
                if (e.code === 'Space') {
                    e.preventDefault(); // Evitar scroll de la página
                    this.spacePressed = true;
                    this.canvas.style.cursor = 'grab';
                }
            });
            
            window.addEventListener('keyup', (e) => {
                const activeTag = document.activeElement ? document.activeElement.tagName.toLowerCase() : '';
                if (activeTag === 'input' || activeTag === 'textarea' || activeTag === 'select') {
                    return;
                }
                if (e.code === 'Space') {
                    this.spacePressed = false;
                    this.canvas.style.cursor = 'default';
                }
            });
            
            this.canvas.addEventListener('touchstart', (e) => {
                if (e.touches.length === 1) {
                    startDrag(e.touches[0].clientX, e.touches[0].clientY);
                }
            });
            this.canvas.addEventListener('touchmove', (e) => {
                if (e.touches.length === 1) {
                    dragMove(e.touches[0].clientX, e.touches[0].clientY);
                }
            });
            window.addEventListener('touchend', stopDrag);
        }
        
        project(X, Y, Z, width, height, depth, screenWidth, screenHeight) {
            const cx = width / 2;
            const cy = height / 2;
            const cz = depth / 2;
            
            let px = X - cx;
            let py = Y - cy;
            let pz = Z - cz;
            
            const cosY = Math.cos(this.angleY);
            const sinY = Math.sin(this.angleY);
            const rx1 = px * cosY - pz * sinY;
            const rz1 = px * sinY + pz * cosY;
            
            const cosX = Math.cos(this.angleX);
            const sinX = Math.sin(this.angleX);
            const ry2 = py * cosX - rz1 * sinX;
            const rz2 = py * sinX + rz1 * cosX;
            
            // Distancia de la cámara para proyección cónica realista (punto de fuga)
            const d = 1500;
            const perspectiveFactor = d / (d + rz2);
            
            // Se suman panX y panY para permitir arrastrar libremente el mueble por la pantalla
            const sx = screenWidth / 2 + rx1 * this.scale * perspectiveFactor + this.panX;
            const sy = screenHeight / 2 - ry2 * this.scale * perspectiveFactor + this.panY;
            
            return { x: sx, y: sy, z: rz2 };
        }

        // Rota una normal de espacio-modelo al espacio de cámara
        // (misma secuencia Y→X que project, pero sin perspectiva ni traslación)
        rotateNormal(nx, ny, nz) {
            const cosY = Math.cos(this.angleY), sinY = Math.sin(this.angleY);
            const rx  = nx * cosY - nz * sinY;
            const rz1 = nx * sinY + nz * cosY;
            const cosX = Math.cos(this.angleX), sinX = Math.sin(this.angleX);
            const ry  = ny * cosX - rz1 * sinX;
            const rz  = ny * sinX + rz1 * cosX;
            return { x: rx, y: ry, z: rz };
        }

        // Calcula la escala necesaria para que el modelo quepa en el 80% del canvas
        computeAutoScale(width, height, depth) {
            const sw = this.canvas.width, sh = this.canvas.height;
            const cx = width/2, cy = height/2, cz = depth/2;
            const cosY = Math.cos(this.angleY), sinY = Math.sin(this.angleY);
            const cosX = Math.cos(this.angleX), sinX = Math.sin(this.angleX);
            const D = 1500;
            const corners = [
                [0,0,0],[width,0,0],[width,height,0],[0,height,0],
                [0,0,depth],[width,0,depth],[width,height,depth],[0,height,depth]
            ];
            let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
            corners.forEach(([X,Y,Z]) => {
                const px=X-cx, py=Y-cy, pz=Z-cz;
                const rx  = px*cosY - pz*sinY;
                const rz1 = px*sinY + pz*cosY;
                const ry  = py*cosX - rz1*sinX;
                const rz  = py*sinX + rz1*cosX;
                const pf  = D/(D+rz);
                minX = Math.min(minX, rx*pf);  maxX = Math.max(maxX, rx*pf);
                minY = Math.min(minY, -ry*pf); maxY = Math.max(maxY, -ry*pf);
            });
            const pad = 0.80;
            const sX = (sw*pad) / Math.max(1, maxX - minX);
            const sY = (sh*pad) / Math.max(1, maxY - minY);
            return Math.min(sX, sY);
        }

        addBoxFaces(x, y, z, w, h, d, fillColor, lineColor, name = 'board') {
            const sw = this.canvas.width;
            const sh = this.canvas.height;
            
            // 8 vértices de un prisma rectangular
            const vertices = [
                {x: x,     y: y,     z: z},     // 0 (Frente, Abajo, Izquierda)
                {x: x + w, y: y,     z: z},     // 1 (Frente, Abajo, Derecha)
                {x: x + w, y: y + h, z: z},     // 2 (Frente, Arriba, Derecha)
                {x: x,     y: y + h, z: z},     // 3 (Frente, Arriba, Izquierda)
                {x: x,     y: y,     z: z + d}, // 4 (Atrás, Abajo, Izquierda)
                {x: x + w, y: y,     z: z + d}, // 5 (Atrás, Abajo, Derecha)
                {x: x + w, y: y + h, z: z + d}, // 6 (Atrás, Arriba, Derecha)
                {x: x,     y: y + h, z: z + d}  // 7 (Atrás, Arriba, Izquierda)
            ];
            
            // Proyectar todos los vértices a la pantalla 2D
            const proj = vertices.map(v => {
                return this.project(v.x, v.y, v.z, this.currentModDims.ancho, this.currentModDims.alto, this.currentModDims.prof, sw, sh);
            });
            
            // 6 caras con normales en espacio-modelo (top/bottom corregidos)
            const boxFaces = [
                { indices: [0, 1, 2, 3], faceName: 'front',  normal: { x:  0, y:  0, z: -1 } },
                { indices: [5, 4, 7, 6], faceName: 'back',   normal: { x:  0, y:  0, z:  1 } },
                { indices: [4, 0, 3, 7], faceName: 'left',   normal: { x: -1, y:  0, z:  0 } },
                { indices: [1, 5, 6, 2], faceName: 'right',  normal: { x:  1, y:  0, z:  0 } },
                { indices: [3, 2, 6, 7], faceName: 'top',    normal: { x:  0, y:  1, z:  0 } }, // y=h: TAPA SUPERIOR
                { indices: [4, 5, 1, 0], faceName: 'bottom', normal: { x:  0, y: -1, z:  0 } }  // y=0: PISO
            ];
            
            boxFaces.forEach(f => {
                const avgZ = f.indices.reduce((sum, idx) => sum + proj[idx].z, 0) / 4;
                const pts  = f.indices.map(idx => proj[idx]);
                this.allFaces.push({
                    pts, avgZ, fillColor, lineColor,
                    faceName: f.faceName,
                    normal:   f.normal,
                    boardName: name
                });
            });
        }
        
        drawBox(width, height, depth, opts = {}) {
            const {
                offsetX = 0,
                color = '#000000',
                fillColor = '#ffffff',
                lineWidth = 1.0,
                drawPanelThickness = true,
                shelves = 0,
                drawers = 0,
                doors = 0,
                palette = null
            } = opts;
            
            const sw = this.canvas.width;
            const sh = this.canvas.height;
            const ctx = this.ctx;
            const t = 18; // 18mm de espesor de melamina
            
            // Guardar las dimensiones del módulo actual para que project() las use como centro de rotación y perspectiva
            this.currentModDims = { ancho: width, alto: height, prof: depth };
            
            // Reiniciar el listado global de caras para el Algoritmo del Pintor
            this.allFaces = [];

            // Auto-escalar para que el módulo siempre quepa en el canvas
            if (this.autoScalePending) {
                this.scale = this.computeAutoScale(width, height, depth);
                this.autoScalePending = false;
            }
            
            // Delineado técnico ultra-fino dinámico de alta definición
            const isDark = document.body.getAttribute('data-theme') === 'dark' || document.body.classList.contains('body-theme-dark');
            const lineColor = isDark ? '#e5e5e5' : '#1e1e1e';
            
            // Seleccionar rellenos opacos de melamina
            const baseFill   = palette ? palette.fillColor : (isDark ? '#2e2e2e' : '#f4f1ea');
            const shelfFill  = palette ? palette.shelfColor : (isDark ? '#363636' : '#ebe7dd');
            const drawerFill = palette ? palette.drawerColor : (isDark ? '#3a3a3a' : '#e5e1d7');
            const doorFill   = palette ? palette.doorColor : (isDark ? '#3d3d3d' : '#ede9df');
            
            if (opts.type === 'ESCRITORIO') {
                // 1. TAPA SUPERIOR
                this.addBoxFaces(offsetX, height - t, 0, width, t, depth, baseFill, lineColor, 'top');
                // 2. LATERAL IZQUIERDO
                this.addBoxFaces(offsetX, 0, 0, t, height - t, depth, baseFill, lineColor, 'left-side');
                // 3. CAJONERA DERECHA (ancho 400)
                this.addBoxFaces(width - t + offsetX, 0, 0, t, height - t, depth, baseFill, lineColor, 'right-side');
                this.addBoxFaces(width - 400 + offsetX, 0, 0, t, height - t, depth, baseFill, lineColor, 'divider');
                this.addBoxFaces(width - 400 + t + offsetX, 0, 0, 400 - 2 * t, t, depth, baseFill, lineColor, 'base-cajonera');
                // 4. FALDÓN TRASERO
                this.addBoxFaces(t + offsetX, height - t - 300, depth - t, width - 400 - t, 300, t, baseFill, lineColor, 'faldon');
                // 5. BANDEJA TECLADO
                this.addBoxFaces(t + 13 + offsetX, height - t - 100, 20, width - 400 - t - 26, t, depth - 40, shelfFill, lineColor, 'bandeja');
                
                // 6. CAJONES (en espacio de cajonera)
                if (drawers > 0) {
                    const hDisponible = height - t - t; // alto menos techo y piso
                    const hSpace = hDisponible / drawers;
                    for (let i = 0; i < drawers; i++) {
                        const yBottom = t + (i * hSpace);
                        this.addBoxFaces(width - 400 + t + 3 + offsetX, yBottom + 3, 0, 400 - 2*t - 6, hSpace - 6, t, drawerFill, lineColor, 'drawer');
                        const tcX = width - 400 + t + (400 - 2*t)/2 + offsetX;
                        const tcY = yBottom + hSpace / 2;
                        this.addBoxFaces(tcX - 45, tcY - 5, -10, 90, 10, 10, '#cccccc', lineColor, 'handle');
                    }
                }
                
                // Ordenar caras y renderizar (mismo proceso)
                this.allFaces.sort((a, b) => b.avgZ - a.avgZ);
                const _Lx = 0.45, _Ly = 0.75, _Lz = -0.48;
                const _Ll = Math.sqrt(_Lx*_Lx + _Ly*_Ly + _Lz*_Lz);
                const light = { x: _Lx/_Ll, y: _Ly/_Ll, z: _Lz/_Ll };
                const ambient = 0.32;
                ctx.lineWidth = 0.8; ctx.lineJoin = 'round'; ctx.lineCap  = 'round';
                this.allFaces.forEach(f => {
                    const rn = this.rotateNormal(f.normal.x, f.normal.y, f.normal.z);
                    if (rn.z > 0.025) return;
                    const diffuse = Math.max(0, rn.x*light.x + rn.y*light.y + rn.z*light.z);
                    const lightLevel = ambient + (1 - ambient) * diffuse;
                    ctx.beginPath(); ctx.moveTo(f.pts[0].x, f.pts[0].y);
                    for (let i = 1; i < f.pts.length; i++) ctx.lineTo(f.pts[i].x, f.pts[i].y);
                    ctx.closePath();
                    ctx.fillStyle = f.fillColor; ctx.fill();
                    const shadowAmt = Math.max(0, (1 - lightLevel) * 0.82);
                    if (shadowAmt > 0.004) { ctx.fillStyle = `rgba(0,0,0,${shadowAmt.toFixed(3)})`; ctx.fill(); }
                    const highlightAmt = Math.max(0, (lightLevel - 0.82) * 0.65);
                    if (highlightAmt > 0.004) { ctx.fillStyle = `rgba(255,255,255,${highlightAmt.toFixed(3)})`; ctx.fill(); }
                    ctx.strokeStyle = f.lineColor; ctx.stroke();
                });
                return;
            }

            // 1. DIBUJAR FONDO/RESPALDO (3mm MDF) - Ubicado al fondo del mueble
            this.addBoxFaces(offsetX, 0, depth - 3, width, height, 3, baseFill, lineColor, 'backboard');
            
            // 2. DIBUJAR LATERAL IZQUIERDO (18mm) - Corregido para que termine bajo el techo
            this.addBoxFaces(offsetX, 0, 0, t, height - t, depth, baseFill, lineColor, 'left-side');
            
            // 3. DIBUJAR LATERAL DERECHO (18mm) - Corregido para que termine bajo el techo
            this.addBoxFaces(width - t + offsetX, 0, 0, t, height - t, depth, baseFill, lineColor, 'right-side');
            
            // 4. DIBUJAR TECHO / TAPA SUPERIOR (18mm) - Corregido para que cubra los laterales
            this.addBoxFaces(offsetX, height - t, 0, width, t, depth, baseFill, lineColor, 'top');
            
            // 5. DIBUJAR PISO / BASE INFERIOR (18mm) - Soporte para Zócalo si corresponde
            let zocaloH = 0;
            if (height >= 800 && drawers > 0) zocaloH = 80;  // Zócalo de 80mm en cajoneras
            if (height === 850 && doors > 0) zocaloH = 120;  // Zócalo de 120mm en bajos mesada
            
            if (zocaloH > 0) {
                // Dibujar Zócalo frontal retranqueado (retrocede 20mm del frente Z = 20)
                this.addBoxFaces(t + offsetX, 0, 20, width - 2 * t, zocaloH, t, baseFill, lineColor, 'zocalo');
                // Piso del mueble sobre el zócalo
                this.addBoxFaces(t + offsetX, zocaloH, 0, width - 2 * t, t, depth, baseFill, lineColor, 'base');
            } else {
                // Piso del mueble a ras del suelo
                this.addBoxFaces(t + offsetX, 0, 0, width - 2 * t, t, depth, baseFill, lineColor, 'base');
            }
            
            const pisoY = zocaloH > 0 ? zocaloH + t : t;
            const techoY = height - t;
            const espacioUtilH = techoY - pisoY;
            
            // 6. DIBUJAR ESTANTES (18mm) - Con retranqueo frontal estándar de 20mm
            if (shelves > 0) {
                const hSpace = espacioUtilH / (shelves + 1);
                for (let i = 1; i <= shelves; i++) {
                    const shelfY = pisoY + i * hSpace - t / 2;
                    this.addBoxFaces(t + offsetX, shelfY, 20, width - 2 * t, t, depth - 20, shelfFill, lineColor, 'shelf');
                }
            }
            
            // 7. DIBUJAR CAJONES (Frentes de cajón de 18mm con holgura de 3mm)
            if (drawers > 0) {
                const hSpace = espacioUtilH / drawers;
                for (let i = 0; i < drawers; i++) {
                    const yBottom = pisoY + i * hSpace;
                    // Frente de cajón de 18mm de espesor embutido, Z = 0
                    this.addBoxFaces(3 + offsetX, yBottom + 3, 0, width - 6, hSpace - 6, t, drawerFill, lineColor, 'drawer');
                    
                    // Tirador de barra horizontal de 3D
                    const tcX = width / 2 + offsetX;
                    const tcY = yBottom + hSpace / 2;
                    this.addBoxFaces(tcX - 45, tcY - 5, -10, 90, 10, 10, '#cccccc', lineColor, 'handle');
                }
            }
            
            // 8. DIBUJAR PUERTAS (Puertas de 18mm)
            if (doors > 0) {
                const wSpace = (width - 6) / doors;
                for (let i = 0; i < doors; i++) {
                    const xLeft = 3 + i * wSpace;
                    // Puertas de 18mm de espesor embutidas, Z = 0
                    this.addBoxFaces(xLeft + offsetX, pisoY + 3, 0, wSpace - 3, espacioUtilH - 6, t, doorFill, lineColor, 'door');
                    
                    // Tirador de barra vertical para las puertas
                    const tiradorX = doors === 1 
                        ? xLeft + wSpace - 30 
                        : (i === 0 ? xLeft + wSpace - 30 : xLeft + 30);
                    const tiradorY = pisoY + espacioUtilH / 2;
                    this.addBoxFaces(tiradorX + offsetX - 5, tiradorY - 50, -10, 10, 100, 10, '#cccccc', lineColor, 'handle');
                }
            }
            
            // =========================================================================
            // RENDERIZADO: PAINTER'S ALGORITHM + ILUMINACIÓN DIFUSA + BACKFACE CULLING
            // =========================================================================
            this.allFaces.sort((a, b) => b.avgZ - a.avgZ);

            // Dirección de luz (arriba-derecha-frente), normalizada
            const _Lx = 0.45, _Ly = 0.75, _Lz = -0.48;
            const _Ll = Math.sqrt(_Lx*_Lx + _Ly*_Ly + _Lz*_Lz);
            const light = { x: _Lx/_Ll, y: _Ly/_Ll, z: _Lz/_Ll };
            const ambient = 0.32; // Luz ambiental mínima (0→completamente negro, 1→sin sombra)

            ctx.lineWidth = 0.8;
            ctx.lineJoin = 'round';
            ctx.lineCap  = 'round';

            this.allFaces.forEach(f => {
                // 1. Rotar la normal al espacio de cámara actual
                const rn = this.rotateNormal(f.normal.x, f.normal.y, f.normal.z);

                // 2. Backface culling: cámara está en -Z.
                //    La cara es visible solo si su normal apunta hacia -Z (rn.z < 0).
                if (rn.z > 0.025) return;

                // 3. Iluminación difusa Lambertiana
                const diffuse    = Math.max(0, rn.x*light.x + rn.y*light.y + rn.z*light.z);
                const lightLevel = ambient + (1 - ambient) * diffuse; // [ambient .. 1.0]

                // 4. Dibujar polígono
                ctx.beginPath();
                ctx.moveTo(f.pts[0].x, f.pts[0].y);
                for (let i = 1; i < f.pts.length; i++) ctx.lineTo(f.pts[i].x, f.pts[i].y);
                ctx.closePath();

                // Base OKLCH de melamina
                ctx.fillStyle = f.fillColor;
                ctx.fill();

                // Sombra proporcional a la falta de luz
                const shadowAmt = Math.max(0, (1 - lightLevel) * 0.82);
                if (shadowAmt > 0.004) {
                    ctx.fillStyle = `rgba(0,0,0,${shadowAmt.toFixed(3)})`;
                    ctx.fill();
                }

                // Brillo especular sutil (solo caras muy iluminadas, p.ej. tapa superior)
                const highlightAmt = Math.max(0, (lightLevel - 0.82) * 0.65);
                if (highlightAmt > 0.004) {
                    ctx.fillStyle = `rgba(255,255,255,${highlightAmt.toFixed(3)})`;
                    ctx.fill();
                }

                // Línea técnica CAD fina
                ctx.strokeStyle = f.lineColor;
                ctx.stroke();
            });
        }
    }

    window.cubical = {
        state: {
            currentScreen: 'dashboard',
            projectName: '',
            environment: '',
            modules: [],
            projects: [],
            results: null,
            selectedMelamina: 'faplac_roble'
        },

        initialized: false,
        renderer: null,

        init: async function() {
            if (this.initialized) return;
            this.initialized = true;
            this.updateThemeUI();
            await this.loadProjects();
            
            // Inicializar renderizadores 3D
            try {
                this.renderer = new Cabinet3DRenderer('canvas-preview');
                this.rendererMobile = new Cabinet3DRenderer('canvas-preview-mobile');
                this.rendererMobile.scale = 0.22;
            } catch (e) {
                console.error("[CubiCal] Falló inicialización de Canvas 3D:", e);
            }
            
            // Cargar tarjetas del catálogo dinámicamente desde templates.js
            await this.renderTemplateCarousel();
            
            // Inicializar Carrusel de Plantillas con Auto-Scroll Lento e Interactivo
            const carousel = document.getElementById('templates-carousel');
            const btnLeft = document.getElementById('carousel-btn-left');
            const btnRight = document.getElementById('carousel-btn-right');
            
            if (carousel && btnLeft && btnRight) {
                btnLeft.addEventListener('click', (e) => {
                    e.preventDefault();
                    carousel.scrollBy({ left: -344, behavior: 'smooth' });
                });
                btnRight.addEventListener('click', (e) => {
                    e.preventDefault();
                    carousel.scrollBy({ left: 344, behavior: 'smooth' });
                });
                
                let autoScrollInterval = null;
                const startAutoScroll = () => {
                    autoScrollInterval = setInterval(() => {
                        if (carousel.scrollLeft >= (carousel.scrollWidth - carousel.clientWidth - 5)) {
                            carousel.scrollTo({ left: 0, behavior: 'smooth' });
                        } else {
                            carousel.scrollBy({ left: 1, behavior: 'auto' });
                        }
                    }, 40);
                };
                const stopAutoScroll = () => {
                    if (autoScrollInterval) {
                        clearInterval(autoScrollInterval);
                        autoScrollInterval = null;
                    }
                };
                startAutoScroll();
                carousel.addEventListener('mouseenter', stopAutoScroll);
                carousel.addEventListener('mouseleave', startAutoScroll);
                carousel.addEventListener('touchstart', stopAutoScroll);
                carousel.addEventListener('touchend', startAutoScroll);
            }

            // Aplicar primer set de presets
            this.autoSetPresets();
            
            this.showScreen('dashboard');
        },

        changeMelamina: function(isMobile = false) {
            const prefix = isMobile ? '-mobile' : '';
            const selectEl = document.getElementById(`mod-melamina${prefix}`);
            if (!selectEl) return;
            const val = selectEl.value;
            this.state.selectedMelamina = val;
            
            // Sincronizar el otro select
            const otherPrefix = isMobile ? '' : '-mobile';
            const otherSelect = document.getElementById(`mod-melamina${otherPrefix}`);
            if (otherSelect) otherSelect.value = val;
            
            this.renderPreview();
        },

        toggleTheme: function() {
            const body = document.body;
            const isDark = body.getAttribute('data-theme') === 'dark' || body.classList.contains('body-theme-dark');
            if (isDark) {
                body.removeAttribute('data-theme');
                body.classList.add('body-theme-light');
                body.classList.remove('body-theme-dark');
                localStorage.setItem('client-theme', 'light');
                localStorage.setItem('sc-theme', 'light');
            } else {
                body.setAttribute('data-theme', 'dark');
                body.classList.add('body-theme-dark');
                body.classList.remove('body-theme-light');
                localStorage.setItem('client-theme', 'dark');
                localStorage.setItem('sc-theme', 'dark');
            }
            this.updateThemeUI();
            this.renderPreview();
        },

        updateThemeUI: function() {
            const isDark = document.body.getAttribute('data-theme') === 'dark' || document.body.classList.contains('body-theme-dark');
            const text = document.getElementById('theme-text');
            const icon = document.getElementById('theme-icon');
            if (text && icon) {
                text.textContent = isDark ? 'MODO CLARO' : 'MODO OSCURO';
                icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            }
        },

        loadProjects: async function() {
            try {
                const response = await fetch(`/api/herramientas/get-cubical?clientId=${CLIENT_ID}`);
                const data = await response.json();
                if (data.success) {
                    this.state.projects = data.projects;
                    this.renderDashboard();
                }
            } catch (e) {
                this.renderDashboard();
            }
        },

        reset3DView: function() {
            if (!this.renderer) return;
            this.renderer.angleY = -0.6;
            this.renderer.angleX = 0.3;
            this.renderer.scale = 0.35;
            this.renderer.panX = 0;
            this.renderer.panY = 0;
            if (this.rendererMobile) {
                this.rendererMobile.angleY = -0.6;
                this.rendererMobile.angleX = 0.3;
                this.rendererMobile.scale = 0.22;
                this.rendererMobile.panX = 0;
                this.rendererMobile.panY = 0;
            }
            this.renderPreview();
        },

        set3DView: function(type) {
            if (!this.renderer) return;
            let ay = 0, ax = 0;
            if (type === 'front') {
                ay = 0; ax = 0;
            } else if (type === 'top') {
                ay = 0; ax = Math.PI / 2;
            }
            this.renderer.angleY = ay;
            this.renderer.angleX = ax;
            if (this.rendererMobile) {
                this.rendererMobile.angleY = ay;
                this.rendererMobile.angleX = ax;
            }
            this.renderPreview();
        },

        zoom3D: function(factor) {
            if (!this.renderer) return;
            this.renderer.scale *= factor;
            this.renderer.scale = Math.max(0.1, Math.min(1.5, this.renderer.scale));
            if (this.rendererMobile) {
                this.rendererMobile.scale *= factor;
                this.rendererMobile.scale = Math.max(0.1, Math.min(1.2, this.rendererMobile.scale));
            }
            this.renderPreview();
        },

        showScreen: function(name) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(`screen-${name}`).classList.remove('hidden');
            this.state.currentScreen = name;
            const saveBtn = document.getElementById('btn-save-project');
            if (saveBtn) saveBtn.classList.toggle('hidden', name !== 'constructor');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        },

        showSetup: function() { this.showScreen('setup'); },
        showDashboard: function() { this.showScreen('dashboard'); },
        showConstructor: function() { 
            this.showScreen('constructor'); 
            setTimeout(() => this.renderPreview(), 100);
        },

        startConstructor: function() {
            const name = document.getElementById('setup-name').value;
            if (!name) { alert("⚠️ Por favor ingresa el nombre del proyecto."); return; }
            this.state.projectName = name;
            this.state.environment = document.getElementById('setup-env').value;
            this.showScreen('constructor');
            this.renderConstructor();
            setTimeout(() => this.renderPreview(), 100);
        },

        loadTemplate: async function(type) {
            // ---------------------------------------------------------------
            // CARGA DE DATOS DESDE EL ARCHIVO EXTERNO DE PLANTILLAS
            // Para agregar nuevas plantillas editar únicamente:
            // /herramientas/logic/cubical/templates/templates.js
            // ---------------------------------------------------------------
            let tplData = null;
            try {
                const mod = await import(`/herramientas/logic/cubical/templates/templates.js?v=` + Date.now());
                tplData = mod.TEMPLATES[type];
            } catch(e) {
                console.warn('[CubiCal] No se pudo cargar templates.js, usando fallback:', e);
            }

            // Fallback: si no hay datos externos, usar valores genéricos
            const modType   = tplData?.modType   || 'CAJONERA';
            const dims      = tplData?.dims      || { alto: 800, ancho: 600, prof: 500, n_cajones: 3, n_puertas: 0, n_estantes: 0 };
            const hingeType = tplData?.hingeType || 'codo_0';
            const name      = tplData?.moduleName || `Modulo A1 - ${type}`;
            
            this.state.projectName = tplData ? `Proyecto Rápido - ${tplData.name}` : `Proyecto Rápido - ${type}`;
            this.state.environment = tplData?.environment || 'cocina';
            this.state.modules = [];
            
            const newId = Date.now();
            this.state.modules.push({ id: newId, type: modType, name, dims, hingeType });
            this.state.activeModuleId = newId;
            
            // Poblar barra lateral Desktop
            document.getElementById('mod-name').value      = name;
            document.getElementById('mod-type').value      = modType;
            document.getElementById('mod-h').value         = dims.alto;
            document.getElementById('mod-w').value         = dims.ancho;
            document.getElementById('mod-p').value         = dims.prof;
            document.getElementById('mod-drawers').value   = dims.n_cajones;
            document.getElementById('mod-doors').value     = dims.n_puertas;
            document.getElementById('mod-shelves').value   = dims.n_estantes;
            
            // Poblar barra lateral Mobile
            document.getElementById('mod-name-mobile').value    = name;
            document.getElementById('mod-type-mobile').value    = modType;
            document.getElementById('mod-h-mobile').value       = dims.alto;
            document.getElementById('mod-w-mobile').value       = dims.ancho;
            document.getElementById('mod-p-mobile').value       = dims.prof;
            document.getElementById('mod-drawers-mobile').value = dims.n_cajones;
            document.getElementById('mod-doors-mobile').value   = dims.n_puertas;
            document.getElementById('mod-shelves-mobile').value = dims.n_estantes;
            
            this.updateHingeVisibility();
            this.updateDrawerEducation();
            
            // Resetear auto-escala para el nuevo módulo
            if (this.renderer) this.renderer.autoScalePending = true;
            if (this.rendererMobile) this.rendererMobile.autoScalePending = true;

            this.showScreen('constructor');
            this.renderConstructor();
            setTimeout(() => this.renderPreview(), 100);
        },

        renderTemplateCarousel: async function() {
            // ---------------------------------------------------------------
            // Genera las tarjetas del carrusel dinámicamente desde templates.js
            // ---------------------------------------------------------------
            const carousel = document.getElementById('templates-carousel');
            if (!carousel) return;

            let TEMPLATES = {};
            try {
                const mod = await import(`/herramientas/logic/cubical/templates/templates.js?v=` + Date.now());
                TEMPLATES = mod.TEMPLATES;
            } catch(e) {
                console.warn('[CubiCal] Error cargando catálogo de plantillas:', e);
                return;
            }

            carousel.innerHTML = Object.values(TEMPLATES).map(t => `
                <div onclick="window.cubical.loadTemplate('${t.id}')" 
                     class="snap-start shrink-0 w-80 bg-[var(--sc-surface)] border border-[var(--sc-border)] p-6 rounded-xl hover:border-[var(--alvarez-red)] transition-all cursor-pointer group shadow-sm flex flex-col justify-between h-56"
                     title="${t.name} — ${t.dims.alto} x ${t.dims.ancho} x ${t.dims.prof} mm">
                    <div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-3xl">${t.emoji}</span>
                            <span class="text-[0.5rem] font-black bg-[var(--sc-surface-alt)] px-2.5 py-1 rounded border border-[var(--sc-border)] uppercase tracking-wider" style="color: ${t.tagColor}">${t.tag}</span>
                        </div>
                        <h4 class="text-lg font-black text-[var(--sc-text)] uppercase tracking-tight group-hover:text-[var(--alvarez-red)] transition-colors mb-1">${t.name}</h4>
                        <p class="text-[0.6rem] text-[var(--sc-text-dim)] font-medium leading-relaxed">${t.description}</p>
                    </div>
                    <div class="text-[0.6rem] font-bold text-[var(--sc-text)] uppercase font-mono tracking-wider">${t.dims.alto} x ${t.dims.ancho} x ${t.dims.prof} mm</div>
                </div>
            `).join('');
        },

        autoSetPresets: function(isMobile = false) {
            const prefix = isMobile ? '-mobile' : '';
            const type = document.getElementById(`mod-type${prefix}`).value;
            const shelvesInput = document.getElementById(`mod-shelves${prefix}`);
            const drawersInput = document.getElementById(`mod-drawers${prefix}`);
            const doorsInput = document.getElementById(`mod-doors${prefix}`);
            const hInput = document.getElementById(`mod-h${prefix}`);
            const wInput = document.getElementById(`mod-w${prefix}`);
            const pInput = document.getElementById(`mod-p${prefix}`);
            
            if (!shelvesInput || !drawersInput || !doorsInput) return;
            
            // Medidas predeterminadas según tipo
            if (type === 'CAJONERA') {
                shelvesInput.value = 0; drawersInput.value = 3; doorsInput.value = 0;
                hInput.value = 800; wInput.value = 600; pInput.value = 500;
            } else if (type === 'PLACARD') {
                shelvesInput.value = 2; drawersInput.value = 0; doorsInput.value = 2;
                hInput.value = 2000; wInput.value = 800; pInput.value = 600;
            } else if (type === 'ALACENA') {
                shelvesInput.value = 2; drawersInput.value = 0; doorsInput.value = 2;
                hInput.value = 700; wInput.value = 600; pInput.value = 320;
            } else if (type === 'BAJO_MESADA') {
                shelvesInput.value = 0; drawersInput.value = 0; doorsInput.value = 2;
                hInput.value = 820; wInput.value = 800; pInput.value = 580;
            } else if (type === 'BIBLIOTECA') {
                shelvesInput.value = 4; drawersInput.value = 0; doorsInput.value = 0;
                hInput.value = 1800; wInput.value = 800; pInput.value = 300;
            } else {
                shelvesInput.value = 0; drawersInput.value = 0; drawersInput.value = 0;
            }
            
            // Sincronizar el otro formulario
            const otherPrefix = isMobile ? '' : '-mobile';
            const otherType = document.getElementById(`mod-type${otherPrefix}`);
            if (otherType) {
                otherType.value = type;
                document.getElementById(`mod-shelves${otherPrefix}`).value = shelvesInput.value;
                document.getElementById(`mod-drawers${otherPrefix}`).value = drawersInput.value;
                document.getElementById(`mod-doors${otherPrefix}`).value = doorsInput.value;
                document.getElementById(`mod-h${otherPrefix}`).value = hInput.value;
                document.getElementById(`mod-w${otherPrefix}`).value = wInput.value;
                document.getElementById(`mod-p${otherPrefix}`).value = pInput.value;
            }

            this.updateHingeVisibility(isMobile);
            this.updateDrawerEducation(isMobile);
        },

        updateHingeVisibility: function(isMobile = false) {
            const prefix = isMobile ? '-mobile' : '';
            const doorsVal = parseInt(document.getElementById(`mod-doors${prefix}`).value) || 0;
            const hingeDiv = document.getElementById(`group-hinge-type${prefix}`);
            const eduTip = document.getElementById('edu-hinge-tip');

            if (doorsVal > 0) {
                hingeDiv.classList.remove('hidden');
                if (eduTip && !isMobile) eduTip.classList.remove('hidden');
            } else {
                hingeDiv.classList.add('hidden');
                if (eduTip && !isMobile) eduTip.classList.add('hidden');
            }
            this.updateHingeEducation(isMobile);
        },

        updateHingeEducation: function(isMobile = false) {
            const prefix = isMobile ? '-mobile' : '';
            const typeSelect = document.getElementById(`mod-hinge-type${prefix}`);
            if (!typeSelect) return;
            const type = typeSelect.value;
            const textSpan = document.getElementById('edu-hinge-text');
            const tipDiv = document.getElementById('edu-hinge-tip');

            if (!textSpan) return;

            let tipText = "";
            let title = "🚪 Bisagra Codo 0 (Superpuesta)";
            if (type === 'codo_0') {
                tipText = "La puerta cubre todo el lateral (18mm) al cerrar. Es la clásica más utilizada en extremos de muebles.";
                title = "🚪 Bisagra Codo 0 (Superpuesta)";
                if (tipDiv) tipDiv.style.borderLeftColor = 'var(--alvarez-red)';
            } else if (type === 'codo_9') {
                tipText = "La puerta cubre la mitad del lateral (9mm). Ideal cuando dos puertas continuas se abren opuestas y comparten el lateral central.";
                title = "🚪 Bisagra Codo 9 (Semi-superpuesta)";
                if (tipDiv) tipDiv.style.borderLeftColor = '#f59e0b';
            } else if (type === 'codo_18') {
                tipText = "La puerta queda adentro del mueble, al ras de los bordes. Deja ver los cantos melamínicos de los laterales.";
                title = "🚪 Bisagra Codo 18 (Embutida)";
                if (tipDiv) tipDiv.style.borderLeftColor = '#10b981';
            }

            textSpan.innerHTML = `<strong>${title}</strong><br>${tipText}`;
        },

        updateDrawerEducation: function(isMobile = false) {
            const prefix = isMobile ? '-mobile' : '';
            const drawersVal = parseInt(document.getElementById(`mod-drawers${prefix}`).value) || 0;
            const tipDiv = document.getElementById('edu-drawer-tip');

            if (!tipDiv) return;

            if (drawersVal > 0) {
                tipDiv.classList.remove('hidden');
            } else {
                tipDiv.classList.add('hidden');
            }
        },

        // Métodos para Bottom Sheets móviles
        openMobileSheet: function(name) {
            this.closeMobileSheets();
            const sheet = document.getElementById(`sheet-${name}`);
            const btn = document.getElementById(`mbtn-${name}`);
            if (sheet) sheet.classList.add('active');
            if (btn) btn.classList.add('active');
        },

        closeMobileSheets: function() {
            document.querySelectorAll('.bottom-sheet').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.bottom-action-btn').forEach(b => b.classList.remove('active'));
        },

        addModule: function(isMobile = false) {
            const prefix = isMobile ? '-mobile' : '';
            const nameInputVal = document.getElementById(`mod-name${prefix}`)?.value || `Modulo A${this.state.modules.length + 1}`;
            const type = document.getElementById(`mod-type${prefix}`).value;
            const dims = {
                alto: parseInt(document.getElementById(`mod-h${prefix}`).value) || 800,
                ancho: parseInt(document.getElementById(`mod-w${prefix}`).value) || 600,
                prof: parseInt(document.getElementById(`mod-p${prefix}`).value) || 500,
                n_cajones: parseInt(document.getElementById(`mod-drawers${prefix}`).value) || 0,
                n_puertas: parseInt(document.getElementById(`mod-doors${prefix}`).value) || 0,
                n_estantes: parseInt(document.getElementById(`mod-shelves${prefix}`).value) || 0
            };
            
            const hingeSelect = document.getElementById(`mod-hinge-type${prefix}`);
            const hingeType = hingeSelect ? hingeSelect.value : 'codo_0';

            const newId = Date.now();
            this.state.modules.push({ id: newId, type, name: nameInputVal, dims, hingeType });
            this.state.activeModuleId = newId; // Activar el módulo
            
            // Auto-increment module name for the next module
            const nextName = `Modulo A${this.state.modules.length + 1}`;
            const dNameInput = document.getElementById('mod-name');
            const mNameInput = document.getElementById('mod-name-mobile');
            if (dNameInput) dNameInput.value = nextName;
            if (mNameInput) mNameInput.value = nextName;

            if (isMobile) {
                this.closeMobileSheets();
            }
            this.renderConstructor();
        },

        removeModule: function(id) {
            this.state.modules = this.state.modules.filter(m => m.id !== id);
            
            // Si el módulo borrado era el activo, activar el último de la lista
            if (this.state.activeModuleId === id) {
                if (this.state.modules.length > 0) {
                    const lastMod = this.state.modules[this.state.modules.length - 1];
                    this.selectModule(lastMod.id);
                } else {
                    this.state.activeModuleId = null;
                }
            }
            
            // Adjust next name index accordingly
            const nextName = `Modulo A${this.state.modules.length + 1}`;
            const dNameInput = document.getElementById('mod-name');
            const mNameInput = document.getElementById('mod-name-mobile');
            if (dNameInput) dNameInput.value = nextName;
            if (mNameInput) mNameInput.value = nextName;

            this.renderConstructor();
        },

        selectModule: function(id) {
            this.state.activeModuleId = id;
            const m = this.state.modules.find(mod => mod.id === id);
            if (m) {
                // Rellenar controles Desktop
                document.getElementById('mod-name').value = m.name;
                document.getElementById('mod-type').value = m.type;
                document.getElementById('mod-h').value = m.dims.alto;
                document.getElementById('mod-w').value = m.dims.ancho;
                document.getElementById('mod-p').value = m.dims.prof;
                document.getElementById('mod-drawers').value = m.dims.n_cajones;
                document.getElementById('mod-doors').value = m.dims.n_puertas;
                document.getElementById('mod-shelves').value = m.dims.n_estantes;
                const hingeSelect = document.getElementById('mod-hinge-type');
                if (hingeSelect) hingeSelect.value = m.hingeType;
                
                // Rellenar controles Mobile
                document.getElementById('mod-name-mobile').value = m.name;
                document.getElementById('mod-type-mobile').value = m.type;
                document.getElementById('mod-h-mobile').value = m.dims.alto;
                document.getElementById('mod-w-mobile').value = m.dims.ancho;
                document.getElementById('mod-p-mobile').value = m.dims.prof;
                document.getElementById('mod-drawers-mobile').value = m.dims.n_cajones;
                document.getElementById('mod-doors-mobile').value = m.dims.n_puertas;
                document.getElementById('mod-shelves-mobile').value = m.dims.n_estantes;
                const hingeSelectMobile = document.getElementById('mod-hinge-type-mobile');
                if (hingeSelectMobile) hingeSelectMobile.value = m.hingeType;
                
                this.updateHingeVisibility();
                this.updateDrawerEducation();
            }
            this.renderConstructor();
        },

        updateActiveModule: function(isMobile = false) {
            if (!this.state.activeModuleId) return;
            const m = this.state.modules.find(mod => mod.id === this.state.activeModuleId);
            if (!m) return;
            
            const prefix = isMobile ? '-mobile' : '';
            const nameVal = document.getElementById(`mod-name${prefix}`)?.value || m.name;
            const typeVal = document.getElementById(`mod-type${prefix}`).value;
            const hVal = parseInt(document.getElementById(`mod-h${prefix}`).value) || 800;
            const wVal = parseInt(document.getElementById(`mod-w${prefix}`).value) || 600;
            const pVal = parseInt(document.getElementById(`mod-p${prefix}`).value) || 500;
            const drawersVal = parseInt(document.getElementById(`mod-drawers${prefix}`).value) || 0;
            const doorsVal = parseInt(document.getElementById(`mod-doors${prefix}`).value) || 0;
            const shelvesVal = parseInt(document.getElementById(`mod-shelves${prefix}`).value) || 0;
            const hingeSelect = document.getElementById(`mod-hinge-type${prefix}`);
            const hingeVal = hingeSelect ? hingeSelect.value : 'codo_0';
            
            m.name = nameVal;
            m.type = typeVal;
            m.dims.alto = hVal;
            m.dims.ancho = wVal;
            m.dims.prof = pVal;
            m.dims.n_cajones = drawersVal;
            m.dims.n_puertas = doorsVal;
            m.dims.n_estantes = shelvesVal;
            m.hingeType = hingeVal;
            
            // Sincronizar formulario opuesto
            const otherPrefix = isMobile ? '' : '-mobile';
            const oName = document.getElementById(`mod-name${otherPrefix}`);
            const oType = document.getElementById(`mod-type${otherPrefix}`);
            const oH = document.getElementById(`mod-h${otherPrefix}`);
            const oW = document.getElementById(`mod-w${otherPrefix}`);
            const oP = document.getElementById(`mod-p${otherPrefix}`);
            const oDrawers = document.getElementById(`mod-drawers${otherPrefix}`);
            const oDoors = document.getElementById(`mod-doors${otherPrefix}`);
            const oShelves = document.getElementById(`mod-shelves${otherPrefix}`);
            const oHinge = document.getElementById(`mod-hinge-type${otherPrefix}`);
            
            if (oName) oName.value = nameVal;
            if (oType) oType.value = typeVal;
            if (oH) oH.value = hVal;
            if (oW) oW.value = wVal;
            if (oP) oP.value = pVal;
            if (oDrawers) oDrawers.value = drawersVal;
            if (oDoors) oDoors.value = doorsVal;
            if (oShelves) oShelves.value = shelvesVal;
            if (oHinge && hingeSelect) oHinge.value = hingeVal;
            
            // Actualizar listados HTML de capas sin destruir eventos
            const list = document.getElementById('module-list');
            const listMobile = document.getElementById('module-list-mobile');
            
            const html = this.state.modules.map(mod => {
                const isActive = mod.id === this.state.activeModuleId;
                return `
                <div onclick="window.cubical.selectModule(${mod.id})" class="bg-[var(--sc-surface)] border-2 ${isActive ? 'border-[var(--alvarez-red)] shadow-md' : 'border-[var(--sc-border)]'} p-5 rounded-lg flex justify-between items-center group hover:border-[var(--alvarez-red)] transition-all cursor-pointer">
                    <div>
                        <div class="text-[0.6rem] font-black text-[var(--alvarez-red)] uppercase">${mod.name || mod.type.replace('_',' ')}</div>
                        <div class="text-sm font-black text-[var(--sc-text)]">${mod.dims.alto}x${mod.dims.ancho}x${mod.dims.prof} <span class="text-[0.6rem] font-normal text-[var(--sc-text-dim)]">mm</span></div>
                        <div class="text-[0.6rem] text-[var(--sc-text-dim)] font-bold mt-1">
                            ${mod.dims.n_estantes > 0 ? `Estantes: ${mod.dims.n_estantes} ` : ''}
                            ${mod.dims.n_cajones > 0 ? `Cajones: ${mod.dims.n_cajones} ` : ''}
                            ${mod.dims.n_puertas > 0 ? `Puertas: ${mod.dims.n_puertas} (${mod.hingeType.toUpperCase()}) ` : ''}
                            ${(mod.dims.n_estantes == 0 && mod.dims.n_cajones == 0 && mod.dims.n_puertas == 0) ? 'Módulo Vacío' : ''}
                        </div>
                    </div>
                    <button onclick="event.stopPropagation(); window.cubical.removeModule(${mod.id})" class="w-10 h-10 bg-[var(--sc-surface-alt)] rounded flex items-center justify-center text-[var(--sc-text-dim)] hover:bg-[var(--alvarez-red)] hover:text-white transition-all shadow-sm">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            `;}).join('');
            
            if (list) list.innerHTML = html;
            if (listMobile) listMobile.innerHTML = html;
            
            this.renderPreview();
        },

        renderConstructor: function() {
            const list = document.getElementById('module-list');
            const listMobile = document.getElementById('module-list-mobile');

            const html = this.state.modules.length === 0 
                ? '<div class="text-center py-8 text-[var(--sc-text-dim)] font-bold text-[0.6rem] uppercase opacity-40">Sin módulos añadidos</div>'
                : this.state.modules.map(m => {
                const isActive = m.id === this.state.activeModuleId;
                return `
                <div onclick="window.cubical.selectModule(${m.id})" class="bg-[var(--sc-surface)] border-2 ${isActive ? 'border-[var(--alvarez-red)] shadow-md' : 'border-[var(--sc-border)]'} p-5 rounded-lg flex justify-between items-center group hover:border-[var(--alvarez-red)] transition-all cursor-pointer">
                    <div>
                        <div class="text-[0.6rem] font-black text-[var(--alvarez-red)] uppercase">${m.name || m.type.replace('_',' ')}</div>
                        <div class="text-sm font-black text-[var(--sc-text)]">${m.dims.alto}x${m.dims.ancho}x${m.dims.prof} <span class="text-[0.6rem] font-normal text-[var(--sc-text-dim)]">mm</span></div>
                        <div class="text-[0.6rem] text-[var(--sc-text-dim)] font-bold mt-1">
                            ${m.dims.n_estantes > 0 ? `Estantes: ${m.dims.n_estantes} ` : ''}
                            ${m.dims.n_cajones > 0 ? `Cajones: ${m.dims.n_cajones} ` : ''}
                            ${m.dims.n_puertas > 0 ? `Puertas: ${m.dims.n_puertas} (${m.hingeType.toUpperCase()}) ` : ''}
                            ${(m.dims.n_estantes == 0 && m.dims.n_cajones == 0 && m.dims.n_puertas == 0) ? 'Módulo Vacío' : ''}
                        </div>
                    </div>
                    <button onclick="event.stopPropagation(); window.cubical.removeModule(${m.id})" class="w-10 h-10 bg-[var(--sc-surface-alt)] rounded flex items-center justify-center text-[var(--sc-text-dim)] hover:bg-[var(--alvarez-red)] hover:text-white transition-all shadow-sm">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            `;}).join('');
            
            if (list) list.innerHTML = html;
            if (listMobile) listMobile.innerHTML = html;
            
            const count = this.state.modules.length;
            const tmods = document.getElementById('stat-total-mods');
            const tmodsMob = document.getElementById('stat-total-mods-mobile');
            
            if (tmods) tmods.textContent = count;
            if (tmodsMob) tmodsMob.textContent = count;
            
            this.renderPreview();
        },

        renderPreview: function() {
            const isDark = document.body.getAttribute('data-theme') === 'dark' || document.body.classList.contains('body-theme-dark');
            const spacing = 120;
            const count = this.state.modules.length;
            const selectedMelamina = this.state.selectedMelamina || 'faplac_roble';
            const palette = MELAMINA_PALETTES[selectedMelamina];
            
            const drawOnCanvas = (canvasId, renderer) => {
                const canvas = document.getElementById(canvasId);
                if (!canvas || !renderer) return;
                const ctx = canvas.getContext('2d');
                const rect = canvas.parentNode.getBoundingClientRect();
                
                canvas.width = rect.width || 800;
                canvas.height = canvasId.includes('mobile') ? 400 : 500;
                
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                
                // Grilla de fondo CAD
                ctx.strokeStyle = isDark ? 'rgba(255,255,255,0.03)' : 'rgba(0,0,0,0.03)';
                ctx.lineWidth = 1;
                const step = 20;
                for (let x = 0; x < canvas.width; x += step) {
                    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); ctx.stroke();
                }
                for (let y = 0; y < canvas.height; y += step) {
                    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(canvas.width, y); ctx.stroke();
                }
                
                if (count === 0) {
                    renderer.scale = 0.22;
                    renderer.drawBox(600, 800, 500, {
                        color: isDark ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0,0,0,0.1)',
                        fillColor: 'rgba(0, 0, 0, 0)',
                        lineWidth: 1.5,
                        drawPanelThickness: false,
                        palette: palette
                    });
                    
                    ctx.fillStyle = isDark ? 'rgba(255,255,255,0.3)' : 'rgba(0,0,0,0.3)';
                    ctx.font = 'bold 11px monospace';
                    ctx.textAlign = 'center';
                    ctx.fillText("VISTA 3D EN TIEMPO REAL — ARRASTRA CON EL MOUSE PARA ROTAR", canvas.width/2, canvas.height/2 + 150);
                    return;
                }
                
                // Buscar el módulo activo para renderizar solo ese (como pidió el usuario)
                const m = this.state.modules.find(mod => mod.id === this.state.activeModuleId) || this.state.modules[this.state.modules.length - 1];
                if (!m) return;
                
                // Calcular escala para el módulo único (centrado y maximizado en pantalla)
                const scaleX = (canvas.width * 0.45) / m.dims.ancho;
                const scaleY = (canvas.height * 0.50) / m.dims.alto;
                renderer.scale = Math.min(canvasId.includes('mobile') ? 0.22 : 0.35, Math.min(scaleX, scaleY));
                
                const boxColor = palette ? palette.lineColor : (isDark ? 'oklch(62.8% 0.25 29.23)' : '#000000');
                const boxFill = palette ? palette.fillColor : (isDark ? 'rgba(215, 40, 40, 0.03)' : 'rgba(0, 0, 0, 0.01)');
                
                renderer.drawBox(m.dims.ancho, m.dims.alto, m.dims.prof, {
                    offsetX: 0,
                    color: boxColor,
                    fillColor: boxFill,
                    lineWidth: 1.0, // Líneas finas SketchUp style
                    drawPanelThickness: true,
                    shelves: m.dims.n_estantes || 0,
                    drawers: m.dims.n_cajones || 0,
                    doors: m.dims.n_puertas || 0,
                    type: m.type,
                    palette: palette
                });
                
                // Medidas en 3D del módulo único
                const labelPos = renderer.project(m.dims.ancho/2, -45, 0, m.dims.ancho, m.dims.alto, m.dims.prof, canvas.width, canvas.height);
                ctx.fillStyle = isDark ? 'rgba(255,255,255,0.4)' : 'rgba(0,0,0,0.6)';
                ctx.font = 'bold 9px monospace';
                ctx.textAlign = 'center';
                ctx.fillText(`${m.dims.ancho}x${m.dims.alto}x${m.dims.prof} mm`, labelPos.x, labelPos.y);
            };

            drawOnCanvas('canvas-preview', this.renderer);
            drawOnCanvas('canvas-preview-mobile', this.rendererMobile);
        },

        generateResults: async function() {
            if (this.state.modules.length === 0) { alert("⚠️ Añade al menos un módulo al plano."); return; }
            this.showScreen('results');
            
            try {
                // Importación dinámica de motores
                const optEngine = await import('/herramientas/logic/cubical/engine.js?v=' + Date.now());
                const hwEngine = await import('/herramientas/logic/cubical/hardware.js?v=' + Date.now());
                
                let allPieces = [];
                this.state.modules.forEach(m => {
                    const pieces = optEngine.calculateModulePieces(m.type, m.dims, 18);
                    allPieces = allPieces.concat(pieces);
                });
                
                // Filtrar melamina de 18mm
                const melaminaPieces = allPieces.filter(p => !p.isBackground).map(p => ({
                    name: p.name,
                    h: p.h,
                    w: p.w,
                    qty: p.qty
                }));
                
                const board = { w: 2750, h: 1820 };
                const optResults = optEngine.optimizeBoards(melaminaPieces, board, 4);
                
                // Calcular herrajes e insumos
                const realHardware = hwEngine.calculateTotalHardware(this.state.modules);
                
                this.state.results = {
                    opt: optResults,
                    hw: realHardware,
                    pieces: allPieces
                };
                
                this.renderResults();
            } catch (e) {
                console.error("[CubiCal] Error ejecutando optimización:", e);
                alert("⚠️ Error al optimizar el despiece. Revisa los datos de tus módulos.");
            }
        },

        exportToSmartCut: function() {
            if (!this.state.results || !this.state.results.pieces) {
                alert("⚠️ Por favor optimiza el cálculo primero.");
                return;
            }
            
            // Filtrar melamina de 18mm (no fondos traseros MDF de 3mm)
            const melaminaPieces = this.state.results.pieces.filter(p => !p.isBackground).map(p => ({
                nombre: p.name,
                alto: p.h || p.alto || 800, // Safe fallbacks
                ancho: p.w || p.ancho || 600,
                cantidad: p.qty || 1,
                tapacanto_h: "none", // Tapacantos default
                tapacanto_w: "none",
                veta: "indiferente"
            }));
            
            // Guardar en sessionStorage
            sessionStorage.setItem('cubical_despiece', JSON.stringify({
                projectName: this.state.projectName,
                thickness: 18,
                pieces: melaminaPieces
            }));
            
            // Redirigir a SmartCut
            window.location.href = '/herramientas/presupuestador';
        },

        renderResults: function() {
            const { opt, hw } = this.state.results;
            
            // Stats principales
            document.getElementById('res-boards-stats').innerHTML = `
                <div class="bg-[var(--sc-surface-alt)] p-6 rounded-lg border border-[var(--sc-border)] shadow-inner">
                    <div class="text-[0.55rem] font-black text-[var(--sc-text-dim)] uppercase mb-2">PLACAS (18mm)</div>
                    <div class="text-3xl font-black text-[var(--alvarez-red)]">${opt.stats.count}</div>
                </div>
                <div class="bg-[var(--sc-surface-alt)] p-6 rounded-lg border border-[var(--sc-border)] shadow-inner">
                    <div class="text-[0.55rem] font-black text-[var(--sc-text-dim)] uppercase mb-2">EFICIENCIA</div>
                    <div class="text-3xl font-black text-[var(--sc-text)]">${opt.stats.efficiency}%</div>
                </div>
                <div class="bg-[var(--sc-surface-alt)] p-6 rounded-lg border border-[var(--sc-border)] shadow-inner">
                    <div class="text-[0.55rem] font-black text-[var(--sc-text-dim)] uppercase mb-2">M2 TOTAL</div>
                    <div class="text-3xl font-black text-[var(--alvarez-blue)]">${opt.stats.totalM2}</div>
                </div>
            `;
            
            // Placas
            document.getElementById('res-boards-list').innerHTML = opt.boards.map(b => {
                return `
                    <div class="bg-[var(--sc-surface-alt)] p-5 rounded-lg border border-[var(--sc-border)] flex justify-between items-center group">
                        <div>
                            <div class="text-xs font-black text-[var(--sc-text)] uppercase">Placa Entera Faplac #${b.id}</div>
                            <div class="text-[0.65rem] text-[var(--sc-text-dim)] font-bold mt-1">Dimensión: 2750 x 1820 mm • ${b.shelves.length} Fila(s) de corte agrupado</div>
                        </div>
                        <div class="text-right">
                            <span class="text-[0.55rem] font-black bg-[var(--sc-surface)] border border-[var(--sc-border)] text-[var(--sc-text-dim)] px-2.5 py-1.5 rounded uppercase tracking-wider">Optimizado</span>
                        </div>
                    </div>
                `;
            }).join('');
            
            // Listado de herrajes
            document.getElementById('res-hardware-list').innerHTML = hw.map(h => `
                <tr class="group hover:bg-[var(--sc-surface-alt)] transition-all">
                    <td class="py-4 font-bold text-[var(--sc-text)] text-xs border-b border-[var(--sc-border)] group-hover:pl-2 transition-all">${h.name}</td>
                    <td class="py-4 font-black text-[var(--alvarez-red)] text-right border-b border-[var(--sc-border)]">${h.qty}</td>
                    <td class="py-4 text-[0.65rem] font-bold text-[var(--sc-text-dim)] uppercase text-right border-b border-[var(--sc-border)]">${h.unit}</td>
                </tr>
            `).join('');

            // Informe de Ensamblaje Didáctico
            let assemblyHTML = '';
            this.state.modules.forEach(m => {
                assemblyHTML += `<div class="p-6 bg-[var(--sc-surface-alt)] rounded-lg border border-[var(--sc-border)] mb-4">
                    <h4 class="text-lg font-black text-[var(--alvarez-red)] uppercase mb-4">Módulo: ${m.name || m.type}</h4>
                    <ul class="list-decimal pl-6 space-y-3 font-medium text-[var(--sc-text)]">`;
                
                if (m.type === 'ESCRITORIO') {
                    assemblyHTML += `
                        <li><strong>Estructura Base:</strong> Atornilla el Faldón Trasero (Modesty Panel) al Lateral Izquierdo y al Divisor Interno de la cajonera para darle rigidez.</li>
                        <li><strong>Cajonera Derecha:</strong> Ensambla la estructura de la cajonera fijando el Piso entre el Divisor Interno y el Lateral Derecho.</li>
                        <li><strong>Tapa:</strong> Coloca el Techo/Tapa apoyando horizontalmente <strong>sobre</strong> los laterales y atornilla desde abajo para que no se vean los tornillos Fix.</li>
                        <li><strong>Correderas:</strong> Fija las correderas telescópicas (Greenway/Bronzen) en los laterales de la cajonera. Recuerda que ya descontamos 26mm al ancho del cajón interior.</li>
                        <li><strong>Bandeja Teclado:</strong> Instala las guías de la bandeja debajo del techo en la sección izquierda.</li>
                    `;
                } else {
                    assemblyHTML += `
                        <li><strong>Armado de Carcasa:</strong> Atornilla los Laterales. Recuerda que el <strong>Techo siempre apoya sobre los laterales</strong> para descargar el peso al piso.</li>
                        <li><strong>Escuadra:</strong> Presenta el Fondo de MDF de 3mm y clávalo para dar escuadra al módulo.</li>`;
                    
                    if (m.dims.n_cajones > 0) {
                        assemblyHTML += `<li><strong>Cajones:</strong> Arma las cajas de los cajones. Las correderas telescópicas requieren 13mm libres por lado (26mm en total). Ya están calculadas en las medidas.</li>`;
                    }
                    if (m.dims.n_puertas > 0) {
                        assemblyHTML += `<li><strong>Puertas:</strong> Instala las bisagras Codo 0 (Greenway/Bronzen) a 10cm de los extremos superior e inferior.</li>`;
                    }
                    if (m.type === 'BAJO_MESADA') {
                        assemblyHTML += `<li><strong>Zócalo:</strong> Fija el zócalo base retranqueado para permitir el espacio de los pies (kicktoe).</li>`;
                    }
                }
                assemblyHTML += `</ul></div>`;
            });
            
            document.getElementById('res-assembly-guide').innerHTML = assemblyHTML;
        },

        renderDashboard: function() {
            const grid = document.getElementById('projects-grid');
            if (this.state.projects.length === 0) {
                grid.innerHTML = '<div class="col-span-2 py-20 text-center border-2 border-dashed border-[var(--sc-border)] rounded-xl text-[var(--sc-text-dim)] font-black uppercase tracking-[0.3em] opacity-30">No hay registros previos</div>';
                return;
            }
            grid.innerHTML = this.state.projects.map(p => `
                <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-8 rounded-xl hover:border-[var(--alvarez-red)] transition-all cursor-pointer group shadow-sm">
                    <div class="flex justify-between mb-6">
                        <div class="w-12 h-12 bg-[var(--sc-surface-alt)] rounded-lg flex items-center justify-center text-[var(--alvarez-red)] group-hover:bg-[var(--alvarez-red)] group-hover:text-white transition-all shadow-sm">
                            <i class="fas fa-folder-open text-xl"></i>
                        </div>
                        <span class="text-[0.55rem] font-black bg-[var(--sc-surface-alt)] px-3 py-1.5 rounded text-[var(--sc-text-dim)] uppercase tracking-widest border border-[var(--sc-border)]">${p.status || 'FINALIZADO'}</span>
                    </div>
                    <h4 class="text-xl font-black text-[var(--sc-text)] uppercase tracking-tighter mb-2">${p.nombre_proyecto}</h4>
                    <div class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase tracking-widest">${p.tipo_ambiente || 'PERSONALIZADO'} • ${p.total_m2_placa || '0.0'} M2</div>
                </div>
            `).join('');
        },

        saveProject: async function(isQuote = false) {
            const payload = {
                clientId: CLIENT_ID,
                name: this.state.projectName,
                env: this.state.environment,
                modules: this.state.modules,
                results: this.state.results,
                isQuote
            };
            try {
                const response = await fetch('/api/herramientas/save-cubical', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const res = await response.json();
                if (res.success) {
                    alert(isQuote ? "🚀 SOLICITUD ENVIADA. Un asesor técnico revisará tu despiece." : "💾 PROYECTO GUARDADO CORRECTAMENTE.");
                    this.loadProjects();
                    this.showScreen('dashboard');
                }
            } catch (e) {
                alert("⚠️ Error de conexión con el servidor.");
            }
        }
    };

    // Iniciar
    document.addEventListener('astro:page-load', () => window.cubical.init());
    window.cubical.init();
</script>

