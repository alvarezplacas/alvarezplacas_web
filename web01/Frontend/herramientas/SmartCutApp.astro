    <style is:global>
        /* ESTILOS DE IMPRESIÓN INDUSTRIAL */
        @media print {
            body * { visibility: hidden; }
            .print-only, .print-only * { visibility: visible; }
            .print-only { position: absolute; left: 0; top: 0; width: 100%; }
            .print-page { padding: 30px; page-break-after: always; background: white; color: #000; min-height: 297mm; }
            .print-header { display: flex; justify-content: space-between; border-bottom: 2.5px solid #000; padding-bottom: 12px; margin-bottom: 15px; }
            .header-left .brand { font-size: 2rem; font-weight: 900; letter-spacing: -1px; text-transform: uppercase; line-height: 1; }
            .header-left .info { font-size: 0.7rem; font-weight: 700; margin-top: 2px; }
            .header-center { text-align: center; }
            .header-center .vendedor { font-size: 1rem; font-weight: 900; margin-bottom: 3px; }
            .header-center .date-time { font-size: 0.75rem; font-weight: 700; }
            .header-right { text-align: right; }
            .header-right .page-num { font-size: 0.85rem; font-weight: 900; }
            .header-right .order-num { font-size: 0.85rem; font-weight: 900; margin-top: 3px; }
            .print-summary-bar { background: #f5f5f5; padding: 10px; font-size: 1.1rem; font-weight: 900; text-align: center; border: 2px solid #000; margin-bottom: 15px; }
            
            /* Plano sin recuadro y bien centrado */
            .print-layout-box-clean { border: none; padding: 0; margin-bottom: 15px; display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; }
            .layout-title-clean { font-size: 0.9rem; font-weight: 900; margin-bottom: 10px; text-align: left; width: 100%; align-self: flex-start; text-transform: uppercase; }
            .print-layout-box-clean canvas { display: block; margin: 0 auto; max-width: 100%; height: auto !important; }
            
            /* Columnas de reporte */
            .print-columns-container { display: flex; gap: 25px; margin-top: 15px; align-items: flex-start; width: 100%; }
            .print-column-left { flex: 1.8; }
            .print-column-right { flex: 1.2; background: #fafafa; border: 2px solid #000; padding: 12px; border-radius: 4px; }
            .table-title-clean { font-size: 0.85rem; font-weight: 900; text-transform: uppercase; border-bottom: 1.5px solid #000; padding-bottom: 6px; margin-bottom: 8px; letter-spacing: 0.5px; }
            
            /* Grilla compacta por renglón sin bordes de celda */
            .print-table { width: 100%; border-collapse: collapse; }
            .print-table th { border-bottom: 1.5px solid #000; padding: 4px 6px; font-size: 0.7rem; font-weight: 800; text-align: left; background: transparent; }
            .print-table td { border-bottom: 1px solid #ddd; padding: 4px 6px; font-size: 0.75rem; font-weight: 700; color: #111; }
            
            /* Tapacantos del Operador */
            .print-edges-summary { display: flex; flex-direction: column; gap: 6px; }
            .print-edge-row { display: flex; align-items: center; justify-content: space-between; border-bottom: 1px dashed #ccc; padding-bottom: 6px; margin-bottom: 2px; }
            .print-edge-row:last-child { border-bottom: none; }
            .edge-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 8px; border: 1px solid #000; flex-shrink: 0; }
            .edge-dot.thick-045 { background-color: #25d366 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .edge-dot.thick-1 { background-color: #007aff !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .edge-dot.thick-2 { background-color: #ff2800 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .edge-info { display: flex; flex-direction: column; flex-grow: 1; text-align: left; }
            .edge-thickness { font-size: 0.75rem; font-weight: 900; }
            .edge-color { font-size: 0.55rem; color: #444; font-weight: 700; margin-top: 1px; }
            .edge-meters { font-size: 0.85rem; font-weight: 900; }
            
            .print-footer { border-top: 2px solid #000; margin-top: 30px; padding-top: 10px; display: flex; gap: 30px; font-size: 0.8rem; font-weight: 900; text-transform: uppercase; }
        }
        .print-only { display: none; }
        @media print { .print-only { display: block; } }
    </style>

