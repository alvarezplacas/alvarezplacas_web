---
const { isLoggedIn = false } = Astro.props;
---
<style is:inline>
    :root {
        --alvarez-red: oklch(62.8% 0.25 29.23);
        --font-mono: 'JetBrains Mono', monospace;
        
        /* Tema Claro / Hueso (Default Industrial) */
        --sc-bg: #f5f5ed;
        --sc-surface: #ffffff;
        --sc-surface-alt: #fcfcfc;
        --sc-text: #1a1a1c;
        --sc-text-dim: #666;
        --sc-border: rgba(0,0,0,0.1);
        --sc-input-bg: #fff;
        --glass-bg: rgba(0,0,0,0.03);
    }

    [data-theme="dark"] {
        --sc-bg: oklch(8% 0.01 280);
        --sc-surface: #0a0a0c;
        --sc-surface-alt: #0d0d0f;
        --sc-text: oklch(98% 0.01 280);
        --sc-text-dim: oklch(60% 0 0);
        --sc-border: oklch(100% 0 0 / 8%);
        --sc-input-bg: #000;
        --glass-bg: oklch(100% 0 0 / 4%);
    }

    body { background: var(--sc-bg); color: var(--sc-text); font-family: 'Inter', sans-serif; margin: 0; transition: background 0.3s, color 0.3s; }

    .smart-bar { background: var(--sc-surface); padding: 12px 40px; border-bottom: 1px solid var(--sc-border); display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 100; }
    .smart-label { font-size: 0.65rem; font-weight: 900; color: var(--alvarez-red); letter-spacing: 2px; }

    .container-sc { padding: 30px 40px; max-width: 1600px; margin: 0 auto; position: relative; min-height: 80vh; }

    .btn-main { 
        background: var(--glass-bg); 
        backdrop-filter: blur(10px);
        color: white; 
        border: 1px solid var(--alvarez-border);
        padding: 12px 25px; 
        border-radius: 6px;
        font-weight: 900; 
        cursor: pointer; 
        display: inline-flex; 
        align-items: center; 
        justify-content: center;
        gap: 10px; 
        text-transform: uppercase;
        transition: 0.3s;
        font-size: 0.7rem;
    }
    .btn-main:hover { background: var(--alvarez-red); border-color: var(--alvarez-red); transform: translateY(-1px); }

    /* STRATEGY PANEL GLASS STYLES */
    .strategy-panel-industrial { 
        display: flex; 
        gap: 15px; 
        background: oklch(100% 0 0 / 2%); 
        padding: 15px 25px; 
        border-radius: 16px; 
        margin-top: 25px; 
        align-items: center;
        border: 1px solid var(--alvarez-border);
        box-shadow: 0 10px 30px oklch(0% 0 0 / 20%);
    }
    .btn-strategy, .btn-action-glass {
        width: 55px;
        height: 55px;
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        border: 1px solid var(--alvarez-border);
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.2s cubic-bezier(0.23, 1, 0.32, 1);
        color: oklch(60% 0 0);
        font-size: 1.1rem;
        gap: 4px;
    }
    .btn-strategy span, .btn-action-glass span { font-size: 0.5rem; font-weight: 800; text-transform: uppercase; }
    
    .btn-strategy:hover, .btn-action-glass:hover { background: oklch(100% 0 0 / 8%); color: #fff; transform: translateY(-2px); border-color: oklch(100% 0 0 / 20%); }
    .btn-strategy.active { background: var(--alvarez-red); color: #fff; border-color: var(--alvarez-red); box-shadow: 0 0 25px oklch(62.8% 0.25 29.23 / 40%); }
    
    .btn-action-glass.save, .btn-action-glass.budget { border-color: oklch(70% 0.15 140 / 30%); color: oklch(70% 0.15 140); }
    @media (min-width: 901px) {
        .btn-action-glass.save, .btn-action-glass.budget { 
            width: auto; 
            padding: 0 25px; 
            flex-direction: row; 
            gap: 12px; 
        }
        .btn-action-glass.save span, .btn-action-glass.budget span { font-size: 0.75rem; letter-spacing: 1.5px; }
    }
    .btn-action-glass.save:hover, .btn-action-glass.budget:hover { background: oklch(70% 0.15 140 / 20%); color: oklch(90% 0.1 140); }

    .strategy-info-text { font-size: 0.65rem; color: oklch(60% 0 0); line-height: 1.4; flex: 1; border-left: 1px solid var(--alvarez-border); padding-left: 20px; }
    .strategy-info-text strong { color: oklch(80% 0 0); display: block; margin-bottom: 2px; text-transform: uppercase; letter-spacing: 1px; }

    .config-panel {
        background: var(--sc-surface);
        border-left: 1px solid var(--sc-border);
        width: 400px;
        position: fixed;
        right: -400px;
        top: 0;
        bottom: 0;
        z-index: 2000;
        padding: 40px;
        transition: 0.5s cubic-bezier(0.19, 1, 0.22, 1);
        box-shadow: -30px 0 60px rgba(0,0,0,0.4);
    }
    .config-panel.open { right: 0; }
    .config-section { margin-bottom: 35px; }
    .config-title { font-size: 0.7rem; font-weight: 900; color: var(--sc-text-dim); text-transform: uppercase; margin-bottom: 20px; letter-spacing: 1.5px; border-bottom: 1px solid var(--sc-border); padding-bottom: 10px; }

    input, select { width: 100%; background: var(--sc-input-bg); border: 1px solid var(--sc-border); color: var(--sc-text); padding: 12px; border-radius: 4px; font-family: var(--font-mono); font-size: 0.85rem; transition: 0.3s; }
    input:focus { border-color: var(--alvarez-red); outline: none; }
    label { display: block; font-size: 0.6rem; color: var(--sc-text-dim); font-weight: 900; margin-bottom: 8px; text-transform: uppercase; }

    .stats-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin-bottom: 30px; }
    .stat-item { background: var(--sc-surface); border: 1px solid var(--sc-border); padding: 20px; border-radius: 8px; text-align: left; }
    .stat-item span { display: block; font-size: 0.6rem; font-weight: 900; color: var(--sc-text-dim); margin-bottom: 5px; text-transform: uppercase; }
    .stat-item strong { font-size: 1.2rem; font-family: var(--font-mono); color: var(--sc-text); }

    /* INDUSTRIAL VISUALIZER STYLES */
    .plate-view-wrap { background: var(--sc-surface-alt); border: 1px solid var(--sc-border); border-radius: 12px; overflow: hidden; margin-top: 20px; }
    .plate-header-industrial { background: var(--sc-surface); padding: 15px 25px; border-bottom: 1px solid var(--sc-border); display: flex; justify-content: space-between; align-items: center; }
    .plate-title { font-size: 0.9rem; font-weight: 900; color: var(--alvarez-red); text-transform: uppercase; }
    .plate-subtitle { font-size: 0.6rem; color: var(--sc-text-dim); font-weight: 800; text-transform: uppercase; }
    
    .industrial-canvas { display: block; margin: 20px auto; border: 1px solid var(--sc-border); background: #000; }

    .industrial-stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--sc-border); border-top: 1px solid var(--sc-border); }
    .stats-group { background: var(--sc-surface); padding: 20px 25px; }
    .stat-main { margin-bottom: 15px; }
    .stat-main span { display: block; font-size: 0.55rem; font-weight: 900; color: var(--sc-text-dim); margin-bottom: 2px; }
    .stat-main strong { font-size: 1.1rem; font-family: var(--font-mono); color: var(--sc-text); }
    
    .edge-stat { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid var(--sc-border); }
    .edge-stat span { font-size: 0.65rem; color: var(--sc-text-dim); font-weight: 600; }
    .edge-stat strong { font-size: 0.8rem; font-family: var(--font-mono); color: #25d366; }

    .hidden { display: none !important; }
    .animate-in { animation: industrialFade 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    @keyframes industrialFade { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    .lepton-form { background: oklch(100% 0 0 / 2%); border: 1px solid var(--alvarez-border); padding: 25px; border-radius: 16px; margin-bottom: 30px; }
    .lepton-row { display: grid; grid-template-columns: 100px 1fr 1fr 2fr 80px; gap: 15px; align-items: end; }
    
    @media (max-width: 900px) {
        .lepton-row { grid-template-columns: 1fr 1fr; gap: 15px; }
        .lepton-row > div:nth-child(4) { grid-column: span 2; }
        .container-sc { padding: 15px; }
        .smart-bar { padding: 10px 20px; }
        .strategy-panel-industrial { flex-direction: column; align-items: stretch; }
        .strategy-info-text { border-left: none; border-top: 1px solid var(--alvarez-border); padding: 15px 0 0 0; margin-top: 10px; }
    }

    /* MOBILE OPTIMIZATIONS (< 600px) */
    @media (max-width: 600px) {
        h2 { font-size: 3.5rem !important; }
        input, select { font-size: 1.1rem !important; padding: 15px !important; }
        label { font-size: 0.8rem !important; }
        
        .lepton-row { grid-template-columns: 80px 1fr 1fr !important; }
        .lepton-row > div:nth-child(1) { width: 70px; } /* CANT */
        .lepton-row > div:nth-child(4) { grid-column: span 3 !important; order: 5; } /* PIEZA */
        .lepton-row > div:nth-child(5) { order: 4; display: flex; flex-direction: column; align-items: center; justify-content: center; } /* GIRAR */
        
        .tapacantos-row { justify-content: center !important; text-align: center; }
        .tapacantos-row > div { justify-content: center !important; width: 100%; }

        .strategy-panel-industrial { padding: 20px !important; }
        .btn-strategy, .btn-action-glass { width: 75px !important; height: 75px !important; }
        .btn-strategy i, .btn-action-glass i { font-size: 1.5rem; }
        .btn-strategy span, .btn-action-glass span { font-size: 0.65rem !important; }
        
        #strategy-selector-root > div { justify-content: center !important; width: 100%; }
        #strategy-selector-root > div:nth-child(2) { border-left: none !important; margin-left: 0 !important; padding-left: 0 !important; margin-top: 15px; }

        .btn-shatter { width: 100%; font-size: 1rem !important; padding: 20px !important; }

        .mobile-stack-grid { grid-template-columns: 1fr !important; }
        
        .mobile-only { display: flex !important; }
        .desktop-only { display: none !important; }
        
        #plates-container.mobile-hidden { display: none !important; }
    }

    .canto-opt {
        padding: 10px 15px;
        background: #f0f0f0;
        border: 1px solid #ccc;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.7rem;
        font-weight: 800;
        color: #666;
        transition: 0.2s;
    }
    .canto-opt:hover { background: #e0e0e0; }
    .canto-opt.active { background: var(--alvarez-red); color: #fff; border-color: var(--alvarez-red); }

    @keyframes pulse-price {
        0% { transform: scale(1); }
        50% { transform: scale(1.05); color: var(--alvarez-red); }
        100% { transform: scale(1); }
    }

    .mobile-only { display: none; }
    .desktop-only { display: inline-block; }

    /* GLASS SHATTER EFFECT */
    .btn-shatter {
        background: var(--alvarez-red);
        color: white;
        border: none;
        padding: 15px 30px;
        border-radius: 12px;
        font-weight: 900;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: 0.1s;
        text-transform: uppercase;
        font-size: 0.8rem;
        box-shadow: 0 10px 20px oklch(62.8% 0.25 29.23 / 30%);
    }
    .btn-shatter:active {
        transform: scale(0.95);
        filter: brightness(1.2);
    }
    .btn-shatter::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: linear-gradient(135deg, transparent 45%, rgba(255,255,255,0.4) 50%, transparent 55%);
        background-size: 200% 200%;
        animation: glass-shimmer 3s infinite;
    }
    @keyframes glass-shimmer {
        0% { background-position: 200% 200%; }
        100% { background-position: -200% -200%; }
    }
    .help-guide { margin-top: 30px; border-top: 1px solid var(--alvarez-border); padding-top: 50px; color: oklch(75% 0 0); font-family: 'Inter', sans-serif; }
    .help-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 50px; margin-top: 35px; }
    .help-item h4 { font-family: 'Montserrat', sans-serif; color: oklch(90% 0 0); font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; display: flex; align-items: center; gap: 12px; }
    .help-item p { font-size: 1.05rem; line-height: 1.8; margin: 0; font-weight: 400; color: oklch(70% 0 0); }
    .btn-legend { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 25px; margin-top: 50px; background: oklch(100% 0 0 / 2.5%); padding: 35px; border-radius: 16px; border: 1px solid var(--alvarez-border); }
    .legend-item { display: flex; align-items: flex-start; gap: 18px; font-size: 0.95rem; font-weight: 400; line-height: 1.6; color: oklch(65% 0 0); }
    .legend-item strong { font-family: 'Montserrat', sans-serif; color: oklch(95% 0 0); display: block; margin-bottom: 4px; font-size: 0.9rem; letter-spacing: 0.5px; }
    .legend-item i { width: 38px; height: 38px; background: var(--glass-bg); border: 1px solid var(--alvarez-border); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: var(--alvarez-red); flex-shrink: 0; font-size: 1rem; margin-top: 2px; }
    
    .nav-link-sc {
        color: #666;
        text-decoration: none;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
    }
    .nav-link-sc:hover { color: var(--alvarez-red); }

    /* CATALOG SUGGESTIONS INDUSTRIAL */
    .catalog-suggestion {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 15px;
        cursor: pointer;
        border-bottom: 1px solid var(--sc-border);
        transition: 0.2s;
    }
    .catalog-suggestion:hover { background: var(--alvarez-red); }
    .catalog-suggestion:hover * { color: white !important; }
    
    #catalog-results::-webkit-scrollbar { width: 6px; }
    #catalog-results::-webkit-scrollbar-thumb { background: var(--sc-border); border-radius: 10px; }

    .selected-product-preview {
        display: flex;
        align-items: center;
        gap: 15px;
        background: var(--sc-surface-alt);
        border: 1px solid var(--sc-border);
        padding: 15px;
        border-radius: 10px;
        margin-top: 10px;
        animation: fadeIn 0.3s ease;
    }
    .selected-product-preview img { width: 50px; height: 50px; border-radius: 6px; object-fit: cover; border: 1px solid var(--sc-border); }
    .selected-product-info { flex: 1; }
    .selected-product-info strong { display: block; font-size: 0.85rem; color: var(--sc-text); text-transform: uppercase; }
    .selected-product-info span { font-size: 0.65rem; color: var(--sc-text-dim); font-weight: 700; }
    /* EXPERIENCE SELECTOR CARDS */
    .mode-card { border: 2px solid #222; }
    .mode-card.active { border-color: var(--alvarez-red) !important; background: rgba(255, 40, 0, 0.05) !important; }
    .mode-card.active i { color: var(--alvarez-red) !important; }
    .mode-card.active div { color: white !important; }

    /* SELECTOR DE MODO - INDUSTRIAL */
    .mode-selector-container {
        display: flex;
        gap: 20px;
        justify-content: center;
        margin: 40px 0;
    }
    .btn-interface-selector {
        flex: 1;
        max-width: 450px;
        background: #ffffff;
        border: 2px solid #dee2e6;
        border-radius: 12px;
        padding: 25px 35px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
        display: flex !important;
        flex-direction: row !important; /* FORZAR HORIZONTAL */
        align-items: center;
        gap: 25px;
        text-align: left;
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
    }
    .btn-interface-selector i {
        font-size: 2.5rem !important; /* ICONO GRANDE */
        color: #adb5bd;
        min-width: 60px;
        text-align: center;
    }
    .btn-interface-selector .text-content {
        display: flex;
        flex-direction: column;
    }
    .btn-interface-selector .text-content span {
        font-weight: 900;
        font-size: 1.1rem;
        color: #000;
        text-transform: uppercase;
        line-height: 1.2;
        letter-spacing: 0.5px;
    }
    .btn-interface-selector .text-content p {
        font-size: 0.7rem;
        color: #666;
        margin: 0;
        margin-top: 4px;
        font-weight: 500;
    }

    /* SELECCIONADO - VERDE ALVAREZ */
    .btn-interface-selector.active {
        border-color: #25d366 !important;
        background: #f0fff4 !important;
        box-shadow: 0 10px 20px rgba(37, 211, 102, 0.1);
    }
    .btn-interface-selector.active i {
        color: #25d366 !important;
    }
    .btn-interface-selector.active span {
        color: #25d366 !important;
    }
    
    .btn-interface-selector:hover:not(.active) {
        border-color: #25d366;
        background: #f9fffb;
    }
    .btn-interface-selector.active {
        background: #25d366 !important;
        border-color: #1eb956 !important;
        box-shadow: 0 4px 12px rgba(37, 211, 102, 0.2);
    }
    .btn-interface-selector.active i, 
    .btn-interface-selector.active .text-content span,
    .btn-interface-selector.active .text-content p {
        color: white !important;
    }

    /* GRILLA INDUSTRIAL HYBRID - THEME ADAPTIVE */
    .lepton-grid-container {
        background: var(--sc-surface);
        border: 1px solid var(--sc-border);
        border-radius: 4px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    .lepton-grid {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Inter', sans-serif;
    }
    .lepton-grid th {
        background: var(--sc-bg);
        color: var(--sc-text);
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        padding: 12px 8px;
        border: 1px solid var(--sc-border);
        text-align: center;
    }
    .lepton-grid td {
        border: 1px solid var(--sc-border);
        padding: 0;
        height: 45px;
    }
    .lepton-grid input {
        width: 100%;
        height: 100%;
        border: none;
        padding: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--sc-text) !important;
        text-align: center;
        background: transparent !important;
    }
    .lepton-grid input:focus {
        background: var(--glass-bg) !important;
        outline: 2px solid var(--alvarez-red) !important;
        z-index: 2;
    }
    .lepton-grid tr:hover td {
        background-color: var(--sc-surface-alt);
    }
    
    .edge-icon-container {
        display: flex;
        justify-content: center;
        gap: 4px;
        padding: 0 5px;
    }
    .edge-check-btn {
        width: 28px;
        height: 28px;
        border: 1px solid var(--sc-border);
        background: var(--sc-input-bg);
        color: var(--sc-text-dim);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 900;
        position: relative;
        transition: all 0.15s ease;
    }
    .edge-check-btn:hover {
        background: var(--sc-surface-alt);
        border-color: var(--sc-text-dim);
    }
    .edge-check-btn.active {
        background: #25d366 !important;
        color: #ffffff !important;
        border-color: #1eb956 !important;
        box-shadow: 0 0 8px rgba(37, 211, 102, 0.4);
    }
    .canto-opt {
        border-radius: 4px;
        border: 1px solid var(--sc-border);
        padding: 8px 20px;
        font-weight: 900;
        cursor: pointer;
        background: var(--sc-input-bg);
        color: var(--sc-text-dim);
        transition: 0.2s;
    }
    .canto-opt.active {
        background: #25d366 !important;
        color: #fff !important;
        border-color: #1eb956 !important;
    }

    /* BOTONES DE ACCIÓN INDUSTRIAL */
    .industrial-controls {
        display: flex;
        gap: 15px;
        margin-top: 25px;
        background: var(--sc-surface-alt);
        padding: 20px;
        border-radius: 8px;
        border: 1px solid var(--sc-border);
    }
    .btn-industrial {
        padding: 15px 30px;
        border-radius: 6px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: 0.2s;
        border: none;
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }
    .btn-industrial.optimize { background: #25d366; color: white; box-shadow: 0 4px 0 #1eb956; }
    .btn-industrial.save { background: #007aff; color: white; box-shadow: 0 4px 0 #0056b3; }
    .btn-industrial.reset { background: #6c757d; color: white; box-shadow: 0 4px 0 #495057; }
    .btn-industrial:active { transform: translateY(4px); box-shadow: none; }
    .btn-industrial:hover { filter: brightness(1.1); }
</style>

<div id="smartcut-bar" class="smart-bar" data-is-logged-in={isLoggedIn ? "true" : "false"}>
    <div style="display: flex; align-items: center; gap: 20px;">
        <a href="/cliente" class="nav-link-sc">
            <i class="fas fa-arrow-left"></i> VOLVER AL PANEL
        </a>
        <div class="smart-label">
            SMARTCUT PRO <span style="background: #000; color: #00ff00; padding: 2px 8px; border-radius: 4px; font-size: 0.5rem; margin-left: 10px; border: 1px solid #00ff00;">v11.2 TREE LOOK-AHEAD</span>
        </div>
    </div>
    
    <div style="display: flex; gap: 20px; align-items: center;">
        <div id="theme-toggle" onclick="toggleTheme()" class="nav-link-sc" style="cursor:pointer; color: var(--sc-text-dim);">
            <i id="theme-icon" class="fas fa-moon"></i> <span id="theme-text">OSCURO</span>
        </div>
        <div style="width: 1px; height: 20px; background: var(--sc-border);"></div>
        <a href={isLoggedIn ? "/cliente/pedidos" : "/login"} class="nav-link-sc" style="font-weight: 800; color: var(--sc-text);">
            <i class="fas fa-user-circle"></i> {isLoggedIn ? 'MI PANEL' : 'INGRESAR'}
        </a>
