</div>

<script is:inline>
    // 🛡️ Inicialización inmediata del tema para evitar parpadeo
    (function() {
        const savedTheme = localStorage.getItem('sc-theme') || 'light';
        if (savedTheme === 'dark') {
            document.body.setAttribute('data-theme', 'dark');
        } else {
            document.body.removeAttribute('data-theme');
        }
    })();

    const IS_LOGGED_IN = document.getElementById('smartcut-bar').dataset.isLoggedIn === 'true';
    let engine, visualizer;
    let session = { 
        projects: [], 
        currentIndex: -1, 
        viewMode: 'grid', // 'grid' por defecto (Modo Clásico)
        activeCanto: 0.45,
        activePriceList: 'precio_l1',
        config: { kerf: 4, trim: 5, edgeWaste: 18, philosophy: 'V', steps: 900 } 
    };

    window.setModeSC = (mode) => {
        session.viewMode = mode;
        document.querySelectorAll('.btn-interface-selector').forEach(c => c.classList.remove('active'));
        document.getElementById(`btn-view-${mode}`).classList.add('active');
    };

    window.setActiveCantoSC = (val) => {
        session.activeCanto = val;
        renderEditorSC();
    };
    const BRANDS = { 'FAPLAC': { w: 2750, h: 1820 }, 'EGGER': { w: 2600, h: 1820 }, 'SADEPAN': { w: 2820, h: 1830 }, 'NOVA': { w: 3660, h: 1830 }, 'OSB': { w: 2440, h: 1220 } };

    async function initSC() {
        try {
            // Actualizar textos del botón de tema según estado actual
            const themeText = document.getElementById('theme-text');
            const themeIcon = document.getElementById('theme-icon');
            if (document.body.getAttribute('data-theme') === 'dark') {
                themeText.textContent = 'BLANCO';
                themeIcon.className = 'fas fa-sun';
            } else {
                themeText.textContent = 'OSCURO';
                themeIcon.className = 'fas fa-moon';
            }

            // Actualizar UI de navegación dinámicamente según sesión
            const hasSession = document.cookie.includes('client_session=') || document.cookie.includes('seller_session=') || document.cookie.includes('admin_session=');
            const navBtn = document.querySelector('.nav-link-sc[style*="font-weight: 800"]');
            if (hasSession && navBtn) {
                navBtn.innerHTML = '<i class="fas fa-user-circle"></i> MI PANEL';
                navBtn.setAttribute('href', '/cliente');
            }

            const opt = await import('/herramientas/logic/core/optimizer.js?v=' + Date.now());
            const vis = await import('/herramientas/logic/core/visualizer.js?v=' + Date.now());
            engine = new opt.SmartCutEngine(session.config);
            visualizer = new vis.SmartCutVisualizer('plates-container');
            
            // KEYBOARD FLOW INTEGRATION
            setupKeyboardFlow();
            
            // INTEGRACIÓN CUBICAL DESPIECE CHECK
            checkCubicalDespieceOnLoad();

            showDashboard();
        } catch (e) { setTimeout(initSC, 1000); }
    }

    function checkCubicalDespieceOnLoad() {
        const despiece = sessionStorage.getItem('cubical_despiece');
        if (despiece) {
            const banner = document.getElementById('cubical-import-banner');
            if (banner) {
                banner.classList.remove('hidden');
            }
            // Auto-redirect them to the setup screen so they can choose their plate/color!
            showSetup();
        }
    }

    function setupKeyboardFlow() {
        const fields = ['p-qty', 'p-len', 'p-wid', 'p-label', 'pe-t', 'pe-b', 'pe-l', 'pe-r'];
        fields.forEach((id, idx) => {
            const el = document.getElementById(id);
            if (!el) return;
            el.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    if (idx < fields.length - 1) {
                        const next = document.getElementById(fields[idx + 1]);
                        next.focus();
                        if (next.tagName === 'INPUT') next.select();
                    } else {
                        window.addPieceSC();
                    }
                }
            });
        });
    }

    window.toggleTheme = () => {
        const body = document.body;
        const text = document.getElementById('theme-text');
        const icon = document.getElementById('theme-icon');
        
        if (body.getAttribute('data-theme') === 'dark') {
            body.removeAttribute('data-theme');
            text.textContent = 'OSCURO';
            icon.className = 'fas fa-moon';
            localStorage.setItem('sc-theme', 'light');
        } else {
            body.setAttribute('data-theme', 'dark');
            text.textContent = 'BLANCO';
            icon.className = 'fas fa-sun';
            localStorage.setItem('sc-theme', 'dark');
        }
    };

    window.toggleConfig = () => document.getElementById('expert-panel').classList.toggle('open');

    window.toggleSCManual = () => {
        const modal = document.getElementById('sc-manual-modal');
        if (modal) {
            modal.classList.toggle('hidden');
        }
    };

    window.updateEngineCfg = () => {
        session.config = {
            kerf: parseInt(document.getElementById('cfg-kerf').value),
            trim: parseInt(document.getElementById('cfg-trim').value),
            edgeWaste: 18,
            profile: document.getElementById('cfg-profile').value,
            mode: document.getElementById('cfg-mode')?.value || session.config.mode,
            steps: 1000
        };
        engine = new engine.constructor(session.config);
        if (session.currentIndex !== -1) renderEditorSC();
    };

    window.setStrategyMode = (m) => {
        session.config.mode = m;
        // Actualizar UI
        document.querySelectorAll('.btn-strategy').forEach(b => b.classList.remove('active'));
        document.getElementById(`btn-mode-${m}`).classList.add('active');
        
        const descs = {
            'MIXED': 'Modo Mixto: Simulación triple (Japón/Alemania) que busca el máximo aprovechamiento del tablero combinando orientaciones.',
            'H': 'Modo Horizontal: Optimización por tiras largas. Ideal para escuadradoras verticales (TECNO LD), maximizando la estabilidad.',
            'V': 'Modo Vertical: Optimización por columnas. Útil para piezas con veta vertical dominante.'
        };
        document.getElementById('strategy-desc').textContent = descs[m];
        
        // Recalcular inmediatamente
        engine = new engine.constructor(session.config);
        if (session.currentIndex !== -1) {
            optimizeNowSC();
            renderEditorSC();
        }
    };

    window.showDashboard = () => {
        document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
        document.getElementById('view-dashboard').classList.remove('hidden');
        document.getElementById('btn-projects-sc').classList.add('hidden');
        renderProjectsSC();
    };

    window.showSetup = () => {
        document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
        document.getElementById('view-setup').classList.remove('hidden');
        applySupportRules(); 
        updateCatalogFlow('brand'); // Cargar catálogo inicial (FAPLAC)
    };

    // Controlador para cancelar peticiones obsoletas
    window._scCatalogController = null;

    window.updateCatalogFlow = async (step) => {
        const brand = document.getElementById('plate-brand').value;
        const lineSelect = document.getElementById('setup-line');
        const designSelect = document.getElementById('setup-design-select');
        const previewImg = document.getElementById('preview-img');
        const previewPlaceholder = document.getElementById('preview-placeholder');

        if (step === 'brand') {
            console.log(`[SmartCut] Reset total para marca: ${brand}`);
            
            // Cancelar peticiones previas en vuelo
            if (window._scCatalogController) {
                window._scCatalogController.abort();
                console.log('[SmartCut] Petición anterior abortada para evitar mezcla de datos.');
            }
            window._scCatalogController = new AbortController();
            const signal = window._scCatalogController.signal;
            
            // LIMPIEZA HARDCORE: Borrar todos los hijos uno por uno
            while (lineSelect.firstChild) lineSelect.removeChild(lineSelect.firstChild);
            while (designSelect.firstChild) designSelect.removeChild(designSelect.firstChild);
            
            lineSelect.disabled = true;
            designSelect.disabled = true;
            lineSelect.innerHTML = '<option value="">Cargando...</option>';
            designSelect.innerHTML = '<option value="">-- Seleccionar Color --</option>';
            
            // Restaurar opciones de espesor estándar
            document.getElementById('plate-thickness').innerHTML = `
                <option value="18">18 mm</option><option value="15">15 mm</option>
                <option value="12">12 mm</option><option value="9">9 mm</option>
                <option value="5.5">5.5 mm (Plus)</option><option value="3">3 mm (Plus)</option>
                <option value="25">25 mm</option><option value="36">36 mm</option>
            `;
            
            previewImg.classList.add('hidden');
            previewPlaceholder.classList.remove('hidden');
            
            if (brand === 'CUSTOM') {
                document.getElementById('custom-dims').classList.remove('hidden');
                toggleManualMode(true);
                lineSelect.innerHTML = '<option value="CUSTOM">PERSONALIZADA</option>';
                lineSelect.disabled = false;
                return;
            } else {
                document.getElementById('custom-dims').classList.add('hidden');
            }

            try {
                // CACHE BUSTER: Agregar timestamp para matar la caché del navegador/ServiceWorker
                const cacheBuster = Date.now();
                const res = await fetch(`/api/herramientas/catalog?type=lines&brand=${encodeURIComponent(brand)}&_t=${cacheBuster}`, { signal });
                const lines = await res.json();
                
                // SEGUNDA LIMPIEZA antes de insertar
                while (lineSelect.firstChild) lineSelect.removeChild(lineSelect.firstChild);
                
                if (Array.isArray(lines) && lines.length > 0) {
                    console.log(`[SmartCut] Líneas recibidas:`, lines);
                    const fragment = document.createDocumentFragment();
                    
                    const defaultOpt = document.createElement('option');
                    defaultOpt.value = "";
                    defaultOpt.textContent = "-- Seleccionar Línea --";
                    fragment.appendChild(defaultOpt);

                    lines.forEach(l => {
                        const opt = document.createElement('option');
                        opt.value = l;
                        opt.textContent = l === 'GENERAL' ? '📦 PRODUCTOS GENERALES' : l;
                        fragment.appendChild(opt);
                    });

                    lineSelect.appendChild(fragment);
                    lineSelect.disabled = false;

                    if (lines.length === 1) {
                        lineSelect.value = lines[0];
                        updateCatalogFlow('line');
                    }
                } else {
                    lineSelect.innerHTML = '<option value="">-- Sin líneas disponibles --</option>';
                }
                toggleManualMode(false);
            } catch (e) {
                if (e.name === 'AbortError') {
                    console.log('[SmartCut] Fetch abortado exitosamente.');
                } else {
                    console.error('[SmartCut] Error Fatal:', e); 
                    lineSelect.innerHTML = '<option value="">-- Error al cargar --</option>';
                }
            }
        }

        if (step === 'line') {
            const line = lineSelect.value;
            if (!line) return;
            
            // Cancelar peticiones previas en vuelo de colores
            if (window._scColorController) {
                window._scColorController.abort();
            }
            window._scColorController = new AbortController();
            const signal = window._scColorController.signal;

            designSelect.disabled = true;
            designSelect.innerHTML = '<option value="">Cargando Colores...</option>';
            // Limpiar previsualización
            previewImg.classList.add('hidden');
            previewPlaceholder.classList.remove('hidden');
            try {
                // MEJORA: usamos type=colors para obtener colores únicos con sus espesores disponibles
                // CACHE BUSTER: Prevenir caché en diseños
                const cacheBuster = Date.now();
                const res = await fetch(`/api/herramientas/catalog?type=colors&brand=${encodeURIComponent(brand)}&line=${encodeURIComponent(line)}&_t=${cacheBuster}`, { signal });
                const colors = await res.json();
                
                // Limpieza total antes de insertar
                while (designSelect.firstChild) designSelect.removeChild(designSelect.firstChild);

                if (Array.isArray(colors) && colors.length > 0) {
                    const fragment = document.createDocumentFragment();
                    const defaultOpt = document.createElement('option');
                    defaultOpt.value = "";
                    defaultOpt.textContent = "-- Seleccionar Color --";
                    fragment.appendChild(defaultOpt);

                    colors.forEach(c => {
                        const imgUrl = c.foto_principal 
                            ? `https://admin.alvarezplacas.com.ar/assets/${c.foto_principal}`
                            : '';
                        const espJson = JSON.stringify(c.espesores || []);
                        const opt = document.createElement('option');
                        opt.value = c.nombre_corto;
                        opt.setAttribute('data-img', imgUrl);
                        opt.setAttribute('data-espesores', espJson);
                        opt.textContent = c.nombre_corto;
                        fragment.appendChild(opt);
                    });

                    designSelect.appendChild(fragment);
                    designSelect.disabled = false;
                } else {
                    designSelect.innerHTML = '<option value="">-- Sin diseños disponibles --</option>';
                }
                toggleManualMode(false);
            } catch (e) {
                if (e.name === 'AbortError') {
                    // abortado silenciosamente
                } else {
                    console.error('[SmartCut] Error cargando colores:', e); 
                    designSelect.innerHTML = '<option value="">-- Error al cargar --</option>';
                }
            }
        }

        if (step === 'design') {
            const opt = designSelect.options[designSelect.selectedIndex];
            if (!opt || !opt.value) return;

            // Mostrar foto del material inmediatamente
            const img = opt.dataset.img;
            if (img && !img.includes('null') && img !== '') {
                previewImg.src = img + '?width=300&quality=85';
                previewImg.classList.remove('hidden');
                previewPlaceholder.classList.add('hidden');
            } else {
                previewImg.classList.add('hidden');
                previewPlaceholder.classList.remove('hidden');
            }

            // Actualizar selector de espesor con las variantes disponibles para este color
            const espesoresRaw = opt.dataset.espesores;
            const thicknessEl = document.getElementById('plate-thickness');
            const supportEl = document.getElementById('plate-support');

            if (espesoresRaw) {
                try {
                    const espesores = JSON.parse(espesoresRaw);
                    if (espesores.length > 0) {
                        // Reemplazar opciones del selector de espesor
                        thicknessEl.innerHTML = espesores.map(e =>
                            `<option value="${e.espesor}" data-soporte="${e.soporte}" data-precio-l1="${e.precio_l1}" data-precio-l2="${e.precio_l2}">${e.espesor} mm (${e.soporte})</option>`
                        ).join('');
                        // Seleccionar el primer espesor y su soporte automáticamente
                        thicknessEl.selectedIndex = 0;
                        const firstOpt = thicknessEl.options[0];
                        if (firstOpt.dataset.soporte) supportEl.value = firstOpt.dataset.soporte;
                    }
                } catch (_) { /* ignorar error de parse */ }
            }

            applySupportRules();
        }
    };

    window.toggleManualMode = (isManual) => {
        const select = document.getElementById('setup-design-select');
        const input = document.getElementById('setup-design-manual');
        const check = document.getElementById('check-manual');
        
        if (isManual) {
            select.classList.add('hidden');
            input.classList.remove('hidden');
            check.checked = true;
        } else {
            select.classList.remove('hidden');
            input.classList.add('hidden');
            check.checked = false;
        }
    };

    window.applySupportRules = () => {
        const brand = document.getElementById('plate-brand').value;
        const thickness = document.getElementById('plate-thickness').value;
        const supportEl = document.getElementById('plate-support');
        
        const isThin = (thickness === '3' || thickness === '5.5');
        const isNova = (brand === 'NOVA');

        if (isThin || isNova) {
            supportEl.value = 'MDF';
            Array.from(supportEl.options).forEach(opt => {
                if (opt.value === 'AGLOMERADO') opt.disabled = true;
            });
            supportEl.classList.add('locked');
        } else {
            Array.from(supportEl.options).forEach(opt => opt.disabled = false);
            supportEl.classList.remove('locked');
        }
    };

    window.showEditorSC = (i) => {
        session.currentIndex = i;
        const p = session.projects[i];
        const designHeader = document.getElementById('display-proj-design');
        const thumb = p.image || 'https://placehold.co/100x100/1a1a1c/white?text=PLACA';
        
        designHeader.innerHTML = `
            <div style="display:flex; align-items:center; gap:15px;">
                <img src="${thumb}" style="width:40px; height:40px; border-radius:6px; border:1px solid rgba(255,255,255,0.1); object-fit:cover;">
                <div style="line-height:1.2">
                    <div style="font-size:0.9rem; font-weight:800;">${p.designName}</div>
                    <div style="font-size:0.65rem; color:var(--alvarez-red); font-weight:800; text-transform:uppercase;">${p.brand} ${p.thickness}mm ${p.support}</div>
                </div>
            </div>
        `;

        document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
        document.getElementById('view-editor').classList.remove('hidden');
        document.getElementById('btn-projects-sc').classList.remove('hidden');
        renderEditorSC();
    };

    window.createProjectSC = () => {
        const brand = document.getElementById('plate-brand').value;
        const line = document.getElementById('setup-line').value;
        const isManual = document.getElementById('check-manual').checked;
        const designSelect = document.getElementById('setup-design-select');
        const manualInput = document.getElementById('setup-design-manual');
        
        let designName = isManual ? manualInput.value : designSelect.value;
        let image = null;

        if (!designName) {
            alert("⚠️ Por favor ingresa el nombre del diseño o selecciónalo del catálogo.");
            return;
        }

        if (isManual) {
            designName = `${designName} (DEF. CLIENTE)`;
        } else {
            const opt = designSelect.options[designSelect.selectedIndex];
            image = opt.dataset.img;
        }

        const thicknessEl = document.getElementById('plate-thickness');
        const thickness = thicknessEl.value;
        // Capturar soporte: primero del data-soporte del espesor elegido (cargado desde catálogo),
        // si no, del selector manual de soporte
        const selectedThickOpt = thicknessEl.options[thicknessEl.selectedIndex];
        const support = (selectedThickOpt?.dataset?.soporte) || document.getElementById('plate-support').value;

        if ((thickness === '3' || thickness === '5.5') && support === 'AGLOMERADO') {
            alert(`⚠️ ERROR INDUSTRIAL: 3mm/5.5mm solo existen en soporte MDF.`);
            return;
        }

        let w = brand === 'CUSTOM' ? parseInt(document.getElementById('setup-w').value) : BRANDS[brand].w;
        let h = brand === 'CUSTOM' ? parseInt(document.getElementById('setup-h').value) : BRANDS[brand].h;
        
        const projectDesign = `${designName} (${brand} ${thickness}mm ${support})`;
        
        const precio_l1 = parseFloat(selectedThickOpt?.dataset?.precioL1 || 0);
        const precio_l2 = parseFloat(selectedThickOpt?.dataset?.precioL2 || 0);

        const project = { 
            brand, 
            design: projectDesign, 
            designName: designName,
            thickness, 
            support, 
            w, h, 
            image: image || null,
            pieces: [], 
            result: null,
            precio_l1,
            precio_l2
        };

        // INTEGRACIÓN DE DESPIECE DE CUBICAL
        const rawDespiece = sessionStorage.getItem('cubical_despiece');
        if (rawDespiece) {
            try {
                const despieceData = JSON.parse(rawDespiece);
                if (despieceData && Array.isArray(despieceData.pieces)) {
                    despieceData.pieces.forEach((p, idx) => {
                        project.pieces.push({
                            id: Date.now() + idx,
                            q: parseInt(p.cantidad) || 1,
                            l: parseInt(p.alto) || 800,
                            h: parseInt(p.ancho) || 600,
                            label: p.nombre || 'Pieza',
                            canRotate: p.veta !== 'con_veta',
                            edgeColor: null,
                            edges: { t: 0, b: 0, l: 0, r: 0 }
                        });
                    });
                    if (despieceData.projectName) {
                        project.design = `${despieceData.projectName.toUpperCase()} - ${project.design}`;
                    }
                }
            } catch (e) {
                console.error("[SmartCut] Error importando despiece de CubiCal:", e);
            }
            sessionStorage.removeItem('cubical_despiece'); // Limpiar despiece
            
            // Ocultar banner si estaba visible
            const banner = document.getElementById('cubical-import-banner');
            if (banner) banner.classList.add('hidden');
        }

        session.projects.push(project);
        window.showEditorSC(session.projects.length - 1);
        
        // AUTO-OPTIMIZACIÓN AL INSTANTE PARA CUBICAL
        if (project.pieces.length > 0) {
            optimizeNowSC();
        }
    };

    window.addPieceSC = () => {
        const p = session.projects[session.currentIndex];
        const l = parseInt(document.getElementById('p-len').value);
        const w = parseInt(document.getElementById('p-wid').value);
        if (!l || !w) return;

        // VALIDACIÓN DE TAMAÑO INDUSTRIAL (Mínimos y Máximos)
        const pMax = Math.max(l, w);
        const pMin = Math.min(l, w);
        const boardMax = Math.max(p.w, p.h);
        const boardMin = Math.min(p.w, p.h);

        // 1. Validar contra el tamaño de la placa
        if (pMax > boardMax || pMin > boardMin) {
            alert(`⚠️ ERROR DE MEDIDA: La pieza (${l}x${w}mm) supera las dimensiones de la placa (${p.w}x${p.h}mm).`);
            return;
        }

        // 2. Validar mínimos industriales (Regla 70x100)
        if (pMin < 70) {
            alert(`⚠️ ERROR DE SEGURIDAD: La medida mínima de corte es 70mm. No se puede procesar una pieza con ${pMin}mm.`);
            return;
        }
        if (pMin === 70 && pMax < 100) {
            alert(`⚠️ REGLA INDUSTRIAL: Si un lado mide 70mm, el otro debe ser de al menos 100mm para garantizar el agarre de la máquina.`);
            return;
        }

        p.pieces.push({
            id: Date.now(), q: parseInt(document.getElementById('p-qty').value) || 1, l, h: w, 
            label: document.getElementById('p-label').value || 'PIEZA', canRotate: document.getElementById('p-rot').checked,
            edgeColor: document.getElementById('p-edge-custom-check').checked ? document.getElementById('p-edge-color').value : null,
            edges: { t: parseFloat(document.getElementById('pe-t').value), b: parseFloat(document.getElementById('pe-b').value), l: parseFloat(document.getElementById('pe-l').value), r: parseFloat(document.getElementById('pe-r').value) }
        });
        ['p-len', 'p-wid'].forEach(id => document.getElementById(id).value = '');
        document.getElementById('p-edge-custom-check').checked = false;
        document.getElementById('p-edge-color').classList.add('hidden');
        document.getElementById('p-edge-color').value = '';
        document.getElementById('p-qty').value = '1'; document.getElementById('p-qty').focus(); document.getElementById('p-qty').select();
        renderEditorSC();
    };

    window.updateGridPieceSC = (idx, field, val) => {
        const p = session.projects[session.currentIndex];
        // Rellenar de forma contigua para evitar sparse arrays con hoyos de undefined
        for (let k = 0; k <= idx; k++) {
            if (!p.pieces[k]) {
                p.pieces[k] = { id: Date.now() + k, q: 0, l: 0, h: 0, label: '', canRotate: true, edges: { t: 0, b: 0, l: 0, r: 0 } };
            }
        }
        if (field === 'q' || field === 'l' || field === 'h') {
            p.pieces[idx][field] = parseInt(val) || 0;
        } else {
            p.pieces[idx][field] = val;
        }
        // NOTA: No recalculamos automáticamente en modo grilla para permitir carga rápida
    };

    window.handleGridKeydown = (e, idx, field) => {
        if (e.key === 'Enter') {
            const p = session.projects[session.currentIndex];
            const nextFields = { 'q': 'l', 'l': 'h', 'h': 'label', 'label': 'q' };
            const nextField = nextFields[field];
            
            if (nextField === 'q') {
                // Al presionar Enter en Detalle, saltamos a la siguiente fila
                const nextIdx = idx + 1;
                for (let k = 0; k <= nextIdx; k++) {
                    if (!p.pieces[k]) {
                        p.pieces[k] = { id: Date.now() + k, q: 0, l: 0, h: 0, label: '', canRotate: true, edges: { t: 0, b: 0, l: 0, r: 0 } };
                    }
                }
                renderEditorSC();
                setTimeout(() => document.getElementById(`grid-q-${nextIdx}`)?.focus(), 10);
            } else {
                document.getElementById(`grid-${nextField}-${idx}`)?.focus();
            }
        }
    };

    window.toggleGridEdgeSC = (idx, side) => {
        const p = session.projects[session.currentIndex];
        for (let k = 0; k <= idx; k++) {
            if (!p.pieces[k]) {
                p.pieces[k] = { id: Date.now() + k, q: 0, l: 0, h: 0, label: '', canRotate: true, edges: { t: 0, b: 0, l: 0, r: 0 } };
            }
        }
        p.pieces[idx].edges[side] = p.pieces[idx].edges[side] > 0 ? 0 : session.activeCanto;
        renderEditorSC();
    };

    window.toggleGridRotateSC = (idx) => {
        const p = session.projects[session.currentIndex];
        for (let k = 0; k <= idx; k++) {
            if (!p.pieces[k]) {
                p.pieces[k] = { id: Date.now() + k, q: 0, l: 0, h: 0, label: '', canRotate: true, edges: { t: 0, b: 0, l: 0, r: 0 } };
            }
        }
        p.pieces[idx].canRotate = !p.pieces[idx].canRotate;
        renderEditorSC();
    };

    window.optimizeNowSC = () => {
        const p = session.projects[session.currentIndex];
        const validPieces = p.pieces.filter(pc => pc.q > 0 && pc.l > 0 && pc.h > 0);
        if (validPieces.length === 0) return alert('❌ Cargue al menos una pieza válida.');
        
        p.result = engine.optimize(p.w, p.h, validPieces);
        const targetContainer = session.viewMode === 'compact' ? 'plates-container-compact' : 'plates-container-grid';
        visualizer.setContainer(targetContainer);
        
        if (p.result && p.result.plates.length > 0) {
            // Asignar Ref ID a las piezas para el reporte
            let refMap = new Map();
            let refCount = 1;
            p.pieces.forEach(pc => {
                if (pc.q > 0) {
                    pc.refId = refCount++;
                    refMap.set(pc.id, pc.refId);
                }
            });
            // Propagar Ref ID a los items optimizados
            p.result.plates.forEach(plate => {
                plate.strips.forEach(s => s.items.forEach(i => {
                    i.refId = refMap.get(i.id);
                }));
            });

            visualizer.render(p.result, p.w, p.h, (u) => { p.result = u; updateStatsSC(); });
            updateStatsSC();
            document.getElementById(targetContainer).scrollIntoView({ behavior: 'smooth' });
            document.getElementById('btn-print-sc')?.classList.remove('hidden');
        }
    };

    window.preparePrintSC = () => {
        const p = session.projects[session.currentIndex];
        const container = document.getElementById('print-report-container');
        const now = new Date();
        const dateStr = now.toLocaleDateString();
        const timeStr = now.toLocaleTimeString();
        const orderId = Math.floor(Math.random() * 9000) + 1000; // Simular ID

        let html = '';
        p.result.plates.forEach((plate, idx) => {
            // Calcular metros de tapacantos específicos para esta placa
            let plateEdges = { "0.45": 0, "1": 0, "2": 0 };
            const calcEdgePrint = (len) => Math.max(len * 1.18, len + 100) / 1000;
            plate.strips.forEach(s => s.items.forEach(i => {
                if (i.edges) {
                    if (i.edges.t) plateEdges[i.edges.t] += calcEdgePrint(i.nominalL);
                    if (i.edges.b) plateEdges[i.edges.b] += calcEdgePrint(i.nominalL);
                    if (i.edges.l) plateEdges[i.edges.l] += calcEdgePrint(i.nominalH);
                    if (i.edges.r) plateEdges[i.edges.r] += calcEdgePrint(i.nominalH);
                }
            }));

            let edgesHtml = '';
            Object.keys(plateEdges).forEach(thick => {
                const meters = plateEdges[thick];
                if (meters > 0) {
                    let colorLabel = p.designName;
                    const customItem = plate.strips.flatMap(s => s.items).find(i => i.edgeColor && i.edges && (i.edges.t == thick || i.edges.b == thick || i.edges.l == thick || i.edges.r == thick));
                    if (customItem && customItem.edgeColor) {
                        colorLabel = `${customItem.edgeColor} (Canto Especial)`;
                    }
                    edgesHtml += `
                        <div class="print-edge-row">
                            <span class="edge-dot thick-${thick.replace('.','')}"></span>
                            <div class="edge-info">
                                <span class="edge-thickness">${thick} mm</span>
                                <span class="edge-color">${colorLabel.toUpperCase()}</span>
                            </div>
                            <strong class="edge-meters">${meters.toFixed(1)}m</strong>
                        </div>
                    `;
                }
            });
            if (!edgesHtml) {
                edgesHtml = `<div style="font-size:0.7rem; color:#666; font-style:italic; padding-top:10px;">Esta placa no requiere tapacantos.</div>`;
            }

            html += `
                <div class="print-page">
                    <header class="print-header">
                        <div class="header-left">
                            <div class="brand">Alvarezplacas</div>
                            <div class="info">AV VERGARA 1605 - 1161411842</div>
                            <div class="info">Email: alvarezplacas@gmail.com</div>
                        </div>
                        <div class="header-center">
                            <div class="vendedor">${document.getElementById('smartcut-bar').dataset.userName || 'OPERADOR'}</div>
                            <div class="date-time">Fecha: ${dateStr}</div>
                            <div class="date-time">Hora: ${timeStr}</div>
                        </div>
                        <div class="header-right">
                            <div class="page-num">Hoja: ${idx + 1} / ${p.result.plates.length}</div>
                            <div class="order-num">Nro.: ${orderId}</div>
                        </div>
                    </header>
                    <div class="print-summary-bar">
                        ${p.design.toUpperCase()}
                    </div>
                    
                    <div class="print-layout-box-clean">
                        <div class="layout-title-clean">${idx + 1} de ${p.w} x ${p.h} Placa Entera</div>
                        <canvas id="print-canvas-${idx}" width="${p.w}" height="${p.h}"></canvas>
                    </div>

                    <div class="print-columns-container">
                        <!-- Columna Izquierda: Piezas Ubicadas -->
                        <div class="print-column-left">
                            <div class="table-title-clean">Piezas ubicadas</div>
                            <table class="print-table">
                                <thead>
                                    <tr>
                                        <th style="width:10%">Ref.</th>
                                        <th style="width:10%">Cant.</th>
                                        <th style="width:20%">Base</th>
                                        <th style="width:20%">Altura</th>
                                        <th style="width:40%">Detalle</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${plate.strips.flatMap(s => s.items).map(i => `
                                        <tr>
                                            <td><strong>(${i.refId})</strong></td>
                                            <td>1</td>
                                            <td>${Math.round(i.nominalL)}</td>
                                            <td>${Math.round(i.nominalH)}</td>
                                            <td>${i.label}</td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- Columna Derecha: Tapacantos -->
                        <div class="print-column-right">
                            <div class="table-title-clean">Tapacantos Requeridos</div>
                            <div class="print-edges-summary">
                                ${edgesHtml}
                            </div>
                        </div>
                    </div>

                    <footer class="print-footer">
                        <div>EFICIENCIA PLACA = ${plate.eff ? plate.eff.toFixed(1) : '0'} %</div>
                        <div>DESPERDICIO = ${plate.eff ? (100 - plate.eff).toFixed(1) : '0'} %</div>
                        <div>CORTES APROX. = ${plate.strips.length * 2}</div>
                    </footer>
                </div>
            `;
        });
        container.innerHTML = html;

        // Renderizar los canvas de impresión en alta resolución (B/N)
        setTimeout(() => {
            p.result.plates.forEach((plate, idx) => {
                const canvas = document.getElementById(`print-canvas-${idx}`);
                const ctx = canvas.getContext('2d');
                // Escalar canvas para que ocupe el ancho de la hoja
                const scale = 800 / p.w;
                canvas.width = 800;
                canvas.height = p.h * scale;
                
                // Usar el visualizador para dibujar en el canvas de impresión (forzando modo luz)
                const tempVis = new visualizer.constructor('print-report-container');
                tempVis.scale = scale;
                tempVis.drawPlate(ctx, plate, p.w, p.h);
            });
            window.print();
        }, 100);
    };

    window.resetProjectSC = () => {
        if (confirm('¿Desea limpiar la carga actual y empezar de nuevo?')) {
            const p = session.projects[session.currentIndex];
            p.pieces = [{ id: Date.now(), q: '', l: '', h: '', label: '', canRotate: true, edges: { t: 0, b: 0, l: 0, r: 0 } }];
            renderEditorSC();
        }
    };

    function renderEditorSC() {
        const p = session.projects[session.currentIndex];
        const compactZone = document.getElementById('editor-compact-zone');
        const gridZone = document.getElementById('editor-grid-zone');

        // Mostrar u ocultar el botón IMPRIMIR según si hay resultado de optimización
        const btnPrint = document.getElementById('btn-print-sc');
        if (btnPrint) {
            if (p.result && p.result.plates && p.result.plates.length > 0) {
                btnPrint.classList.remove('hidden');
            } else {
                btnPrint.classList.add('hidden');
            }
        }

        // Actualizar UI de botones de selección
        document.querySelectorAll('.btn-interface-selector').forEach(b => b.classList.remove('active'));
        document.getElementById(`btn-view-${session.viewMode}`)?.classList.add('active');

        if (session.viewMode === 'compact') {
            compactZone.classList.remove('hidden');
            gridZone.classList.add('hidden');
            
            const list = document.getElementById('pieces-list');
            list.innerHTML = p.pieces.filter(pc => pc && pc.q > 0).slice().reverse().map(pc => `
                <div style="background:#0d0d0f; border:1px solid #1a1a1c; padding:15px; border-radius:6px; margin-bottom:10px; display:flex; justify-content:space-between; align-items:center;">
                    <span style="font-size:0.85rem; font-family:var(--font-mono)">
                        <strong>${pc.q}x</strong> ${pc.l}x${pc.h} 
                        <small style="color:#444; margin-left:10px;">${pc.label}</small>
                    </span>
                    <div class="delete-actions">
                        <i class="fas fa-trash-alt" style="color:#222; cursor:pointer;" onclick="removePieceSC(${pc.id})"></i>
                    </div>
                </div>`).join('');
            document.getElementById('count-label').textContent = p.pieces.filter(pc => pc && pc.q > 0).length;
            
            // Auto-optimizar solo en compacto
            const valid = p.pieces.filter(pc => pc && pc.q > 0 && pc.l > 0 && pc.h > 0);
            if (valid.length > 0) {
                p.result = engine.optimize(p.w, p.h, valid);
                visualizer.setContainer('plates-container-compact');
                visualizer.render(p.result, p.w, p.h, (u) => { p.result = u; updateStatsSC(); });
                updateStatsSC();
            }
        } else {
            compactZone.classList.add('hidden');
            gridZone.classList.remove('hidden');
            
            // Actualizar barra de cantos
            document.querySelectorAll('.canto-opt').forEach(opt => {
                opt.classList.remove('active');
            });
            const activeId = session.activeCanto === 0.45 ? '045' : session.activeCanto.toString().replace('.','');
            const activeBtn = document.getElementById(`opt-canto-${activeId}`);
            if (activeBtn) activeBtn.classList.add('active');

            const gridRoot = document.getElementById('grid-root');
            let tableHtml = `
                <table class="lepton-grid">
                    <thead>
                        <tr>
                            <th style="width:40px">ID</th>
                            <th style="width:80px">CANT.</th>
                            <th style="width:100px">LARGO</th>
                            <th style="width:100px">ANCHO</th>
                            <th>DETALLE PIEZA</th>
                            <th style="width:180px">TAPACANTOS (${session.activeCanto})</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            // En modo grilla industrial, siempre mostramos todas las piezas y rellenamos hasta llegar a un mínimo de 10 filas de base
            const minRows = 10;
            const displayPieces = [...p.pieces];
            while (displayPieces.length < minRows) {
                displayPieces.push({
                    id: Date.now() + displayPieces.length,
                    q: '',
                    l: '',
                    h: '',
                    label: '',
                    edges: { t: 0, b: 0, l: 0, r: 0 },
                    canRotate: true
                });
            }
            
            // Helper para la etiqueta de los cantos
            const getEdgeLabel = (val, def) => (val > 0 ? (val === 0.45 ? '.4' : val) : def);

            displayPieces.forEach((pc, i) => {
                tableHtml += `
                    <tr>
                        <td style="text-align:center; color:var(--sc-text-dim); font-size:0.7rem; font-weight:800; background:var(--sc-surface-alt); border-right:1px solid var(--sc-border);">${i+1}</td>
                        <td><input type="number" id="grid-q-${i}" value="${pc.q || ''}" oninput="updateGridPieceSC(${i}, 'q', this.value)" onkeydown="handleGridKeydown(event, ${i}, 'q')" placeholder="0"></td>
                        <td><input type="number" id="grid-l-${i}" value="${pc.l || ''}" oninput="updateGridPieceSC(${i}, 'l', this.value)" onkeydown="handleGridKeydown(event, ${i}, 'l')" placeholder="0"></td>
                        <td><input type="number" id="grid-h-${i}" value="${pc.h || ''}" oninput="updateGridPieceSC(${i}, 'h', this.value)" onkeydown="handleGridKeydown(event, ${i}, 'h')" placeholder="0"></td>
                        <td><input type="text" id="grid-label-${i}" value="${pc.label || ''}" oninput="updateGridPieceSC(${i}, 'label', this.value)" onkeydown="handleGridKeydown(event, ${i}, 'label')" placeholder="Ej: Lateral" style="text-align:left; padding-left:15px;"></td>
                        <td>
                            <div class="edge-icon-container">
                                <button onclick="toggleGridEdgeSC(${i}, 't')" class="edge-check-btn ${pc.edges?.t > 0 ? 'active' : ''}" title="Superior Largo 1">${getEdgeLabel(pc.edges?.t, 'L1')}</button>
                                <button onclick="toggleGridEdgeSC(${i}, 'b')" class="edge-check-btn ${pc.edges?.b > 0 ? 'active' : ''}" title="Inferior Largo 2">${getEdgeLabel(pc.edges?.b, 'L2')}</button>
                                <button onclick="toggleGridEdgeSC(${i}, 'l')" class="edge-check-btn ${pc.edges?.l > 0 ? 'active' : ''}" title="Izquierda Ancho 1">${getEdgeLabel(pc.edges?.l, 'A1')}</button>
                                <button onclick="toggleGridEdgeSC(${i}, 'r')" class="edge-check-btn ${pc.edges?.r > 0 ? 'active' : ''}" title="Derecha Ancho 2">${getEdgeLabel(pc.edges?.r, 'A2')}</button>
                                <div style="width:1px; background:var(--sc-border); margin:0 2px;"></div>
                                <button onclick="toggleGridRotateSC(${i})" class="edge-check-btn active" title="Girar/Veta" style="color:#007aff; position: relative;">
                                    <i class="fas fa-sync"></i>
                                    ${pc && !pc.canRotate ? '<i class="fas fa-times" style="position:absolute; color:#ff2800; font-size:1.2rem; top: -2px; left: -2px;"></i>' : ''}
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });
            tableHtml += `</tbody></table>`;
            tableHtml += `
                <div style="display:flex; gap:10px; margin-top:15px; margin-bottom: 20px;">
                    <button onclick="addBlankRowSC()" class="sc-btn" style="background:#1a1a1c; border:1px solid #333; color:#fff; padding:8px 16px; border-radius:6px; font-size:0.75rem; font-weight:800; cursor:pointer; display:inline-flex; align-items:center; gap:6px; transition:0.2s;" onmouseover="this.style.background='#252528'" onmouseout="this.style.background='#1a1a1c'">
                        <i class="fas fa-plus"></i> AGREGAR FILA
                    </button>
                </div>
            `;
            gridRoot.innerHTML = tableHtml;
        }
    }

    window.setPriceListSC = (val) => {
        session.activePriceList = val;
        updateStatsSC();
    };

    function updateStatsSC() {
        const p = session.projects[session.currentIndex];
        if (!p || !p.result || !p.result.stats) return;
        const s = p.result.stats;
        document.getElementById('stat-sheets').textContent = s.totalPlates;
        document.getElementById('stat-eff').textContent = s.efficiency.toFixed(1) + '%';
        const totalEdges = Object.values(s.edgeMeters).reduce((a, b) => a + b, 0);
        document.getElementById('stat-edges').textContent = totalEdges.toFixed(1) + 'm';

        // Cálculo de Presupuesto Estimado
        const boardPrice = session.activePriceList === 'precio_l1' ? (p.precio_l1 || 0) : (p.precio_l2 || 0);
        const totalBoards = s.totalPlates;
        
        // Estimación de costo de tapacantos (Valores industriales base)
        const totalEdges045 = s.edgeMeters["0.45"] || 0;
        const totalEdges1 = s.edgeMeters["1"] || 0;
        const totalEdges2 = s.edgeMeters["2"] || 0;
        const edgeCost = (totalEdges045 * 1200) + (totalEdges1 * 1800) + (totalEdges2 * 2800);

        const totalMoney = (totalBoards * boardPrice) + edgeCost;
        
        const formatter = new Intl.NumberFormat('es-AR', { 
            style: 'currency', 
            currency: 'ARS', 
            maximumFractionDigits: 0 
        });
        
        const totalEl = document.getElementById('stat-total-money');
        if (totalEl) {
            totalEl.textContent = formatter.format(totalMoney);
            // Efecto visual de actualización
            totalEl.style.animation = 'none';
            setTimeout(() => totalEl.style.animation = 'pulse-price 0.5s ease', 10);
        }
    }

    function renderProjectsSC() {
        const list = document.getElementById('projects-list');
        const checkoutContainer = document.getElementById('budget-checkout-container');
        if (session.projects.length > 0) {
            if (checkoutContainer) {
                checkoutContainer.classList.remove('hidden');
                
                // Inicializar fecha de entrega a 7 días hábiles de hoy
                const dateInput = document.getElementById('final-fecha-entrega');
                if (dateInput && !dateInput.value) {
                    const today = new Date();
                    // Plazo mínimo de 7 días corridos
                    const deliveryDate = new Date(today.getTime() + 7 * 24 * 60 * 60 * 1000);
                    const yyyy = deliveryDate.getFullYear();
                    const mm = String(deliveryDate.getMonth() + 1).padStart(2, '0');
                    const dd = String(deliveryDate.getDate()).padStart(2, '0');
                    const minStr = `${yyyy}-${mm}-${dd}`;
                    dateInput.value = minStr;
                    dateInput.min = minStr; // Bloquea cualquier fecha menor a 7 días desde hoy
                }
            }
            list.innerHTML = session.projects.map((p, i) => `
                <div style="background:#0a0a0c; border:1px solid #151517; padding:25px; border-radius:10px; cursor:pointer; position:relative; transition:0.3s;" onclick="showEditorSC(${i})" onmouseover="this.style.borderColor='var(--alvarez-red)'" onmouseout="this.style.borderColor='#151517'">
                    <i class="fas fa-times" style="position:absolute; top:15px; right:15px; color:#222;" onclick="removeProjectSC(${i}, event)"></i>
                    <h3 style="color:var(--alvarez-red); margin:0 0 10px 0; font-size:1.1rem; letter-spacing:-0.5px;">${p.design}</h3>
                    <p style="font-size:0.6rem; color:#444; font-weight:900; text-transform:uppercase;">${p.brand} • ${p.pieces.length} PIEZAS</p>
                </div>`).join('');
        } else {
            if (checkoutContainer) checkoutContainer.classList.add('hidden');
            list.innerHTML = '<p style="color:#222; grid-column: 1/-1; text-align:center; padding:30px 0; font-weight:900; text-transform:uppercase; letter-spacing:2px; font-size:1.5rem; opacity:0.3; margin:0;">Sin proyectos activos</p>';
        }
    }

    window.toggleGridRotateSC = (idx) => {
        const p = session.projects[session.currentIndex];
        if (!p.pieces[idx]) return;
        p.pieces[idx].canRotate = !p.pieces[idx].canRotate;
        renderEditorSC();
    };

    window.removePieceSC = (id) => {
        const p = session.projects[session.currentIndex];
        if (session.viewMode === 'grid') {
            const idx = p.pieces.findIndex(pc => pc.id === id);
            if (idx !== -1) p.pieces[idx] = { id: Date.now() + idx, q: 0, l: 0, h: 0, label: '', canRotate: true, edges: { t: 0, b: 0, l: 0, r: 0 } };
        } else {
            p.pieces = p.pieces.filter(pc => pc.id !== id);
        }
        renderEditorSC();
    };

    window.addBlankRowSC = () => {
        const p = session.projects[session.currentIndex];
        p.pieces.push({
            id: Date.now() + p.pieces.length,
            q: '',
            l: '',
            h: '',
            label: '',
            edges: { t: 0, b: 0, l: 0, r: 0 },
            canRotate: true
        });
        renderEditorSC();
        setTimeout(() => {
            const nextIdx = p.pieces.length - 1;
            document.getElementById(`grid-q-${nextIdx}`)?.focus();
        }, 10);
    };

    window.removeProjectSC = (i, e) => { if (e) { e.preventDefault(); e.stopPropagation(); } if (confirm(`Eliminar ${session.projects[i].design}?`)) { session.projects.splice(i, 1); renderProjectsSC(); } };
    window.openLoginWall = () => document.getElementById('login-wall').classList.remove('hidden');

    window.handleBudgetClick = () => {
        // En producción las cookies son HttpOnly, por lo que document.cookie no puede leerlas.
        // Confiamos plenamente en IS_LOGGED_IN el cual se renderiza de forma estricta desde el servidor.
        if (!IS_LOGGED_IN) {
            openLoginWall();
            return;
        }
        saveBudgetToDirectus();
    };

    async function saveBudgetToDirectus() {
        const btn = document.getElementById('btn-final-send');
        const originalContent = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> ENVIANDO...';

        try {
            // Recopilar datos de todos los proyectos activos
            const data = {
                projects: session.projects.map(p => ({
                    brand: p.brand,
                    design: p.design,
                    pieces: p.pieces,
                    stats: p.result?.stats,
                    precio_l1: p.precio_l1,
                    precio_l2: p.precio_l2
                })),
                activePriceList: session.activePriceList,
                fecha_entrega_requerida: document.getElementById('final-fecha-entrega')?.value || null
            };

            const response = await fetch('/api/herramientas/save-budget', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const res = await response.json();
            if (res.success) {
                alert('✅ Presupuesto enviado con éxito. Serás redirigido a tu panel de control para ver el estado y descargar tu reporte.');
                window.location.href = '/cliente/pedidos';
            } else {
                alert('❌ Error: ' + res.message);
            }
        } catch (e) {
            console.error(e);
            alert('❌ Error de conexión al enviar el presupuesto.');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalContent;
        }
    }
    window.toggleMobilePlan = () => {
        const container = document.getElementById('plates-container');
        const btn = document.getElementById('btn-view-plan');
        const isHidden = container.classList.toggle('mobile-hidden');
        btn.querySelector('span').textContent = isHidden ? 'PLANO' : 'CERRAR';
        btn.querySelector('i').className = isHidden ? 'fas fa-th' : 'fas fa-times';
        if (!isHidden) container.scrollIntoView({ behavior: 'smooth' });
    };

    initSC();
</script>
