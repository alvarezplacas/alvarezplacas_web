---
/**
 * SmartMatchProposal - Propuesta visual para la combinación 60-30-10.
 * Propiedad del Agente 5 (Frontend/Herramientas).
 */
const { matchResult } = Astro.props;
---

<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 animate-in fade-in slide-in-from-bottom-8 duration-700">
    <!-- Columna Izquierda: La Elección (60%) -->
    <div class="lg:col-span-4 space-y-6">
        <div class="relative group">
            <div class="absolute -inset-1 bg-gradient-to-r from-primary to-orange-600 rounded-[2rem] blur opacity-25 group-hover:opacity-60 transition duration-1000"></div>
            <div class="relative bg-[#0a0a0a] rounded-[2rem] overflow-hidden border border-white/5 shadow-2xl">
                <div class="aspect-[4/5] w-full relative">
                    <img src={matchResult.base.imagen} alt={matchResult.base.nombre} class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent"></div>
                    <div class="absolute bottom-6 left-6 right-6">
                        <span class="bg-primary text-black text-[9px] font-black px-3 py-1 rounded-full uppercase tracking-[0.2em] mb-3 inline-block shadow-lg">60% BASE</span>
                        <h3 class="text-3xl font-black mb-1 uppercase italic tracking-tighter text-white">{matchResult.base.nombre}</h3>
                        <p class="text-gray-400 text-xs uppercase tracking-[0.15em] font-medium">{matchResult.base.marca} | {matchResult.base.linea}</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-[#111111]/80 backdrop-blur-md p-8 rounded-[2rem] border border-white/5 relative overflow-hidden group shadow-xl">
            <div class="absolute top-0 left-0 w-1.5 h-full bg-primary/80 group-hover:h-1/2 transition-all duration-500"></div>
            <p class="text-gray-300 text-sm leading-relaxed italic font-medium">
                “{matchResult.base.argumento}”
            </p>
        </div>
    </div>

    <!-- Columna Derecha: Sugerencias (30-10) -->
    <div class="lg:col-span-8 space-y-8">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-2xl font-black flex items-center gap-4 uppercase italic tracking-tighter text-white">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center border border-primary/20">
                    <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                </div>
                Propuesta de Combinación
            </h2>
            <button onclick="window.print()" class="bg-white/5 hover:bg-white/10 text-white text-[10px] font-black py-3 px-6 rounded-full border border-white/10 transition-all flex items-center gap-3 uppercase tracking-widest no-print">
                <i class="fas fa-print"></i> Imprimir Propuesta
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-print">
            <!-- 30% Secundario -->
            <div class="bg-[#0f0f0f] rounded-[2.5rem] overflow-hidden border border-white/5 flex flex-col h-full group/card shadow-2xl transition-all hover:border-primary/20 hover:-translate-y-2 duration-500">
                <div class="h-64 overflow-hidden relative">
                    <div class="absolute top-6 left-6 z-10 bg-slate-100 text-slate-950 text-[9px] font-black px-4 py-1.5 rounded-full tracking-[0.2em] shadow-2xl uppercase">30% CONTRASTE</div>
                    <img src={matchResult.secundario.imagen} alt={matchResult.secundario.nombre} class="w-full h-full object-cover transition-transform duration-1000 group-hover/card:scale-110 opacity-80 group-hover/card:opacity-100" />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#0f0f0f] via-transparent to-transparent"></div>
                </div>
                <div class="p-10 pt-4">
                    <h4 class="text-xl font-black mb-1 uppercase text-white tracking-tight">{matchResult.secundario.nombre}</h4>
                    <p class="text-primary/60 text-[10px] uppercase tracking-[0.2em] font-bold mb-6">{matchResult.secundario.marca} | {matchResult.secundario.linea}</p>
                    <p class="text-gray-400 text-sm leading-relaxed font-medium">
                        {matchResult.secundario.argumento}
                    </p>
                </div>
            </div>

            <!-- 10% Acento -->
            <div class="bg-[#0f0f0f] rounded-[2.5rem] overflow-hidden border border-white/5 flex flex-col h-full group/card shadow-2xl transition-all hover:border-primary/20 hover:-translate-y-2 duration-500">
                <div class="h-64 overflow-hidden relative">
                    <div class="absolute top-6 left-6 z-10 bg-primary text-black text-[9px] font-black px-4 py-1.5 rounded-full tracking-[0.2em] shadow-2xl uppercase">10% ACENTO</div>
                    <img src={matchResult.acento.imagen} alt={matchResult.acento.nombre} class="w-full h-full object-cover transition-transform duration-1000 group-hover/card:scale-110 opacity-80 group-hover/card:opacity-100" />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#0f0f0f] via-transparent to-transparent"></div>
                </div>
                <div class="p-10 pt-4">
                    <h4 class="text-xl font-black mb-1 uppercase text-white tracking-tight">{matchResult.acento.nombre}</h4>
                    <p class="text-primary/60 text-[10px] uppercase tracking-[0.2em] font-bold mb-6">{matchResult.acento.marca} | {matchResult.acento.linea}</p>
                    <p class="text-gray-400 text-sm leading-relaxed font-medium">
                        {matchResult.acento.argumento}
                    </p>
                </div>
            </div>
        </div>

        <!-- Argumento Final -->
        <div class="bg-gradient-to-br from-primary/10 to-transparent p-10 rounded-[2.5rem] border border-primary/10">
            <h5 class="text-primary text-[10px] font-black uppercase tracking-[0.3em] mb-4">Análisis de Estilo AI</h5>
            <p class="text-gray-200 text-lg leading-relaxed italic">
                “{matchResult.explicacion_general}”
            </p>
        </div>

        <!-- Botones de Acción -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-8 no-print">
            <a 
                href={`https://wa.me/5491161411842?text=Hola! Estuve usando el Smart Match de Alvarez Placas y me encantó esta combinación: 60% Base ${matchResult.base.nombre}, 30% Contraste ${matchResult.secundario.nombre} y 10% Acento ${matchResult.acento.nombre}. ¿Me pasarías presupuesto?`}
                target="_blank"
                class="bg-[#25D366] hover:bg-[#1ebd5a] text-white font-black py-5 px-6 rounded-2xl flex items-center justify-center gap-4 transition-all shadow-[0_10px_30px_rgba(37,211,102,0.3)] hover:shadow-[0_15px_40px_rgba(37,211,102,0.4)] uppercase tracking-widest text-xs group"
            >
                <i class="fab fa-whatsapp text-xl group-hover:scale-125 transition-transform"></i> Enviar Combinación
            </a>
            <a href="/catalogo" class="bg-white/5 hover:bg-white/10 text-white font-black py-5 px-6 rounded-2xl flex items-center justify-center gap-4 border border-white/10 transition-all uppercase tracking-widest text-xs hover:border-primary/40">
                <i class="fas fa-th-large"></i> Elegir otra placa
            </a>
        </div>
    </div>
</div>

<style>
    @media print {
        .no-print { display: none !important; }
        .text-print { color: black !important; }
        .bg-print { background: white !important; }
    }

    .animate-in {
        animation: animate-in 0.8s ease-out forwards;
    }

    @keyframes animate-in {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
