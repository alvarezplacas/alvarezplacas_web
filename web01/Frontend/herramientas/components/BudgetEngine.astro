---
/**
 * BudgetEngine - Motor interactivo de presupuestos "SmartFlow".
 * Versión Restaurada y Potenciada con Exportación LEPTOM.
 * Propiedad del Agente 5 (Frontend/Herramientas).
 */
import { directus, readItem } from '@conexiones/directus.js';

const userId = Astro.cookies.get('client_session')?.value;
let userProfile = null;

if (userId) {
    try {
        const res = await directus.request(readItem('clientes', userId, {
            fields: ['id', 'name', { vendedor_id: ['id', 'name', 'whatsapp'] }]
        }));
        if (res) {
            userProfile = {
                id: res.id,
                name: res.name,
                vendedor: res.vendedor_id ? {
                    id: res.vendedor_id.id,
                    name: res.vendedor_id.name,
                    phone: res.vendedor_id.whatsapp
                } : null
            };
        }
    } catch (e) {
        console.error("Error fetching user for budget engine:", e);
    }
}
---
<div class="max-w-4xl mx-auto" id="smart-flow-engine">
    
    {userProfile && (
        <div class="mb-6 bg-primary/10 border border-primary/20 rounded-2xl p-4 flex items-center justify-between animate-in fade-in duration-700">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-primary/20 text-primary flex items-center justify-center font-black">
                    {userProfile.name[0]}
                </div>
                <div>
                    <p class="text-[10px] text-white/40 uppercase font-black tracking-widest">Sesión Iniciada</p>
                    <p class="text-white font-bold">{userProfile.name}</p>
                </div>
            </div>
            {userProfile.vendedor && (
                <div class="text-right">
                    <p class="text-[10px] text-white/40 uppercase font-black tracking-widest">Asesor Asignado</p>
                    <p class="text-primary font-bold">{userProfile.vendedor.name}</p>
                </div>
            )}
        </div>
    )}

    <!-- STEP 1: SHEET CONFIGURATION -->
    <div id="step-setup" class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-3xl p-8 shadow-2xl animate-in fade-in zoom-in duration-500">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-black text-white mb-2 tracking-tighter uppercase italic">Configuración de Placa</h2>
            <p class="text-white/60 text-sm">Define el material base antes de cargar los cortes</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-4">
                <div>
                    <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1 tracking-widest">Marca / Fabricante</label>
                    <div class="grid grid-cols-2 gap-2">
                        {['FAPLAC', 'EGGER', 'SADEPAN', 'OTRO'].map(brand => (
                            <button class="brand-btn bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl py-4 text-white font-bold transition-all" data-brand={brand}>{brand}</button>
                        ))}
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1 tracking-widest">Espesor (mm)</label>
                        <select id="setup-thickness" class="w-full bg-white/10 border border-white/10 rounded-2xl px-4 py-3 text-white font-bold outline-none focus:border-primary transition-all">
                            <option value="25" class="bg-gray-900">25 mm</option>
                            <option value="18" selected class="bg-gray-900">18 mm</option>
                            <option value="15" class="bg-gray-900">15 mm</option>
                            <option value="9" class="bg-gray-900">9 mm</option>
                            <option value="5.5" class="bg-gray-900">5.5 mm</option>
                            <option value="3" class="bg-gray-900">3 mm</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1 tracking-widest">Nombre / Diseño</label>
                        <input type="text" id="setup-plate-name" placeholder="Ej: CEDRO" class="w-full bg-white/10 border border-white/10 rounded-2xl px-4 py-3 text-white font-bold outline-none focus:border-primary transition-all uppercase" />
                    </div>
                </div>
            </div>

            <div id="custom-size-panel" class="space-y-4 opacity-100 transition-opacity">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1 tracking-widest">Largo Placa (mm)</label>
                        <input type="number" id="setup-width" value="2750" class="w-full bg-white/10 border border-white/10 rounded-2xl px-4 py-3 text-white font-bold outline-none focus:border-primary transition-all" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1 tracking-widest">Ancho Placa (mm)</label>
                        <input type="number" id="setup-height" value="1830" class="w-full bg-white/10 border border-white/10 rounded-2xl px-4 py-3 text-white font-bold outline-none focus:border-primary transition-all" />
                    </div>
                </div>
                <div class="bg-primary/20 border border-primary/30 rounded-2xl p-4">
                    <p class="text-[10px] text-primary font-black uppercase mb-1 tracking-widest text-center md:text-left">Cálculo de Refilado</p>
                    <p class="text-xs text-white/80 text-center md:text-left">Se descontarán <span class="font-bold underline text-primary">5mm perimetrales</span> automáticamente para asegurar cortes limpios.</p>
                </div>
            </div>
        </div>

        <button id="start-loading-btn" class="w-full mt-8 py-5 bg-primary hover:bg-orange-500 text-black font-black rounded-2xl shadow-[0_0_30px_rgba(255,40,0,0.3)] transform transition-all active:scale-95 uppercase tracking-widest border-b-4 border-black/20">
            Comenzar Carga de Cortes
        </button>
    </div>

    <!-- STEP 2: PIECE ENTRY (HIDDEN INITIALLY) -->
    <div id="step-entry" class="hidden space-y-6">
        
        <!-- Header / Stats Overlay -->
        <div class="flex justify-between items-center bg-white/5 backdrop-blur-md p-4 rounded-2xl border border-white/10 sticky top-4 z-10 shadow-xl">
            <button id="back-to-setup" class="text-white/60 hover:text-white flex items-center gap-2 text-xs font-bold uppercase transition-all">
               <i class="fas fa-cog"></i> Config. Material
            </button>
            <div class="flex gap-4">
                <div class="text-right">
                    <p class="text-[9px] text-white/40 uppercase font-bold">Piezas</p>
                    <p id="stat-pieces" class="text-xl font-black text-primary">0</p>
                </div>
                <div class="text-right border-l border-white/10 pl-4">
                    <p class="text-[9px] text-white/40 uppercase font-bold">Placas Est.</p>
                    <p id="stat-sheets" class="text-xl font-black text-white">0</p>
                </div>
                <div class="text-right border-l border-white/10 pl-4">
                    <p class="text-[9px] text-white/40 uppercase font-bold">Total m²</p>
                    <p id="stat-m2" class="text-xl font-black text-white">0.00</p>
                </div>
            </div>
        </div>

        <!-- MOVIMIENTO: List of Pieces -->
        <div class="space-y-3" id="pieces-container">
            <!-- Piece cards will be injected here -->
        </div>

        <!-- The "One-at-a-time" Entry Form -->
        <div class="bg-primary/95 border-b-8 border-black/20 rounded-3xl p-6 shadow-2xl relative overflow-hidden group">
            <h3 class="text-black font-black uppercase text-xl mb-4 tracking-tighter">Nueva Pieza</h3>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="col-span-2 md:col-span-1">
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Cantidad</label>
                    <input type="number" id="p-qty" placeholder="1" class="w-full bg-white border-2 border-black rounded-xl px-4 py-3 text-xl font-black text-black outline-none" />
                </div>
                <div>
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Largo (mm)</label>
                    <input type="number" id="p-len" placeholder="0" class="w-full bg-white border-2 border-black rounded-xl px-4 py-3 text-xl font-black text-black outline-none" />
                </div>
                <div>
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Ancho (mm)</label>
                    <input type="number" id="p-wid" placeholder="0" class="w-full bg-white border-2 border-black rounded-xl px-4 py-3 text-xl font-black text-black outline-none" />
                </div>
                <div class="col-span-2 md:col-span-1">
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Veta</label>
                    <label class="flex items-center gap-2 bg-white border-2 border-black rounded-xl py-3 px-4 cursor-pointer hover:bg-white/80 transition-all h-[54px]">
                        <input type="checkbox" id="p-check-rot" checked class="w-5 h-5 accent-black" />
                        <span class="text-[10px] font-black text-black uppercase">Permitir Gire</span>
                    </label>
                </div>
            </div>

            <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Nombre / Identificador</label>
                    <input type="text" id="p-label" placeholder="Ej: Puerta Bajo Mesada" class="w-full bg-white border-2 border-black rounded-xl px-4 py-3 text-lg font-bold text-black outline-none" />
                </div>
                <div>
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Tapacantos <span class="text-[8px] opacity-70">(S, I, L, R)</span></label>
                    <div class="flex gap-1">
                        <select id="pe-t" class="flex-1 bg-white border-2 border-black rounded-lg py-3 text-[11px] font-black text-black appearance-none text-center">
                            <option value="0">SIN</option>
                            <option value="0.45">0.45</option>
                            <option value="1">1.0</option>
                            <option value="2">2.0</option>
                        </select>
                        <select id="pe-b" class="flex-1 bg-white border-2 border-black rounded-lg py-3 text-[11px] font-black text-black appearance-none text-center">
                            <option value="0">SIN</option>
                            <option value="0.45">0.45</option>
                            <option value="1">1.0</option>
                            <option value="2">2.0</option>
                        </select>
                        <select id="pe-l" class="flex-1 bg-white border-2 border-black rounded-lg py-3 text-[11px] font-black text-black appearance-none text-center">
                            <option value="0">SIN</option>
                            <option value="0.45">0.45</option>
                            <option value="1">1.0</option>
                            <option value="2">2.0</option>
                        </select>
                        <select id="pe-r" class="flex-1 bg-white border-2 border-black rounded-lg py-3 text-[11px] font-black text-black appearance-none text-center">
                            <option value="0">SIN</option>
                            <option value="0.45">0.45</option>
                            <option value="1">1.0</option>
                            <option value="2">2.0</option>
                        </select>
                    </div>
                </div>
            </div>
            
            <button id="p-add-btn" class="w-full mt-6 py-4 bg-black text-white font-black rounded-xl hover:bg-gray-900 transition-all uppercase tracking-widest shadow-xl flex items-center justify-center gap-2">
               <i class="fas fa-plus"></i> Agregar Pieza (Enter)
            </button>
        </div>

        <div id="material-actions" class="mt-8 flex flex-col md:flex-row gap-4">
            <button id="btn-finalize-sheet" class="flex-1 py-5 bg-white/10 hover:bg-white/20 text-white font-black rounded-2xl border border-white/10 transition-all flex items-center justify-center gap-2 uppercase tracking-widest">
                <i class="fas fa-layer-group"></i> AGREGAR OTRA PLACA
            </button>

            <button id="btn-pdf-generator" class="flex-1 py-5 bg-blue-600 hover:bg-blue-500 text-white font-black rounded-2xl transition-all flex items-center justify-center gap-2 uppercase tracking-widest shadow-xl">
                <i class="fas fa-file-pdf"></i> PDF PROFESIONAL
            </button>

            <button id="final-send-seller" class="flex-[1.5] py-6 bg-primary text-black font-black rounded-2xl uppercase tracking-widest transition-all shadow-[0_0_30px_rgba(255,40,0,0.3)] hover:scale-[1.02] flex items-center justify-center gap-2">
                <i class="fab fa-whatsapp text-xl"></i> ENVIAR A VENTAS
            </button>
        </div>

        <!-- History -->
        <div id="materials-history" class="hidden mt-12 space-y-4">
            <h3 class="text-xl font-black text-white uppercase tracking-tighter flex items-center gap-3">
                Historial de Placas
            </h3>
            <div id="history-container" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
        </div>
    </div>
</div>

<div id="user-profile-data" data-user={JSON.stringify(userProfile)}></div>

<script>
    import { 
        currentSheetItems, addPiece, removePiece, sheetConfig, 
        updateSheetConfig, finalizeSheet, allSheets, getVisualSummary, 
        userContext, savePedidoToDirectus 
    } from '../logic/budgetStore.js';

    const setupPanel = document.getElementById('step-setup');
    const entryPanel = document.getElementById('step-entry');
    const brandBtns = document.querySelectorAll('.brand-btn');
    const startBtn = document.getElementById('start-loading-btn');
    const backBtn = document.getElementById('back-to-setup');
    const finalizeBtn = document.getElementById('btn-finalize-sheet');
    const whatsappBtn = document.getElementById('final-send-seller');
    
    // Inputs
    const pQty = document.getElementById('p-qty') as HTMLInputElement;
    const pLen = document.getElementById('p-len') as HTMLInputElement;
    const pWid = document.getElementById('p-wid') as HTMLInputElement;
    const pCheckRot = document.getElementById('p-check-rot') as HTMLInputElement;
    const pLab = document.getElementById('p-label') as HTMLInputElement;
    const peT = document.getElementById('pe-t') as HTMLSelectElement;
    const peB = document.getElementById('pe-b') as HTMLSelectElement;
    const peL = document.getElementById('pe-l') as HTMLSelectElement;
    const peR = document.getElementById('pe-r') as HTMLSelectElement;
    const pAdd = document.getElementById('p-add-btn');

    // SYNC USER CONTEXT
    const profileEl = document.getElementById('user-profile-data');
    if (profileEl?.dataset.user) {
        userContext.set(JSON.parse(profileEl.dataset.user));
    }

    // SETUP - Sync inputs with store
    sheetConfig.subscribe(config => {
        const wInput = document.getElementById('setup-width') as HTMLInputElement;
        const hInput = document.getElementById('setup-height') as HTMLInputElement;
        const nInput = document.getElementById('setup-plate-name') as HTMLInputElement;
        if (wInput) wInput.value = config.width.toString();
        if (hInput) hInput.value = config.height.toString();
        if (nInput) nInput.value = config.plateName || '';
        
        // Highlight active brand
        brandBtns.forEach(btn => {
            if ((btn as HTMLElement).dataset.brand === config.brand) {
                btn.classList.add('bg-primary', 'text-black');
            } else {
                btn.classList.remove('bg-primary', 'text-black');
            }
        });
    });

    brandBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            updateSheetConfig({ brand: (btn as HTMLElement).dataset.brand });
        });
    });

    startBtn.addEventListener('click', () => {
        const nameInput = document.getElementById('setup-plate-name') as HTMLInputElement;
        updateSheetConfig({ 
            thickness: parseFloat((document.getElementById('setup-thickness') as HTMLSelectElement).value), 
            width: parseInt((document.getElementById('setup-width') as HTMLInputElement).value), 
            height: parseInt((document.getElementById('setup-height') as HTMLInputElement).value),
            plateName: nameInput.value.trim().toUpperCase(),
            isSetup: true 
        });
        setupPanel.classList.add('hidden');
        entryPanel.classList.remove('hidden');
        window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    backBtn.addEventListener('click', () => {
        setupPanel.classList.remove('hidden');
        entryPanel.classList.add('hidden');
    });

    finalizeBtn.addEventListener('click', () => {
        if (currentSheetItems.get().length === 0) return alert("Agregue piezas antes de cerrar la placa.");
        if (finalizeSheet()) {
            setupPanel.classList.remove('hidden');
            entryPanel.classList.add('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    });

    // PIECE LOGIC
    pAdd.addEventListener('click', savePiece);
    function savePiece() {
        const q = parseInt(pQty.value) || 1;
        const l = parseInt(pLen.value);
        const w = parseInt(pWid.value);
        if (!l || !w) return alert('Complete medidas de largo y ancho');

        addPiece({
            quantity: q,
            length: l,
            width: w,
            label: pLab.value,
            canRotate: pCheckRot.checked,
            edges: {
                top: parseFloat(peT.value),
                bottom: parseFloat(peB.value),
                left: parseFloat(peL.value),
                right: parseFloat(peR.value),
            }
        });

        pQty.value = ''; pLen.value = ''; pWid.value = ''; pLab.value = '';
        pQty.focus();
    }

    // KEYBOARD SHORTCUT
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !entryPanel.classList.contains('hidden')) {
            const activeElem = document.activeElement;
            if (activeElem?.id !== 'start-loading-btn' && activeElem?.id !== 'final-send-seller') {
                savePiece();
            }
        }
    });

    // PIECES RENDERING
    currentSheetItems.subscribe(items => {
        const config = sheetConfig.get();
        document.getElementById('stat-pieces').textContent = items.reduce((acc, i) => acc + i.quantity, 0).toString();
        const m2 = items.reduce((acc, i) => acc + ((i.length + 3) * (i.width + 3) * i.quantity) / 1000000, 0);
        const m2El = document.getElementById('stat-m2');
        if (m2El) m2El.textContent = m2.toFixed(2);

        const netSheetM2 = (config.netWidth * config.netHeight) / 1000000;
        const sheetsEstimated = Math.ceil(m2 / netSheetM2) || 0;
        const sheetsEl = document.getElementById('stat-sheets');
        if (sheetsEl) sheetsEl.textContent = sheetsEstimated.toString();

        document.getElementById('pieces-container').innerHTML = items.slice().reverse().map(item => `
            <div class="bg-white/5 border border-white/10 rounded-2xl p-4 flex justify-between items-center group animate-in slide-in-from-right duration-300">
                <div class="flex gap-4 items-center">
                    <div class="bg-primary text-black font-black w-10 h-10 rounded-full flex items-center justify-center">${item.quantity}</div>
                    <div>
                        <p class="text-white font-black text-lg">${item.length} x ${item.width}</p>
                        <p class="text-white/40 text-[10px] uppercase">${item.label || 'Pieza'} <span class="text-primary/60 ml-2">+3mm sierra</span></p>
                    </div>
                </div>
                <button onclick="window.removeSmartPiece('${item.id}')" class="text-white/20 hover:text-red-500 transition-all p-2 flex items-center gap-1">
                    <i class="fas fa-trash-alt"></i> <span class="text-[8px] font-bold uppercase">Borrar</span>
                </button>
            </div>
        `).join('');
    });

    allSheets.subscribe(sheets => {
        if (sheets.length > 0) {
            document.getElementById('materials-history').classList.remove('hidden');
            document.getElementById('history-container').innerHTML = sheets.map((s, idx) => `
                <div class="bg-white/5 border border-primary/20 rounded-2xl p-5 flex justify-between items-center">
                    <div>
                        <p class="text-[10px] text-white/40 uppercase font-black">Placa #${idx + 1}</p>
                        <p class="text-white font-bold text-lg">${s.config.plateName || s.config.brand} <span class="text-primary font-medium text-xs">${s.config.thickness}mm</span></p>
                        <p class="text-xs text-white/30">${s.items.length} piezas cargadas</p>
                    </div>
                    <div class="text-primary/40"><i class="fas fa-check-circle text-xl"></i></div>
                </div>
            `).join('');
        }
    });

    (window as any).removeSmartPiece = (id: string) => removePiece(id);

    // PDF GENERATOR INTEGRATION
    const pdfBtn = document.getElementById('btn-pdf-generator');
    pdfBtn?.addEventListener('click', () => {
        // Collect all items from all sheets
        const allItems = [];
        // Add items from previously finalized sheets
        allSheets.get().forEach(sheet => {
            sheet.items.forEach(item => {
                allItems.push({
                    description: `${sheet.config.brand} ${sheet.config.plateName} ${sheet.config.thickness}mm - ${item.label || 'Pieza'}`,
                    quantity: item.quantity,
                    dimensions: `${item.length}x${item.width}`
                });
            });
        });
        // Add items from the current active sheet
        currentSheetItems.get().forEach(item => {
            const config = sheetConfig.get();
            allItems.push({
                description: `${config.brand} ${config.plateName} ${config.thickness}mm - ${item.label || 'Pieza'}`,
                quantity: item.quantity,
                dimensions: `${item.length}x${item.width}`
            });
        });

        if (allItems.length === 0) return alert("Cargue al menos una pieza para generar el PDF.");

        // Save to sessionStorage and redirect
        sessionStorage.setItem('alvarez_budget_import', JSON.stringify(allItems));
        window.location.href = '/cliente/creador-presupuestos';
    });

    // WHATSAPP & DB SAVE
    whatsappBtn.addEventListener('click', async () => {
        const summary = getVisualSummary();
        const user = userContext.get();
        
        whatsappBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> PROCESANDO...';
        whatsappBtn.classList.add('opacity-70');
        
        // 1. Guardar en DB si está logueado
        if (user) {
            await savePedidoToDirectus();
        }

        // 2. Elegir Teléfono
        const phone = user?.vendedor?.phone || '5491161411842';
        const text = encodeURIComponent(`Hola, envío mi pedido web:\n\n${summary}`);
        
        // 3. Abrir WhatsApp
        window.open(`https://wa.me/${phone}?text=${text}`, '_blank');
        
        whatsappBtn.innerHTML = '<i class="fab fa-whatsapp text-xl"></i> ENVIAR A VENTAS';
        whatsappBtn.classList.remove('opacity-70');
    });

</script>

<style>
    .brand-btn.bg-primary { box-shadow: 0 0 20px rgba(255, 40, 0, 0.4); }
    .animate-in { animation: fadeIn 0.5s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>
