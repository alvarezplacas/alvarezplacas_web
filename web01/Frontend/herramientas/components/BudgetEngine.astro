---
/**
 * BudgetEngine - Motor interactivo de presupuestos "SmartFlow".
 * Versión Restaurada y Potenciada con Exportación LEPTOM.
 * Propiedad del Agente 5 (Frontend/Herramientas).
 */
---
<div class="max-w-4xl mx-auto" id="smart-flow-engine">
    
    <!-- STEP 1: SHEET CONFIGURATION -->
    <div id="step-setup" class="bg-white/10 backdrop-blur-xl border border-white/20 rounded-3xl p-8 shadow-2xl animate-in fade-in zoom-in duration-500">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-black text-white mb-2 tracking-tighter uppercase italic">Configuración de Placa</h2>
            <p class="text-white/60 text-sm">Define el material base antes de cargar los cortes</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-4">
                <div>
                    <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1 tracking-widest">Marca / Fabricante</label>
                    <div class="grid grid-cols-2 gap-2">
                        {['FAPLAC', 'EGGER', 'SADEPAN', 'OTRO'].map(brand => (
                            <button class="brand-btn bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl py-4 text-white font-bold transition-all" data-brand={brand}>{brand}</button>
                        ))}
                    </div>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1 tracking-widest">Espesor Placa (mm)</label>
                    <select id="setup-thickness" class="w-full bg-white/10 border border-white/10 rounded-2xl px-4 py-3 text-white font-bold outline-none focus:border-primary transition-all">
                        <option value="25" class="bg-gray-900">25 mm</option>
                        <option value="18" selected class="bg-gray-900">18 mm</option>
                        <option value="15" class="bg-gray-900">15 mm</option>
                        <option value="9" class="bg-gray-900">9 mm</option>
                        <option value="5.5" class="bg-gray-900">5.5 mm</option>
                        <option value="3" class="bg-gray-900">3 mm</option>
                    </select>
                </div>
            </div>

            <div id="custom-size-panel" class="space-y-4 opacity-100 transition-opacity">
                <div>
                    <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1 tracking-widest">Largo de Placa (mm)</label>
                    <input type="number" id="setup-width" value="2750" class="w-full bg-white/10 border border-white/10 rounded-2xl px-4 py-3 text-white font-bold outline-none focus:border-primary transition-all" />
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-white/40 uppercase mb-2 ml-1 tracking-widest">Ancho de Placa (mm)</label>
                    <input type="number" id="setup-height" value="1830" class="w-full bg-white/10 border border-white/10 rounded-2xl px-4 py-3 text-white font-bold outline-none focus:border-primary transition-all" />
                </div>
                <div class="bg-primary/20 border border-primary/30 rounded-2xl p-4">
                    <p class="text-[10px] text-primary font-black uppercase mb-1 tracking-widest">Cálculo de Refilado</p>
                    <p class="text-xs text-white/80">Se descontarán <span class="font-bold underline">5mm</span> automáticamente de cada lado para asegurar cortes limpios.</p>
                </div>
            </div>
        </div>

        <button id="start-loading-btn" class="w-full mt-8 py-5 bg-primary hover:bg-orange-500 text-black font-black rounded-2xl shadow-[0_0_30px_rgba(255,40,0,0.3)] transform transition-all active:scale-95 uppercase tracking-widest border-b-4 border-black/20">
            Comenzar Carga de Cortes
        </button>
    </div>

    <!-- STEP 2: PIECE ENTRY (HIDDEN INITIALLY) -->
    <div id="step-entry" class="hidden space-y-6">
        
        <!-- Header / Stats Overlay -->
        <div class="flex justify-between items-center bg-white/5 backdrop-blur-md p-4 rounded-2xl border border-white/10 sticky top-4 z-10 shadow-xl">
            <button id="back-to-setup" class="text-white/60 hover:text-white flex items-center gap-2 text-xs font-bold uppercase transition-all">
                Config. Placa
            </button>
            <div class="flex gap-4">
                <div class="text-right">
                    <p class="text-[9px] text-white/40 uppercase font-bold">Piezas</p>
                    <p id="stat-pieces" class="text-xl font-black text-primary">0</p>
                </div>
                <div class="text-right">
                    <p class="text-[9px] text-white/40 uppercase font-bold">Total m²</p>
                    <p id="stat-m2" class="text-xl font-black text-white">0.00</p>
                </div>
            </div>
        </div>

        <!-- MOVIMIENTO: List of Pieces -->
        <div class="space-y-3" id="pieces-container">
            <!-- Piece cards will be injected here -->
        </div>

        <!-- The "One-at-a-time" Entry Form -->
        <div class="bg-primary/95 border-b-8 border-black/20 rounded-3xl p-6 shadow-2xl relative overflow-hidden group">
            <h3 class="text-black font-black uppercase text-xl mb-4 tracking-tighter">Nueva Pieza</h3>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="col-span-2 md:col-span-1">
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Cantidad</label>
                    <input type="number" id="p-qty" placeholder="1" class="w-full bg-white border-2 border-black rounded-xl px-4 py-3 text-xl font-black text-black outline-none" />
                </div>
                <div>
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Largo (mm)</label>
                    <input type="number" id="p-len" placeholder="0" class="w-full bg-white border-2 border-black rounded-xl px-4 py-3 text-xl font-black text-black outline-none" />
                </div>
                <div>
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Ancho (mm)</label>
                    <input type="number" id="p-wid" placeholder="0" class="w-full bg-white border-2 border-black rounded-xl px-4 py-3 text-xl font-black text-black outline-none" />
                </div>
                <div class="col-span-2 md:col-span-1">
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Sentido de Veta</label>
                    <label class="flex items-center gap-2 bg-white border-2 border-black rounded-xl py-3 px-4 cursor-pointer hover:bg-white/80 transition-all h-[54px]">
                        <input type="checkbox" id="p-check-rot" checked class="w-5 h-5 accent-black" />
                        <span class="text-[10px] font-black text-black uppercase">Permitir Gire</span>
                    </label>
                </div>
            </div>

            <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Nombre / Identificador</label>
                    <input type="text" id="p-label" placeholder="Ej: Puerta Bajo Mesada" class="w-full bg-white border-2 border-black rounded-xl px-4 py-3 text-lg font-bold text-black outline-none" />
                </div>
                <div>
                    <label class="block text-[10px] font-black text-black/60 uppercase mb-1">Tapacantos (Sup-Inf-Izq-Der) <span class="text-[8px] opacity-70">- Espesor en mm</span></label>
                    <div class="flex gap-1">
                        <select id="pe-t" class="flex-1 bg-white border-2 border-black rounded-lg py-3 text-[11px] font-black text-black appearance-none text-center">
                            <option value="0">SIN</option>
                            <option value="0.45">0.45</option>
                            <option value="1">1.00</option>
                            <option value="2">2.00</option>
                        </select>
                        <select id="pe-b" class="flex-1 bg-white border-2 border-black rounded-lg py-3 text-[11px] font-black text-black appearance-none text-center">
                            <option value="0">SIN</option>
                            <option value="0.45">0.45</option>
                            <option value="1">1.00</option>
                            <option value="2">2.00</option>
                        </select>
                        <select id="pe-l" class="flex-1 bg-white border-2 border-black rounded-lg py-3 text-[11px] font-black text-black appearance-none text-center">
                            <option value="0">SIN</option>
                            <option value="0.45">0.45</option>
                            <option value="1">1.00</option>
                            <option value="2">2.00</option>
                        </select>
                        <select id="pe-r" class="flex-1 bg-white border-2 border-black rounded-lg py-3 text-[11px] font-black text-black appearance-none text-center">
                            <option value="0">SIN</option>
                            <option value="0.45">0.45</option>
                            <option value="1">1.00</option>
                            <option value="2">2.00</option>
                        </select>
                    </div>
                </div>
            </div>
            
            <button id="p-add-btn" class="w-full mt-6 py-4 bg-black text-white font-black rounded-xl hover:bg-gray-900 transition-all uppercase tracking-widest shadow-xl flex items-center justify-center gap-2">
                Agregar Pieza (Enter)
            </button>
        </div>

        <!-- ACTIONS -->
        <div id="material-actions" class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
            <button id="btn-finalize-sheet" class="py-5 bg-gray-800 hover:bg-gray-700 text-white font-black rounded-2xl border border-white/10 transition-all flex items-center justify-center gap-2 uppercase tracking-widest">
                Terminar Placa Actual
            </button>

            <button id="btn-copy-leptom" class="py-5 bg-teal-600 hover:bg-teal-700 text-white font-black rounded-2xl border border-white/10 transition-all flex items-center justify-center gap-2 uppercase tracking-widest shadow-lg shadow-teal-900/40">
                Copiar para LEPTOM
            </button>

            <button id="btn-export-pdf" class="py-5 bg-blue-600 hover:bg-blue-700 text-white font-black rounded-2xl border border-white/10 transition-all flex items-center justify-center gap-2 uppercase tracking-widest shadow-lg shadow-blue-900/40">
                Generar PDF Cliente
            </button>

            <button id="final-send-seller" class="py-6 bg-primary text-black font-black rounded-2xl uppercase tracking-widest transition-all shadow-[0_0_30px_rgba(255,40,0,0.3)] hover:scale-[1.02] md:col-span-2">
                Enviar a Vendedor (WhatsApp)
            </button>
        </div>

        <!-- History -->
        <div id="materials-history" class="hidden mt-12 space-y-4">
            <h3 class="text-xl font-black text-white uppercase tracking-tighter flex items-center gap-3">
                Historial de Placas
            </h3>
            <div id="history-container" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
        </div>
    </div>
</div>

<!-- CDN Scripts for PDF -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>

<script>
    import { currentSheetItems, addPiece, removePiece, sheetConfig, updateSheetConfig, finalizeSheet, allSheets, getLeptomExport, getVisualSummary, assignSeller } from '../logic/budgetStore.js';

    const setupPanel = document.getElementById('step-setup');
    const entryPanel = document.getElementById('step-entry');
    const brandBtns = document.querySelectorAll('.brand-btn');
    const startBtn = document.getElementById('start-loading-btn');
    const backBtn = document.getElementById('back-to-setup');
    const finalizeBtn = document.getElementById('btn-finalize-sheet');
    const copyLeptomBtn = document.getElementById('btn-copy-leptom');
    const pdfBtn = document.getElementById('btn-export-pdf');
    const whatsappBtn = document.getElementById('final-send-seller');
    
    // Inputs
    const pQty = document.getElementById('p-qty');
    const pLen = document.getElementById('p-len');
    const pWid = document.getElementById('p-wid');
    const pCheckRot = document.getElementById('p-check-rot');
    const pLab = document.getElementById('p-label');
    const peT = document.getElementById('pe-t');
    const peB = document.getElementById('pe-b');
    const peL = document.getElementById('pe-l');
    const peR = document.getElementById('pe-r');
    const pAdd = document.getElementById('p-add-btn');

    // SETUP
    brandBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            brandBtns.forEach(b => b.classList.remove('bg-primary', 'text-black'));
            btn.classList.add('bg-primary', 'text-black');
            updateSheetConfig({ brand: btn.dataset.brand });
        });
    });

    startBtn.addEventListener('click', () => {
        updateSheetConfig({ 
            thickness: parseFloat(document.getElementById('setup-thickness').value), 
            width: parseInt(document.getElementById('setup-width').value), 
            height: parseInt(document.getElementById('setup-height').value),
            isSetup: true 
        });
        setupPanel.classList.add('hidden');
        entryPanel.classList.remove('hidden');
    });

    backBtn.addEventListener('click', () => {
        setupPanel.classList.remove('hidden');
        entryPanel.classList.add('hidden');
    });

    finalizeBtn.addEventListener('click', () => {
        if (finalizeSheet()) {
            setupPanel.classList.remove('hidden');
            entryPanel.classList.add('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    });

    // LEPTOM COPY
    copyLeptomBtn.addEventListener('click', () => {
        const text = getLeptomExport();
        if (!text) return alert('Agregue piezas primero');
        
        navigator.clipboard.writeText(text).then(() => {
            const originalText = copyLeptomBtn.textContent;
            copyLeptomBtn.textContent = '¡COPIADO!';
            copyLeptomBtn.classList.replace('bg-teal-600', 'bg-green-600');
            setTimeout(() => {
                copyLeptomBtn.textContent = originalText;
                copyLeptomBtn.classList.replace('bg-green-600', 'bg-teal-600');
            }, 2000);
        });
    });

    // PIECE LOGIC
    pAdd.addEventListener('click', savePiece);
    function savePiece() {
        const q = parseInt(pQty.value) || 1;
        const l = parseInt(pLen.value);
        const w = parseInt(pWid.value);
        if (!l || !w) return alert('Complete medidas');

        addPiece({
            quantity: q,
            length: l,
            width: w,
            label: pLab.value,
            canRotate: pCheckRot.checked,
            edges: {
                top: parseFloat(peT.value),
                bottom: parseFloat(peB.value),
                left: parseFloat(peL.value),
                right: parseFloat(peR.value),
            }
        });

        pQty.value = ''; pLen.value = ''; pWid.value = ''; pLab.value = '';
        pQty.focus();
    }

    // PIECES RENDERING
    currentSheetItems.subscribe(items => {
        document.getElementById('stat-pieces').textContent = items.reduce((acc, i) => acc + i.quantity, 0);
        const m2 = items.reduce((acc, i) => acc + (i.length * i.width * i.quantity) / 1000000, 0);
        document.getElementById('stat-m2').textContent = m2.toFixed(2);

        document.getElementById('pieces-container').innerHTML = items.slice().reverse().map(item => `
            <div class="bg-white/5 border border-white/10 rounded-2xl p-4 flex justify-between items-center group">
                <div class="flex gap-4 items-center">
                    <div class="bg-primary text-black font-black w-10 h-10 rounded-full flex items-center justify-center">${item.quantity}</div>
                    <div>
                        <p class="text-white font-black text-lg">${item.length} x ${item.width}</p>
                        <p class="text-white/40 text-xs uppercase">${item.label || 'Pieza'}</p>
                    </div>
                </div>
                <button onclick="window.removeSmartPiece('${item.id}')" class="text-white/20 hover:text-red-500 transition-all p-2">
                    <i class="fas fa-trash-alt"></i> Eliminar
                </button>
            </div>
        `).join('');
    });

    allSheets.subscribe(sheets => {
        if (sheets.length > 0) {
            document.getElementById('materials-history').classList.remove('hidden');
            document.getElementById('history-container').innerHTML = sheets.map((s, idx) => `
                <div class="bg-white/5 border border-primary/20 rounded-2xl p-4">
                    <p class="text-white font-bold">#${idx + 1} - ${s.config.brand} ${s.config.thickness}mm</p>
                    <p class="text-xs text-white/40">${s.items.length} piezas</p>
                </div>
            `).join('');
        }
    });

    window.removeSmartPiece = (id) => removePiece(id);

    // WHATSAPP
    whatsappBtn.addEventListener('click', () => {
        const summary = getVisualSummary();
        const text = encodeURIComponent(`Hola, envío mi pedido:\n\n${summary}`);
        window.open(`https://wa.me/5491161411842?text=${text}`, '_blank');
    });

</script>

<style>
    .brand-btn.bg-primary { box-shadow: 0 0 20px rgba(255, 40, 0, 0.4); }
    .animate-in { animation: fadeIn 0.5s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>
