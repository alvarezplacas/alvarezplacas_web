---
/**
 * Herramientas Index - Centro de utilidades para el usuario.
 * Estética Taller Digital (OKLCH + Glass + 3 Col).
 */
import Layout from '../../home/layouts/Layout.astro';
import Header from '@components/Header.astro';
import '../../home/styles/workshop.css';

const tools = [
  {
    title: "Smart Match",
    description: "IA que sugiere combinaciones de colores usando la regla 60-30-10.",
    icon: "fa-magic",
    link: "/herramientas/smart-match",
    color: "var(--primary)"
  },
  {
    title: "Envío de Cortes",
    description: "Calcula tus cortes y envíalos directamente a nuestro equipo.",
    icon: "fa-calculator",
    link: "/herramientas/presupuestador",
    color: "oklch(70% 0.15 150)"
  },
  {
    title: "Presupuestos Online",
    description: "Generación de presupuestos profesionales en PDF para tus clientes.",
    icon: "fa-file-invoice-dollar",
    link: "/cliente/creador-presupuestos",
    color: "oklch(60% 0.18 260)"
  }
];
---

<Layout title="Herramientas Expertas | Alvarez Placas">
  <Header />
  
  <main class="relative pt-32 pb-24 min-h-screen bg-[#050505] overflow-hidden">
    
    <!-- Workshop Grids -->
    <div class="absolute inset-0 z-0 workshop-grid pointer-events-none"></div>
    <div class="absolute inset-0 z-0 workshop-grid-fine pointer-events-none"></div>

    <div class="relative z-10 max-w-[1800px] mx-auto px-6 lg:px-12">
      
      <!-- Titular -->
      <div class="mb-20 text-center">
        <h1 class="text-6xl md:text-8xl font-black mb-8 tracking-tighter text-white">
          Herramientas <span class="italic text-[oklch(65%_0.23_35)]">Expertas</span>
        </h1>
        <p class="text-[oklch(85%_0.01_250)] text-xl max-w-3xl mx-auto leading-relaxed font-light">
          Potencia tus proyectos con nuestras utilidades inteligentes diseñadas para <span class="text-white font-medium">carpinteros y entusiastas del diseño</span>.
        </p>
      </div>

      <!-- Grid de Herramientas (3 Columnas Full Width) -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {tools.map(tool => (
          <a href={tool.link} class="group relative block h-full">
            <div class="glass-card p-10 rounded-[2rem] h-full flex flex-col items-center text-center overflow-hidden">
              
              <!-- Icon with Glow -->
              <div class="relative w-20 h-20 rounded-2xl flex items-center justify-center mb-10 transition-transform duration-500 group-hover:scale-110"
                   style={`background-color: ${tool.color}; box-shadow: 0 15px 30px -10px ${tool.color}60;`}>
                <i class={`fas ${tool.icon} text-3xl text-white`}></i>
              </div>

              <h2 class="text-3xl font-bold text-white mb-6 tracking-tight">{tool.title}</h2>
              <p class="text-gray-400 text-lg group-hover:text-gray-200 transition-colors duration-500">
                {tool.description}
              </p>

              <!-- Glass Button Link -->
              <div class="mt-12 py-3 px-8 rounded-full border border-white/10 bg-white/5 text-xs font-bold uppercase tracking-[0.2em] text-white/60 group-hover:text-white group-hover:border-primary/50 group-hover:bg-primary/10 transition-all duration-500">
                Explorar <i class="fas fa-chevron-right ml-2 text-[8px]"></i>
              </div>

            </div>
          </a>
        ))}
      </div>

    </div>
  </main>
</Layout>

<style>
  main {
    animation: fadeIn 1s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
