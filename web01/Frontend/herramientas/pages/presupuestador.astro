---
// Alvarez SmartCut - Optimizador de Corte Grand Master (v4.4)
// Versión Integrada Profesional - Mayo 2026
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Optimizador Grand Master | Alvarez Placas</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800&family=JetBrains+Mono:wght@400;700;800&display=swap" rel="stylesheet">
    
    <style is:inline>
        :root {
            --alvarez-red: #e63946;
            --alvarez-dark: #000;
            --alvarez-silver: #c0c0c0;
            --alvarez-gold: #d4af37;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: var(--alvarez-dark); color: white; font-family: 'Inter', sans-serif; overflow-x: hidden; }
        #app { min-height: 100vh; display: flex; flex-direction: column; }

        .main-header { padding: 20px 40px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1a1a1a; background: rgba(0,0,0,0.8); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 100; }
        .logo h1 { font-size: 1.5rem; font-weight: 800; letter-spacing: -1px; margin: 0; }
        .logo .accent { color: var(--alvarez-red); }
        .logo .subtitle { font-size: 0.7rem; letter-spacing: 3px; color: #666; margin-top: -5px; }

        .logo-area { display: flex; align-items: center; gap: 40px; flex: 1; }
        .main-nav { display: flex; gap: 25px; margin-left: auto; margin-right: 40px; }
        .main-nav a { color: #fff; text-decoration: none; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; transition: all 0.3s; }
        .main-nav a:hover { color: var(--alvarez-red); }
        .btn-contact { border: 1px solid var(--alvarez-red); color: var(--alvarez-red); padding: 8px 25px; border-radius: 50px; text-decoration: none; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; transition: all 0.3s; }
        .btn-contact:hover { background: var(--alvarez-red); color: white; }

        main { flex: 1; padding: 40px; }
        .animate-in { animation: fadeIn 0.5s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .card-glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.05); padding: 30px; border-radius: 8px; }
        .btn-main { background: var(--alvarez-red); color: white; border: none; padding: 12px 30px; border-radius: 4px; font-weight: 700; cursor: pointer; transition: all 0.3s; }
        .btn-main:hover { background: #ff4d5a; transform: translateY(-2px); }
        .btn-sm { background: #222; color: #888; border: 1px solid #333; padding: 8px 15px; border-radius: 4px; cursor: pointer; font-size: 0.8rem; }
        .btn-red { color: var(--alvarez-red); }
        .btn-icon { background: transparent; border: 1px solid #333; color: #aaa; padding: 10px 20px; border-radius: 4px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 0.8rem; }
        .btn-icon:hover { border-color: var(--alvarez-red); color: white; }

        .setup-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 20px; margin-top: 20px; }
        .input-field { display: flex; flex-direction: column; gap: 8px; }
        .input-field label { font-size: 0.75rem; color: #666; text-transform: uppercase; font-weight: 700; }
        .input-field input, .input-field select { background: #111; border: 1px solid #222; color: white; padding: 12px; border-radius: 4px; font-family: 'JetBrains Mono', monospace; }
        .input-field input:focus { border-color: var(--alvarez-red); outline: none; }

        /* Grand Master Layout Form */
        .lepton-form { background: #0a0a0b; border: 1px solid #333; padding: 15px 25px; border-radius: 4px; width: 100%; }
        .plate-name-header { color: var(--alvarez-red); font-size: 0.85rem; font-weight: 900; margin-bottom: 15px; border-bottom: 1px solid #222; padding-bottom: 10px; }
        
        .main-data { display: grid; grid-template-columns: auto 60px auto auto 100px auto auto 100px auto auto 1fr auto auto 60px; gap: 8px; align-items: center; white-space: nowrap; }
        .edges-data { display: grid; grid-template-columns: auto auto 60px auto 60px auto 60px auto 60px auto 1fr; gap: 10px; align-items: center; margin-top: 15px; }
        .lepton-separator { height: 1px; background: #333; margin: 15px 0; }
        .l-label { font-size: 0.7rem; font-weight: 900; color: #666; }
        .l-label-red { font-size: 0.7rem; font-weight: 900; color: var(--alvarez-red); }
        .l-divider { color: #333; font-weight: 900; font-size: 1.2rem; padding: 0 5px; }
        
        .lepton-form input, .lepton-form select { background: #141417; border: 1px solid #333; color: #fff; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; padding: 6px 10px; border-radius: 2px; }
        .lepton-form input:focus { border-color: var(--alvarez-red); }
        
        #p-qty { width: 55px; text-align: center; }
        #p-len, #p-wid { width: 90px; text-align: center; }
        #p-label { width: 100%; }

        .l-btn-add { background: #fff; color: #000; border: none; padding: 8px 20px; font-weight: 900; font-size: 0.75rem; cursor: pointer; text-transform: uppercase; margin-left: auto; }
        .l-btn-add:hover { background: var(--alvarez-red); color: white; }

        .list-column { background: #050505; border: 1px solid #111; border-radius: 8px; display: flex; flex-direction: column; }
        .column-header { padding: 15px; font-size: 0.7rem; color: #444; font-weight: 900; border-bottom: 1px solid #111; letter-spacing: 2px; }
        .pieces-scroll, .plates-grid-scroll { padding: 15px; max-height: 600px; overflow-y: auto; }
        
        .piece-item { display: flex; justify-content: space-between; align-items: center; padding: 10px; border-bottom: 1px solid #111; }
        .piece-info h4 { font-size: 0.9rem; color: #fff; }
        .piece-info p { font-size: 0.7rem; color: #666; }
        .piece-info .corte { color: var(--alvarez-red); font-weight: 700; margin-left: 5px; }
        .btn-del { background: transparent; border: none; color: #444; cursor: pointer; }
        .btn-del:hover { color: var(--alvarez-red); }

        canvas { border: 1px solid #222; max-width: 100%; height: auto; margin-top: 10px; }
        .plate-view-wrap { margin-bottom: 40px; }
        .plate-label { font-size: 0.7rem; color: #555; font-weight: 800; margin-bottom: 8px; letter-spacing: 1px; }

        .stats-bar-new { display: flex; gap: 10px; height: 70px; align-items: stretch; margin-bottom: 20px; }
        .stats-bar-new .stat { flex: 1; background: #111; border: 1px solid #222; display: flex; flex-direction: column; justify-content: center; align-items: center; border-radius: 4px; }
        .stat span { font-size: 0.65rem; color: #555; font-weight: 900; text-transform: uppercase; }
        .stat strong { display: block; font-size: 1.3rem; color: var(--alvarez-red); }

        .hero-container { padding: 60px 20px; text-align: center; max-width: 800px; margin: 0 auto; }
        .hero-content h2 { font-size: 2.5rem; color: var(--alvarez-silver); margin-bottom: 10px; font-weight: 800; }
        .hero-content p { color: #888; margin-bottom: 40px; font-size: 1.1rem; }
        .btn-main-large { background: var(--alvarez-red); color: white; border: none; padding: 18px 45px; font-size: 1.2rem; font-weight: 700; border-radius: 50px; cursor: pointer; box-shadow: 0 10px 30px rgba(230, 57, 70, 0.3); transition: all 0.3s; text-transform: uppercase; }
        .btn-main-large:hover { transform: translateY(-5px); background: #ff4d5a; }

        .global-actions { display: flex; flex-direction: column; align-items: center; padding: 40px 0; border-top: 1px solid #1a1a1a; }
        .btn-whatsapp-large { background: linear-gradient(135deg, #25d366, #128c7e) !important; color: white !important; border: none !important; padding: 22px 60px !important; font-size: 1.3rem !important; font-weight: 800 !important; border-radius: 60px !important; cursor: pointer; display: flex; align-items: center; gap: 15px; box-shadow: 0 15px 35px rgba(37, 211, 102, 0.2); transition: all 0.4s; text-transform: uppercase; }
        .btn-print { background: #444 !important; color: white !important; border: none !important; padding: 22px 40px !important; font-size: 1.1rem !important; font-weight: 700 !important; border-radius: 60px !important; cursor: pointer; display: flex; align-items: center; gap: 12px; transition: all 0.3s; text-transform: uppercase; }
        .btn-whatsapp-large:hover, .btn-print:hover { transform: translateY(-5px); filter: brightness(1.1); }
        .flex-actions { display: flex; gap: 20px; align-items: center; }
        .send-summary { color: #666; font-size: 0.9rem; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 2px; }

        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.85); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 9999; }
        .modal-content { max-width: 450px; padding: 40px; text-align: center; }
        .icon-lock { font-size: 3rem; color: var(--alvarez-red); margin-bottom: 20px; }

        .hidden { display: none !important; }
        .mt-4 { margin-top: 15px; }
        .mt-6 { margin-top: 25px; }
        .mt-8 { margin-top: 35px; }
        .mt-12 { margin-top: 60px; }
        .main-layout { display: grid; grid-template-columns: 320px 1fr; gap: 30px; margin-top: 30px; }

        #btn-recalc { background: linear-gradient(135deg, #d4af37, #aa8507) !important; color: #000 !important; font-weight: 800 !important; border: none !important; padding: 0 25px !important; height: 100% !important; border-radius: 4px; cursor: pointer; text-transform: uppercase; font-family: 'JetBrains Mono', monospace; }
        .btn-finish { background: #333 !important; color: #fff !important; border: 1px solid #444 !important; padding: 0 20px !important; height: 100% !important; border-radius: 4px; cursor: pointer; text-transform: uppercase; }

        .projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
        .project-card { display: flex; justify-content: space-between; align-items: center; padding: 20px; }
        .proj-info h3 { color: var(--alvarez-red); font-size: 1rem; }
        .proj-info p { color: #888; font-size: 0.8rem; }
        .proj-actions { display: flex; gap: 10px; }

        @media (max-width: 800px) {
            .main-data, .edges-data { display: flex; flex-direction: column; align-items: stretch; }
            .l-divider { display: none; }
            .main-layout { grid-template-columns: 1fr; }
        }

        @media print {
            body * { visibility: hidden; }
            #plates-container, #plates-container * { visibility: visible; }
            #plates-container { position: absolute; left: 0; top: 0; width: 100%; }
            canvas { width: 100% !important; height: auto !important; filter: invert(1) grayscale(1); border: 1px solid #000; }
            .plate-view-wrap { page-break-after: always; }
        }
    </style>
</head>
<body>
    <div id="app">
        <header class="main-header">
            <div class="logo-area">
                <div class="logo">
                    <h1>ALVAREZ <span class="accent">PLACAS</span></h1>
                    <p class="subtitle">OPTIMIZADOR DE CORTE</p>
                </div>
                <nav class="main-nav">
                    <a href="/catalogo">CATÁLOGO</a>
                    <a href="/presupuestador" style="color: var(--alvarez-red);">PRESUPUESTAR</a>
                    <a href="/herramientas">HERRAMIENTAS</a>
                    <a href="/club">CLUB</a>
                    <a href="/contacto" class="btn-contact">CONTACTO</a>
                </nav>
            </div>
            <div class="header-actions">
                <button id="btn-back-home" class="btn-icon hidden"><i class="fas fa-arrow-left"></i> VOLVER</button>
            </div>
        </header>

        <main>
            <section id="home-section" class="animate-in">
                <div class="hero-container">
                    <div class="hero-content">
                        <h2>Optimizador de Corte</h2>
                        <p>Inicia una nueva optimización profesional para tus placas.</p>
                        <button id="btn-new-opt" class="btn-main-large"><i class="fas fa-plus"></i> NUEVA CARGA DE MATERIAL</button>
                    </div>
                    <div class="global-settings card-glass mt-12">
                        <div class="settings-header" style="margin-bottom: 20px; font-weight: 800; font-size: 0.8rem; color: #555;"><i class="fas fa-cog"></i> AJUSTES DEL OPTIMIZADOR</div>
                        <div class="setup-grid">
                            <div class="input-field">
                                <label>Visualización</label>
                                <select id="global-show-gfx">
                                    <option value="yes" selected>SÍ - Ver Tableros</option>
                                    <option value="no">NO - Solo Datos</option>
                                </select>
                            </div>
                            <div class="input-field">
                                <label>Potencia</label>
                                <select id="global-opt-level">
                                    <option value="4">Estándar</option>
                                    <option value="100">Profesional</option>
                                    <option value="1000" selected>Maestro</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="projects-section mt-12">
                    <h3 style="text-align: center; color: #333; font-size: 0.7rem; letter-spacing: 2px; margin-bottom: 30px;">TUS OPTIMIZACIONES ACTIVAS</h3>
                    <div id="session-projects-list" class="projects-grid"></div>
                    <div class="global-actions mt-12 hidden"></div>
                </div>
            </section>

            <section id="setup-section" class="card-glass animate-in hidden">
                <div class="section-title" style="margin-bottom: 20px;"><h2>Configurar Material</h2></div>
                <div class="setup-grid">
                    <div class="input-field"><label>Marca</label><select id="plate-brand"><option value="EGGER">EGGER</option><option value="FAPLAC" selected>FAPLAC</option><option value="SADEPAN">SADEPAN</option><option value="NOVA">NOVA</option><option value="MASISA">MASISA</option><option value="ARAUCO">ARAUCO</option><option value="OSB">OSB</option><option value="FIBROPLUS">FIBROPLUS</option><option value="OTRO">OTRO</option></select></div>
                    <div class="input-field"><label>Espesor</label><select id="plate-thickness"><option value="3">3 mm</option><option value="5.5">5.5 mm</option><option value="9">9 mm</option><option value="12">12 mm</option><option value="15">15 mm</option><option value="18" selected>18 mm</option><option value="22">22 mm</option><option value="25">25 mm</option><option value="30">30 mm</option></select></div>
                    <div class="input-field"><label>Largo</label><input type="number" id="plate-width" value="2750"></div>
                    <div class="input-field"><label>Alto</label><input type="number" id="plate-height" value="1830"></div>
                </div>
                <div style="margin-top: 20px; font-size: 0.7rem; color: #555; text-align: center;">Refilado: 5mm | Sierra: 4mm | Útil: <strong id="useful-dim">2740 x 1820</strong>mm</div>
                <button id="btn-start" class="btn-main mt-6">CONFIRMAR E INICIAR</button>
            </section>

            <section id="entry-section" class="hidden animate-in">
                <div class="stats-bar-new">
                    <button id="btn-finish-opt" class="btn-finish">GUARDAR Y VOLVER</button>
                    <div class="stat"><span>Piezas</span><strong id="stat-count">0</strong></div>
                    <div class="stat"><span>Placas</span><strong id="stat-sheets">0</strong></div>
                    <div class="stat"><span>M²</span><strong id="stat-m2">0.00</strong></div>
                    <button id="btn-recalc" class="btn-sm">RE-CALCULAR</button>
                </div>
                <div class="lepton-form">
                    <div class="plate-name-header">OPTIMIZANDO: <span id="display-plate-name">FAPLAC 18MM</span></div>
                    <div class="main-data">
                        <span class="l-label">CANT:</span><input type="number" id="p-qty" value="1" data-next="p-len"><div class="l-divider">|</div>
                        <span class="l-label">LARGO:</span><input type="number" id="p-len" placeholder="0000" data-next="p-wid"><div class="l-divider">|</div>
                        <span class="l-label">ALTO:</span><input type="number" id="p-wid" placeholder="0000" data-next="p-label"><div class="l-divider">|</div>
                        <span class="l-label">NOM:</span><input type="text" id="p-label" placeholder="xxxx" data-next="pe-t"><div class="l-divider">|</div>
                        <span class="l-label">GIRAR:</span><input type="checkbox" id="p-rot" checked>
                    </div>
                    <div class="lepton-separator"></div>
                    <div class="edges-data">
                        <span class="l-label-red">TAPACANTO:</span>
                        <select id="pe-t" data-next="pe-b"><option value="0">0</option><option value="0.45">.45</option><option value="1">1</option><option value="2">2</option></select><div class="l-divider">|</div>
                        <select id="pe-b" data-next="pe-l"><option value="0">0</option><option value="0.45">.45</option><option value="1">1</option><option value="2">2</option></select><div class="l-divider">|</div>
                        <select id="pe-l" data-next="pe-r"><option value="0">0</option><option value="0.45">.45</option><option value="1">1</option><option value="2">2</option></select><div class="l-divider">|</div>
                        <select id="pe-r" data-next="btn-add"><option value="0">0</option><option value="0.45">.45</option><option value="1">1</option><option value="2">2</option></select>
                        <button id="btn-add" class="l-btn-add">AÑADIR (ENTER)</button>
                    </div>
                </div>
                <div class="main-layout mt-8">
                    <div class="list-column"><div class="column-header">PIEZAS CARGADAS</div><div id="pieces-list" class="pieces-scroll"></div></div>
                    <div class="plates-column" id="plates-visual-area"><div class="column-header">PLANO ESTIMADO</div><div id="plates-container" class="plates-grid-scroll"></div></div>
                </div>
            </section>
        </main>

        <div id="auth-modal" class="modal-overlay hidden">
            <div class="modal-content card-glass animate-in">
                <i class="fas fa-lock icon-lock"></i>
                <h2>Función Exclusiva</h2>
                <p>Para enviar este pedido o descargar el plano, debes estar registrado en Alvarez Placas.</p>
                <div class="modal-actions mt-6">
                    <a href="/login" class="btn-main">INICIAR SESIÓN</a>
                    <a href="/registro" style="color: #888; text-decoration: none; margin-left: 20px; font-weight: 700; font-size: 0.8rem;">REGISTRARSE GRATIS</a>
                </div>
                <button id="btn-close-modal" class="btn-sm mt-4">Cerrar</button>
            </div>
        </div>
    </div>

    <script is:inline>
        const SIERRA = 4; const REFILADO = 5;
        const BRANDS = { 'EGGER': {w:2600,h:1830}, 'FAPLAC': {w:2750,h:1830}, 'SADEPAN': {w:2820,h:1830}, 'NOVA': {w:3660,h:1830}, 'MASISA': {w:2600,h:1830}, 'ARAUCO': {w:2600,h:1830}, 'OSB': {w:2440,h:1220}, 'FIBROPLUS': {w:2600,h:1830}, 'OTRO': {w:2750,h:1830} };
        
        let session = { 
            projects: [], 
            currentProjectIndex: -1, 
            settings: { showGraphics: true, optLevel: 1000 } 
        };

        // UI Selectors
        const homeSection = document.getElementById('home-section');
        const setupSection = document.getElementById('setup-section');
        const entrySection = document.getElementById('entry-section');
        const btnBackHome = document.getElementById('btn-back-home');
        const authModal = document.getElementById('auth-modal');
        const usefulDim = document.getElementById('useful-dim');

        function isAuthenticated() { return document.cookie.includes('client_session') || document.cookie.includes('seller_session') || document.cookie.includes('admin_session'); }
        
        function showSection(id) { 
            [homeSection, setupSection, entrySection].forEach(s => s.classList.add('hidden')); 
            document.getElementById(id).classList.remove('hidden'); 
            if(id==='home-section') btnBackHome.classList.add('hidden'); 
            else btnBackHome.classList.remove('hidden'); 
        }

        function updateUseful() {
            const w = parseInt(document.getElementById('plate-width').value) || 0;
            const h = parseInt(document.getElementById('plate-height').value) || 0;
            usefulDim.textContent = `${w - REFILADO*2} x ${h - REFILADO*2}`;
        }
        document.getElementById('plate-width').oninput = updateUseful;
        document.getElementById('plate-height').oninput = updateUseful;
        document.getElementById('plate-brand').onchange = (e) => {
            const b = BRANDS[e.target.value];
            if(b) { document.getElementById('plate-width').value = b.w; document.getElementById('plate-height').value = b.h; updateUseful(); }
        };

        renderSession();

        function renderSession() {
            showSection('home-section');
            const list = document.getElementById('session-projects-list'); list.innerHTML = '';
            let totalSheets = 0; let totalPieces = 0;
            if (session.projects.length === 0) { list.innerHTML = '<div style="grid-column: 1/-1; text-align: center; color: #444; padding: 40px;">No hay optimizaciones activas.</div>'; document.querySelector('.global-actions').classList.add('hidden'); }
            else {
                session.projects.forEach((proj, idx) => {
                    totalSheets += proj.sheets; totalPieces += proj.pieces.length;
                    const div = document.createElement('div'); div.className = 'project-card card-glass';
                    div.innerHTML = `<div class="proj-info"><h3>${proj.brand} ${proj.thickness}mm</h3><p>${proj.pieces.length} piezas | ${proj.sheets} placas</p></div><div class="proj-actions"><button class="btn-sm" onclick="editProject(${idx})"><i class="fas fa-edit"></i></button><button class="btn-sm btn-red" onclick="deleteProject(${idx})"><i class="fas fa-trash"></i></button></div>`;
                    list.appendChild(div);
                });
                const act = document.querySelector('.global-actions'); act.classList.remove('hidden');
                act.innerHTML = `<div class="send-summary">TOTAL: ${totalPieces} PIEZAS | ${totalSheets} PLACAS</div><div class="flex-actions"><button id="btn-send-all" class="btn-whatsapp-large"><i class="fab fa-whatsapp"></i> ENVIAR PEDIDO</button><button id="btn-print-all" class="btn-print"><i class="fas fa-print"></i> IMPRIMIR</button></div>`;
                document.getElementById('btn-send-all').onclick = () => { if(!isAuthenticated()) authModal.classList.remove('hidden'); else sendAllWhatsApp(); };
                document.getElementById('btn-print-all').onclick = () => { if(!isAuthenticated()) authModal.classList.remove('hidden'); else window.print(); };
            }
        }

        window.editProject = (idx) => { session.currentProjectIndex = idx; startEntry(); };
        window.deleteProject = (idx) => { if(confirm('¿Eliminar?')) { session.projects.splice(idx, 1); renderSession(); } };
        
        document.getElementById('btn-new-opt').onclick = () => showSection('setup-section');
        document.getElementById('btn-close-modal').onclick = () => authModal.classList.add('hidden');
        document.getElementById('btn-back-home').onclick = () => renderSession();
        document.getElementById('btn-finish-opt').onclick = () => renderSession();

        document.getElementById('btn-start').onclick = () => {
            const b = document.getElementById('plate-brand').value;
            const t = document.getElementById('plate-thickness').value;
            const w = parseInt(document.getElementById('plate-width').value);
            const h = parseInt(document.getElementById('plate-height').value);
            session.projects.push({ 
                brand: b, thickness: t, pieces: [], sheets: 0, 
                w, h, netW: w - REFILADO*2, netH: h - REFILADO*2 
            });
            session.currentProjectIndex = session.projects.length-1; startEntry();
        };

        function startEntry() { 
            const proj = session.projects[session.currentProjectIndex]; 
            document.getElementById('display-plate-name').textContent = `${proj.brand} ${proj.thickness}MM`; 
            showSection('entry-section'); 
            renderPieces(true); 
        }

        document.getElementById('btn-add').onclick = addPiece;
        document.getElementById('btn-recalc').onclick = () => updatePlatesDisplay(true);

        function addPiece() {
            const proj = session.projects[session.currentProjectIndex];
            const q = parseInt(document.getElementById('p-qty').value) || 1;
            const l = parseInt(document.getElementById('p-len').value);
            const h = parseInt(document.getElementById('p-wid').value);
            const label = document.getElementById('p-label').value || 'Pieza';
            const canRotate = document.getElementById('p-rot').checked;
            const et = parseFloat(document.getElementById('pe-t').value) || 0;
            const eb = parseFloat(document.getElementById('pe-b').value) || 0;
            const el = parseFloat(document.getElementById('pe-l').value) || 0;
            const er = parseFloat(document.getElementById('pe-r').value) || 0;
            
            if(!l || !h) return;
            
            proj.pieces.push({ 
                id: Date.now(), q, l, h, 
                cutL: l, cutH: h, 
                label, canRotate, 
                edges: { et, eb, el, er } 
            });
            
            // Reset fields
            document.getElementById('p-len').value = '';
            document.getElementById('p-wid').value = '';
            document.getElementById('p-label').value = '';
            document.getElementById('p-qty').value = '1';
            document.getElementById('p-qty').focus();
            
            renderPieces(false);
        }

        function renderPieces(fullRecalc = false) {
            const proj = session.projects[session.currentProjectIndex];
            const list = document.getElementById('pieces-list'); list.innerHTML = '';
            let totalQty = 0; let totalM2 = 0;
            
            proj.pieces.slice().reverse().forEach(p => {
                totalQty += p.q; totalM2 += (p.l * p.h * p.q) / 1000000;
                const div = document.createElement('div'); div.className = 'piece-item';
                div.innerHTML = `<div class="piece-info"><h4>${p.q}un | ${p.l}x${p.h}</h4><p>${p.label}</p></div><button class="btn-del" onclick="removePiece(${p.id})"><i class="fas fa-trash"></i></button>`;
                list.appendChild(div);
            });
            
            document.getElementById('stat-count').textContent = totalQty;
            document.getElementById('stat-m2').textContent = totalM2.toFixed(2);
            updatePlatesDisplay(fullRecalc);
        }

        window.removePiece = (id) => {
            const proj = session.projects[session.currentProjectIndex];
            proj.pieces = proj.pieces.filter(p => p.id !== id);
            renderPieces(false);
        };

        // Grand Master Optimizer Engine v4.4
        class IntensiveOptimizer {
            constructor(w, h, kerf, level) { this.w = w; this.h = h; this.kerf = kerf; this.level = level; }
            optimize(pieces) {
                let bestResult = null; let basePieces = [];
                pieces.forEach(p => { for(let i=0; i<p.q; i++) basePieces.push({...p}); });
                
                const heuristics = [
                    (a, b) => (b.cutL * b.cutH) - (a.cutL * a.cutH),
                    (a, b) => Math.max(b.cutL, b.cutH) - Math.max(a.cutL, a.cutH),
                    (a, b) => b.cutL - a.cutL,
                    (a, b) => b.cutH - a.cutH
                ];

                heuristics.forEach(fn => {
                    const res = this.runSimulation([...basePieces].sort(fn));
                    if (!bestResult || this.isBetter(res, bestResult)) bestResult = res;
                });

                if (this.level > 4) {
                    for (let i = 0; i < this.level; i++) {
                        const res = this.runSimulation(this.shuffle([...basePieces]));
                        if (this.isBetter(res, bestResult)) bestResult = res;
                    }
                }
                return bestResult;
            }
            isBetter(a, b) { 
                if (a.length < b.length) return true; 
                if (a.length > b.length) return false; 
                return a.reduce((s,p)=>s+p.freeRects.length,0) < b.reduce((s,p)=>s+p.freeRects.length,0); 
            }
            shuffle(arr) { for (let i = arr.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [arr[i], arr[j]] = [arr[j], arr[i]]; } return arr; }
            runSimulation(pieces) {
                let plates = []; let pPack = [...pieces];
                while (pPack.length > 0) {
                    let plate = { pieces: [], freeRects: [{ x: 0, y: 0, w: this.w, h: this.h }] };
                    for (let i = 0; i < pPack.length; i++) {
                        let p = pPack[i]; let bFit = null;
                        for (let r = 0; r < plate.freeRects.length; r++) {
                            let rect = plate.freeRects[r];
                            const variants = [{w: p.cutL, h: p.cutH, rot: false}, ...(p.canRotate ? [{w: p.cutH, h: p.cutL, rot: true}] : [])];
                            for (let v of variants) {
                                if (v.w <= rect.w && v.h <= rect.h) {
                                    let sc = Math.min(rect.w - v.w, rect.h - v.h);
                                    if (!bFit || sc < bFit.score) bFit = { rectIdx: r, w: v.w, h: v.h, score: sc, rot: v.rot };
                                }
                            }
                        }
                        if (bFit) {
                            let rect = plate.freeRects.splice(bFit.rectIdx, 1)[0];
                            plate.pieces.push({ x: rect.x, y: rect.y, w: bFit.w, h: bFit.h, label: p.label, edges: p.edges, rot: bFit.rot });
                            if (rect.w - bFit.w >= rect.h - bFit.h) {
                                if (rect.w - bFit.w > 0) plate.freeRects.push({ x: rect.x + bFit.w + this.kerf, y: rect.y, w: rect.w - bFit.w - this.kerf, h: rect.h });
                                if (rect.h - bFit.h > 0) plate.freeRects.push({ x: rect.x, y: rect.y + bFit.h + this.kerf, w: bFit.w, h: rect.h - bFit.h - this.kerf });
                            } else {
                                if (rect.h - bFit.h > 0) plate.freeRects.push({ x: rect.x, y: rect.y + bFit.h + this.kerf, w: rect.w, h: rect.h - bFit.h - this.kerf });
                                if (rect.w - bFit.w > 0) plate.freeRects.push({ x: rect.x + bFit.w + this.kerf, y: rect.y, w: rect.w - bFit.w - this.kerf, h: bFit.h });
                            }
                            pPack.splice(i, 1); i--; plate.freeRects.sort((a,b) => (b.w*b.h) - (a.w*a.h));
                        }
                    }
                    plates.push(plate);
                }
                return plates;
            }
        }

        function updatePlatesDisplay(fullRecalc = false) {
            const proj = session.projects[session.currentProjectIndex];
            const container = document.getElementById('plates-container'); container.innerHTML = '';
            
            const level = parseInt(document.getElementById('global-opt-level').value);
            const master = new IntensiveOptimizer(proj.netW, proj.netH, SIERRA, level);
            const optimizedPlates = master.optimize(proj.pieces);
            
            proj.sheets = optimizedPlates.length;
            document.getElementById('stat-sheets').textContent = proj.sheets;
            
            if (document.getElementById('global-show-gfx').value === 'no') return;

            const scale = 800 / proj.w;
            optimizedPlates.forEach((plate, idx) => {
                const wrap = document.createElement('div'); wrap.className = 'plate-view-wrap';
                wrap.innerHTML = `<div class="plate-label">TABLERO ${idx + 1} (${proj.brand} ${proj.thickness}mm)</div>`;
                const canvas = document.createElement('canvas'); canvas.width = 800; canvas.height = (proj.h / proj.w) * 800;
                const ctx = canvas.getContext('2d');
                
                ctx.fillStyle = '#111'; ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)'; ctx.lineWidth = 1;
                for (let i = -1000; i < 2000; i += 10) { ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i + canvas.height, canvas.height); ctx.stroke(); }
                
                ctx.strokeStyle = '#333'; ctx.strokeRect(REFILADO * scale, REFILADO * scale, proj.netW * scale, proj.netH * scale);

                plate.pieces.forEach(pc => {
                    const px = (pc.x + REFILADO) * scale; const py = (pc.y + REFILADO) * scale;
                    const pw = pc.w * scale; const ph = pc.h * scale;
                    
                    ctx.fillStyle = '#050505'; ctx.fillRect(px, py, pw, ph);
                    ctx.strokeStyle = 'rgba(192, 192, 192, 0.3)'; ctx.lineWidth = 1; ctx.strokeRect(px, py, pw, ph);

                    ctx.setLineDash([5, 5]); ctx.strokeStyle = '#e63946'; ctx.lineWidth = 3;
                    const e = pc.edges;
                    const draw = pc.rot ? { t: e.el, b: e.er, l: e.eb, r: e.et } : e;
                    if(draw.t>0){ ctx.beginPath(); ctx.moveTo(px,py); ctx.lineTo(px+pw,py); ctx.stroke(); }
                    if(draw.b>0){ ctx.beginPath(); ctx.moveTo(px,py+ph); ctx.lineTo(px+pw,py+ph); ctx.stroke(); }
                    if(draw.l>0){ ctx.beginPath(); ctx.moveTo(px,py); ctx.lineTo(px,py+ph); ctx.stroke(); }
                    if(draw.r>0){ ctx.beginPath(); ctx.moveTo(px+pw,py); ctx.lineTo(px+pw,py+ph); ctx.stroke(); }
                    ctx.setLineDash([]);

                    if (pw > 40) { 
                        ctx.fillStyle = '#aaa'; ctx.font = '10px JetBrains Mono'; 
                        ctx.fillText(`${Math.round(pc.w)}x${Math.round(pc.h)}`, px + 5, py + 15);
                        ctx.fillStyle = '#666'; ctx.font = '8px JetBrains Mono';
                        ctx.fillText(pc.label, px + 5, py + 28);
                    }
                });
                wrap.appendChild(canvas); container.appendChild(wrap);
            });
        }

        function sendAllWhatsApp() {
            let t = "*PEDIDO ALVAREZ PLACAS*\n\n";
            session.projects.forEach(p => { 
                t += `*${p.brand} ${p.thickness}MM* (${p.sheets} Placas)\n`; 
                p.pieces.forEach(pc => {
                    let tc = "";
                    const e = pc.edges;
                    if(e.et>0 || e.eb>0 || e.el>0 || e.er>0) {
                        tc = ` [TC: `;
                        if(e.et > 0) tc += `Sup:${e.et} `;
                        if(e.eb > 0) tc += `Inf:${e.eb} `;
                        if(e.el > 0) tc += `Izq:${e.el} `;
                        if(e.er > 0) tc += `Der:${e.er}`;
                        tc += `]`;
                    }
                    t += `- ${pc.q}un | ${pc.l}x${pc.h} (${pc.label})${tc}\n`;
                }); 
                t += "\n";
            });
            window.open(`https://wa.me/5491112345678?text=${encodeURIComponent(t)}`, '_blank');
        }

        // Shortcut support
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                const active = document.activeElement; const nextId = active?.getAttribute('data-next');
                if (nextId) {
                    e.preventDefault(); const nextEl = document.getElementById(nextId);
                    if (nextEl) { if (nextId === 'btn-add') addPiece(); else { nextEl.focus(); if (nextEl.tagName === 'INPUT') nextEl.select(); } }
                }
            }
        });
    </script>
</body>
