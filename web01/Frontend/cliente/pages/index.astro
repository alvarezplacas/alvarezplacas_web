---
/**
 * Panel de Cliente - Mi Cuenta.
 * Propiedad del Agente 3 (Frontend/Home) / Agente 5 (Herramientas).
 */
import Layout from '../../home/layouts/Layout.astro';
import Header from '@components/Header.astro';
import BottomNav from '@components/BottomNav.astro';
import { createDirectus, rest, readItems, readItem } from '@directus/sdk';
import { CommunicationService } from '@dashboard/logic/communication.js';

const PUBLIC_DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL || 'https://admin.alvarezplacas.com.ar';
const directus = createDirectus(PUBLIC_DIRECTUS_URL).with(rest());

// Strict session check
const userCookie = Astro.cookies.get('client_session')?.value;
if (!userCookie) {
    return Astro.redirect('/login');
}

const userId = userCookie;
let cliente = null;
let pedidos = [];

try {
    cliente = await directus.request(readItem('clientes', userId, {
        fields: ['*', { vendedor_asignado: ['Nombre', 'Whatsapp'] }]
    }));
    pedidos = await directus.request(readItems('pedidos', {
        filter: { cliente_id: { _eq: userId } },
        sort: ['-fecha_pedido']
    }));
} catch (e) {
    console.error('Error Directus Dashboard:', e);
}

if (!cliente) {
    Astro.cookies.delete('client_session', { path: '/' });
    return Astro.redirect('/login');
}

const templateData = {
    ...cliente,
    seller_name: cliente.vendedor_asignado?.Nombre || 'Sin asignar',
    seller_phone: cliente.vendedor_asignado?.Whatsapp || '',
    full_name: cliente.nombre_empresa || cliente.nombre,
    points: cliente.puntaje || 0,
    debt_amount: cliente.debt_amount || 0,
    fin_status: cliente.fin_status || 'clean',
    client_number: cliente.id
};

const processedPedidos = (pedidos || []).map((p) => ({
    ...p,
    created_at: p.fecha_pedido,
    total_amount: p.total,
    tracking_code: p.tracking_id,
    status: p.status
}));

const unreadCount = await CommunicationService.getUnreadCount(userId);
const sellerId = cliente.vendedor_asignado?.id;
const chatMessages = sellerId ? await CommunicationService.getChat(userId, sellerId) : [];
---

<Layout title="Mi Panel | Alvarez Placas">
    <Header />
    
    <div class="flex min-h-screen bg-[#0a0a0a]">
        <!-- Dashboard Content -->
        <main class="flex-grow pb-24 md:pb-12">
            <div class="p-4 sm:p-8 lg:p-12 max-w-6xl mx-auto space-y-8">
                
                <!-- Welcome Banner -->
                <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <div class="lg:col-span-2 bg-gradient-to-br from-primary/10 via-[#1a1a1a] to-[#111111] border border-white/5 rounded-[2.5rem] p-8 sm:p-10 relative overflow-hidden shadow-2xl">
                        <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/20 rounded-full blur-[100px] pointer-events-none"></div>
                        <div class="relative z-10">
                            <h1 class="text-3xl sm:text-4xl font-black text-white mb-4 tracking-tight">
                                ¡Hola, {templateData.full_name?.split(' ')[0]}!
                            </h1>
                            <p class="text-gray-400 text-lg max-w-md leading-relaxed">
                                Bienvenido a tu panel exclusivo. Aquí podrás gestionar tus pedidos, puntos y usar nuestras herramientas profesionales.
                            </p>
                        </div>
                    </div>

                    <div class="bg-[#1a1a1a] border border-white/5 rounded-[2.5rem] p-8 flex flex-col justify-center items-center text-center shadow-xl">
                        <div class="w-20 h-20 rounded-3xl bg-primary/20 text-primary flex items-center justify-center text-3xl mb-4 transform rotate-3 shadow-lg shadow-primary/10">
                            <i class="fas fa-award"></i>
                        </div>
                        <p class="text-xs text-gray-500 font-black uppercase tracking-[0.2em] mb-1">Puntos Alvarez</p>
                        <p class="text-5xl font-black text-white tracking-tighter">{templateData.points}</p>
                    </div>
                </section>

                <!-- Tools Quick Grid -->
                <section class="space-y-4">
                    <h2 class="text-lg font-black text-white uppercase tracking-tighter flex items-center gap-3 px-2">
                        Herramientas Profesionales
                    </h2>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <a href="/herramientas/presupuestador" class="bg-[#141414] border border-white/5 p-6 rounded-[2rem] flex flex-col items-center text-center hover:bg-white/5 transition-all group">
                            <div class="w-12 h-12 rounded-2xl bg-primary/10 text-primary flex items-center justify-center text-xl mb-3 group-hover:scale-110 transition-transform">
                                <i class="fas fa-paper-plane"></i>
                            </div>
                            <span class="text-[10px] font-bold text-white uppercase tracking-tighter leading-tight">Envío de<br/>Cortes</span>
                        </a>

                        <a href="/cliente/creador-presupuestos" class="bg-[#141414] border border-white/5 p-6 rounded-[2rem] flex flex-col items-center text-center hover:bg-white/5 transition-all group">
                            <div class="w-12 h-12 rounded-2xl bg-blue-500/10 text-blue-500 flex items-center justify-center text-xl mb-3 group-hover:scale-110 transition-transform">
                                <i class="fas fa-file-pdf"></i>
                            </div>
                            <span class="text-[10px] font-bold text-white uppercase tracking-tighter leading-tight">Creador de<br/>Presupuestos</span>
                        </a>

                        <a href="/herramientas/smart-match" class="bg-[#141414] border border-white/5 p-6 rounded-[2rem] flex flex-col items-center text-center hover:bg-white/5 transition-all group">
                            <div class="w-12 h-12 rounded-2xl bg-orange-500/10 text-orange-500 flex items-center justify-center text-xl mb-3 group-hover:scale-110 transition-transform">
                                <i class="fas fa-magic"></i>
                            </div>
                            <span class="text-[10px] font-bold text-white uppercase tracking-tighter leading-tight">Smart<br/>Match</span>
                        </a>

                        <div class="bg-[#141414] border border-white/5 p-6 rounded-[2rem] flex flex-col items-center justify-center opacity-30 cursor-not-allowed">
                            <i class="fas fa-lock text-sm mb-2"></i>
                            <span class="text-[9px] font-bold text-gray-500 uppercase">Próximamente</span>
                        </div>
                    </div>
                </section>

                <!-- Status & Support -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="bg-[#141414] border border-white/5 rounded-[2.5rem] p-8 space-y-6">
                        <div class="flex items-center justify-between">
                            <h2 class="text-lg font-bold text-white uppercase tracking-tighter">Estado Financiero</h2>
                            <div class={`w-3 h-3 rounded-full ${templateData.fin_status === 'clean' ? 'bg-green-500' : 'bg-red-500'} shadow-[0_0_10px_currentColor]`}></div>
                        </div>
                        <p class="text-4xl font-black text-white tracking-tighter">
                            ${Number(templateData.debt_amount || 0).toLocaleString()}
                        </p>
                        <div class="text-[10px] font-bold text-gray-500 uppercase tracking-widest bg-white/5 px-4 py-2 rounded-xl border border-white/5">
                            {templateData.fin_status === 'clean' ? 'Cuenta al día' : 'Pendientes de pago'}
                        </div>
                    </div>

                    <div class="bg-[#141414] border border-white/5 rounded-[2.5rem] p-8 flex flex-col justify-between">
                        <div>
                            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest mb-1">Vendedor Asignado</p>
                            <h3 class="text-xl font-bold text-white">{templateData.seller_name}</h3>
                        </div>
                        <a href={`https://wa.me/549${templateData.seller_phone}`} class="w-full bg-[#25D366] hover:bg-[#128C7E] text-black font-black py-4 rounded-2xl flex items-center justify-center gap-3 transition-all mt-6 uppercase text-xs">
                            <i class="fab fa-whatsapp"></i> Chat Directo
                        </a>
                    </div>
                </div>

                <!-- Chat Interno Section -->
                <section id="chat-interno" class="bg-[#141414] border border-white/5 rounded-[2.5rem] overflow-hidden shadow-2xl relative">
                    <div class="p-6 border-b border-white/5 flex items-center justify-between">
                        <h2 class="text-xl font-black text-white uppercase tracking-tighter">Mensajería Interna</h2>
                        {unreadCount > 0 && <span class="bg-primary text-white text-[10px] font-black px-2 py-0.5 rounded-full">{unreadCount} nuevos</span>}
                    </div>
                    
                    <div class="h-80 overflow-y-auto p-6 space-y-4 bg-black/20" id="client-chat-box">
                        {chatMessages.length === 0 ? (
                            <div class="h-full flex flex-col items-center justify-center text-center opacity-30">
                                <i class="fas fa-comments text-4xl mb-2"></i>
                                <p class="text-xs font-bold uppercase">Inicia una conversación con {templateData.seller_name}</p>
                            </div>
                        ) : (
                            chatMessages.map(m => (
                                <div class={`flex ${m.remitente_id === userId ? 'justify-end' : 'justify-start'}`}>
                                    <div class={`max-w-[85%] p-4 rounded-2xl text-sm ${m.remitente_id === userId ? 'bg-primary/20 text-white rounded-tr-none border border-primary/20' : 'bg-[#222] text-gray-300 rounded-tl-none border border-white/5'}`}>
                                        <p>{m.mensaje}</p>
                                    </div>
                                </div>
                            ))
                        )}
                    </div>

                    <div class="p-4 border-t border-white/5 bg-black/40">
                        <form id="client-chat-form" class="flex gap-2">
                            <input 
                                type="text" 
                                id="client-chat-input" 
                                placeholder="Escribe tu consulta aquí..." 
                                class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white text-sm outline-none focus:border-primary transition-all"
                                autocomplete="off"
                            />
                            <button type="submit" class="bg-primary hover:bg-white text-white hover:text-black px-6 rounded-xl font-black uppercase text-xs transition-all flex items-center justify-center">
                                Enviar
                            </button>
                        </form>
                    </div>
                </section>

                <!-- Pedidos -->
                <section class="space-y-4">
                    <h2 class="text-xl font-black text-white uppercase tracking-tighter px-2">Mis Pedidos Recientes</h2>
                    <div class="bg-[#141414] border border-white/5 rounded-[2.5rem] overflow-hidden shadow-2xl overflow-x-auto">
                        <table class="w-full text-left">
                            <tr class="text-[10px] font-black text-gray-500 uppercase tracking-widest bg-white/2">
                                <th class="px-8 py-6">Fecha</th>
                                <th class="px-8 py-6">Seguimiento</th>
                                <th class="px-8 py-6">Total</th>
                                <th class="px-8 py-6">Estado</th>
                            </tr>
                            {processedPedidos.map(p => (
                                <tr class="border-t border-white/5 hover:bg-white/2 transition-colors">
                                    <td class="px-8 py-6 text-sm">{new Date(p.created_at).toLocaleDateString()}</td>
                                    <td class="px-8 py-6 text-sm font-mono text-primary">{p.tracking_code || '---'}</td>
                                    <td class="px-8 py-6 text-sm font-black text-white">${Number(p.total_amount).toLocaleString()}</td>
                                    <td class="px-8 py-6">
                                        <span class="px-3 py-1 bg-white/5 rounded-full text-[9px] font-black uppercase text-gray-400">{p.status}</span>
                                    </td>
                                </tr>
                            ))}
                        </table>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <BottomNav />

    <script>
        const chatForm = document.getElementById('client-chat-form') as HTMLFormElement;
        const chatInput = document.getElementById('client-chat-input') as HTMLInputElement;
        const chatBox = document.getElementById('client-chat-box');

        if (chatForm && chatInput) {
            chatForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const msg = chatInput.value.trim();
                if (!msg) return;

                // Simple integration using our new API
                // We'll pass the IDs from the template data if available or let the backend extract from session
                // Since this is a demo, we'll try to fetch the essential IDs
                try {
                    const response = await fetch('/api/messages', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ content: msg, isClient: true }) // Backend can identify role from session
                    });

                    if (response.ok) {
                        chatInput.value = '';
                        location.reload();
                    }
                } catch (err) {
                    console.error("Chat error:", err);
                }
            });

            if (chatBox) chatBox.scrollTop = chatBox.scrollHeight;
        }
    </script>
</Layout>
