---
/**
 * Layout - Contenedor principal del sitio.
 * Propiedad del Agente 3 (Frontend/Home).
 */
import { ClientRouter } from 'astro:transitions';
import BottomNav from '@components/BottomNav.astro';
import Footer from '@components/Footer.astro';
import '@home/styles/global.css';
import '@home/styles/workshop.css';

interface Props {
	title: string;
	description?: string;
}

const { 
	title, 
	description = "Alvarez Placas - La mejor calidad en cortes de melamina y soluciones para el mueble." 
} = Astro.props;

// Force canonical URL to use Astro.site to prevent internal proxy hostnames (e.g. localhost) in SSR
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Open Graph & Canonical -->
		<link rel="canonical" href={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content="https://alvarezplacas.com.ar/logo.png" />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://alvarezplacas.com.ar/logo.png" />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		
		<!-- Font Awesome -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

		<!-- Analytics -->
		<script defer src="https://stats.javiermix.ar/script.js" data-website-id="d70f2548-e4c6-4aa9-bd21-00b8d3e93995"></script>
		<ClientRouter />

		<!-- Schema Markup (LocalBusiness) -->
		<script type="application/ld+json" is:inline>
			{
			  "@context": "https://schema.org",
			  "@type": "LocalBusiness",
			  "name": "Alvarez Placas",
			  "image": "https://alvarezplacas.com.ar/logo.png",
			  "@id": "https://alvarezplacas.com.ar",
			  "url": "https://alvarezplacas.com.ar",
			  "telephone": "+541100000000",
			  "address": {
				"@type": "PostalAddress",
				"streetAddress": "Av. Vergara",
				"addressLocality": "Villa Tesei",
				"addressRegion": "Buenos Aires",
				"addressCountry": "AR"
			  },
			  "geo": {
				"@type": "GeoCoordinates",
				"latitude": -34.6212,
				"longitude": -58.6473
			  },
			  "areaServed": [
				"Villa Tesei",
				"Castelar",
				"Hurlingham",
				"Parque Leloir",
				"San Isidro",
				"Capital Federal"
			  ],
			  "priceRange": "$$",
			  "description": "Proveedor líder en zona oeste (Villa Tesei). Cortes de melamina, herrajes y soluciones para interioristas, constructoras y carpinteros en Parque Leloir, Castelar, San Isidro y CABA."
			}
		</script>

		<style is:inline>
			#nprogress-bar {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 3px;
				background: #ff4d00;
				z-index: 9999;
				transform: translateX(-100%);
				transition: transform 0.4s ease-out;
				pointer-events: none;
			}
			#nprogress-bar.loading {
				transform: translateX(-20%);
			}
			#nprogress-bar.finished {
				transform: translateX(0);
				opacity: 0;
				transition: transform 0.2s ease-out, opacity 0.5s ease-out 0.2s;
			}
		</style>
		<script is:inline>
			document.addEventListener('astro:before-preparation', () => {
				const bar = document.getElementById('nprogress-bar');
				if (bar) {
					bar.classList.remove('finished');
					bar.style.opacity = '1';
					bar.classList.add('loading');
				}
			});
			document.addEventListener('astro:after-navigation', () => {
				const bar = document.getElementById('nprogress-bar');
				if (bar) {
					bar.classList.remove('loading');
					bar.classList.add('finished');
				}
			});
		</script>
	</head>
	<body class="bg-jet-black text-white font-sans antialiased pb-20 md:pb-0 min-h-screen flex flex-col">
		<div id="nprogress-bar"></div>
		<main class="flex-grow">
			<slot />
		</main>
        <Footer />
        <BottomNav />
	</body>
</html>

<style is:global>
	html { scroll-behavior: smooth; }
	body { margin: 0; padding: 0; }
</style>
