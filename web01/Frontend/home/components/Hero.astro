---
/**
 * Hero - Versión Final Estandarizada (Astro 6 + Directus SDK 18).
 */
import { directus } from '@conexiones/directus.js';
import { readFiles } from '@directus/sdk';

// IDs de las subcarpetas de background
const FOLDER_IDS = [
    "5a7d169e-14d5-4f0b-8002-366fbc223e43", // D
    "a491f578-f1da-48fc-889a-5f66d2e352ad", // H
    "036c8173-5a1e-4a50-90ce-e84c49b8a2b0", // I
    "e85b8fee-3409-4425-8312-07a2bbf786b2", // M
    "11fcca14-6c93-4d54-8dde-59cad7ed7ddf", // R
    "01417601-e3dc-4695-b044-073d35c2b7ae", // S
    "05303f39-97bd-4d6c-a4c2-1792e881a6ba"  // T
];

let backgroundImages = [];

try {
    // 🛡️ Usando readFiles (Requerido por SDK v18 para colecciones core)
    const files = await directus.request(readFiles({
        filter: { 
          folder: { _in: FOLDER_IDS },
          type: { _contains: 'image' }
        },
        fields: ['id'],
        limit: 30
    }));
    
    backgroundImages = (files || []).map(f => `https://admin.alvarezplacas.com.ar/assets/${f.id}?quality=80&format=webp`);
    // Mezcla aleatoria para frescura visual
    backgroundImages = backgroundImages.sort(() => Math.random() - 0.5);

} catch (e) {
    console.error("❌ Error Directus SDK 18:", e);
}
---
<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden bg-[#0a0a0a]">
  
  <div class="absolute inset-0 z-0" id="hero-slider">
    {backgroundImages.length > 0 ? (
      backgroundImages.map((img, index) => (
        <div 
          class={`absolute inset-0 bg-cover bg-center transition-all duration-[3000ms] ease-in-out hero-slide ${index === 0 ? 'opacity-100 scale-100' : 'opacity-0 scale-110'}`}
          style={`background-image: url('${img}');`}
        >
          <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-transparent to-[#0a0a0a]"></div>
        </div>
      ))
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-neutral-900 to-black"></div>
    )}
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 py-20 text-center">
      <h2 class="text-6xl md:text-9xl font-black text-white tracking-tighter mb-8 uppercase italic leading-[0.8] animate-fade-in">
        Inspiración <br/> 
        <span class="text-primary drop-shadow-[0_0_50px_rgba(255,77,0,0.7)]">Tecnológica</span>
      </h2>
      <p class="text-xl md:text-3xl text-white/90 font-medium mb-12 max-w-2xl mx-auto drop-shadow-2xl">
        Innovación en cortes y materiales para tus proyectos.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="/presupuestador" class="w-full sm:w-auto px-16 py-6 bg-primary text-black font-black rounded-2xl shadow-2xl hover:scale-105 transition-all text-xl uppercase tracking-widest">
          Presupuestar
        </a>
        <a href="/contacto" class="w-full sm:w-auto px-16 py-6 bg-white/5 border border-white/20 backdrop-blur-2xl text-white font-black rounded-2xl hover:bg-white/10 transition-all text-xl uppercase tracking-widest">
          Contacto
        </a>
      </div>
  </div>
</section>

<script>
  function runSlider() {
    const slides = document.querySelectorAll('.hero-slide');
    if (slides.length <= 1) return;
    let current = 0;
    setInterval(() => {
      slides[current].classList.replace('opacity-100', 'opacity-0');
      slides[current].classList.add('scale-110');
      current = (current + 1) % slides.length;
      slides[current].classList.replace('opacity-0', 'opacity-100');
      slides[current].classList.remove('scale-110');
    }, 5000);
  }
  document.addEventListener('astro:page-load', runSlider);
  runSlider();
</script>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in { animation: fade-in 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
</style>
