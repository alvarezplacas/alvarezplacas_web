---
/**
 * Home Index - Página principal del sitio modular.
 * Propiedad del Agente 3 (Frontend/Home).
 */
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Hero from '@components/Hero.astro';
import ClubSection from '@home/components/ClubSection.astro';
import { getHomeBackgroundUrl } from '@conexiones/background.js';

const backgroundUrl = await getHomeBackgroundUrl();
---

<Layout 
	title="Alvarez Placas | Insumos y Cortes a Medida para Arquitectos y Fabricantes"
	description="Proveedor líder en zona oeste (Villa Tesei). Cortes de melamina, herrajes y soluciones para interioristas, constructoras y carpinteros en Parque Leloir, Castelar, San Isidro y CABA."
>
	<Header />
	<Hero backgroundUrl={backgroundUrl} />
    
    <ClubSection />

	<section class="py-20 text-center">
        <p class="text-gray-500 italic text-sm uppercase tracking-widest">Nuevas secciones modulares llegando pronto...</p>
    </section>
</Layout>
