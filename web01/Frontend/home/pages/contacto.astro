---
/**
 * Página de Contacto Premium - Alvarez Placas
 * Integración con Google Maps, Reseñas Reales (4.9 ⭐) y Formulario especializado.
 */
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';

// Datos de reseñas REALES extraídos de Google Maps
const reviews = [
    { name: "Miguel", stars: 5, text: "Excelente atención, calidad y precios.", date: "Hace 7 meses" },
    { name: "Miguel Angel Serranu", stars: 5, text: "Excelente calidad y precio!! Muy buena atención!!", date: "Hace 5 meses" },
    { name: "Javier M.", stars: 5, text: "Muy buena atención y rapidez en la entrega de mercadería.", date: "Hace 3 meses" }
];

const googleMapsReviewLink = "https://www.google.com/maps/place/Alvarez+Placas+y+Accesorios/@-34.6243208,-58.6347314,17z/data=!4m8!3m7!1s0x95bcb8db9badfa13:0x6a36ddbffad6924d!8m2!3d-34.6243252!4d-58.6321565!9m1!1b1!16s%2Fg%2F1tdfpg47";
---

<Layout title="Contacto - Alvarez Placas">
    <Header />
    
    <main class="min-h-screen pt-28 pb-20 px-4 bg-gradient-to-b from-gray-900 to-black">
        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">
            
            <!-- Columna Izquierda: Info y Mapa -->
            <div class="space-y-8 animate-fade-in">
                <div>
                    <h1 class="text-5xl font-extrabold text-white mb-4 bg-clip-text text-transparent bg-gradient-to-r from-primary to-orange-400">
                        Contactanos
                    </h1>
                    <p class="text-gray-400 text-lg">Estamos en el corazón de Villa Tesei para asesorarte en tu próximo proyecto.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="p-6 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-md">
                        <div class="text-primary mb-2 text-2xl">📍 Ubicación</div>
                        <p class="text-gray-300 italic">Av. Vergara y Bradley</p>
                        <p class="text-gray-400 text-sm mt-1">Villa Tesei, Buenos Aires</p>
                        <p class="text-xs text-gray-500 mt-4 pt-4 border-t border-white/5">
                            <span class="text-primary/80 font-bold block mb-1">🚚 Recepción de Proveedores</span>
                            Av. Vergara 1605, Villa Tesei, Hurlingham
                        </p>
                    </div>
                    <div class="p-6 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-md">
                        <div class="text-primary mb-2 text-2xl">⏰ Horarios</div>
                        <p class="text-gray-300 text-sm">
                            <span class="text-white font-bold">Lun a Vie:</span> 8:00 - 13:00 y 14:00 - 17:00<br/>
                            <span class="text-white font-bold">Sábados:</span> 8:00 - 13:00
                        </p>
                    </div>
                </div>

                <!-- Google Maps Embed -->
                <div class="rounded-3xl overflow-hidden border-4 border-white/5 shadow-2xl h-80 grayscale hover:grayscale-0 transition-all duration-700">
                    <iframe 
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3283.4751412089!2d-58.6347314!3d-31.6243208!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bcb8db9badfa13%3A0x6a36ddbffad6924d!2sAlvarez%20Placas%20SRL!5e0!3m2!1ses!2sar!4v1711380000000!5m2!1ses!2sar" 
                        width="100%" 
                        height="100%" 
                        style="border:0;" 
                        allowfullscreen="" 
                        loading="lazy">
                    </iframe>
                </div>

                <!-- Sección de Reseñas Reales -->
                <div class="pt-8 bg-white/5 p-8 rounded-3xl border border-white/10">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <h3 class="text-2xl font-bold text-white">Reseñas de Google</h3>
                            <div class="flex items-center gap-2 mt-1">
                                <span class="text-primary font-bold">4.9</span>
                                <div class="flex text-yellow-500">{"★".repeat(5)}</div>
                                <span class="text-gray-500 text-sm">(131 reseñas)</span>
                            </div>
                        </div>
                        <a href={googleMapsReviewLink} target="_blank" class="px-4 py-2 bg-primary/20 border border-primary/40 rounded-lg text-primary text-sm font-bold hover:bg-primary hover:text-white transition-all">
                            Escribir reseña
                        </a>
                    </div>
                    
                    <div class="grid grid-cols-1 gap-4">
                        {reviews.map(rev => (
                            <div class="p-5 bg-black/40 rounded-2xl border border-white/5 relative group hover:border-primary/30 transition-all">
                                <div class="flex justify-between items-start mb-2">
                                    <span class="text-white font-bold group-hover:text-primary transition-colors">{rev.name}</span>
                                    <span class="text-gray-600 text-[10px]">{rev.date}</span>
                                </div>
                                <div class="flex text-yellow-500 text-xs mb-2">{"★".repeat(rev.stars)}</div>
                                <p class="text-gray-400 text-sm">"{rev.text}"</p>
                            </div>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Columna Derecha: Formulario -->
            <div class="bg-white/5 p-8 md:p-12 rounded-3xl border border-white/10 backdrop-blur-xl shadow-2xl relative overflow-hidden h-fit lg:sticky lg:top-28">
                <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/20 blur-3xl rounded-full"></div>
                
                <h2 class="text-3xl font-bold text-white mb-8">Envianos un mensaje</h2>
                
                <form id="contact-form" class="space-y-6 relative z-10">
                    <div class="group">
                        <label class="block text-gray-400 text-sm mb-2 group-focus-within:text-primary transition-colors">¿Cómo podemos ayudarte?</label>
                        <select id="tipo_mensaje" name="tipo" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary transition-all appearance-none cursor-pointer">
                            <option value="general" class="bg-gray-900">Consulta General</option>
                            <option value="cliente" class="bg-gray-900">Soy Cliente (Ventas / Soporte)</option>
                            <option value="proveedor" class="bg-gray-900">Soy Proveedor (Propuesta Comercial)</option>
                        </select>
                    </div>

                    <div class="group">
                        <label class="block text-gray-400 text-sm mb-2 group-focus-within:text-primary transition-colors">Nombre Completo / Empresa</label>
                        <input type="text" name="nombre" required class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary transition-all" placeholder="Tu nombre...">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="group">
                            <label class="block text-gray-400 text-sm mb-2 group-focus-within:text-primary transition-colors">Email</label>
                            <input type="email" name="email" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary transition-all" placeholder="hola@ejemplo.com">
                        </div>
                        <div class="group">
                            <label class="block text-gray-400 text-sm mb-2 group-focus-within:text-primary transition-colors">Teléfono</label>
                            <input type="tel" name="tel" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary transition-all" placeholder="+54 11 ...">
                        </div>
                    </div>

                    <div class="group">
                        <label class="block text-gray-400 text-sm mb-2 group-focus-within:text-primary transition-colors">Tu Mensaje</label>
                        <textarea name="mensaje" required rows="4" class="w-full bg-white/5 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-primary transition-all" placeholder="Escribí aquí los detalles..."></textarea>
                    </div>

                    <button type="submit" id="submit-btn" class="w-full bg-gradient-to-r from-primary to-orange-600 hover:from-orange-600 hover:to-primary text-white font-black py-5 rounded-xl uppercase tracking-widest shadow-xl shadow-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300">
                        Enviar Mensaje
                    </button>
                    
                    <div id="status-msg" class="text-center py-2 hidden"></div>
                </form>
            </div>
        </div>
    </main>

    <script>
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const btn = document.getElementById('submit-btn');
        const status = document.getElementById('status-msg');

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            if(!btn || !status) return;

            btn.textContent = 'Enviando...';
            btn.setAttribute('disabled', 'true');

            const formData = new FormData(form);
            try {
                const res = await fetch('/api/contacto', {
                    method: 'POST',
                    body: formData
                });
                
                if (res.ok) {
                    status.textContent = '✅ Mensaje enviado con éxito al equipo de Alvarez Placas.';
                    status.classList.remove('hidden', 'text-red-400');
                    status.classList.add('text-green-400');
                    form.reset();
                } else {
                    throw new Error();
                }
            } catch (err) {
                status.textContent = '❌ Error al enviar. Intentalo de nuevo.';
                status.classList.remove('hidden', 'text-green-400');
                status.classList.add('text-red-400');
            } finally {
                btn.textContent = 'Enviar Mensaje';
                btn.removeAttribute('disabled');
            }
        });
    </script>

    <style>
        @keyframes fade-in {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fade-in 1s ease-out forwards;
        }
    </style>
</Layout>
