---
// Header.astro
// Sticky navigation with glassmorphism effect
---

<header class="sticky top-0 z-50 w-full bg-black/80 backdrop-blur-md border-b border-white/10 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-center md:justify-between items-center h-20">
      
      <!-- Logo -->
      <a href="/" class="flex-shrink-0 flex items-center text-lg font-black tracking-widest text-white hover:opacity-95 transition-opacity select-none uppercase">
        <span class="glow-letter">A</span>
        <span class="glow-letter">L</span>
        <span class="glow-letter">V</span>
        <span class="glow-letter">A</span>
        <span class="glow-letter">R</span>
        <span class="glow-letter">E</span>
        <span class="glow-letter">Z</span>
        <span class="w-1.5 inline-block"></span>
        <span class="glow-letter text-primary">P</span>
        <span class="glow-letter text-primary">L</span>
        <span class="glow-letter text-primary">A</span>
        <span class="glow-letter text-primary">C</span>
        <span class="glow-letter text-primary">A</span>
        <span class="glow-letter text-primary">S</span>
      </a>

      <!-- Desktop Menu (Hidden on Mobile) -->
      <nav class="hidden md:flex items-center space-x-8">
        <a href="/catalogo" class="text-sm font-black uppercase text-white hover:text-primary transition-colors tracking-widest">Catálogo</a>
        <a href="/presupuestador" class="text-sm font-black uppercase text-white hover:text-primary transition-colors tracking-widest">Presupuestar</a>
        <a href="/herramientas" class="text-sm font-black uppercase text-white hover:text-primary transition-colors tracking-widest">Herramientas</a>
        <a href="/login" class="text-sm font-black uppercase text-white hover:text-primary transition-colors tracking-widest">Club</a>
        
        <!-- CTA Botón Contacto -->
        <a href="/contacto" class="ml-4 px-6 py-2.5 rounded-full bg-primary/10 border border-primary text-primary text-sm font-bold uppercase hover:bg-primary hover:text-white transition-all shadow-[0_0_15px_rgba(255,40,0,0.3)] hover:shadow-[0_0_20px_rgba(255,40,0,0.5)]">
          Contacto
        </a>
      </nav>
      
    </div>
  </div>
</header>

<style>
  .glow-letter {
    display: inline-block;
    transition: transform 0.2s ease, text-shadow 0.3s ease;
    animation: sweep-forward 6s infinite ease-in-out, sweep-backward 6s infinite ease-in-out;
  }

  /* Base colors for letters */
  .glow-letter:not(.text-primary) {
    color: #ffffff;
    --glow-color: rgba(255, 255, 255, 0.8);
    --glow-highlight: #ffffff;
  }
  .glow-letter.text-primary {
    color: #ff2800;
    --glow-color: rgba(255, 40, 0, 0.8);
    --glow-highlight: #ff5020;
  }

  /* Forward sweep delays (left-to-right) */
  .glow-letter:nth-child(1)  { animation-delay: 0.0s, 4.2s; } /* A */
  .glow-letter:nth-child(2)  { animation-delay: 0.1s, 4.1s; } /* L */
  .glow-letter:nth-child(3)  { animation-delay: 0.2s, 4.0s; } /* V */
  .glow-letter:nth-child(4)  { animation-delay: 0.3s, 3.9s; } /* A */
  .glow-letter:nth-child(5)  { animation-delay: 0.4s, 3.8s; } /* R */
  .glow-letter:nth-child(6)  { animation-delay: 0.5s, 3.7s; } /* E */
  .glow-letter:nth-child(7)  { animation-delay: 0.6s, 3.6s; } /* Z */
  /* Spans 9 to 14 correspond to P L A C A S */
  .glow-letter:nth-child(9)  { animation-delay: 0.7s, 3.5s; } /* P */
  .glow-letter:nth-child(10) { animation-delay: 0.8s, 3.4s; } /* L */
  .glow-letter:nth-child(11) { animation-delay: 0.9s, 3.3s; } /* A */
  .glow-letter:nth-child(12) { animation-delay: 1.0s, 3.2s; } /* C */
  .glow-letter:nth-child(13) { animation-delay: 1.1s, 3.1s; } /* A */
  .glow-letter:nth-child(14) { animation-delay: 1.2s, 3.0s; } /* S */

  /* Keyframe animations */
  @keyframes sweep-forward {
    0%, 100%, 25%, 75% {
      text-shadow: none;
      transform: scale(1);
    }
    10% {
      text-shadow: 0 0 8px var(--glow-color), 0 0 20px var(--glow-color);
      transform: scale(1.12);
      color: var(--glow-highlight);
    }
  }

  @keyframes sweep-backward {
    0%, 100%, 25%, 75% {
      text-shadow: none;
      transform: scale(1);
    }
    10% {
      text-shadow: 0 0 8px var(--glow-color), 0 0 20px var(--glow-color);
      transform: scale(1.12);
      color: var(--glow-highlight);
    }
  }
</style>
