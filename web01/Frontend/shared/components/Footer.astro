---
// Footer.astro
// Discreto — créditos y acceso rápido al webmail interno
---

<footer class="w-full bg-[#050505] py-16 px-6 border-t border-white/5 mt-auto">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      
      <!-- Brand & Info -->
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="text-2xl font-bold tracking-tight text-white mb-6 block">
          ALVAREZ<span class="text-primary">PLACAS</span>
        </a>
        <p class="text-gray-500 text-sm leading-relaxed max-w-sm">
          Líderes en la industria del mueble desde 2018. 
          Tecnología industrial y soluciones integrales para profesionales de la carpintería.
        </p>
        <div class="flex gap-4 mt-8">
          <a href="https://www.instagram.com/alvarezplacas/" target="_blank" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:bg-primary hover:text-white hover:border-primary transition-all">
            <i class="fa-brands fa-instagram"></i>
          </a>
          <a href="https://wa.me/541161411842" target="_blank" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:bg-green-500 hover:text-white hover:border-green-500 transition-all">
            <i class="fa-brands fa-whatsapp"></i>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-white font-bold text-xs uppercase tracking-widest mb-6">Navegación</h4>
        <ul class="space-y-4">
          <li><a href="/quienes-somos" class="text-gray-500 hover:text-primary text-sm transition-colors">Quienes Somos</a></li>
          <li><a href="/catalogo" class="text-gray-500 hover:text-primary text-sm transition-colors">Catálogo</a></li>
          <li><a href="/herramientas" class="text-gray-500 hover:text-primary text-sm transition-colors">Herramientas</a></li>
          <li><a href="/presupuestador" class="text-gray-500 hover:text-primary text-sm transition-colors">Presupuestador</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-bold text-xs uppercase tracking-widest mb-6">Contacto</h4>
        <ul class="space-y-4 text-sm text-gray-500">
          <li class="flex items-start gap-3">
            <i class="fa-solid fa-location-dot mt-1 text-primary"></i>
            <span>Mariano Bradley y Av. Vergara,<br/>Ciudad Tesei, Hurlingham.</span>
          </li>
          <li class="flex items-center gap-3">
            <i class="fa-solid fa-phone text-primary"></i>
            <span>11 6141-11842</span>
          </li>
          <li>
            <a href="https://mail.alvarezplacas.com.ar/" target="_blank" class="flex items-center gap-3 hover:text-white transition-colors">
              <i class="fa-solid fa-envelope text-primary"></i>
              <span>Webmail Interno</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Suppliers -->
      <div>
        <h4 class="text-white font-bold text-xs uppercase tracking-widest mb-6">Socios</h4>
        <div class="bg-white/5 border border-white/10 rounded-xl p-5">
            <p class="text-gray-400 text-xs leading-relaxed mb-4">
                <strong>Atención a proveedores:</strong> envíanos tu propuesta hoy mismo.
            </p>
            <a href="/proveedores" class="inline-flex items-center gap-2 text-primary font-bold text-xs uppercase tracking-wider hover:gap-3 transition-all">
                Ingresa aquí <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-[10px] text-gray-600 uppercase tracking-widest font-medium">
        &copy; 2026 <span class="text-gray-500">Alvarez Placas</span> — Todos los derechos reservados.
      </p>
      <div class="text-[9px] text-gray-700 opacity-50 hover:opacity-100 transition-opacity flex items-center gap-2">
        <span>Diseño & Desarrollo por</span>
        <span class="text-gray-400">Javier Mix</span>
      </div>
    </div>
  </div>
</footer>

<style>
  footer {
    position: relative;
    z-index: 10;
  }
</style>
