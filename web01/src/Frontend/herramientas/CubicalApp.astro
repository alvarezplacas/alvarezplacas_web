            // Informe de Ensamblaje Didáctico
            let assemblyHTML = '';
            this.state.modules.forEach(m => {
                assemblyHTML += `<div class="p-6 bg-[var(--sc-surface-alt)] rounded-lg border border-[var(--sc-border)] mb-4">
