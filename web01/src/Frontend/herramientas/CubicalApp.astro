                    assemblyHTML += `
                        <li><strong>Armado de Carcasa:</strong> Atornilla los Laterales. Recuerda que el <strong>Techo siempre apoya sobre los laterales</strong> para descargar el peso al piso.</li>
                        <li><strong>Escuadra:</strong> Presenta el Fondo de MDF de 3mm y clávalo para dar escuadra al módulo.</li>`;
                    
                    if (m.dims.n_cajones > 0) {
                        assemblyHTML += `<li><strong>Cajones:</strong> Arma las cajas de los cajones. Las correderas telescópicas requieren 13mm libres por lado (26mm en total). Ya están calculadas en las medidas.</li>`;
                    }
                    if (m.dims.n_puertas > 0) {
                        assemblyHTML += `<li><strong>Puertas:</strong> Instala las bisagras Codo 0 (Greenway/Bronzen) a 10cm de los extremos superior e inferior.</li>`;
