            if (list) list.innerHTML = html;
            if (listMobile) listMobile.innerHTML = html;
            
            const count = this.state.modules.length;
            const tmods = document.getElementById('stat-total-mods');
            const tmodsMob = document.getElementById('stat-total-mods-mobile');
            
            if (tmods) tmods.textContent = count;
            if (tmodsMob) tmodsMob.textContent = count;
            
            this.renderPreview();
        },
        
        renderCustomVarsUI: function() {
            if (!this.state.activeModuleId) return;
            const m = this.state.modules.find(mod => mod.id === this.state.activeModuleId);
            if (!m) return;
            
            const doRender = (isMobile) => {
                const prefix = isMobile ? '-mobile' : '';
                const group = document.getElementById(`group-custom-vars${prefix}`);
                const container = document.getElementById(`custom-vars-container${prefix}`);
                if (!group || !container) return;
                
                if (!m.customVars || Object.keys(m.customVars).length === 0) {
                    group.classList.add('hidden');
                    return;
                }
                
                group.classList.remove('hidden');
                container.innerHTML = Object.keys(m.customVars).map(key => {
                    let label = key;
                    if (key === 'colCenterWidth') label = "Ancho Centro (mm)";
                    if (key === 'cajoneraWidth') label = "Ancho Cajonera (mm)";
                    
                    return `
                    <div>
                        <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-1">${label}</label>
                        <input type="number" id="mod-cv-${key}${prefix}" value="${m.customVars[key]}" oninput="window.cubical.updateActiveModule(${isMobile}); window.cubical.renderPreview()" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-2 rounded text-xs font-mono font-bold">
                    </div>
                    `;
                }).join('');
            };
            
            doRender(false);
            doRender(true);
        },

        renderPreview: function() {
            const isDark = document.body.getAttribute('data-theme') === 'dark' || document.body.classList.contains('body-theme-dark');
            const spacing = 120;
            const count = this.state.modules.length;
            const selectedMelamina = this.state.selectedMelamina || 'faplac_roble';
            const palette = MELAMINA_PALETTES[selectedMelamina];
            
            const drawOnCanvas = (canvasId, renderer) => {
                const canvas = document.getElementById(canvasId);
                if (!canvas || !renderer) return;
                
                // Grilla de fondo CAD (WebGL)
                if (!renderer.scene.children.some(c => c.isGridHelper)) {
                    const gridHelper = new THREE.GridHelper(2000, 40, isDark ? 0xffffff : 0x000000, isDark ? 0xffffff : 0x000000);
                    gridHelper.material.opacity = 0.05;
                    gridHelper.material.transparent = true;
                    gridHelper.position.y = 0;
                    renderer.scene.add(gridHelper);
                }
                
                if (count === 0) {
                    renderer.drawBox(600, 800, 500, {
                        color: isDark ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0,0,0,0.1)',
                        fillColor: 'rgba(0, 0, 0, 0)',
                        lineWidth: 1.5,
                        drawPanelThickness: false,
                        palette: palette
                    });
                    return;
                }
                
                // Buscar el módulo activo para renderizar solo ese (como pidió el usuario)
                const m = this.state.modules.find(mod => mod.id === this.state.activeModuleId) || this.state.modules[this.state.modules.length - 1];
                if (!m) return;
                
                const boxColor = palette ? palette.lineColor : (isDark ? '#e5e5e5' : '#1e1e1e');
                const boxFill = palette ? palette.fillColor : (isDark ? '#2e2e2e' : '#f4f1ea');
                
                const prefix = canvasId.includes('mobile') ? '-mobile' : '';
                const showDrawers = document.getElementById(`show-drawers${prefix}`) ? document.getElementById(`show-drawers${prefix}`).checked : true;
                const showDoors = document.getElementById(`show-doors${prefix}`) ? document.getElementById(`show-doors${prefix}`).checked : true;
                const showTop = document.getElementById(`show-top${prefix}`) ? document.getElementById(`show-top${prefix}`).checked : true;

                renderer.drawBox(m.dims.ancho, m.dims.alto, m.dims.prof, {
                    offsetX: 0,
                    color: boxColor,
                    fillColor: boxFill,
                    lineWidth: 1.0, // Líneas finas SketchUp style
                    drawPanelThickness: true,
                    shelves: m.dims.n_estantes || 0,
                    drawers: m.dims.n_cajones || 0,
                    doors: m.dims.n_puertas || 0,
                    type: m.type,
                    palette: palette,
                    showDrawers,
                    showDoors,
                    showTop,
                    customVars: m.customVars || {}
                });
            };

            drawOnCanvas('canvas-preview', this.renderer);
            drawOnCanvas('canvas-preview-mobile', this.rendererMobile);
        },

        generateResults: async function() {
            if (this.state.modules.length === 0) { alert("⚠️ Añade al menos un módulo al plano."); return; }
            
            const rootEl = document.getElementById('cubical-app-root');
            const userIsLoggedIn = rootEl && rootEl.dataset.isLoggedIn === 'true';
            
            if (!userIsLoggedIn) {
                alert("🔒 ACCESO RESTRINGIDO\n\nPara obtener el despiece exacto para producción, la lista de herrajes optimizada y la guía de ensamblaje paso a paso, necesitas tener una cuenta en Álvarez Placas.\n\nPor favor, inicia sesión para continuar.");
                window.location.href = "/cliente/login";
                return;
            }

            this.showScreen('results');
            
            try {
                // Importación dinámica de motores
                const optEngine = await import('/herramientas/logic/cubical/engine.js?v=' + Date.now());
                const hwEngine = await import('/herramientas/logic/cubical/hardware.js?v=' + Date.now());
                
                let allPieces = [];
                this.state.modules.forEach(m => {
                    const pieces = optEngine.calculateModulePieces(m.type, m.dims, 18, m.customVars);
                    allPieces = allPieces.concat(pieces);
                });
                
                // Filtrar melamina de 18mm
                const melaminaPieces = allPieces.filter(p => !p.isBackground).map(p => ({
                    name: p.name,
                    h: p.h,
                    w: p.w,
                    qty: p.qty
                }));
                
                const board = { w: 2750, h: 1820 };
                const optResults = optEngine.optimizeBoards(melaminaPieces, board, 4);
                
                // Calcular herrajes e insumos
                const realHardware = hwEngine.calculateTotalHardware(this.state.modules);
                
                this.state.results = {
                    opt: optResults,
                    hw: realHardware,
                    pieces: allPieces
                };
                
                this.renderResults();
            } catch (e) {
                console.error("[CubiCal] Error ejecutando optimización:", e);
                alert("⚠️ Error al optimizar el despiece. Revisa los datos de tus módulos.");
            }
        },

        exportToSmartCut: function() {
            if (!this.state.results || !this.state.results.pieces) {
                alert("⚠️ Por favor optimiza el cálculo primero.");
                return;
            }
            
            // Mapear melamina seleccionada a marca y diseño del catálogo
            const selectedMelamina = this.state.selectedMelamina || 'faplac_roble';
            let brand = 'FAPLAC';
            let designName = 'Roble Americano';

            if (selectedMelamina.startsWith('egger_')) {
                brand = 'EGGER';
                if (selectedMelamina === 'egger_helsinki') designName = 'Helsinki Birch';
                else if (selectedMelamina === 'egger_arcilla') designName = 'Gris Arcilla';
                else if (selectedMelamina === 'egger_ceniza') designName = 'Ceniza Egger';
            } else if (selectedMelamina.startsWith('sadepan_')) {
                brand = 'SADEPAN';
                if (selectedMelamina === 'sadepan_cerezo') designName = 'Cerezo';
                else if (selectedMelamina === 'sadepan_haya') designName = 'Haya';
                else if (selectedMelamina === 'sadepan_grafito') designName = 'Grafito Sadepan';
            } else if (selectedMelamina.startsWith('faplac_')) {
                brand = 'FAPLAC';
                if (selectedMelamina === 'faplac_roble') designName = 'Roble Americano';
                else if (selectedMelamina === 'faplac_seda') designName = 'Seda Giorno';
                else if (selectedMelamina === 'faplac_nogal') designName = 'Nogal Habano';
                else if (selectedMelamina === 'faplac_gris') designName = 'Gris Humo';
            }
            
            // Filtrar melamina de 18mm (no fondos traseros MDF de 3mm)
            const melaminaPieces = this.state.results.pieces.filter(p => !p.isBackground).map(p => ({
                nombre: p.name,
                alto: p.h || p.alto || 800, // Safe fallbacks
                ancho: p.w || p.ancho || 600,
                cantidad: p.qty || 1,
                tapacanto_h: "none", // Tapacantos default
                tapacanto_w: "none",
                veta: "indiferente"
            }));
            
            // Guardar en sessionStorage
            sessionStorage.setItem('cubical_despiece', JSON.stringify({
                projectName: this.state.projectName,
                thickness: 18,
                brand: brand,
                designName: designName,
                pieces: melaminaPieces,
                hardware: this.state.results.hw || []
            }));
            
            // Redirigir a SmartCut con estado de carga visual interactivo
            const btn = document.querySelector('button[onclick="window.cubical.exportToSmartCut()"]');
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> PREPARANDO SMARTCUT...';
            }
            window.location.href = '/herramientas/presupuestador';
        },

