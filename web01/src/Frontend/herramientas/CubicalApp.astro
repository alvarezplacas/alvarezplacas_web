                return `
                <div onclick="window.cubical.selectModule(${m.id})" class="bg-[var(--sc-surface)] border-2 ${isActive ? 'border-[var(--alvarez-red)] shadow-md' : 'border-[var(--sc-border)]'} p-5 rounded-lg flex justify-between items-center group hover:border-[var(--alvarez-red)] transition-all cursor-pointer">
                    <div>
                        <div class="text-[0.6rem] font-black text-[var(--alvarez-red)] uppercase">${m.name || m.type.replace('_',' ')}</div>
                        <div class="text-sm font-black text-[var(--sc-text)]">${m.dims.alto}x${m.dims.ancho}x${m.dims.prof} <span class="text-[0.6rem] font-normal text-[var(--sc-text-dim)]">mm</span></div>
                        <div class="text-[0.6rem] text-[var(--sc-text-dim)] font-bold mt-1">
                            ${m.dims.n_estantes > 0 ? `Estantes: ${m.dims.n_estantes} ` : ''}
                            ${m.dims.n_cajones > 0 ? `Cajones: ${m.dims.n_cajones} ` : ''}
                            ${m.dims.n_puertas > 0 ? `Puertas: ${m.dims.n_puertas} (${m.hingeType.toUpperCase()}) ` : ''}
