        class Cabinet3DRenderer {
        constructor(canvasId) {
            this.canvas = document.getElementById(canvasId);
            
            // Configurar Three.js
            this.scene = new THREE.Scene();
            // Fondo similar al anterior pero con soporte 3D
            this.scene.background = new THREE.Color(document.body.getAttribute('data-theme') === 'dark' ? '#1e1e1e' : '#f5f5f5');
            
            // Antialiasing para líneas perfectas
            this.renderer = new THREE.WebGLRenderer({ canvas: this.canvas, antialias: true });
            this.renderer.setSize(this.canvas.clientWidth || 800, this.canvas.clientHeight || 500);
            this.renderer.shadowMap.enabled = true;
            this.renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            
            this.camera = new THREE.PerspectiveCamera(45, (this.canvas.clientWidth || 800) / (this.canvas.clientHeight || 500), 1, 10000);
            
            // Luces Realistas tipo SketchUp
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.7);
            this.scene.add(ambientLight);
            
            const hemiLight = new THREE.HemisphereLight(0xffffff, 0x444444, 0.6);
            hemiLight.position.set(0, 2000, 0);
            this.scene.add(hemiLight);
            
            const dirLight = new THREE.DirectionalLight(0xffffff, 0.8);
            dirLight.position.set(1500, 2500, 1500);
            dirLight.castShadow = true;
            dirLight.shadow.mapSize.width = 2048;
            dirLight.shadow.mapSize.height = 2048;
            dirLight.shadow.camera.left = -1500;
            dirLight.shadow.camera.right = 1500;
            dirLight.shadow.camera.top = 1500;
            dirLight.shadow.camera.bottom = -1500;
            dirLight.shadow.bias = -0.001;
            this.scene.add(dirLight);
            
            // Controles Órbita (Rotación nativa y fluida)
            this.controls = new THREE.OrbitControls(this.camera, this.renderer.domElement);
            this.controls.enableDamping = true;
            this.controls.dampingFactor = 0.05;
            
            // Panning con la barra espaciadora
            window.addEventListener('keydown', (e) => {
                if (e.code === 'Space') {
                    this.controls.mouseButtons.LEFT = THREE.MOUSE.PAN;
                }
            });
            window.addEventListener('keyup', (e) => {
                if (e.code === 'Space') {
                    this.controls.mouseButtons.LEFT = THREE.MOUSE.ROTATE;
                }
            });
            
            // Textura de madera
            const textureLoader = new THREE.TextureLoader();
            this.woodTexture = textureLoader.load('/textures/wood_pattern.png');
            this.woodTexture.wrapS = THREE.RepeatWrapping;
            this.woodTexture.wrapT = THREE.RepeatWrapping;
            
            // Actualizar vista dinámicamente si interactúan
            this.controls.addEventListener('change', () => {
                this.renderer.render(this.scene, this.camera);
            });
            
            this.meshes = [];
            this.firstRender = true;
            
            // Resize observer
            window.addEventListener('resize', () => {
                if(this.canvas.clientWidth) {
                    this.renderer.setSize(this.canvas.clientWidth, this.canvas.clientHeight);
                    this.camera.aspect = this.canvas.clientWidth / this.canvas.clientHeight;
                    this.camera.updateProjectionMatrix();
                    this.renderer.render(this.scene, this.camera);
                }
            });
        }
        
        addBoxFaces(x, y, z, w, h, d, fillColor, lineColor, name = 'board', hiddenFaces = []) {
            const cx = x + w / 2;
            const cy = y + h / 2;
            const cz = z + d / 2;
            
            const geometry = new THREE.BoxGeometry(w, h, d);
            
            // Material con textura de madera y color de melamina
            // Clonar la textura para poder escalar los UV independientemente para cada placa
            const tex = this.woodTexture ? this.woodTexture.clone() : null;
            if (tex) {
                tex.needsUpdate = true;
                // Repetir la textura según el tamaño real de la placa para que no se deforme (asumiendo textura de 600x600mm)
                tex.repeat.set(Math.max(w, d) / 600, h / 600 || 1);
            }
            
            const material = new THREE.MeshStandardMaterial({ 
                color: new THREE.Color(fillColor),
                map: tex,
                roughness: 0.85,
                metalness: 0.05
            });
            
            const mesh = new THREE.Mesh(geometry, material);
            mesh.position.set(cx, cy, cz);
            mesh.castShadow = true;
            mesh.receiveShadow = true;
            
            // Delineado técnico (Edges)
            const edgesGeo = new THREE.EdgesGeometry(geometry);
            const edgesMat = new THREE.LineBasicMaterial({ color: lineColor, linewidth: 1 });
            const edges = new THREE.LineSegments(edgesGeo, edgesMat);
            mesh.add(edges);
            
            this.scene.add(mesh);
            this.meshes.push(mesh);
        }
        
        drawBox(width, height, depth, opts = {}) {
            const {
                offsetX = 0,
                color = '#000000',
                fillColor = '#ffffff',
                lineWidth = 1.0,
                drawPanelThickness = true,
                shelves = 0,
                drawers = 0,
                doors = 0,
                palette = null,
                showTop = true,
                showDrawers = true,
                showDoors = true
            } = opts;
            
            const sw = this.canvas.width;
            const sh = this.canvas.height;
            
            const t = 18;
            // Limpiar escena anterior
            this.meshes.forEach(m => this.scene.remove(m));
            this.meshes = [];
            this.scene.background = new THREE.Color(document.body.getAttribute('data-theme') === 'dark' ? '#1e1e1e' : '#f5f5f5');
 // 18mm de espesor de melamina
            
            // Guardar las dimensiones del módulo actual para que project() las use como centro de rotación y perspectiva
            
            
            // Reiniciar el listado global de caras para el Algoritmo del Pintor
            
            // Delineado técnico ultra-fino dinámico de alta definición
            const isDark = document.body.getAttribute('data-theme') === 'dark' || document.body.classList.contains('body-theme-dark');
            const lineColor = isDark ? '#e5e5e5' : '#1e1e1e';
            
            // Seleccionar rellenos opacos de melamina
            const baseFill   = palette ? palette.fillColor : (isDark ? '#2e2e2e' : '#f4f1ea');
            const shelfFill  = palette ? palette.shelfColor : (isDark ? '#363636' : '#ebe7dd');
            const drawerFill = palette ? palette.drawerColor : (isDark ? '#3a3a3a' : '#e5e1d7');
            const doorFill   = palette ? palette.doorColor : (isDark ? '#3d3d3d' : '#ede9df');
            
            if (opts.type === 'ESCRITORIO') {
                const cajoneraW = (opts.customVars && opts.customVars.cajoneraWidth) ? opts.customVars.cajoneraWidth : 400;
                // 1. TAPA SUPERIOR
                if (showTop) this.addBoxFaces(offsetX, height - t, 0, width, t, depth, baseFill, lineColor, 'top');
                // 2. LATERAL IZQUIERDO
                this.addBoxFaces(offsetX, 0, 0, t, height - t, depth, baseFill, lineColor, 'left-side');
                // 3. CAJONERA DERECHA (ancho variable)
                this.addBoxFaces(width - t + offsetX, 0, 0, t, height - t, depth, baseFill, lineColor, 'right-side', ['top']);
                this.addBoxFaces(width - cajoneraW + offsetX, 0, 0, t, height - t, depth, baseFill, lineColor, 'divider', ['top', 'bottom']);
                this.addBoxFaces(width - cajoneraW + t + offsetX, 0, 0, cajoneraW - 2 * t, t, depth, baseFill, lineColor, 'base-cajonera', ['left', 'right']);
                // 4. FALDÓN TRASERO
                this.addBoxFaces(t + offsetX, height - t - 300, depth - t, width - cajoneraW - t, 300, t, baseFill, lineColor, 'faldon');
                // 5. BANDEJA TECLADO
                this.addBoxFaces(t + 13 + offsetX, height - t - 100, 20, width - cajoneraW - t - 26, t, depth - 40, shelfFill, lineColor, 'bandeja', ['left', 'right']);
                
                // 6. CAJONES (en espacio de cajonera)
                if (drawers > 0) {
                    const hDisponible = height - t - t; // alto menos techo y piso
                    const hSpace = hDisponible / drawers;
                    for (let i = 0; i < drawers; i++) {
                        const yBottom = t + (i * hSpace);
                        
                        // Si el usuario eligió no mostrar frentes, mostramos solo la caja interior
                        if (!showDrawers) {
                            // Caja interna simplificada
                            const cW = cajoneraW - 2*t - 6 - 26; // Descuenta espesores y correderas
                            const cH = Math.min(150, hSpace - 30);
                            const cD = depth - 50;
                            const cX = width - cajoneraW + t + 16 + offsetX; // Margen correderas
                            const cY = yBottom + 10;
                            // Lateral Izq, Der, Frente Interno, Trasero
                            this.addBoxFaces(cX, cY, 10, t, cH, cD, drawerFill, lineColor, 'cajon-lat-izq');
                            this.addBoxFaces(cX + cW - t, cY, 10, t, cH, cD, drawerFill, lineColor, 'cajon-lat-der');
                            this.addBoxFaces(cX + t, cY, 10, cW - 2*t, cH, t, drawerFill, lineColor, 'cajon-frente-int');
                            this.addBoxFaces(cX + t, cY, 10 + cD - t, cW - 2*t, cH, t, drawerFill, lineColor, 'cajon-trasero');
                        } else {
                            this.addBoxFaces(width - cajoneraW + t + 3 + offsetX, yBottom + 3, 0, cajoneraW - 2*t - 6, hSpace - 6, t, drawerFill, lineColor, 'drawer', ['left', 'right', 'top', 'bottom', 'back']);
                            const tcX = width - cajoneraW + t + (cajoneraW - 2*t)/2 + offsetX;
                            const tcY = yBottom + hSpace / 2;
                            this.addBoxFaces(tcX - 45, tcY - 5, -10, 90, 10, 10, '#cccccc', lineColor, 'handle');
                        }
                    }
                }
                // Posicionar cámara y controles
                this.controls.target.set(width/2, height/2, depth/2);
                if (this.firstRender) {
                    this.camera.position.set(width * 1.5, height * 1.5, depth * 2.5);
                    this.firstRender = false;
                }
                this.controls.update();
                this.renderer.render(this.scene, this.camera);
                return;
            }

            if (opts.type === 'RACK_TV') {
                const centerW = (opts.customVars && opts.customVars.colCenterWidth) ? opts.customVars.colCenterWidth : 600;
                const sideW = (width - 4 * t - centerW) / 2;
                const pisoY = t;
                const techoY = height - t;
                const espacioUtilH = techoY - pisoY;
                const divLeftX = offsetX + t + sideW;
                const divRightX = divLeftX + t + centerW;
                
                // Fondo, Laterales, Techo, Piso (Similares al genérico)
                this.addBoxFaces(offsetX, 0, depth - 3, width, height, 3, baseFill, lineColor, 'backboard', ['back', 'top', 'bottom', 'left', 'right']);
                this.addBoxFaces(offsetX, 0, 0, t, height - t, depth, baseFill, lineColor, 'left-side', ['top']);
                this.addBoxFaces(width - t + offsetX, 0, 0, t, height - t, depth, baseFill, lineColor, 'right-side', ['top']);
                if (showTop) this.addBoxFaces(offsetX, height - t, 0, width, t, depth, baseFill, lineColor, 'top', ['bottom']);
                else {
                    const fajaY = height - 2 * t;
                    this.addBoxFaces(t + offsetX, fajaY, 20, width - 2*t, t, 100, baseFill, lineColor, 'faja-frente');
                    this.addBoxFaces(t + offsetX, fajaY, depth - 100, width - 2*t, t, 100, baseFill, lineColor, 'faja-fondo');
                }
                this.addBoxFaces(t + offsetX, 0, 0, width - 2 * t, t, depth, baseFill, lineColor, 'base', ['left', 'right']);
                
                // Divisores verticales interiores
                this.addBoxFaces(divLeftX, pisoY, 20, t, espacioUtilH, depth - 20, baseFill, lineColor, 'div-izq', ['top', 'bottom']);
                this.addBoxFaces(divRightX, pisoY, 20, t, espacioUtilH, depth - 20, baseFill, lineColor, 'div-der', ['top', 'bottom']);
                
                // Puertas en laterales
                if (doors > 0 && showDoors) {
                    let tiradorY = Math.min(1000, pisoY + espacioUtilH - 50);
                    this.addBoxFaces(offsetX + 3, pisoY + 3, 0, sideW + t - 3, espacioUtilH - 6, t, doorFill, lineColor, 'door-izq');
                    this.addBoxFaces(offsetX + sideW/2, tiradorY, -10, 30, 10, 10, '#cccccc', lineColor, 'handle-izq');
                }
                if (doors > 1 && showDoors) {
                    let tiradorY = Math.min(1000, pisoY + espacioUtilH - 50);
                    this.addBoxFaces(divRightX + 3, pisoY + 3, 0, sideW + t - 6, espacioUtilH - 6, t, doorFill, lineColor, 'door-der');
                    this.addBoxFaces(divRightX + sideW/2, tiradorY, -10, 30, 10, 10, '#cccccc', lineColor, 'handle-der');
                }
                
                // Centro
                let centerH = espacioUtilH;
                let bottomY = pisoY;
                
                // Cajones al centro
                if (drawers > 0) {
                    const totalDrawerH = 200 * drawers; // aprox
                    centerH = Math.max(espacioUtilH - totalDrawerH, espacioUtilH / 2); // Dejar al menos mitad para estante
                    const finalDrawerH = espacioUtilH - centerH;
                    const hSpace = finalDrawerH / drawers;
                    bottomY = pisoY + finalDrawerH;
                    
                    for (let i = 0; i < drawers; i++) {
                        const yBottom = pisoY + i * hSpace;
                        if (!showDrawers) {
                            const cW = centerW - 26; 
                            const cH = Math.min(150, hSpace - 30);
                            const cD = depth - 50;
                            const cX = divLeftX + t + 13;
                            const cY = yBottom + 10;
                            this.addBoxFaces(cX, cY, 10, t, cH, cD, drawerFill, lineColor, 'cajon-lat-izq');
                            this.addBoxFaces(cX + cW - t, cY, 10, t, cH, cD, drawerFill, lineColor, 'cajon-lat-der');
                            this.addBoxFaces(cX + t, cY, 10, cW - 2*t, cH, t, drawerFill, lineColor, 'cajon-frente-int');
                            this.addBoxFaces(cX + t, cY, 10 + cD - t, cW - 2*t, cH, t, drawerFill, lineColor, 'cajon-trasero');
                        } else {
                            this.addBoxFaces(divLeftX + t + 3, yBottom + 3, 0, centerW - 6, hSpace - 6, t, drawerFill, lineColor, 'drawer-center');
                            const tcX = divLeftX + t + centerW / 2;
                            const tcY = yBottom + hSpace / 2;
                            this.addBoxFaces(tcX - 45, tcY - 5, -10, 90, 10, 10, '#cccccc', lineColor, 'handle-center');
                        }
                    }
                }
                
                // Estantes en el centro
                if (shelves > 0) {
                    const hSpace = centerH / (shelves + 1);
                    for (let i = 1; i <= shelves; i++) {
                        const shelfY = bottomY + i * hSpace - t / 2;
                        this.addBoxFaces(divLeftX + t, shelfY, 20, centerW, t, depth - 20, shelfFill, lineColor, 'shelf-center', ['left', 'right']);
                    }
                }
                
                // Render WebGL
                this.controls.target.set(width/2, height/2, depth/2);
                if (this.firstRender) {
                    this.camera.position.set(width * 1.5, height * 1.5, depth * 2.5);
                    this.firstRender = false;
                }
                this.controls.update();
                this.renderer.render(this.scene, this.camera);
                
                return;
            }

            // 1. DIBUJAR FONDO/RESPALDO (3mm MDF) - Ubicado al fondo del mueble
            this.addBoxFaces(offsetX, 0, depth - 3, width, height, 3, baseFill, lineColor, 'backboard', ['back', 'top', 'bottom', 'left', 'right']);
            
            // 2. DIBUJAR LATERAL IZQUIERDO (18mm) - Corregido para que termine bajo el techo
            this.addBoxFaces(offsetX, 0, 0, t, height - t, depth, baseFill, lineColor, 'left-side', ['top']);
            
            // 3. DIBUJAR LATERAL DERECHO (18mm) - Corregido para que termine bajo el techo
            this.addBoxFaces(width - t + offsetX, 0, 0, t, height - t, depth, baseFill, lineColor, 'right-side', ['top']);
            
            // 4. DIBUJAR TECHO / TAPA SUPERIOR (18mm)
            if (showTop) {
                this.addBoxFaces(offsetX, height - t, 0, width, t, depth, baseFill, lineColor, 'top', ['bottom']);
            } else {
                // Dibujar Fajas de anclaje (espigas) si no hay tapa y es bajo mesada o simplemente para ver estructura
                // Faja frontal y trasera por dentro de los laterales y a ras de su borde superior
                const fajaY = height - 2 * t; // El lateral llega hasta height - t
                this.addBoxFaces(t + offsetX, fajaY, 20, width - 2*t, t, 100, baseFill, lineColor, 'faja-frente');
                this.addBoxFaces(t + offsetX, fajaY, depth - 100, width - 2*t, t, 100, baseFill, lineColor, 'faja-fondo');
            }
            
            // 5. DIBUJAR PISO / BASE INFERIOR (18mm) - Soporte para Zócalo si corresponde
            let zocaloH = 0;
            if (height >= 800 && drawers > 0) zocaloH = 80;  // Zócalo de 80mm en cajoneras
            if (height === 850 && doors > 0) zocaloH = 120;  // Zócalo de 120mm en bajos mesada
            
            if (zocaloH > 0) {
                // Dibujar Zócalo frontal retranqueado (retrocede 20mm del frente Z = 20)
                this.addBoxFaces(t + offsetX, 0, 20, width - 2 * t, zocaloH, t, baseFill, lineColor, 'zocalo', ['top', 'bottom']);
                // Piso del mueble sobre el zócalo
                this.addBoxFaces(t + offsetX, zocaloH, 0, width - 2 * t, t, depth, baseFill, lineColor, 'base', ['left', 'right']);
            } else {
                // Piso del mueble a ras del suelo
                this.addBoxFaces(t + offsetX, 0, 0, width - 2 * t, t, depth, baseFill, lineColor, 'base', ['left', 'right', 'bottom']);
            }
            
            const pisoY = zocaloH > 0 ? zocaloH + t : t;
            const techoY = height - t;
            const espacioUtilH = techoY - pisoY;
            
            // Dividir espacio para cajones y puertas
            let drawerSpaceH = 0;
            let doorSpaceH = 0;
            
            if (drawers > 0 && doors > 0) {
                drawerSpaceH = drawers * 200; // 200mm aprox por cajón
                if (drawerSpaceH > espacioUtilH - 300) drawerSpaceH = espacioUtilH - 300; // Dejar 300 para puertas
                doorSpaceH = espacioUtilH - drawerSpaceH;
            } else if (drawers > 0) {
                drawerSpaceH = espacioUtilH;
            } else if (doors > 0) {
                doorSpaceH = espacioUtilH;
            }
            
            // 6. DIBUJAR ESTANTES (18mm) - Con retranqueo frontal estándar de 20mm
            // Los estantes se calculan sobre el espacio de las puertas si las hay (para que queden ocultos tras la puerta)
            if (shelves > 0) {
                const hSpace = (doors > 0 ? doorSpaceH : espacioUtilH) / (shelves + 1);
                for (let i = 1; i <= shelves; i++) {
                    const shelfY = pisoY + i * hSpace - t / 2;
                    this.addBoxFaces(t + offsetX, shelfY, 20, width - 2 * t, t, depth - 20, shelfFill, lineColor, 'shelf', ['left', 'right', 'back']);
                }
            }
            
            // 7. DIBUJAR CAJONES (Frentes de cajón de 18mm con holgura de 3mm)
            if (drawers > 0) {
                const hSpace = drawerSpaceH / drawers;
                // Si hay puertas, los cajones van arriba de ellas.
                const drawerStartY = pisoY + doorSpaceH;
                for (let i = 0; i < drawers; i++) {
                    const yBottom = drawerStartY + i * hSpace;
                    
                    if (!showDrawers) {
                        // Dibujar estructura interna del cajón
                        const cW = width - 6 - 26; // Ancho menos holgura exterior y correderas (13mm x2)
                        const cH = Math.min(150, hSpace - 30);
                        const cD = depth - 50;
                        const cX = offsetX + 3 + 13; // Margen exterior + corredera
                        const cY = yBottom + 10;
                        
                        this.addBoxFaces(cX, cY, 10, t, cH, cD, drawerFill, lineColor, 'cajon-lat-izq');
                        this.addBoxFaces(cX + cW - t, cY, 10, t, cH, cD, drawerFill, lineColor, 'cajon-lat-der');
                        this.addBoxFaces(cX + t, cY, 10, cW - 2*t, cH, t, drawerFill, lineColor, 'cajon-frente-int');
                        this.addBoxFaces(cX + t, cY, 10 + cD - t, cW - 2*t, cH, t, drawerFill, lineColor, 'cajon-trasero');
                    } else {
                        // Frente de cajón de 18mm de espesor embutido, Z = 0
                        this.addBoxFaces(3 + offsetX, yBottom + 3, 0, width - 6, hSpace - 6, t, drawerFill, lineColor, 'drawer', ['left', 'right', 'top', 'bottom', 'back']);
                        
                        // Tirador de barra horizontal de 3D
                        const tcX = width / 2 + offsetX;
                        const tcY = yBottom + hSpace / 2;
                        this.addBoxFaces(tcX - 45, tcY - 5, -10, 90, 10, 10, '#cccccc', lineColor, 'handle');
                    }
                }
            }
            
            // 8. DIBUJAR PUERTAS (Puertas de 18mm)
            if (doors > 0 && showDoors) {
                const wSpace = (width - 6) / doors;
                for (let i = 0; i < doors; i++) {
                    const xLeft = 3 + i * wSpace;
                    // Puertas de 18mm de espesor embutidas, Z = 0
                    this.addBoxFaces(xLeft + offsetX, pisoY + 3, 0, wSpace - 3, doorSpaceH - 6, t, doorFill, lineColor, 'door', ['left', 'right', 'top', 'bottom', 'back']);
                    
                    // Tirador de barra vertical para las puertas
                    const tiradorX = doors === 1 
                        ? xLeft + wSpace - 30 
                        : (i === 0 ? xLeft + wSpace - 30 : xLeft + 30);
                    // Lógica de altura ergonómica del tirador
                    let tiradorY;
                    if (opts.type === 'ALACENA') {
                        tiradorY = pisoY + 80; // Cerca de la base para módulos colgantes
                    } else if (doorSpaceH + pisoY > 1500) {
                        tiradorY = 1000; // Altura estándar ergonómica desde el suelo para muebles altos
                    } else {
                        tiradorY = pisoY + doorSpaceH - 60; // Cerca del borde superior para muebles bajos
                    }
                    this.addBoxFaces(tiradorX + offsetX - 5, tiradorY - 50, -10, 10, 100, 10, '#cccccc', lineColor, 'handle');
                }
            }
            // Render WebGL
            this.controls.target.set(width/2, height/2, depth/2);
            if (this.firstRender) {
                this.camera.position.set(width * 1.5, height * 1.5, depth * 2.5);
                this.firstRender = false;
            }
            this.controls.update();
            this.renderer.render(this.scene, this.camera);
        }
    }

    window.cubical = {
        state: {
            currentScreen: 'dashboard',
            projectName: '',
            environment: '',
            modules: [],
            projects: [],
            results: null,
            selectedMelamina: 'faplac_roble'
        },

        initialized: false,
        renderer: null,

        init: async function() {
            if (this.initialized) return;
            this.initialized = true;
            this.updateThemeUI();
            await this.loadProjects();
            
            // Inicializar renderizadores 3D
            try {
                this.renderer = new Cabinet3DRenderer('canvas-preview');
                this.rendererMobile = new Cabinet3DRenderer('canvas-preview-mobile');
                this.rendererMobile.scale = 0.22;
            } catch (e) {
                console.error("[CubiCal] Falló inicialización de Canvas 3D:", e);
            }
            
            // Cargar tarjetas del catálogo dinámicamente desde templates.js
            await this.renderTemplateCarousel();
            
            // Inicializar Carrusel de Plantillas con Auto-Scroll Lento e Interactivo
            const carousel = document.getElementById('templates-carousel');
            const btnLeft = document.getElementById('carousel-btn-left');
            const btnRight = document.getElementById('carousel-btn-right');
            
            if (carousel && btnLeft && btnRight) {
                btnLeft.addEventListener('click', (e) => {
                    e.preventDefault();
                    carousel.scrollBy({ left: -344, behavior: 'smooth' });
                });
                btnRight.addEventListener('click', (e) => {
                    e.preventDefault();
                    carousel.scrollBy({ left: 344, behavior: 'smooth' });
                });
                
                // Auto-scroll eliminado porque entra en conflicto con CSS snap-x snap-mandatory
            }

            // Aplicar primer set de presets
            this.autoSetPresets();
            
            this.showScreen('dashboard');
        },

        changeMelamina: function(isMobile = false) {
            const prefix = isMobile ? '-mobile' : '';
            const selectEl = document.getElementById(`mod-melamina${prefix}`);
            if (!selectEl) return;
            const val = selectEl.value;
            this.state.selectedMelamina = val;
            
            // Sincronizar el otro select
            const otherPrefix = isMobile ? '' : '-mobile';
            const otherSelect = document.getElementById(`mod-melamina${otherPrefix}`);
            if (otherSelect) otherSelect.value = val;
            
            this.renderPreview();
        },

        toggleTheme: function() {
            const body = document.body;
            const isDark = body.getAttribute('data-theme') === 'dark' || body.classList.contains('body-theme-dark');
            if (isDark) {
                body.removeAttribute('data-theme');
                body.classList.add('body-theme-light');
                body.classList.remove('body-theme-dark');
                localStorage.setItem('client-theme', 'light');
                localStorage.setItem('sc-theme', 'light');
            } else {
                body.setAttribute('data-theme', 'dark');
                body.classList.add('body-theme-dark');
                body.classList.remove('body-theme-light');
                localStorage.setItem('client-theme', 'dark');
                localStorage.setItem('sc-theme', 'dark');
            }
            this.updateThemeUI();
            this.renderPreview();
        },

        updateThemeUI: function() {
            const isDark = document.body.getAttribute('data-theme') === 'dark' || document.body.classList.contains('body-theme-dark');
            const text = document.getElementById('theme-text');
            const icon = document.getElementById('theme-icon');
            if (text && icon) {
                text.textContent = isDark ? 'MODO CLARO' : 'MODO OSCURO';
                icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            }
        },

        loadProjects: async function() {
            try {
                const response = await fetch(`/api/herramientas/get-cubical?clientId=${CLIENT_ID}`);
                const data = await response.json();
                if (data.success) {
                    this.state.projects = data.projects;
                    this.renderDashboard();
                }
            } catch (e) {
                this.renderDashboard();
            }
        },

        reset3DView: function() {
            if (!this.renderer) return;
            this.renderer.angleY = -0.6;
            this.renderer.angleX = 0.3;
            this.renderer.autoScalePending = true;
            this.renderer.panX = 0;
            this.renderer.panY = 0;
            if (this.rendererMobile) {
                this.rendererMobile.angleY = -0.6;
                this.rendererMobile.angleX = 0.3;
                this.rendererMobile.autoScalePending = true;
                this.rendererMobile.panX = 0;
                this.rendererMobile.panY = 0;
            }
            this.renderPreview();
        },

        set3DView: function(type) {
            if (!this.renderer) return;
            let ay = 0, ax = 0;
            if (type === 'front') {
                ay = 0; ax = 0;
            } else if (type === 'top') {
                ay = 0; ax = Math.PI / 2;
            }
            this.renderer.angleY = ay;
            this.renderer.angleX = ax;
            if (this.rendererMobile) {
                this.rendererMobile.angleY = ay;
                this.rendererMobile.angleX = ax;
            }
            this.renderPreview();
        },

        zoom3D: function(factor) {
            if (!this.renderer) return;
            this.renderer.scale *= factor;
            this.renderer.scale = Math.max(0.1, Math.min(1.5, this.renderer.scale));
            if (this.rendererMobile) {
                this.rendererMobile.scale *= factor;
                this.rendererMobile.scale = Math.max(0.1, Math.min(1.2, this.rendererMobile.scale));
            }
            this.renderPreview();
        },

        showRealPhoto: function() {
            let imgName = 'ropero';
            if (this.currentTemplateId && this.templates[this.currentTemplateId]) {
                 imgName = this.templates[this.currentTemplateId].name.toLowerCase().replace(/ /g, '_');
            } else {
                 const name = document.getElementById('mod-name')?.value.toLowerCase() || '';
                 if (name.includes('chifonier')) imgName = 'chifonier';
                 else if (name.includes('bajo mesada')) imgName = 'bajo_mesada';
                 else if (name.includes('alacena')) imgName = 'alacena';
                 else if (name.includes('placard') || name.includes('ropero') || name.includes('vestidor')) imgName = 'ropero';
                 else if (name.includes('biblioteca')) imgName = 'biblioteca';
                 else if (name.includes('vanitory')) imgName = 'vanitory';
                 else if (name.includes('rack tv')) imgName = 'rack_tv';
                 else if (name.includes('escritorio')) imgName = 'escritorio';
            }

            const modal = document.getElementById('real-photo-modal');
            const img = document.getElementById('real-photo-img');
            
            if (modal && img) {
                modal.classList.remove('hidden');
                img.style.opacity = '0.5';
                
                // Buscar primero en la carpeta "cubical" de Directus
                const folderId = '204f3934-548e-44b1-92d8-db065fba2ac5';
                fetch(`https://admin.alvarezplacas.com.ar/files?filter[folder][_eq]=${folderId}&filter[title][_icontains]=${imgName}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data.data && data.data.length > 0) {
                            // Se encontró en Directus
                            img.src = `https://admin.alvarezplacas.com.ar/assets/${data.data[0].id}`;
                        } else {
                            // Fallback a la imagen local
                            img.src = `/herramientas/assets/renders/${imgName}.png`;
                        }
                        img.onload = () => img.style.opacity = '1';
                    })
                    .catch(err => {
                        console.error('Error fetching from Directus:', err);
                        img.src = `/herramientas/assets/renders/${imgName}.png`;
                        img.onload = () => img.style.opacity = '1';
                    });
            }
        },

        closeRealPhoto: function() {
            const modal = document.getElementById('real-photo-modal');
            if (modal) modal.classList.add('hidden');
        },

        showScreen: function(name) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(`screen-${name}`).classList.remove('hidden');
            this.state.currentScreen = name;
            const saveBtn = document.getElementById('btn-save-project');
            if (saveBtn) saveBtn.classList.toggle('hidden', name !== 'constructor');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        },

        showSetup: function() { this.showScreen('setup'); },
        showDashboard: function() { this.showScreen('dashboard'); },
        showConstructor: function() { 
            this.showScreen('constructor'); 
            setTimeout(() => this.renderPreview(), 100);
        },

        startConstructor: function() {
            const name = document.getElementById('setup-name').value;
            if (!name) { alert("⚠️ Por favor ingresa el nombre del proyecto."); return; }
            this.state.projectName = name;
            this.state.environment = document.getElementById('setup-env').value;
            this.showScreen('constructor');
            this.renderConstructor();
            setTimeout(() => this.renderPreview(), 100);
        },

        loadTemplate: async function(type) {
            // ---------------------------------------------------------------
            // CARGA DE DATOS DESDE EL ARCHIVO EXTERNO DE PLANTILLAS
            // Para agregar nuevas plantillas editar únicamente:
            // /herramientas/logic/cubical/templates/templates.js
            // ---------------------------------------------------------------
            let tplData = null;
            try {
                const mod = await import(`/herramientas/logic/cubical/templates/templates.js?v=` + Date.now());
                tplData = mod.TEMPLATES[type];
            } catch(e) {
                console.warn('[CubiCal] No se pudo cargar templates.js, usando fallback:', e);
            }

            // Fallback: si no hay datos externos, usar valores genéricos
            const modType   = tplData?.modType   || 'CAJONERA';
            const dims      = tplData?.dims      || { alto: 800, ancho: 600, prof: 500, n_cajones: 3, n_puertas: 0, n_estantes: 0 };
            const hingeType = tplData?.hingeType || 'codo_0';
            const name      = tplData?.moduleName || `Modulo A1 - ${type}`;
            
            this.state.projectName = tplData ? `Proyecto Rápido - ${tplData.name}` : `Proyecto Rápido - ${type}`;
            this.state.environment = tplData?.environment || 'cocina';
            this.state.modules = [];
            
            const newId = Date.now();
            this.state.modules.push({ id: newId, type: modType, name, dims, hingeType, customVars: tplData?.customVars || {} });
            this.state.activeModuleId = newId;
            
            // Poblar barra lateral Desktop
            document.getElementById('mod-name').value      = name;
            document.getElementById('mod-type').value      = modType;
            document.getElementById('mod-h').value         = dims.alto;
            document.getElementById('mod-w').value         = dims.ancho;
            document.getElementById('mod-p').value         = dims.prof;
            document.getElementById('mod-drawers').value   = dims.n_cajones;
            document.getElementById('mod-doors').value     = dims.n_puertas;
            document.getElementById('mod-shelves').value   = dims.n_estantes;
            
            // Poblar barra lateral Mobile
            document.getElementById('mod-name-mobile').value    = name;
            document.getElementById('mod-type-mobile').value    = modType;
            document.getElementById('mod-h-mobile').value       = dims.alto;
            document.getElementById('mod-w-mobile').value       = dims.ancho;
            document.getElementById('mod-p-mobile').value       = dims.prof;
            document.getElementById('mod-drawers-mobile').value = dims.n_cajones;
            document.getElementById('mod-doors-mobile').value   = dims.n_puertas;
            document.getElementById('mod-shelves-mobile').value = dims.n_estantes;
            
            this.updateHingeVisibility();
            this.updateDrawerEducation();
            this.renderCustomVarsUI();
            
            // Resetear auto-escala para el nuevo módulo
            if (this.renderer) this.renderer.autoScalePending = true;
            if (this.rendererMobile) this.rendererMobile.autoScalePending = true;

            this.showScreen('constructor');
            this.renderConstructor();
            setTimeout(() => this.renderPreview(), 100);
        },

        renderTemplateCarousel: async function() {
            // ---------------------------------------------------------------
            // Genera las tarjetas del carrusel dinámicamente desde templates.js
            // ---------------------------------------------------------------
            const carousel = document.getElementById('templates-carousel');
            if (!carousel) return;

            let TEMPLATES = {};
            try {
                const mod = await import(`/herramientas/logic/cubical/templates/templates.js?v=` + Date.now());
                TEMPLATES = mod.TEMPLATES;
            } catch(e) {
                console.warn('[CubiCal] Error cargando catálogo de plantillas:', e);
                return;
            }

            carousel.innerHTML = Object.values(TEMPLATES).map(t => `
                <div onclick="window.cubical.loadTemplate('${t.id}')" 
                     class="snap-start shrink-0 w-80 bg-[var(--sc-surface)] border border-[var(--sc-border)] p-6 rounded-xl hover:border-[var(--alvarez-red)] transition-all cursor-pointer group shadow-sm flex flex-col justify-between h-56"
                     title="${t.name} — ${t.dims.alto} x ${t.dims.ancho} x ${t.dims.prof} mm">
                    <div>
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-3xl">${t.emoji}</span>
                            <span class="text-[0.5rem] font-black bg-[var(--sc-surface-alt)] px-2.5 py-1 rounded border border-[var(--sc-border)] uppercase tracking-wider" style="color: ${t.tagColor}">${t.tag}</span>
                        </div>
                        <h4 class="text-lg font-black text-[var(--sc-text)] uppercase tracking-tight group-hover:text-[var(--alvarez-red)] transition-colors mb-1">${t.name}</h4>
                        <p class="text-[0.6rem] text-[var(--sc-text-dim)] font-medium leading-relaxed">${t.description}</p>
                    </div>
                    <div class="text-[0.6rem] font-bold text-[var(--sc-text)] uppercase font-mono tracking-wider">${t.dims.alto} x ${t.dims.ancho} x ${t.dims.prof} mm</div>
                </div>
            `).join('');
        },

        autoSetPresets: function(isMobile = false) {
            const prefix = isMobile ? '-mobile' : '';
            const type = document.getElementById(`mod-type${prefix}`).value;
            const shelvesInput = document.getElementById(`mod-shelves${prefix}`);
            const drawersInput = document.getElementById(`mod-drawers${prefix}`);
            const doorsInput = document.getElementById(`mod-doors${prefix}`);
            const hInput = document.getElementById(`mod-h${prefix}`);
            const wInput = document.getElementById(`mod-w${prefix}`);
            const pInput = document.getElementById(`mod-p${prefix}`);
            
            if (!shelvesInput || !drawersInput || !doorsInput) return;
            
            // Medidas predeterminadas según tipo
            if (type === 'CAJONERA') {
                shelvesInput.value = 0; drawersInput.value = 3; doorsInput.value = 0;
                hInput.value = 800; wInput.value = 600; pInput.value = 500;
            } else if (type === 'PLACARD') {
                shelvesInput.value = 2; drawersInput.value = 0; doorsInput.value = 2;
                hInput.value = 2000; wInput.value = 800; pInput.value = 600;
            } else if (type === 'ALACENA') {
                shelvesInput.value = 2; drawersInput.value = 0; doorsInput.value = 2;
                hInput.value = 700; wInput.value = 600; pInput.value = 320;
            } else if (type === 'BAJO_MESADA') {
                shelvesInput.value = 0; drawersInput.value = 0; doorsInput.value = 2;
                hInput.value = 820; wInput.value = 800; pInput.value = 580;
            } else if (type === 'BIBLIOTECA') {
                shelvesInput.value = 4; drawersInput.value = 0; doorsInput.value = 0;
                hInput.value = 1800; wInput.value = 800; pInput.value = 300;
            } else if (type === 'ESCRITORIO') {
                shelvesInput.value = 0; drawersInput.value = 4; doorsInput.value = 0;
                hInput.value = 750; wInput.value = 1200; pInput.value = 600;
            } else {
                shelvesInput.value = 0; drawersInput.value = 0; drawersInput.value = 0;
            }
            
            // Sincronizar el otro formulario
            const otherPrefix = isMobile ? '' : '-mobile';
            const otherType = document.getElementById(`mod-type${otherPrefix}`);
            if (otherType) {
                otherType.value = type;
                document.getElementById(`mod-shelves${otherPrefix}`).value = shelvesInput.value;
                document.getElementById(`mod-drawers${otherPrefix}`).value = drawersInput.value;
                document.getElementById(`mod-doors${otherPrefix}`).value = doorsInput.value;
                document.getElementById(`mod-h${otherPrefix}`).value = hInput.value;
                document.getElementById(`mod-w${otherPrefix}`).value = wInput.value;
                document.getElementById(`mod-p${otherPrefix}`).value = pInput.value;
            }

            this.updateHingeVisibility(isMobile);
            this.updateDrawerEducation(isMobile);
        },

        updateHingeVisibility: function(isMobile = false) {
            const prefix = isMobile ? '-mobile' : '';
            const doorsVal = parseInt(document.getElementById(`mod-doors${prefix}`).value) || 0;
            const hingeDiv = document.getElementById(`group-hinge-type${prefix}`);
            const eduTip = document.getElementById('edu-hinge-tip');

            if (doorsVal > 0) {
                hingeDiv.classList.remove('hidden');
                if (eduTip && !isMobile) eduTip.classList.remove('hidden');
            } else {
                hingeDiv.classList.add('hidden');
                if (eduTip && !isMobile) eduTip.classList.add('hidden');
            }
            this.updateHingeEducation(isMobile);
        },

        updateHingeEducation: function(isMobile = false) {
            const prefix = isMobile ? '-mobile' : '';
            const typeSelect = document.getElementById(`mod-hinge-type${prefix}`);
            if (!typeSelect) return;
            const type = typeSelect.value;
            const textSpan = document.getElementById('edu-hinge-text');
            const tipDiv = document.getElementById('edu-hinge-tip');

            if (!textSpan) return;

            let tipText = "";
            let title = "🚪 Bisagra Codo 0 (Superpuesta)";
            if (type === 'codo_0') {
                tipText = "La puerta cubre todo el lateral (18mm) al cerrar. Es la clásica más utilizada en extremos de muebles.";
                title = "🚪 Bisagra Codo 0 (Superpuesta)";
                if (tipDiv) tipDiv.style.borderLeftColor = 'var(--alvarez-red)';
            } else if (type === 'codo_9') {
                tipText = "La puerta cubre la mitad del lateral (9mm). Ideal cuando dos puertas continuas se abren opuestas y comparten el lateral central.";
                title = "🚪 Bisagra Codo 9 (Semi-superpuesta)";
                if (tipDiv) tipDiv.style.borderLeftColor = '#f59e0b';
            } else if (type === 'codo_18') {
                tipText = "La puerta queda adentro del mueble, al ras de los bordes. Deja ver los cantos melamínicos de los laterales.";
                title = "🚪 Bisagra Codo 18 (Embutida)";
                if (tipDiv) tipDiv.style.borderLeftColor = '#10b981';
            }

            textSpan.innerHTML = `<strong>${title}</strong><br>${tipText}`;
        },

        updateDrawerEducation: function(isMobile = false) {
            const prefix = isMobile ? '-mobile' : '';
            const drawersVal = parseInt(document.getElementById(`mod-drawers${prefix}`).value) || 0;
            const tipDiv = document.getElementById('edu-drawer-tip');

            if (!tipDiv) return;

            if (drawersVal > 0) {
                tipDiv.classList.remove('hidden');
            } else {
                tipDiv.classList.add('hidden');
            }
        },

        // Métodos para Bottom Sheets móviles
        openMobileSheet: function(name) {
            this.closeMobileSheets();
            const sheet = document.getElementById(`sheet-${name}`);
            const btn = document.getElementById(`mbtn-${name}`);
            if (sheet) sheet.classList.add('active');
            if (btn) btn.classList.add('active');
        },

        closeMobileSheets: function() {
            document.querySelectorAll('.bottom-sheet').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.bottom-action-btn').forEach(b => b.classList.remove('active'));
        },

        addModule: function(isMobile = false) {
            const prefix = isMobile ? '-mobile' : '';
            const nameInputVal = document.getElementById(`mod-name${prefix}`)?.value || `Modulo A${this.state.modules.length + 1}`;
            const type = document.getElementById(`mod-type${prefix}`).value;
            const dims = {
                alto: parseInt(document.getElementById(`mod-h${prefix}`).value) || 800,
                ancho: parseInt(document.getElementById(`mod-w${prefix}`).value) || 600,
                prof: parseInt(document.getElementById(`mod-p${prefix}`).value) || 500,
                n_cajones: parseInt(document.getElementById(`mod-drawers${prefix}`).value) || 0,
                n_puertas: parseInt(document.getElementById(`mod-doors${prefix}`).value) || 0,
                n_estantes: parseInt(document.getElementById(`mod-shelves${prefix}`).value) || 0
            };
            
            const hingeSelect = document.getElementById(`mod-hinge-type${prefix}`);
            const hingeType = hingeSelect ? hingeSelect.value : 'codo_0';

            const newId = Date.now();
            this.state.modules.push({ id: newId, type, name: nameInputVal, dims, hingeType });
            this.state.activeModuleId = newId; // Activar el módulo
            
            // Auto-increment module name for the next module
            const nextName = `Modulo A${this.state.modules.length + 1}`;
            const dNameInput = document.getElementById('mod-name');
            const mNameInput = document.getElementById('mod-name-mobile');
            if (dNameInput) dNameInput.value = nextName;
            if (mNameInput) mNameInput.value = nextName;

            if (isMobile) {
                this.closeMobileSheets();
            }
            this.renderConstructor();
        },

        removeModule: function(id) {
            this.state.modules = this.state.modules.filter(m => m.id !== id);
            
            // Si el módulo borrado era el activo, activar el último de la lista
            if (this.state.activeModuleId === id) {
                if (this.state.modules.length > 0) {
                    const lastMod = this.state.modules[this.state.modules.length - 1];
                    this.selectModule(lastMod.id);
                } else {
                    this.state.activeModuleId = null;
                }
            }
            
            // Adjust next name index accordingly
