        updateActiveModule: function(isMobile = false) {
            if (!this.state.activeModuleId) return;
            const m = this.state.modules.find(mod => mod.id === this.state.activeModuleId);
            if (!m) return;
            
            const prefix = isMobile ? '-mobile' : '';
            const nameVal = document.getElementById(`mod-name${prefix}`)?.value || m.name;
            const typeVal = document.getElementById(`mod-type${prefix}`).value;
            const hVal = parseInt(document.getElementById(`mod-h${prefix}`).value) || 800;
            const wVal = parseInt(document.getElementById(`mod-w${prefix}`).value) || 600;
            const pVal = parseInt(document.getElementById(`mod-p${prefix}`).value) || 500;
            const drawersVal = parseInt(document.getElementById(`mod-drawers${prefix}`).value) || 0;
            const doorsVal = parseInt(document.getElementById(`mod-doors${prefix}`).value) || 0;
            const shelvesVal = parseInt(document.getElementById(`mod-shelves${prefix}`).value) || 0;
            const hingeSelect = document.getElementById(`mod-hinge-type${prefix}`);
            const hingeVal = hingeSelect ? hingeSelect.value : 'codo_0';
            
            m.name = nameVal;
            m.type = typeVal;
            m.dims.alto = hVal;
            m.dims.ancho = wVal;
            m.dims.prof = pVal;
            m.dims.n_cajones = drawersVal;
            m.dims.n_puertas = doorsVal;
            m.dims.n_estantes = shelvesVal;
            m.hingeType = hingeVal;
            
            // Sincronizar Custom Vars desde los inputs dinámicos
            if (m.customVars) {
                Object.keys(m.customVars).forEach(key => {
                    const input = document.getElementById(`mod-cv-${key}${prefix}`);
                    if (input) {
                        m.customVars[key] = parseInt(input.value) || m.customVars[key];
                    }
                });
            }
            
            // Sincronizar formulario opuesto
            const otherPrefix = isMobile ? '' : '-mobile';
            const oName = document.getElementById(`mod-name${otherPrefix}`);
            const oType = document.getElementById(`mod-type${otherPrefix}`);
            const oH = document.getElementById(`mod-h${otherPrefix}`);
            const oW = document.getElementById(`mod-w${otherPrefix}`);
            const oP = document.getElementById(`mod-p${otherPrefix}`);
            const oDrawers = document.getElementById(`mod-drawers${otherPrefix}`);
            const oDoors = document.getElementById(`mod-doors${otherPrefix}`);
            const oShelves = document.getElementById(`mod-shelves${otherPrefix}`);
            const oHinge = document.getElementById(`mod-hinge-type${otherPrefix}`);
            
            if (oName) oName.value = nameVal;
            if (oType) oType.value = typeVal;
            if (oH) oH.value = hVal;
            if (oW) oW.value = wVal;
            if (oP) oP.value = pVal;
            if (oDrawers) oDrawers.value = drawersVal;
            if (oDoors) oDoors.value = doorsVal;
            if (oShelves) oShelves.value = shelvesVal;
            if (oHinge && hingeSelect) oHinge.value = hingeVal;
            
            // Sincronizar UI de Custom Vars al otro formulario
            if (m.customVars) {
                Object.keys(m.customVars).forEach(key => {
                    const oInput = document.getElementById(`mod-cv-${key}${otherPrefix}`);
                    if (oInput) oInput.value = m.customVars[key];
                });
            }
            
            // Actualizar listados HTML de capas sin destruir eventos
            const list = document.getElementById('module-list');
            const listMobile = document.getElementById('module-list-mobile');
            
            const html = this.state.modules.map(mod => {
                const isActive = mod.id === this.state.activeModuleId;
                return `
                <div onclick="window.cubical.selectModule(${mod.id})" class="bg-[var(--sc-surface)] border-2 ${isActive ? 'border-[var(--alvarez-red)] shadow-md' : 'border-[var(--sc-border)]'} p-5 rounded-lg flex justify-between items-center group hover:border-[var(--alvarez-red)] transition-all cursor-pointer">
                    <div>
                        <div class="text-[0.6rem] font-black text-[var(--alvarez-red)] uppercase">${mod.name || mod.type.replace('_',' ')}</div>
                        <div class="text-sm font-black text-[var(--sc-text)]">${mod.dims.alto}x${mod.dims.ancho}x${mod.dims.prof} <span class="text-[0.6rem] font-normal text-[var(--sc-text-dim)]">mm</span></div>
                        <div class="text-[0.6rem] text-[var(--sc-text-dim)] font-bold mt-1">
                            ${mod.dims.n_estantes > 0 ? `Estantes: ${mod.dims.n_estantes} ` : ''}
                            ${mod.dims.n_cajones > 0 ? `Cajones: ${mod.dims.n_cajones} ` : ''}
                            ${mod.dims.n_puertas > 0 ? `Puertas: ${mod.dims.n_puertas} (${mod.hingeType.toUpperCase()}) ` : ''}
                            ${(mod.dims.n_estantes == 0 && mod.dims.n_cajones == 0 && mod.dims.n_puertas == 0) ? 'Módulo Vacío' : ''}
                        </div>
                    </div>
                    <button onclick="event.stopPropagation(); window.cubical.removeModule(${mod.id})" class="w-10 h-10 bg-[var(--sc-surface-alt)] rounded flex items-center justify-center text-[var(--sc-text-dim)] hover:bg-[var(--alvarez-red)] hover:text-white transition-all shadow-sm">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            `;}).join('');
            
            if (list) list.innerHTML = html;
            if (listMobile) listMobile.innerHTML = html;
            
            this.renderPreview();
        },

