<style>
    :root {
        --alvarez-red: oklch(62.8% 0.25 29.23);
        --alvarez-blue: oklch(65% 0.18 220);
        --alvarez-border: oklch(0% 0 0 / 10%);
        --sc-text: oklch(20% 0 0);
        --sc-text-dim: oklch(50% 0 0);
        --sc-surface: oklch(98% 0.01 90); /* Papel Hueso */
        --sc-surface-alt: oklch(94% 0.01 90);
        --sc-border: oklch(0% 0 0 / 8%);
        --sc-input-bg: oklch(100% 0 0);
    }
    
    [data-theme="dark"],
    .body-theme-dark,
    body.body-theme-dark {
        --sc-text: oklch(95% 0 0);
        --sc-text-dim: oklch(70% 0 0);
        --sc-surface: oklch(12% 0.01 260);
        --sc-surface-alt: oklch(18% 0.01 260);
        --sc-border: oklch(100% 0 0 / 10%);
        --sc-input-bg: oklch(5% 0 0);
        --alvarez-border: oklch(100% 0 0 / 15%);
    }

    /* 📐 AutoCAD & Photoshop Precisión Industrial para todos los Inputs/Selects y Colores Explícitos */
    .cubical-container input,
    .cubical-container select,
    .cubical-container textarea {
        color: var(--sc-text) !important;
        background-color: var(--sc-input-bg) !important;
        border-color: var(--sc-border) !important;
        border-radius: 4px !important;
    }
    .cubical-container input:focus,
    .cubical-container select:focus {
        border-color: var(--alvarez-red) !important;
        box-shadow: 0 0 0 3px oklch(62.8% 0.25 29.23 / 15%) !important;
    }
    .cubical-container input::placeholder {
        color: var(--sc-text-dim) !important;
        opacity: 0.6;
    }

    .nav-link-sc {
        color: var(--sc-text-dim);
        text-decoration: none;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
    }
    .nav-link-sc:hover { color: var(--alvarez-red); }

    .animate-fade-in { animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: var(--sc-border); border-radius: 10px; }

    /* ============================================================== */
    /* 📱 DISEÑO MÓVIL ESTILO PHOTOSHOP & SKETCHUP WEB (BOTTOM SHEETS) */
    /* ============================================================== */
    .bottom-action-bar {
        display: flex;
        justify-content: space-around;
        align-items: stretch;
        background: var(--sc-surface);
        border-top: 1px solid var(--sc-border);
        padding: 0;
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 40;
        box-shadow: 0 -3px 15px rgba(0,0,0,0.1);
        min-height: 60px;
    }
    .bottom-action-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        color: var(--sc-text-dim);
        font-size: 0.55rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.2s ease;
        flex: 1;
        text-align: center;
        padding: 12px 8px;
        justify-content: center;
    }
    .bottom-action-btn:hover,
    .bottom-action-btn.active {
        color: var(--alvarez-red);
    }
    .bottom-action-btn i {
        font-size: 1.1rem;
        margin-bottom: 2px;
    }

    /* Bottom Sheets Overlay */
    .bottom-sheet {
        position: absolute;
        bottom: 60px; /* Altura de la barra inferior */
        left: 0;
        right: 0;
        background: var(--sc-surface);
        border-top: 2px solid var(--alvarez-red);
        border-radius: 16px 16px 0 0;
        transform: translateY(calc(100% + 60px));
        transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.35s ease;
        z-index: 50;
        padding: 20px;
        box-shadow: 0 -10px 30px rgba(0, 0, 0, 0.15);
        max-height: 80%;
        overflow-y: auto;
        opacity: 0;
        pointer-events: none;
    }
    .bottom-sheet.active {
        transform: translateY(0);
        opacity: 1;
        pointer-events: auto;
    }
    .bottom-sheet-handle {
        width: 100%;
        height: 24px;
        margin: -10px auto 10px auto;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .bottom-sheet-handle::after {
        content: "";
        display: block;
        width: 40px;
        height: 4px;
        background: var(--sc-text-dim);
        opacity: 0.3;
        border-radius: 2px;
    }

</style>

