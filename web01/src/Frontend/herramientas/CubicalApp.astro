                // Rellenar controles Desktop
                document.getElementById('mod-name').value = m.name;
                document.getElementById('mod-type').value = m.type;
                document.getElementById('mod-h').value = m.dims.alto;
                document.getElementById('mod-w').value = m.dims.ancho;
                document.getElementById('mod-p').value = m.dims.prof;
                document.getElementById('mod-drawers').value = m.dims.n_cajones;
                document.getElementById('mod-doors').value = m.dims.n_puertas;
                document.getElementById('mod-shelves').value = m.dims.n_estantes;
                const hingeSelect = document.getElementById('mod-hinge-type');
                if (hingeSelect) hingeSelect.value = m.hingeType;
                
                // Rellenar controles Mobile
                document.getElementById('mod-name-mobile').value = m.name;
                document.getElementById('mod-type-mobile').value = m.type;
                document.getElementById('mod-h-mobile').value = m.dims.alto;
                document.getElementById('mod-w-mobile').value = m.dims.ancho;
                document.getElementById('mod-p-mobile').value = m.dims.prof;
                document.getElementById('mod-drawers-mobile').value = m.dims.n_cajones;
                document.getElementById('mod-doors-mobile').value = m.dims.n_puertas;
                document.getElementById('mod-shelves-mobile').value = m.dims.n_estantes;
