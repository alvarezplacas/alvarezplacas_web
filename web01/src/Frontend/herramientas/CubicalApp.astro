---
/**
 * CubiCal PRO - El Corazón de la Herramienta
 * Versión 1.1 - Industrialización Industrial (Modo Hueso)
 */
const { clientId } = Astro.props;
const isLoggedIn = !!clientId;
---

<div id="cubical-app-root" class="cubical-container mx-auto max-w-[1600px] px-4 py-8" data-is-logged-in={isLoggedIn}>
    <!-- BARRA SUPERIOR -->
    <header class="flex justify-between items-center mb-12 bg-[var(--sc-surface)] border border-[var(--sc-border)] p-6 rounded-lg shadow-sm">
        <div class="flex items-center gap-6">
             <a href="/" class="nav-link-sc">
                <i class="fas fa-home"></i> INICIO
            </a>
            <div style="width: 1px; height: 20px; background: var(--sc-border);"></div>
            <div>
                <div class="text-[0.6rem] font-black text-[var(--alvarez-red)] tracking-[0.2em] uppercase mb-1">CubiCal PRO v1.1</div>
                <h1 class="text-3xl font-black tracking-tighter uppercase italic text-[var(--sc-text)]">CALCULADOR <span class="text-[var(--alvarez-red)]">INDUSTRIAL</span></h1>
            </div>
        </div>
        <div class="flex gap-4 items-center">
             <div id="theme-toggle" onclick="window.cubical.toggleTheme()" class="nav-link-sc" style="cursor:pointer; color: var(--sc-text-dim);">
                <i id="theme-icon" class="fas fa-moon"></i> <span id="theme-text">MODO OSCURO</span>
            </div>
            <div style="width: 1px; height: 20px; background: var(--sc-border);"></div>
            <button id="btn-save-project" class="hidden px-6 py-2 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] rounded text-xs font-black uppercase text-[var(--sc-text)] hover:bg-[var(--sc-border)] transition-all">Guardar Proyecto</button>
            <button id="btn-goto-dashboard" onclick="window.cubical.showDashboard()" class="px-6 py-2 bg-[var(--alvarez-red)] text-white rounded text-xs font-black uppercase hover:scale-105 transition-all shadow-lg">Mis Proyectos</button>
        </div>
    </header>

    <!-- PANTALLA 1: DASHBOARD -->
    <section id="screen-dashboard" class="animate-fade-in">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="md:col-span-2">
                <h2 class="text-5xl font-black mb-4 tracking-tighter text-[var(--sc-text)]">ESTACIÓN DE TRABAJO</h2>
                <div class="w-20 h-1 bg-[var(--alvarez-red)] mb-8"></div>
                <p class="text-[var(--sc-text-dim)] mb-12 max-w-xl text-lg font-medium">Gestiona tus proyectos de mobiliario a medida y obtén el despiece optimizado para producción.</p>
                
                <div id="projects-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <!-- Dinámico -->
                    <div class="bg-[var(--sc-surface-alt)] h-40 rounded-lg animate-pulse"></div>
                    <div class="bg-[var(--sc-surface-alt)] h-40 rounded-lg animate-pulse"></div>
                </div>
            </div>
            
            <div class="bg-[var(--sc-surface)] border-2 border-dashed border-[var(--sc-border)] p-12 rounded-xl flex flex-col items-center justify-center text-center">
                <div class="w-24 h-24 bg-[var(--alvarez-red)] text-white rounded-xl flex items-center justify-center mb-8 rotate-3 shadow-xl">
                    <i class="fas fa-plus text-4xl"></i>
                </div>
                <h3 class="text-2xl font-black mb-4 text-[var(--sc-text)] uppercase tracking-tighter">¿Nuevo Mueble?</h3>
                <p class="text-[var(--sc-text-dim)] text-sm mb-10 font-medium">Calcula materiales y herrajes en segundos para tu próximo cliente.</p>
                <button onclick="window.cubical.showSetup()" class="w-full py-5 bg-[var(--alvarez-red)] text-white font-black rounded-lg hover:scale-105 transition-all uppercase tracking-widest shadow-xl">NUEVO CÁLCULO</button>
            </div>
        </div>
    </section>

    <!-- PANTALLA 2: SETUP -->
    <section id="screen-setup" class="hidden max-w-2xl mx-auto animate-fade-in">
        <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-12 rounded-xl shadow-2xl">
            <h2 class="text-3xl font-black mb-10 tracking-tight text-center uppercase text-[var(--sc-text)]">Configuración del Proyecto</h2>
            
            <div class="space-y-8">
                <div>
                    <label class="block text-[0.65rem] font-black text-[var(--sc-text-dim)] uppercase tracking-[0.2em] mb-3">Nombre del Proyecto o Cliente</label>
                    <input type="text" id="setup-name" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-5 rounded text-[var(--sc-text)] focus:border-[var(--alvarez-red)] outline-none font-bold text-lg" placeholder="Ej: Cocina Moderna - Juan Pérez">
                </div>
                
                <div>
                    <label class="block text-[0.65rem] font-black text-[var(--sc-text-dim)] uppercase tracking-[0.2em] mb-3">Tipo de Ambiente</label>
                    <select id="setup-env" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-5 rounded text-[var(--sc-text)] focus:border-[var(--alvarez-red)] outline-none font-bold">
                        <option value="cocina">🍳 Cocina / Bajo Mesada</option>
                        <option value="dormitorio">🛏️ Dormitorio / Vestidor</option>
                        <option value="oficina">🖥️ Oficina / Estudio</option>
                        <option value="living">🛋️ Living / Comedor</option>
                        <option value="baño">🚿 Baño / Vanitory</option>
                    </select>
                </div>

                <div class="pt-8 grid grid-cols-2 gap-4">
                    <button onclick="window.cubical.startConstructor()" class="py-5 bg-[var(--alvarez-red)] text-white font-black rounded-lg hover:scale-105 transition-all uppercase tracking-widest shadow-lg">CONTINUAR</button>
                    <button onclick="window.cubical.showDashboard()" class="py-5 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] text-[var(--sc-text-dim)] font-black rounded-lg hover:text-[var(--sc-text)] transition-all uppercase tracking-widest">CANCELAR</button>
                </div>
            </div>
        </div>
    </section>

    <!-- PANTALLA 3: CONSTRUCTOR -->
    <section id="screen-constructor" class="hidden animate-fade-in">
        <!-- CARTEL INFORMATIVO BETA DE ALVAREZ PLACAS -->
        <div class="w-full mb-6 bg-amber-500/10 border border-amber-500/30 rounded-xl p-5 flex items-start gap-4 shadow-sm backdrop-blur-md">
            <div class="w-10 h-10 rounded-lg bg-amber-500/20 flex items-center justify-center text-amber-500 flex-shrink-0">
                <i class="fas fa-exclamation-triangle text-lg"></i>
            </div>
            <div class="flex-grow space-y-1">
                <div class="flex items-center gap-3 flex-wrap">
                    <span class="text-[0.6rem] font-black uppercase bg-amber-500 text-black px-2 py-0.5 rounded tracking-widest">CUBICAL 3D PRO — v1.2 BETA</span>
                    <span class="text-[0.55rem] font-black text-amber-500/90 tracking-widest uppercase">Desarrollo Exclusivo de Alvarez Placas</span>
                </div>
                <p class="text-xs text-[var(--sc-text-dim)] font-medium leading-relaxed">
                    Este software se encuentra en fase de <strong>Prueba y Desarrollo</strong>. Las comprobaciones de despieces, optimizaciones de placas y cómputos de herrajes aún pueden tener variaciones o ser estimativos. Se aconseja revisar físicamente antes del corte industrial.
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- PANEL IZQUIERDO: FORMULARIO -->
            <div class="lg:col-span-4 space-y-6">
                <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-8 rounded-xl shadow-sm">
                    <h3 class="text-xs font-black text-[var(--alvarez-red)] uppercase tracking-[0.2em] mb-8 flex items-center gap-3">
                        <i class="fas fa-cubes"></i> AÑADIR MÓDULO AL PLANO
                    </h3>
                    
                    <div class="grid grid-cols-3 gap-4">
                        <div class="col-span-3">
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-2">Tipo de Módulo</label>
                            <select id="mod-type" onchange="window.cubical.autoSetPresets()" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-4 rounded text-sm font-bold">
                                <option value="CAJONERA">🗄️ Cajonera Estándar</option>
                                <option value="PLACARD">🚪 Placard / Ropero</option>
                                <option value="ALACENA">🪜 Alacena Superior</option>
                                <option value="BAJO_MESADA">🍽️ Bajo Mesada</option>
                                <option value="BIBLIOTECA">📚 Biblioteca / Estantería</option>
                                <option value="CUSTOM">⚙️ Módulo a Medida Libre</option>
                            </select>
                        </div>
                        <div>
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-2">Alto (mm)</label>
                            <input type="number" id="mod-h" value="800" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-4 rounded text-sm font-mono font-bold">
                        </div>
                        <div>
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-2">Ancho (mm)</label>
                            <input type="number" id="mod-w" value="600" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-4 rounded text-sm font-mono font-bold">
                        </div>
                        <div>
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-2">Prof. (mm)</label>
                            <input type="number" id="mod-p" value="500" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-4 rounded text-sm font-mono font-bold">
                        </div>
                        <div>
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-2">Estantes</label>
                            <input type="number" id="mod-shelves" value="0" min="0" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-4 rounded text-sm font-mono font-bold">
                        </div>
                        <div>
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-2">Cajones</label>
                            <input type="number" id="mod-drawers" value="3" min="0" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-4 rounded text-sm font-mono font-bold">
                        </div>
                        <div>
                            <label class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase block mb-2">Puertas</label>
                            <input type="number" id="mod-doors" value="0" min="0" class="w-full bg-[var(--sc-input-bg)] border border-[var(--sc-border)] p-4 rounded text-sm font-mono font-bold">
                        </div>
                    </div>
                    
                    <button onclick="window.cubical.addModule()" class="w-full mt-8 py-5 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] rounded text-xs font-black uppercase hover:bg-[var(--alvarez-red)] hover:text-white transition-all shadow-sm">AÑADIR A LA LISTA</button>
                </div>

                <div class="bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] p-6 rounded-xl">
                    <h3 class="text-xs font-black text-[var(--sc-text-dim)] uppercase tracking-widest mb-6">Módulos del Proyecto</h3>
                    <div id="module-list" class="space-y-3 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
                        <!-- Dinámico -->
                    </div>
                </div>
            </div>

            <!-- PANEL CENTRAL: VISUALIZADOR 3D INTERACTIVO -->
            <div class="lg:col-span-8 flex flex-col gap-6">
                <div class="bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] rounded-xl min-h-[500px] flex items-center justify-center relative overflow-hidden shadow-inner">
                    <div class="absolute top-8 left-10 text-[0.65rem] font-black text-[var(--sc-text-dim)] uppercase tracking-[0.5em] opacity-30">PROYECCIÓN TÉCNICA 3D (CAD BLUEPRINT)</div>
                    
                    <!-- TOOLBAR 3D INTERACTIVA CON TOOLTIPS -->
                    <div class="absolute top-6 right-6 flex items-center gap-2 bg-[var(--sc-surface)]/85 border border-[var(--sc-border)] px-3 py-2 rounded-lg shadow-lg backdrop-blur-md z-10">
                        <!-- Vista Perspectiva (Reset) -->
                        <div class="relative group">
                            <button onclick="window.cubical.reset3DView()" class="w-8 h-8 rounded bg-[var(--sc-surface-alt)] hover:bg-[var(--alvarez-red)] hover:text-white text-[var(--sc-text-dim)] flex items-center justify-center transition-all shadow-sm" style="transition: all 0.2s ease;">
                                <i class="fas fa-sync-alt text-xs"></i>
                            </button>
                            <div class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] text-[0.55rem] font-black uppercase text-[var(--sc-text)] py-1.5 px-3 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all shadow-md tracking-wider">
                                Restaurar Vista 3D
                            </div>
                        </div>
                        
                        <!-- Vista Frontal -->
                        <div class="relative group">
                            <button onclick="window.cubical.set3DView('front')" class="w-8 h-8 rounded bg-[var(--sc-surface-alt)] hover:bg-[var(--alvarez-red)] hover:text-white text-[var(--sc-text-dim)] flex items-center justify-center transition-all shadow-sm" style="transition: all 0.2s ease;">
                                <i class="fas fa-square text-xs"></i>
                            </button>
                            <div class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] text-[0.55rem] font-black uppercase text-[var(--sc-text)] py-1.5 px-3 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all shadow-md tracking-wider">
                                Vista Frontal
                            </div>
                        </div>

                        <!-- Vista Superior -->
                        <div class="relative group">
                            <button onclick="window.cubical.set3DView('top')" class="w-8 h-8 rounded bg-[var(--sc-surface-alt)] hover:bg-[var(--alvarez-red)] hover:text-white text-[var(--sc-text-dim)] flex items-center justify-center transition-all shadow-sm" style="transition: all 0.2s ease;">
                                <i class="fas fa-border-all text-xs"></i>
                            </button>
                            <div class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] text-[0.55rem] font-black uppercase text-[var(--sc-text)] py-1.5 px-3 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all shadow-md tracking-wider">
                                Vista Superior
                            </div>
                        </div>

                        <!-- Separador -->
                        <div class="w-[1px] h-6 bg-[var(--sc-border)] mx-1"></div>

                        <!-- Zoom In -->
                        <div class="relative group">
                            <button onclick="window.cubical.zoom3D(1.15)" class="w-8 h-8 rounded bg-[var(--sc-surface-alt)] hover:bg-[var(--alvarez-red)] hover:text-white text-[var(--sc-text-dim)] flex items-center justify-center transition-all shadow-sm" style="transition: all 0.2s ease;">
                                <i class="fas fa-search-plus text-xs"></i>
                            </button>
                            <div class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] text-[0.55rem] font-black uppercase text-[var(--sc-text)] py-1.5 px-3 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all shadow-md tracking-wider">
                                Acercar (+)
                            </div>
                        </div>

                        <!-- Zoom Out -->
                        <div class="relative group">
                            <button onclick="window.cubical.zoom3D(0.85)" class="w-8 h-8 rounded bg-[var(--sc-surface-alt)] hover:bg-[var(--alvarez-red)] hover:text-white text-[var(--sc-text-dim)] flex items-center justify-center transition-all shadow-sm" style="transition: all 0.2s ease;">
                                <i class="fas fa-search-minus text-xs"></i>
                            </button>
                            <div class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 bg-[var(--sc-surface-alt)] border border-[var(--sc-border)] text-[0.55rem] font-black uppercase text-[var(--sc-text)] py-1.5 px-3 rounded whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-all shadow-md tracking-wider">
                                Alejar (-)
                            </div>
                        </div>
                    </div>

                    <canvas id="canvas-preview" class="w-full h-full max-h-[600px] cursor-grab active:cursor-grabbing" style="min-height:500px; display:block;"></canvas>
                </div>
                
                <div class="flex justify-between items-center bg-[var(--sc-surface)] p-6 rounded-xl border border-[var(--sc-border)]">
                    <div class="flex gap-4">
                        <div class="bg-[var(--sc-surface-alt)] px-8 py-4 rounded-lg border border-[var(--sc-border)]">
                            <div class="text-[0.55rem] font-black text-[var(--sc-text-dim)] uppercase mb-1">Módulos Totales</div>
                            <div id="stat-total-mods" class="text-3xl font-black text-[var(--alvarez-red)]">0</div>
                        </div>
                    </div>
                    <button onclick="window.cubical.generateResults()" class="px-16 py-6 bg-[var(--alvarez-red)] text-white font-black rounded hover:scale-105 transition-all uppercase tracking-[0.2em] flex items-center gap-4">
                        OPTIMIZAR CÁLCULO <i class="fas fa-microchip"></i>
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- PANTALLA 4: RESULTADOS -->
    <section id="screen-results" class="hidden animate-fade-in">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- COLUMNA PLACAS -->
            <div class="space-y-6">
                <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-10 rounded-xl shadow-sm">
                    <h3 class="text-2xl font-black mb-8 uppercase italic text-[var(--alvarez-red)]">REPORTE DE MATERIALES</h3>
                    <div id="res-boards-stats" class="grid grid-cols-3 gap-5 mb-10">
                        <!-- Dinámico -->
                    </div>
                    <div id="res-boards-list" class="space-y-4">
                        <!-- Dinámico -->
                    </div>
                </div>
            </div>
            
            <!-- COLUMNA HERRAJES -->
            <div class="space-y-6">
                <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-10 rounded-xl shadow-sm">
                    <h3 class="text-2xl font-black mb-8 uppercase italic text-[var(--sc-text)]">LISTA DE HERRAJES</h3>
                    <table class="w-full text-sm text-left">
                        <thead class="text-[0.65rem] font-black text-[var(--sc-text-dim)] uppercase border-bottom border-[var(--sc-border)]">
                            <tr>
                                <th class="pb-6">Descripción del Insumo</th>
                                <th class="pb-6 text-right">Cant.</th>
                                <th class="pb-6 text-right">Unidad</th>
                            </tr>
                        </thead>
                        <tbody id="res-hardware-list" class="divide-y divide-[var(--sc-border)]">
                            <!-- Dinámico -->
                        </tbody>
                    </table>
                </div>
                
                <div class="flex gap-4 p-4 bg-[var(--sc-surface-alt)] rounded-xl border border-[var(--sc-border)]">
                    <button onclick="window.cubical.saveProject(true)" class="flex-1 py-6 bg-[var(--alvarez-red)] text-white font-black rounded hover:scale-105 transition-all uppercase tracking-widest shadow-xl">ENVIAR A PRODUCCIÓN</button>
                    <button onclick="window.cubical.showConstructor()" class="px-10 py-6 bg-[var(--sc-surface)] border border-[var(--sc-border)] text-[var(--sc-text)] rounded border-none font-black hover:bg-[var(--sc-surface-alt)] transition-all uppercase text-xs">RE-EDITAR PLANO</button>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    :root {
        --alvarez-red: oklch(62.8% 0.25 29.23);
        --alvarez-blue: oklch(65% 0.18 220);
        --alvarez-border: oklch(0% 0 0 / 10%);
        --sc-text: oklch(20% 0 0);
        --sc-text-dim: oklch(50% 0 0);
        --sc-surface: oklch(98% 0.01 90); /* Papel Hueso */
        --sc-surface-alt: oklch(94% 0.01 90);
        --sc-border: oklch(0% 0 0 / 8%);
        --sc-input-bg: oklch(100% 0 0);
    }
    
    [data-theme="dark"],
    .body-theme-dark,
    body.body-theme-dark {
        --sc-text: oklch(95% 0 0);
        --sc-text-dim: oklch(70% 0 0);
        --sc-surface: oklch(12% 0.01 260);
        --sc-surface-alt: oklch(18% 0.01 260);
        --sc-border: oklch(100% 0 0 / 10%);
        --sc-input-bg: oklch(5% 0 0);
        --alvarez-border: oklch(100% 0 0 / 15%);
    }

    /* 📐 AutoCAD Precisión Industrial para todos los Inputs/Selects y Colores Explícitos */
    .cubical-container input,
    .cubical-container select,
    .cubical-container textarea {
        color: var(--sc-text) !important;
        background-color: var(--sc-input-bg) !important;
        border-color: var(--sc-border) !important;
        border-radius: 4px !important;
    }
    .cubical-container input:focus,
    .cubical-container select:focus {
        border-color: var(--alvarez-red) !important;
        box-shadow: 0 0 0 3px oklch(62.8% 0.25 29.23 / 15%) !important;
    }
    .cubical-container input::placeholder {
        color: var(--sc-text-dim) !important;
        opacity: 0.6;
    }

    .nav-link-sc {
        color: var(--sc-text-dim);
        text-decoration: none;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
    }
    .nav-link-sc:hover { color: var(--alvarez-red); }

    .animate-fade-in { animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

    .hidden { display: none !important; }
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: var(--sc-border); border-radius: 10px; }
</style>

<script is:inline>
    // 🛡️ Inicialización inmediata del tema sincronizada con el Layout principal de Alvarez Placas
    (function() {
        const savedTheme = localStorage.getItem('client-theme') || localStorage.getItem('sc-theme') || 'light';
        if (savedTheme === 'dark') {
            document.body.setAttribute('data-theme', 'dark');
            document.body.classList.add('body-theme-dark');
            document.body.classList.remove('body-theme-light');
        } else {
            document.body.removeAttribute('data-theme');
            document.body.classList.add('body-theme-light');
            document.body.classList.remove('body-theme-dark');
        }
    })();

    const CLIENT_ID = "{clientId}";

    class Cabinet3DRenderer {
        constructor(canvasId) {
            this.canvas = document.getElementById(canvasId);
            this.ctx = this.canvas.getContext('2d');
            this.angleY = -0.6; // Ángulo de rotación por defecto
            this.angleX = 0.3;  // Ángulo de inclinación por defecto
            this.scale = 0.35;
            this.setupInteraction();
        }
        
        setupInteraction() {
            let isDragging = false;
            let lastX = 0, lastY = 0;
            
            const startDrag = (x, y) => {
                isDragging = true;
                lastX = x;
                lastY = y;
            };
            
            const dragMove = (x, y) => {
                if (!isDragging) return;
                const dx = x - lastX;
                const dy = y - lastY;
                this.angleY += dx * 0.007;
                this.angleX += dy * 0.007;
                this.angleX = Math.max(-Math.PI/3, Math.min(Math.PI/3, this.angleX)); // Evitar dar la vuelta
                lastX = x;
                lastY = y;
                if (window.cubical && typeof window.cubical.renderPreview === 'function') {
                    window.cubical.renderPreview();
                }
            };
            
            const stopDrag = () => { isDragging = false; };
            
            this.canvas.addEventListener('mousedown', (e) => startDrag(e.clientX, e.clientY));
            this.canvas.addEventListener('mousemove', (e) => dragMove(e.clientX, e.clientY));
            window.addEventListener('mouseup', stopDrag);
            
            this.canvas.addEventListener('touchstart', (e) => {
                if (e.touches.length === 1) {
                    startDrag(e.touches[0].clientX, e.touches[0].clientY);
                }
            });
            this.canvas.addEventListener('touchmove', (e) => {
                if (e.touches.length === 1) {
                    dragMove(e.touches[0].clientX, e.touches[0].clientY);
                }
            });
            window.addEventListener('touchend', stopDrag);
        }
        
        project(X, Y, Z, width, height, depth, screenWidth, screenHeight) {
            const cx = width / 2;
            const cy = height / 2;
            const cz = depth / 2;
            
            let px = X - cx;
            let py = Y - cy;
            let pz = Z - cz;
            
            const cosY = Math.cos(this.angleY);
            const sinY = Math.sin(this.angleY);
            const rx1 = px * cosY - pz * sinY;
            const rz1 = px * sinY + pz * cosY;
            
            const cosX = Math.cos(this.angleX);
            const sinX = Math.sin(this.angleX);
            const ry2 = py * cosX - rz1 * sinX;
            const rz2 = py * sinX + rz1 * cosX;
            
            const sx = screenWidth / 2 + rx1 * this.scale;
            const sy = screenHeight / 2 - ry2 * this.scale;
            
            return { x: sx, y: sy, z: rz2 };
        }
        
        drawBox(width, height, depth, opts = {}) {
            const {
                offsetX = 0,
                color = '#ff4d4d',
                fillColor = 'rgba(255, 77, 77, 0.05)',
                lineWidth = 2,
                drawPanelThickness = true,
                shelves = 0,
                drawers = 0,
                doors = 0
            } = opts;
            
            const sw = this.canvas.width;
            const sh = this.canvas.height;
            const ctx = this.ctx;
            const t = 18; // 18mm espesor madera
            
            const vertices = [
                {x: 0,     y: 0,      z: 0},
                {x: width, y: 0,      z: 0},
                {x: width, y: height, z: 0},
                {x: 0,     y: height, z: 0},
                {x: 0,     y: 0,      z: depth},
                {x: width, y: 0,      z: depth},
                {x: width, y: height, z: depth},
                {x: 0,     y: height, z: depth}
            ];
            
            const proj = vertices.map(v => this.project(v.x + offsetX, v.y, v.z, width, height, depth, sw, sh));
            
            const line = (p1, p2, dotted = false) => {
                ctx.beginPath();
                ctx.moveTo(p1.x, p1.y);
                ctx.lineTo(p2.x, p2.y);
                if (dotted) {
                    ctx.setLineDash([4, 4]);
                } else {
                    ctx.setLineDash([]);
                }
                ctx.stroke();
            };
            
            const fillFace = (indices, fill) => {
                ctx.beginPath();
                ctx.moveTo(proj[indices[0]].x, proj[indices[0]].y);
                for(let i = 1; i < indices.length; i++) {
                    ctx.lineTo(proj[indices[i]].x, proj[indices[i]].y);
                }
                ctx.closePath();
                ctx.fillStyle = fill;
                ctx.fill();
            };
            
            ctx.strokeStyle = color;
            ctx.lineWidth = lineWidth;
            
            // Relleno semi-transparente de las caras exteriores
            fillFace([4, 5, 6, 7], fillColor);
            fillFace([0, 1, 5, 4], fillColor);
            fillFace([2, 3, 7, 6], fillColor);
            fillFace([0, 3, 7, 4], fillColor);
            fillFace([1, 2, 6, 5], fillColor);
            
            // Dibujar estructura trasera en líneas de proyección técnica
            line(proj[4], proj[5], true);
            line(proj[5], proj[6], true);
            line(proj[6], proj[7], true);
            line(proj[7], proj[4], true);
            
            // Diagonales de profundidad
            line(proj[0], proj[4], true);
            line(proj[1], proj[5], true);
            line(proj[2], proj[6], true);
            line(proj[3], proj[7], true);
            
            // Dibujar marco frontal sólido
            fillFace([0, 1, 2, 3], 'rgba(255,255,255,0.01)');
            line(proj[0], proj[1]);
            line(proj[1], proj[2]);
            line(proj[2], proj[3]);
            line(proj[3], proj[0]);
            
            // Espesores de Carcasa 3D (CAD Style)
            if (drawPanelThickness) {
                ctx.strokeStyle = document.body.getAttribute('data-theme') === 'dark' || document.body.classList.contains('body-theme-dark')
                    ? 'rgba(255,255,255,0.15)'
                    : 'rgba(0,0,0,0.15)';
                ctx.lineWidth = 1;
                
                // Lateral izquierdo
                const lLeft = this.project(t + offsetX, 0, 0, width, height, depth, sw, sh);
                const rLeft = this.project(t + offsetX, height, 0, width, height, depth, sw, sh);
                const lLeftBack = this.project(t + offsetX, 0, depth, width, height, depth, sw, sh);
                const rLeftBack = this.project(t + offsetX, height, depth, width, height, depth, sw, sh);
                line(lLeft, rLeft, true);
                line(lLeft, lLeftBack, true);
                line(rLeft, rLeftBack, true);
                
                // Lateral derecho
                const lRight = this.project(width - t + offsetX, 0, 0, width, height, depth, sw, sh);
                const rRight = this.project(width - t + offsetX, height, 0, width, height, depth, sw, sh);
                const lRightBack = this.project(width - t + offsetX, 0, depth, width, height, depth, sw, sh);
                const rRightBack = this.project(width - t + offsetX, height, depth, width, height, depth, sw, sh);
                line(lRight, rRight, true);
                line(lRight, lRightBack, true);
                line(rRight, rRightBack, true);
            }
            
            // Estantes Regulables (Si posee contenido)
            if (shelves > 0) {
                ctx.strokeStyle = 'oklch(70% 0.15 80)'; // Color madera/estante cálido
                ctx.lineWidth = 2.5;
                
                const hSpace = (height - 36) / (shelves + 1);
                for (let i = 1; i <= shelves; i++) {
                    const currY = t + i * hSpace;
                    
                    const sfL = this.project(t + offsetX, currY, 0, width, height, depth, sw, sh);
                    const sfR = this.project(width - t + offsetX, currY, 0, width, height, depth, sw, sh);
                    const sbL = this.project(t + offsetX, currY, depth - 20, width, height, depth, sw, sh);
                    const sbR = this.project(width - t + offsetX, currY, depth - 20, width, height, depth, sw, sh);
                    
                    line(sfL, sfR);
                    line(sfL, sbL, true);
                    line(sfR, sbR, true);
                    line(sbL, sbR, true);
                }
            }
            
            // Cajoneras (Si posee contenido)
            if (drawers > 0) {
                ctx.strokeStyle = 'oklch(65% 0.18 220)'; // Color cian de cajoneras
                ctx.lineWidth = 2.5;
                
                const hSpace = height / drawers;
                for (let i = 0; i < drawers; i++) {
                    const yBottom = i * hSpace;
                    const yTop = (i + 1) * hSpace;
                    
                    // Frente de cajón
                    const fBL = this.project(3 + offsetX, yBottom + 3, 0, width, height, depth, sw, sh);
                    const fBR = this.project(width - 3 + offsetX, yBottom + 3, 0, width, height, depth, sw, sh);
                    const fTL = this.project(3 + offsetX, yTop - 3, 0, width, height, depth, sw, sh);
                    const fTR = this.project(width - 3 + offsetX, yTop - 3, 0, width, height, depth, sw, sh);
                    
                    line(fBL, fBR);
                    line(fBR, fTR);
                    line(fTR, fTL);
                    line(fTL, fBL);
                    
                    // Cuerpo de cajón interno (en proyección discontinua hacia el fondo)
                    const bBL = this.project(t + 13 + offsetX, yBottom + t, depth - 50, width, height, depth, sw, sh);
                    const bBR = this.project(width - t - 13 + offsetX, yBottom + t, depth - 50, width, height, depth, sw, sh);
                    
                    line(fBL, bBL, true);
                    line(fBR, bBR, true);
                    line(bBL, bBR, true);
                    
                    // Tirador metálico en el centro
                    const tcX = width / 2 + offsetX;
                    const tcY = yBottom + hSpace / 2;
                    const hL = this.project(tcX - 45, tcY, 0, width, height, depth, sw, sh);
                    const hR = this.project(tcX + 45, tcY, 0, width, height, depth, sw, sh);
                    ctx.strokeStyle = '#ffffff';
                    ctx.lineWidth = 3.5;
                    line(hL, hR);
                    ctx.strokeStyle = 'oklch(65% 0.18 220)';
                    ctx.lineWidth = 2.5;
                }
            }
            
            // Puertas (Si posee contenido)
            if (doors > 0) {
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.85)';
                ctx.lineWidth = 2.5;
                
                const wSpace = width / doors;
                for (let i = 0; i < doors; i++) {
                    const xLeft = i * wSpace;
                    const xRight = (i + 1) * wSpace;
                    
                    const dBL = this.project(xLeft + 3 + offsetX, 3, 0, width, height, depth, sw, sh);
                    const dBR = this.project(xRight - 3 + offsetX, 3, 0, width, height, depth, sw, sh);
                    const dTL = this.project(xLeft + 3 + offsetX, height - 3, 0, width, height, depth, sw, sh);
                    const dTR = this.project(xRight - 3 + offsetX, height - 3, 0, width, height, depth, sw, sh);
                    
                    line(dBL, dBR);
                    line(dBR, dTR);
                    line(dTR, dTL);
                    line(dTL, dBL);
                    
                    // Tiradores de perilla
                    const knobX = i === 0 ? xRight - 20 : xLeft + 20;
                    const knobY = height / 2;
                    const kp = this.project(knobX + offsetX, knobY, 0, width, height, depth, sw, sh);
                    ctx.beginPath();
                    ctx.arc(kp.x, kp.y, 4.5, 0, 2*Math.PI);
                    ctx.fillStyle = '#ffffff';
                    ctx.fill();
                }
            }
        }
    }

    const CLIENT_ID = "{clientId}";

    window.cubical = {
        state: {
            currentScreen: 'dashboard',
            projectName: '',
            environment: '',
            modules: [],
            projects: [],
            results: null
        },

        renderer: null,

        init: async function() {
            this.updateThemeUI();
            await this.loadProjects();
            
            // Inicializar renderizador 3D
            try {
                this.renderer = new Cabinet3DRenderer('canvas-preview');
            } catch (e) {
                console.error("[CubiCal] Falló inicialización del Canvas 3D:", e);
            }
            
            // Aplicar primer set de presets
            this.autoSetPresets();
            
            this.showScreen('dashboard');
        },

        toggleTheme: function() {
            const body = document.body;
            const isDark = body.getAttribute('data-theme') === 'dark' || body.classList.contains('body-theme-dark');
            if (isDark) {
                body.removeAttribute('data-theme');
                body.classList.add('body-theme-light');
                body.classList.remove('body-theme-dark');
                localStorage.setItem('client-theme', 'light');
                localStorage.setItem('sc-theme', 'light');
            } else {
                body.setAttribute('data-theme', 'dark');
                body.classList.add('body-theme-dark');
                body.classList.remove('body-theme-light');
                localStorage.setItem('client-theme', 'dark');
                localStorage.setItem('sc-theme', 'dark');
            }
            this.updateThemeUI();
            this.renderPreview();
        },

        updateThemeUI: function() {
            const isDark = document.body.getAttribute('data-theme') === 'dark' || document.body.classList.contains('body-theme-dark');
            const text = document.getElementById('theme-text');
            const icon = document.getElementById('theme-icon');
            if (text && icon) {
                text.textContent = isDark ? 'MODO CLARO' : 'MODO OSCURO';
                icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            }
        },

        loadProjects: async function() {
            try {
                const response = await fetch(`/api/herramientas/get-cubical?clientId=${CLIENT_ID}`);
                const data = await response.json();
                if (data.success) {
                    this.state.projects = data.projects;
                    this.renderDashboard();
                }
            } catch (e) {
                this.renderDashboard();
            }
        },

        reset3DView: function() {
            if (!this.renderer) return;
            this.renderer.angleY = -0.6;
            this.renderer.angleX = 0.3;
            this.renderer.scale = 0.35;
            this.renderPreview();
        },

        set3DView: function(type) {
            if (!this.renderer) return;
            if (type === 'front') {
                this.renderer.angleY = 0;
                this.renderer.angleX = 0;
            } else if (type === 'top') {
                this.renderer.angleY = 0;
                this.renderer.angleX = Math.PI / 2;
            }
            this.renderPreview();
        },

        zoom3D: function(factor) {
            if (!this.renderer) return;
            this.renderer.scale *= factor;
            this.renderer.scale = Math.max(0.1, Math.min(1.5, this.renderer.scale));
            this.renderPreview();
        },

        showScreen: function(name) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(`screen-${name}`).classList.remove('hidden');
            this.state.currentScreen = name;
            const saveBtn = document.getElementById('btn-save-project');
            if (saveBtn) saveBtn.classList.toggle('hidden', name !== 'constructor');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        },

        showSetup: function() { this.showScreen('setup'); },
        showDashboard: function() { this.showScreen('dashboard'); },
        showConstructor: function() { 
            this.showScreen('constructor'); 
            setTimeout(() => this.renderPreview(), 100);
        },

        startConstructor: function() {
            const name = document.getElementById('setup-name').value;
            if (!name) { alert("⚠️ Por favor ingresa el nombre del proyecto."); return; }
            this.state.projectName = name;
            this.state.environment = document.getElementById('setup-env').value;
            this.showScreen('constructor');
            this.renderConstructor();
            setTimeout(() => this.renderPreview(), 100);
        },

        autoSetPresets: function() {
            const type = document.getElementById('mod-type').value;
            const shelvesInput = document.getElementById('mod-shelves');
            const drawersInput = document.getElementById('mod-drawers');
            const doorsInput = document.getElementById('mod-doors');
            
            if (!shelvesInput || !drawersInput || !doorsInput) return;
            
            if (type === 'CAJONERA') {
                shelvesInput.value = 0;
                drawersInput.value = 3;
                doorsInput.value = 0;
            } else if (type === 'PLACARD') {
                shelvesInput.value = 2;
                drawersInput.value = 0;
                doorsInput.value = 2;
            } else if (type === 'ALACENA') {
                shelvesInput.value = 2;
                drawersInput.value = 0;
                doorsInput.value = 2;
            } else if (type === 'BAJO_MESADA') {
                shelvesInput.value = 0;
                drawersInput.value = 0;
                doorsInput.value = 2;
            } else if (type === 'BIBLIOTECA') {
                shelvesInput.value = 4;
                drawersInput.value = 0;
                doorsInput.value = 0;
            } else {
                // Módulo a Medida Libre
                shelvesInput.value = 0;
                drawersInput.value = 0;
                doorsInput.value = 0;
            }
        },

        addModule: function() {
            const type = document.getElementById('mod-type').value;
            const dims = {
                alto: parseInt(document.getElementById('mod-h').value) || 800,
                ancho: parseInt(document.getElementById('mod-w').value) || 600,
                prof: parseInt(document.getElementById('mod-p').value) || 500,
                n_cajones: parseInt(document.getElementById('mod-drawers').value) || 0,
                n_puertas: parseInt(document.getElementById('mod-doors').value) || 0,
                n_estantes: parseInt(document.getElementById('mod-shelves').value) || 0
            };
            this.state.modules.push({ id: Date.now(), type, dims });
            this.renderConstructor();
        },

        removeModule: function(id) {
            this.state.modules = this.state.modules.filter(m => m.id !== id);
            this.renderConstructor();
        },

        renderConstructor: function() {
            const list = document.getElementById('module-list');
            list.innerHTML = this.state.modules.length === 0 
                ? '<div class="text-center py-8 text-[var(--sc-text-dim)] font-bold text-[0.6rem] uppercase opacity-40">Sin módulos añadidos</div>'
                : this.state.modules.map(m => `
                <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-5 rounded-lg flex justify-between items-center group hover:border-[var(--alvarez-red)] transition-all">
                    <div>
                        <div class="text-[0.6rem] font-black text-[var(--alvarez-red)] uppercase">${m.type.replace('_',' ')}</div>
                        <div class="text-sm font-black text-[var(--sc-text)]">${m.dims.alto}x${m.dims.ancho}x${m.dims.prof} <span class="text-[0.6rem] font-normal text-[var(--sc-text-dim)]">mm</span></div>
                        <div class="text-[0.6rem] text-[var(--sc-text-dim)] font-bold mt-1">
                            ${m.dims.n_estantes > 0 ? `Estantes: ${m.dims.n_estantes} ` : ''}
                            ${m.dims.n_cajones > 0 ? `Cajones: ${m.dims.n_cajones} ` : ''}
                            ${m.dims.n_puertas > 0 ? `Puertas: ${m.dims.n_puertas} ` : ''}
                            ${(m.dims.n_estantes == 0 && m.dims.n_cajones == 0 && m.dims.n_puertas == 0) ? 'Módulo Vacío (Sin contenido)' : ''}
                        </div>
                    </div>
                    <button onclick="window.cubical.removeModule(${m.id})" class="w-10 h-10 bg-[var(--sc-surface-alt)] rounded flex items-center justify-center text-[var(--sc-text-dim)] hover:bg-[var(--alvarez-red)] hover:text-white transition-all shadow-sm">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </div>
            `).join('');
            
            document.getElementById('stat-total-mods').textContent = this.state.modules.length;
            this.renderPreview();
        },

        renderPreview: function() {
            if (!this.renderer) return;
            const canvas = document.getElementById('canvas-preview');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const rect = canvas.parentNode.getBoundingClientRect();
            
            canvas.width = rect.width || 800;
            canvas.height = 500;
            
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            const isDark = document.body.getAttribute('data-theme') === 'dark' || document.body.classList.contains('body-theme-dark');
            
            // Grilla de plano CAD en background
            ctx.strokeStyle = isDark ? 'rgba(255,255,255,0.03)' : 'rgba(0,0,0,0.03)';
            ctx.lineWidth = 1;
            const step = 20;
            for (let x = 0; x < canvas.width; x += step) {
                ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); ctx.stroke();
            }
            for (let y = 0; y < canvas.height; y += step) {
                ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(canvas.width, y); ctx.stroke();
            }
            
            const count = this.state.modules.length;
            if (count === 0) {
                this.renderer.scale = 0.22;
                this.renderer.drawBox(600, 800, 500, {
                    color: isDark ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0,0,0,0.1)',
                    fillColor: 'rgba(0, 0, 0, 0)',
                    lineWidth: 1.5,
                    drawPanelThickness: false
                });
                
                ctx.fillStyle = isDark ? 'rgba(255,255,255,0.3)' : 'rgba(0,0,0,0.3)';
                ctx.font = 'bold 11px monospace';
                ctx.textAlign = 'center';
                ctx.fillText("VISTA 3D EN TIEMPO REAL — ARRASTRA CON EL MOUSE PARA ROTAR", canvas.width/2, canvas.height/2 + 250);
                return;
            }
            
            const spacing = 120;
            const totalWidth = this.state.modules.reduce((sum, m) => sum + m.dims.ancho, 0) + (count - 1) * spacing;
            const maxHeight = this.state.modules.reduce((max, m) => Math.max(max, m.dims.alto), 0);
            
            const scaleX = (canvas.width * 0.7) / totalWidth;
            const scaleY = (canvas.height * 0.6) / maxHeight;
            this.renderer.scale = Math.min(0.28, Math.min(scaleX, scaleY));
            
            let currentX = -totalWidth / 2;
            
            this.state.modules.forEach((m) => {
                const boxColor = isDark ? 'oklch(62.8% 0.25 29.23)' : '#000000';
                const boxFill = isDark ? 'rgba(215, 40, 40, 0.03)' : 'rgba(0, 0, 0, 0.01)';
                
                this.renderer.drawBox(m.dims.ancho, m.dims.alto, m.dims.prof, {
                    offsetX: currentX,
                    color: boxColor,
                    fillColor: boxFill,
                    lineWidth: 2,
                    drawPanelThickness: true,
                    shelves: m.dims.n_estantes || 0,
                    drawers: m.dims.n_cajones || 0,
                    doors: m.dims.n_puertas || 0
                });
                
                // Etiquetas de medidas en 3D
                const labelPos = this.renderer.project(currentX + m.dims.ancho/2, -45, 0, m.dims.ancho, m.dims.alto, m.dims.prof, canvas.width, canvas.height);
                ctx.fillStyle = isDark ? 'rgba(255,255,255,0.4)' : 'rgba(0,0,0,0.6)';
                ctx.font = 'bold 9px monospace';
                ctx.textAlign = 'center';
                ctx.fillText(`${m.dims.ancho}x${m.dims.alto}x${m.dims.prof} mm`, labelPos.x, labelPos.y);
                
                currentX += m.dims.ancho + spacing;
            });
        },

        generateResults: async function() {
            if (this.state.modules.length === 0) { alert("⚠️ Añade al menos un módulo al plano."); return; }
            this.showScreen('results');
            
            try {
                // Importación dinámica de motores puros
                const optEngine = await import('/herramientas/logic/cubical/engine.js?v=' + Date.now());
                const hwEngine = await import('/herramientas/logic/cubical/hardware.js?v=' + Date.now());
                
                let allPieces = [];
                this.state.modules.forEach(m => {
                    const pieces = optEngine.calculateModulePieces(m.type, m.dims, 18);
                    allPieces = allPieces.concat(pieces);
                });
                
                // Filtrar fondos de MDF para la optimización de placas de melamina de 18mm
                const melaminaPieces = allPieces.filter(p => !p.isBackground).map(p => ({
                    name: p.name,
                    h: p.h,
                    w: p.w,
                    qty: p.qty
                }));
                
                // Faplac estándar 18mm 2750x1820
                const board = { w: 2750, h: 1820 };
                const optResults = optEngine.optimizeBoards(melaminaPieces, board, 4);
                
                // Calcular herrajes e insumos
                const realHardware = hwEngine.calculateTotalHardware(this.state.modules);
                
                this.state.results = {
                    opt: optResults,
                    hw: realHardware
                };
                
                this.renderResults();
            } catch (e) {
                console.error("[CubiCal] Error ejecutando optimización industrial:", e);
                alert("⚠️ Error al optimizar el despiece. Asegúrate de que las medidas ingresadas sean válidas.");
            }
        },

        renderResults: function() {
            const { opt, hw } = this.state.results;
            
            // Stats principales
            document.getElementById('res-boards-stats').innerHTML = `
                <div class="bg-[var(--sc-surface-alt)] p-6 rounded-lg border border-[var(--sc-border)] shadow-inner">
                    <div class="text-[0.55rem] font-black text-[var(--sc-text-dim)] uppercase mb-2">PLACAS (18mm)</div>
                    <div class="text-3xl font-black text-[var(--alvarez-red)]">${opt.stats.count}</div>
                </div>
                <div class="bg-[var(--sc-surface-alt)] p-6 rounded-lg border border-[var(--sc-border)] shadow-inner">
                    <div class="text-[0.55rem] font-black text-[var(--sc-text-dim)] uppercase mb-2">EFICIENCIA</div>
                    <div class="text-3xl font-black text-[var(--sc-text)]">${opt.stats.efficiency}%</div>
                </div>
                <div class="bg-[var(--sc-surface-alt)] p-6 rounded-lg border border-[var(--sc-border)] shadow-inner">
                    <div class="text-[0.55rem] font-black text-[var(--sc-text-dim)] uppercase mb-2">M2 TOTAL</div>
                    <div class="text-3xl font-black text-[var(--alvarez-blue)]">${opt.stats.totalM2}</div>
                </div>
            `;
            
            // Lista desglosada de placas optimizadas
            document.getElementById('res-boards-list').innerHTML = opt.boards.map(b => {
                return `
                    <div class="bg-[var(--sc-surface-alt)] p-5 rounded-lg border border-[var(--sc-border)] flex justify-between items-center group">
                        <div>
                            <div class="text-xs font-black text-[var(--sc-text)] uppercase">Placa Entera Faplac #${b.id}</div>
                            <div class="text-[0.65rem] text-[var(--sc-text-dim)] font-bold mt-1">Dimensión: 2750 x 1820 mm • ${b.shelves.length} Fila(s) de corte agrupado</div>
                        </div>
                        <div class="text-right">
                            <span class="text-[0.55rem] font-black bg-[var(--sc-surface)] border border-[var(--sc-border)] text-[var(--sc-text-dim)] px-2.5 py-1.5 rounded uppercase tracking-wider">Optimizado</span>
                        </div>
                    </div>
                `;
            }).join('');
            
            // Listado de herrajes comerciales
            document.getElementById('res-hardware-list').innerHTML = hw.map(h => `
                <tr class="group hover:bg-[var(--sc-surface-alt)] transition-all">
                    <td class="py-5 font-bold text-[var(--sc-text)] uppercase text-xs tracking-tight">${h.name}</td>
                    <td class="py-5 text-right font-black text-[var(--alvarez-red)] text-lg">${h.qty}</td>
                    <td class="py-5 text-right text-[var(--sc-text-dim)] text-[0.6rem] font-black uppercase tracking-widest">${h.unit}</td>
                </tr>
            `).join('');
        },

        renderDashboard: function() {
            const grid = document.getElementById('projects-grid');
            if (this.state.projects.length === 0) {
                grid.innerHTML = '<div class="col-span-2 py-20 text-center border-2 border-dashed border-[var(--sc-border)] rounded-xl text-[var(--sc-text-dim)] font-black uppercase tracking-[0.3em] opacity-30">No hay registros previos</div>';
                return;
            }
            grid.innerHTML = this.state.projects.map(p => `
                <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-8 rounded-xl hover:border-[var(--alvarez-red)] transition-all cursor-pointer group shadow-sm">
                    <div class="flex justify-between mb-6">
                        <div class="w-12 h-12 bg-[var(--sc-surface-alt)] rounded-lg flex items-center justify-center text-[var(--alvarez-red)] group-hover:bg-[var(--alvarez-red)] group-hover:text-white transition-all shadow-sm">
                            <i class="fas fa-folder-open text-xl"></i>
                        </div>
                        <span class="text-[0.55rem] font-black bg-[var(--sc-surface-alt)] px-3 py-1.5 rounded text-[var(--sc-text-dim)] uppercase tracking-widest border border-[var(--sc-border)]">${p.status || 'FINALIZADO'}</span>
                    </div>
                    <h4 class="text-xl font-black text-[var(--sc-text)] uppercase tracking-tighter mb-2">${p.nombre_proyecto}</h4>
                    <div class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase tracking-widest">${p.tipo_ambiente || 'PERSONALIZADO'} • ${p.total_m2_placa || '0.0'} M2</div>
                </div>
            `).join('');
        },

        saveProject: async function(isQuote = false) {
            const payload = {
                clientId: CLIENT_ID,
                name: this.state.projectName,
                env: this.state.environment,
                modules: this.state.modules,
                results: this.state.results,
                isQuote
            };
            try {
                const response = await fetch('/api/herramientas/save-cubical', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const res = await response.json();
                if (res.success) {
                    alert(isQuote ? "🚀 SOLICITUD ENVIADA. Un asesor técnico revisará tu despiece." : "💾 PROYECTO GUARDADO CORRECTAMENTE.");
                    this.loadProjects();
                    this.showScreen('dashboard');
                }
            } catch (e) {
                alert("⚠️ Error de conexión con el servidor.");
            }
        }
    };

    // Iniciar
    document.addEventListener('astro:page-load', () => window.cubical.init());
    window.cubical.init();
</script>
