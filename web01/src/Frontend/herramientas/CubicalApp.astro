                    if (m.type === 'BAJO_MESADA') {
                        assemblyHTML += `<li><strong>Zócalo:</strong> Fija el zócalo base retranqueado para permitir el espacio de los pies (kicktoe).</li>`;
                    }
                }
                assemblyHTML += `</ul></div>`;
            });
            
            document.getElementById('res-assembly-guide').innerHTML = assemblyHTML;
        },

        renderDashboard: function() {
            const grid = document.getElementById('projects-grid');
            if (this.state.projects.length === 0) {
                grid.innerHTML = '<div class="col-span-2 py-20 text-center border-2 border-dashed border-[var(--sc-border)] rounded-xl text-[var(--sc-text-dim)] font-black uppercase tracking-[0.3em] opacity-30">No hay registros previos</div>';
                return;
            }
            grid.innerHTML = this.state.projects.map(p => `
                <div class="bg-[var(--sc-surface)] border border-[var(--sc-border)] p-8 rounded-xl hover:border-[var(--alvarez-red)] transition-all cursor-pointer group shadow-sm">
                    <div class="flex justify-between mb-6">
                        <div class="w-12 h-12 bg-[var(--sc-surface-alt)] rounded-lg flex items-center justify-center text-[var(--alvarez-red)] group-hover:bg-[var(--alvarez-red)] group-hover:text-white transition-all shadow-sm">
                            <i class="fas fa-folder-open text-xl"></i>
                        </div>
                        <span class="text-[0.55rem] font-black bg-[var(--sc-surface-alt)] px-3 py-1.5 rounded text-[var(--sc-text-dim)] uppercase tracking-widest border border-[var(--sc-border)]">${p.status || 'FINALIZADO'}</span>
                    </div>
                    <h4 class="text-xl font-black text-[var(--sc-text)] uppercase tracking-tighter mb-2">${p.nombre_proyecto}</h4>
                    <div class="text-[0.6rem] font-black text-[var(--sc-text-dim)] uppercase tracking-widest">${p.tipo_ambiente || 'PERSONALIZADO'} • ${p.total_m2_placa || '0.0'} M2</div>
                </div>
            `).join('');
        },

        saveProject: async function(isQuote = false) {
            const payload = {
                clientId: CLIENT_ID,
                name: this.state.projectName,
                env: this.state.environment,
                modules: this.state.modules,
                results: this.state.results,
                isQuote
            };
            try {
                const response = await fetch('/api/herramientas/save-cubical', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const res = await response.json();
                if (res.success) {
                    alert(isQuote ? "🚀 SOLICITUD ENVIADA. Un asesor técnico revisará tu despiece." : "💾 PROYECTO GUARDADO CORRECTAMENTE.");
                    this.loadProjects();
                    this.showScreen('dashboard');
                }
            } catch (e) {
                alert("⚠️ Error de conexión con el servidor.");
            }
        }
    };

    // Iniciar
    document.addEventListener('astro:page-load', () => window.cubical.init());
    window.cubical.init();
</script>

