---
/**
 * Quienes Somos - Página de historia y equipo.
 * Diseño Split 50/50 con scroll independiente y slideshow.
 */
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import { directus, readItems } from '@conexiones/directus';

const FOLDER_ID = 'b11e9dc3-8cdb-49d6-ad2f-8d231ce0a528';
let images = [];

try {
    // Aplicamos el filtro correcto para que SOLO traiga archivos de esa carpeta específica
    const response = await fetch(`https://admin.alvarezplacas.com.ar/files?filter[folder][_eq]=${FOLDER_ID}&fields=id,type&sort=uploaded_on`);
    const { data: files } = await response.json();
    
    if (files && files.length > 0) {
        images = files.map(file => ({
            url: `https://admin.alvarezplacas.com.ar/assets/${file.id}`,
            type: file.type
        }));
    } else {
        throw new Error('No files found in folder');
    }
} catch (e) {
    console.warn('[Quienes Somos] Usando imágenes de respaldo:', e.message);
    images = [
        { url: '/images/quienes-somos/workshop.png', type: 'image/png' },
        { url: '/images/quienes-somos/team.png', type: 'image/png' },
        { url: '/images/quienes-somos/detail.png', type: 'image/png' }
    ];
}
---

<Layout title="Quienes Somos | Alvarez Placas" description="Conoce nuestra historia, equipo y el compromiso que nos impulsa a ser líderes en la industria del mueble.">
    <Header />
    
    <div class="split-container">
        <!-- Media Side (Left) -->
        <div class="media-side">
            <div class="slideshow">
                {images.map((media, i) => (
                    media.type.includes('video') ? (
                        <video class={`slide slide-${i}`} autoplay muted loop playsinline style={`object-fit: cover; width: 100%; height: 100%; animation-duration: ${images.length * 6}s; animation-delay: ${i * 6}s;`}>
                            <source src={media.url} type={media.type} />
                        </video>
                    ) : (
                        <div class={`slide slide-${i}`} style={`background-image: url('${media.url}'); animation-duration: ${images.length * 6}s; animation-delay: ${i * 6}s;`}></div>
                    )
                ))}
                <div class="overlay"></div>
                <div class="media-content">
                    <span class="badge">DESDE 2018</span>
                    <h2>Nuestra Pasión <br/> <span class="text-alvarez-red">en cada corte.</span></h2>
                </div>
            </div>
        </div>

        <!-- Content Side (Right) -->
        <div class="content-side">
            <div class="text-content">
                <section class="section-block">
                    <h1>Quienes <span class="text-alvarez-red">Somos</span></h1>
                    <div class="divider"></div>
                </section>

                <section class="section-block">
                    <h3 class="industrial-title">Historia</h3>
                    <p>Nuestra historia comenzó el <strong>1 de Mayo de 2018</strong> en Av. Camargo, partido de Hurlingham, donde con dedicación y perseverancia iniciamos un sueño. Hemos cultivado relaciones sólidas con nuestros proveedores y clientes, lo que nos ha permitido crecer y expandirnos.</p>
                </section>

                <section class="section-block">
                    <h3 class="industrial-title">Nuestro Compromiso</h3>
                    <p>En <strong>Álvarez Placas</strong>, nos comprometemos a ofrecer productos y servicios de la más alta calidad, priorizando la satisfacción y las necesidades de nuestros clientes.</p>
                    <p>Ubicados ahora en Mariano Bradley y Av. Gobernador Vergara, Ciudad Tesei, Hurlingham, ofrecemos una amplia gama de servicios y productos, acompañados de una atención personalizada que garantiza soluciones integrales para el desarrollo de proyectos en la industria del mueble y la decoración.</p>
                </section>

                <section class="section-block">
                    <h3 class="industrial-title">Valores</h3>
                    <p>Valoramos la creatividad, la innovación y la capacidad de adaptación como pilares fundamentales en nuestro trabajo. Nos esforzamos por mantener una comunicación abierta, siempre dispuestos a escuchar sugerencias y críticas constructivas que nos permitan mejorar continuamente.</p>
                </section>

                <section class="section-block">
                    <div class="highlight-box">
                        <h3 class="industrial-title">Equipo</h3>
                        <p>Nuestro equipo está integrado por profesionales apasionados y comprometidos, cuyo <strong>principal objetivo es superar las expectativas de nuestros clientes</strong>. Nos enorgullece contar con un grupo de jóvenes emprendedores que aportan frescura y dinamismo a nuestra empresa.</p>
                    </div>
                </section>

                <section class="section-block">
                    <h3 class="industrial-title">Misión y Visión</h3>
                    <p>Nuestra misión es proporcionar soluciones innovadoras y de calidad que impulsen el crecimiento y la excelencia en la industria del mueble y la decoración.</p>
                    <p><strong>Nos visualizamos como líderes reconocidos a nivel Local y Provincial</strong>, siendo un referente de confianza y calidad para nuestros clientes y colaboradores.</p>
                    <p>En Alvarez Placas, estamos comprometidos con la excelencia, la integridad y el servicio al cliente. <strong>¡Déjanos ser tu socio en el éxito de tus proyectos!</strong></p>
                </section>

                <footer class="contact-footer">
                    <div class="contact-item">
                        <i class="fab fa-whatsapp"></i>
                        <span>1161411842</span>
                    </div>
                    <div class="contact-item">
                        <i class="far fa-envelope"></i>
                        <span>info@alvarezplacas.com.ar</span>
                    </div>
                </footer>
            </div>
        </div>
    </div>
</Layout>

<style>
    :root {
        --alvarez-red: #ff2800;
        --glass-bg: rgba(255, 255, 255, 0.03);
        --border-color: rgba(255, 255, 255, 0.1);
    }

    .split-container {
        display: flex;
        height: 100vh;
        overflow: hidden;
        background: #050505;
    }

    /* Media Side */
    .media-side {
        width: 50%;
        position: relative;
        overflow: hidden;
    }

    .slideshow {
        width: 100%;
        height: 100%;
        position: relative;
    }

    .slide {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background-size: cover;
        background-position: center;
        opacity: 0;
        animation: slideTransition linear infinite;
    }


    @keyframes slideTransition {
        0% { opacity: 0; transform: scale(1.1); }
        5% { opacity: 1; }
        33% { opacity: 1; }
        38% { opacity: 0; transform: scale(1); }
        100% { opacity: 0; }
    }

    .overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, rgba(0,0,0,0.6), rgba(0,0,0,0.2), transparent);
        z-index: 5;
    }

    .media-content {
        position: absolute;
        bottom: 10%;
        left: 10%;
        z-index: 10;
        color: white;
    }

    .badge {
        background: var(--alvarez-red);
        font-size: 0.6rem;
        font-weight: 900;
        padding: 4px 10px;
        border-radius: 4px;
        letter-spacing: 2px;
    }

    .media-content h2 {
        font-size: 4rem;
        font-weight: 900;
        line-height: 0.9;
        margin-top: 15px;
        letter-spacing: -2px;
    }

    .text-alvarez-red { color: var(--alvarez-red); }

    /* Content Side */
    .content-side {
        width: 50%;
        overflow-y: auto;
        padding: 100px 80px;
        scroll-behavior: smooth;
        scrollbar-width: thin;
        scrollbar-color: var(--alvarez-red) transparent;
    }

    .text-content {
        max-width: 600px;
    }

    .section-block {
        margin-bottom: 60px;
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .section-block:nth-child(1) { animation-delay: 0.1s; }
    .section-block:nth-child(2) { animation-delay: 0.2s; }
    .section-block:nth-child(3) { animation-delay: 0.3s; }
    .section-block:nth-child(4) { animation-delay: 0.4s; }
    .section-block:nth-child(5) { animation-delay: 0.5s; }
    .section-block:nth-child(6) { animation-delay: 0.6s; }

    h1 {
        font-size: 5rem;
        font-weight: 900;
        letter-spacing: -4px;
        line-height: 0.8;
        margin-bottom: 20px;
    }

    .divider {
        width: 80px;
        height: 6px;
        background: var(--alvarez-red);
        margin-bottom: 40px;
    }

    .industrial-title {
        font-size: 0.75rem;
        font-weight: 900;
        color: #444;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .industrial-title::after {
        content: '';
        flex-grow: 1;
        height: 1px;
        background: var(--border-color);
    }

    p {
        font-size: 1.1rem;
        line-height: 1.8;
        color: #aaa;
        margin-bottom: 25px;
    }

    p strong {
        color: white;
    }

    .highlight-box {
        background: var(--glass-bg);
        border: 1px solid var(--border-color);
        padding: 40px;
        border-radius: 20px;
    }

    .contact-footer {
        margin-top: 80px;
        padding-top: 40px;
        border-top: 1px solid var(--border-color);
        display: flex;
        gap: 40px;
    }

    .contact-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.9rem;
        color: #666;
    }

    .contact-item i {
        color: var(--alvarez-red);
    }

    /* Mobile Adaptivity */
    @media (max-width: 900px) {
        .split-container {
            flex-direction: column;
            height: auto;
            overflow: visible;
        }

        .media-side {
            width: 100%;
            height: 40vh;
        }

        .media-content h2 {
            font-size: 2.5rem;
        }

        .content-side {
            width: 100%;
            padding: 60px 30px;
        }

        h1 {
            font-size: 3.5rem;
        }
    }
</style>
