---
/**
 * CubiCal PRO - Pagina Maestra
 * Solo accesible para clientes registrados.
 */
import MainLayout from '@layouts/MainLayout.astro';
import CubicalApp from '../../Frontend/herramientas/CubicalApp.astro';

// 🔐 AUTH GUARD (Permite clientes, vendedores y administradores)
const hasClient = Astro.cookies.has('client_session');
const hasSeller = Astro.cookies.has('seller_session');
const hasAdmin = Astro.cookies.has('admin_session');

const isLoggedIn = hasClient || hasSeller || hasAdmin;
if (!isLoggedIn) {
    return Astro.redirect('/login?from=/herramientas/cubical');
}

const clientId = parseInt(Astro.cookies.get('client_session')?.value || Astro.cookies.get('seller_session')?.value || Astro.cookies.get('admin_session')?.value || '0');
---

<MainLayout title="CubiCal PRO - Calculadora de Muebles | Alvarez Placas">
    <main class="bg-[var(--sc-surface-alt)] min-h-screen pt-20">
        <CubicalApp clientId={clientId} />
    </main>
</MainLayout>

<style is:global>
    :root {
        --alvarez-red: oklch(62.8% 0.25 29.23);
        --alvarez-green: oklch(70% 0.15 140);
        --alvarez-blue: oklch(65% 0.18 220);
        --glass-bg: oklch(100% 0 0 / 4%);
        --alvarez-border: oklch(100% 0 0 / 8%);
    }

    body {
        background-color: var(--sc-surface-alt) !important;
        color: var(--sc-text) !important;
        transition: background-color 0.3s ease, color 0.3s ease;
    }
</style>
