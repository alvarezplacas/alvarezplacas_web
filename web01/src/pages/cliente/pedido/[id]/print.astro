---
import { directus, readItem } from '@conexiones/directus.js';

const { id } = Astro.params;
const clientId = Astro.cookies.get('client_session')?.value;
const isSeller = Astro.cookies.has('seller_session');
const isAdmin = Astro.cookies.has('admin_session');

if (!clientId && !isSeller && !isAdmin) return Astro.redirect('/login');

let pedido = null;
try {
    pedido = await directus.request(readItem('pedidos', id, {
        fields: ['*', 'datos_optimizacion']
    }));

    // Seguridad: verificar que el pedido sea del cliente, a menos que sea staff (vendedor o admin)
    if (pedido.cliente_id != clientId && !isSeller && !isAdmin) {
        return Astro.redirect('/cliente');
    }
} catch (e) {
    return Astro.redirect(isSeller ? '/vendedor' : isAdmin ? '/admin' : '/cliente');
}

const data = pedido.datos_optimizacion;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Reporte Industrial #{pedido.id} | Alvarez Placas</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&family=JetBrains+Mono:wght@700&display=swap');
        
        :root {
            --alvarez-red: #ff2800;
            --font-mono: 'JetBrains Mono', monospace;
        }

        body { 
            background: white; 
            color: black; 
            font-family: 'Inter', sans-serif; 
            margin: 0; 
            padding: 40px; 
        }

        .print-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 2px solid #000;
            padding-bottom: 20px;
            margin-bottom: 40px;
        }

        .logo-area h1 { font-weight: 900; font-size: 1.5rem; margin: 0; }
        .logo-area span { color: var(--alvarez-red); }

        .order-info { text-align: right; }
        .order-info h2 { font-weight: 900; margin: 0; text-transform: uppercase; font-size: 1.2rem; }
        .order-info p { margin: 5px 0; font-size: 0.8rem; color: #666; font-weight: 700; }

        .project-section { margin-bottom: 60px; page-break-inside: avoid; }
        .project-title { 
            background: #f4f4f4; 
            padding: 10px 20px; 
            font-weight: 900; 
            text-transform: uppercase; 
            font-size: 0.9rem; 
            border-left: 4px solid var(--alvarez-red);
            margin-bottom: 20px;
        }

        .plate-view-wrap { margin-bottom: 40px; border: 1px solid #eee; border-radius: 8px; overflow: hidden; }
        .plate-header-industrial { background: #fafafa; padding: 10px 20px; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; }
        .plate-title { font-weight: 900; font-size: 0.8rem; }
        .plate-subtitle { font-size: 0.7rem; color: #999; font-weight: 700; }

        .industrial-canvas { display: block; margin: 10px auto; border: 1px solid #ccc; background: #fff; max-width: 100%; }

        .industrial-stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; padding: 15px 20px; background: #fff; border-top: 1px solid #eee; }
        .stat-main span { display: block; font-size: 0.6rem; color: #999; font-weight: 800; text-transform: uppercase; }
        .stat-main strong { font-size: 1rem; font-family: var(--font-mono); }

        .edge-stat { display: flex; justify-content: space-between; font-size: 0.7rem; padding: 4px 0; border-bottom: 1px dotted #eee; }
        .edge-stat strong { color: var(--alvarez-red); }

        .btn-print {
            position: fixed;
            bottom: 40px;
            right: 40px;
            background: black;
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 50px;
            font-weight: 900;
            cursor: pointer;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            gap: 10px;
            text-transform: uppercase;
            font-size: 0.8rem;
        }

        @media print {
            .btn-print { display: none; }
            body { padding: 0; }
            .plate-view-wrap { border: 1px solid #ddd; }
        }
    </style>
</head>
<body>

    <header class="print-header">
        <div class="logo-area">
            <h1>ALVAREZ <span>PLACAS</span></h1>
            <p style="font-size: 0.6rem; font-weight: 800; letter-spacing: 2px;">INDUSTRIAL SOLUTIONS</p>
        </div>
        <div class="order-info">
            <h2>REPORTE DE CORTE #${pedido.id}</h2>
            <p>FECHA: ${new Date(pedido.fecha_pedido).toLocaleDateString('es-AR')}</p>
            <p>ESTADO: ${pedido.status.toUpperCase()}</p>
            <p style="color: var(--alvarez-red); font-weight: 900; font-size: 0.85rem; margin-top: 5px; text-transform: uppercase;">
                ENTREGA SOLICITADA: ${data?.fecha_entrega_requerida ? new Date(data.fecha_entrega_requerida).toLocaleDateString('es-AR') : 'A CONFIRMAR'}
            </p>
        </div>
    </header>

    <div id="render-target"></div>

    <button onclick="window.print()" class="btn-print">
        <i class="fas fa-print"></i> Imprimir Reporte
    </button>

    <script is:inline define:vars={{ data }}>
        async function init() {
            const opt = await import('/herramientas/logic/core/optimizer.js');
            const vis = await import('/herramientas/logic/core/visualizer.js');
            
            const container = document.getElementById('render-target');
            
            data.projects.forEach((proj, pIdx) => {
                const section = document.createElement('div');
                section.className = 'project-section';
                section.innerHTML = `
                    <div class="project-title">PROYECTO: ${proj.design} (${proj.brand})</div>
                    <div id="project-plates-${pIdx}"></div>
                `;
                container.appendChild(section);
                
                const visualizer = new vis.SmartCutVisualizer(`project-plates-${pIdx}`);
                
                // Configuración del motor (usamos la guardada o default industrial)
                const engine = new opt.SmartCutEngine({ 
                    kerf: 4, 
                    trim: 5, 
                    edgeWaste: 18, 
                    mode: 'MIXED',
                    steps: 1200 
                });

                // Resolucion de dimensiones según marca del material
                const BRANDS = { 
                    'EGGER': { w: 2600, h: 1830 }, 
                    'FAPLAC': { w: 2750, h: 1830 }, 
                    'SADEPAN': { w: 2820, h: 1830 }, 
                    'NOVA': { w: 3660, h: 1830 },
                    'MASISA': { w: 2600, h: 1830 },
                    'ARAUCO': { w: 2600, h: 1830 },
                    'FIBROPLUS': { w: 2600, h: 1830 },
                    'OSB': { w: 2440, h: 1220 }
                };
                
                const brandConfig = BRANDS[String(proj.brand).toUpperCase().trim()] || { w: 2750, h: 1830 };
                const plateWidth = brandConfig.w;
                const plateHeight = brandConfig.h;

                // Recalcular el resultado para renderizar
                if (proj.pieces && proj.pieces.length > 0) {
                    const result = engine.optimize(plateWidth, plateHeight, proj.pieces);
                    
                    // Override visualizer para impresión (Blanco/Negro)
                    visualizer.drawPlate = function(ctx, plate, pw, ph) {
                        ctx.save();
                        ctx.scale(this.scale, this.scale);
                        ctx.fillStyle = '#ffffff';
                        ctx.fillRect(0, 0, pw, ph);
                        ctx.strokeStyle = '#eee';
                        ctx.strokeRect(0,0,pw,ph);
                        plate.strips.forEach(strip => {
                            strip.items.forEach(item => this.drawItem(ctx, item));
                        });
                        ctx.restore();
                    };

                    visualizer.drawItem = function(ctx, item) {
                        ctx.fillStyle = '#f8f9fa';
                        ctx.strokeStyle = '#333';
                        ctx.lineWidth = 1;
                        ctx.beginPath();
                        ctx.roundRect(item.x, item.y, item.l, item.h, 2);
                        ctx.fill();
                        ctx.stroke();

                        if (item.edges) {
                            ctx.save();
                            ctx.lineWidth = 2 / this.scale;
                            const drawE = (x1, y1, x2, y2) => {
                                ctx.strokeStyle = '#ff2800'; 
                                ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x2, y2); ctx.stroke();
                            };
                            if (item.edges.t) drawE(item.x, item.y, item.x + item.l, item.y);
                            if (item.edges.b) drawE(item.x, item.y + item.h, item.x + item.l, item.y + item.h);
                            if (item.edges.l) drawE(item.x, item.y, item.x, item.y + item.h);
                            if (item.edges.r) drawE(item.x + item.l, item.y, item.x + item.l, item.y + item.h);
                            ctx.restore();
                        }

                        const fontSize = 11 / this.scale;
                        ctx.fillStyle = '#000';
                        ctx.font = `bold ${fontSize}px Inter`;
                        ctx.textAlign = 'center';
                        if (item.l > 25/this.scale) {
                            ctx.fillText(`${Math.round(item.nominalL)}x${Math.round(item.nominalH)}`, item.x + item.l/2, item.y + item.h/2);
                        }
                    };

                    visualizer.render(result, plateWidth, plateHeight);
                }
            });
        }
        init();
    </script>
</body>
</html>
