{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "@backend/*": ["Backend/*"],
      "@frontend/*": ["Frontend/*"],
      "@conexiones/*": ["Backend/conexiones/*"],
      "@home/*": ["Frontend/home/*"],
      "@catalogo/*": ["Frontend/catalogo/*"],
      "@herramientas/*": ["Frontend/herramientas/*"],
      "@dashboard/*": ["Backend/dashboard/*"],
      "@components/*": ["Frontend/shared/components/*"]
    }
  }
}
