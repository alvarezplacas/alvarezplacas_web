---
/**
 * Layout - Contenedor principal del sitio.
 * Propiedad del Agente 3 (Frontend/Home).
 */
import { ClientRouter } from 'astro:transitions';
import BottomNav from '../components/BottomNav.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { 
	title, 
	description = "Alvarez Placas - La mejor calidad en cortes de melamina y soluciones para el mueble." 
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		
		<!-- Font Awesome -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

		<!-- Analytics -->
		<script defer src="https://stats.javiermix.ar/script.js" data-website-id="d70f2548-e4c6-4aa9-bd21-00b8d3e93995"></script>
		<ClientRouter />
	</head>
	<body class="bg-jet-black text-white font-sans antialiased pb-20 md:pb-0 min-h-screen flex flex-col">
		<main class="flex-grow">
			<slot />
		</main>
        <Footer />
        <BottomNav />
	</body>
</html>

<style is:global>
	html { scroll-behavior: smooth; }
	body { margin: 0; padding: 0; }
</style>
