---
/**
 * Presupuestador - Página de envío de cortes.
 * Propiedad del Agente 5 (Frontend/Herramientas).
 */
import Layout from '../../home/layouts/Layout.astro';
import Header from '../../home/components/Header.astro';
import BudgetEngine from '../components/BudgetEngine.astro';
---

<Layout title="Presupuestador Libre - Alvarezplacas">
    <Header />
    <div class="max-w-6xl mx-auto px-4 py-8 relative">
        <header class="mb-12 text-center">
            <h1 class="text-4xl md:text-5xl font-black text-white mb-4 tracking-tight">
                PRESUPUESTO <span class="text-primary">RÁPIDO</span>
            </h1>
            <p class="text-gray-400 max-w-2xl mx-auto">
                Obtén un cálculo aproximado instantáneo y envíalo a nuestros vendedores.
            </p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2">
                <BudgetEngine />
            </div>
            <div class="bg-[#1a1a1a] border border-gray-800 rounded-2xl p-6 h-fit">
                <h3 class="text-lg font-bold text-white mb-4">Instrucciones</h3>
                <ul class="space-y-3 text-sm text-gray-400">
                    <li>1. Elige el material.</li>
                    <li>2. Ingresa medidas en mm.</li>
                    <li>3. Indica tapacantos.</li>
                </ul>
            </div>
        </div>
    </div>
</Layout>
