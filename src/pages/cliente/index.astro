---
import '@styles/global.css';
import BottomNav from '@components/BottomNav.astro';
import { query } from '@lib/db.js';

const { title = "Mi Cuenta | Alvarez Placas" } = Astro.props;

// In a real app, we get the user ID from the session cookie
const userCookie = Astro.cookies.get('client_session')?.value;
// MOCK: For demonstration, if no cookie, we'll try to find the first client
let userId = userCookie ? parseInt(userCookie) : null;

// Fetch Client Data
const clientResult = await query(`
    SELECT u.*, s.full_name as seller_name, s.phone as seller_phone
    FROM users u
    LEFT JOIN users s ON u.assigned_seller_id = s.id
    WHERE u.id = $1 OR ($1 IS NULL AND u.role = 'client')
    LIMIT 1
`, [userId]);

const cliente = clientResult.rows[0] || {
    full_name: "Invitado",
    points: 0,
    client_number: "ALV-XXXX",
    seller_name: "No asignado",
    seller_phone: ""
};

// Fetch Orders
const ordersResult = await query(`
    SELECT * FROM orders WHERE user_id = $1 ORDER BY created_at DESC
`, [cliente.id]);

const pedidos = ordersResult.rows;
---
<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="bg-[#111111] text-gray-200 font-sans antialiased pb-20 md:pb-0">

    <header class="bg-[#1a1a1a] border-b border-gray-800 sticky top-0 z-50">
        <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
            <a href="/" class="text-xl font-bold tracking-tight text-white">
                ALVAREZ<span class="text-primary">PLACAS</span>
            </a>
            <div class="flex items-center gap-3">
                <div class="px-3 py-1 bg-white/5 rounded-lg border border-white/10 text-xs text-gray-400">
                    ID: {cliente.client_number}
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-5xl mx-auto p-4 sm:p-6 lg:p-8 space-y-6">

        <div class="bg-gradient-to-br from-primary/10 via-[#1a1a1a] to-[#111111] border border-white/10 rounded-2xl p-6 relative overflow-hidden shadow-lg">
            <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">Hola, {cliente.full_name.split(' ')[0]}</h1>
                    <p class="text-gray-400">Bienvenido a tu panel exclusivo profesional.</p>
                </div>
                
                <div class="bg-black/40 border border-white/10 rounded-xl p-4 flex items-center gap-4 shrink-0">
                    <div class="w-14 h-14 rounded-full bg-primary/20 text-primary flex items-center justify-center text-2xl">
                        <i class="fas fa-star"></i>
                    </div>
                    <div>
                        <p class="text-xs text-gray-400 font-semibold uppercase">Puntos Acumulados</p>
                        <p class="text-3xl font-extrabold text-white">{cliente.points}</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
            <!-- Vendedor Asignado -->
            <div class="bg-white/5 border border-white/10 rounded-2xl p-6 flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full bg-blue-500/20 text-blue-400 flex items-center justify-center text-xl">
                        <i class="fas fa-headset"></i>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase font-bold">Vendedor Asignado</p>
                        <h3 class="text-white font-bold">{cliente.seller_name}</h3>
                    </div>
                </div>
                <a href={`https://wa.me/549${cliente.seller_phone}`} class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition-colors">
                    <i class="fab fa-whatsapp"></i> Chat Directo
                </a>
            </div>

            <!-- Acceso Rápido/Herramientas -->
            <div class="bg-white/5 border border-white/10 rounded-2xl p-6 flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full bg-primary/20 text-primary flex items-center justify-center text-xl">
                        <i class="fas fa-calculator"></i>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase font-bold">Nueva Cotización</p>
                        <h3 class="text-white font-bold">Presupuestador</h3>
                    </div>
                </div>
                <a href="/presupuestador" class="bg-primary hover:bg-primary-dark text-white px-4 py-2 rounded-lg text-sm font-bold transition-colors">
                    Empezar
                </a>
            </div>

            <!-- Budgeter PRO (NUEVO) -->
            <div class="bg-gradient-to-br from-[#1a1a1a] to-black border border-white/10 rounded-2xl p-6 flex items-center justify-between group">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full bg-amber-500/20 text-amber-500 flex items-center justify-center text-xl group-hover:bg-amber-500/30 transition-all">
                        <i class="fas fa-file-signature"></i>
                    </div>
                    <div>
                        <p class="text-[10px] text-amber-500 uppercase font-black tracking-widest leading-none mb-1">Herramienta PRO</p>
                        <h3 class="text-white font-bold">Generador de Presupuestos</h3>
                        <p class="text-[10px] text-gray-500">Crea presupuestos para tus clientes</p>
                    </div>
                </div>
                <a href="/cliente/presupuestador-pro" class="bg-white/5 hover:bg-white/10 text-white px-4 py-2 rounded-lg text-sm font-bold border border-white/10 transition-colors">
                    Abrir
                </a>
            </div>
        </div>

        <!-- Informe Financiero -->
        <div class="bg-white/5 border border-white/10 rounded-2xl overflow-hidden mt-6">
            <div class="p-6 border-b border-white/5 flex items-center justify-between">
                <h2 class="text-xl font-bold text-white flex items-center gap-3">
                    <i class="fas fa-file-invoice-dollar text-primary"></i> Informe Financiero
                </h2>
                <span class="text-[10px] text-gray-500 uppercase font-bold tracking-widest">Actualizado hoy</span>
            </div>
            <div class="p-8 grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
                <!-- Semaforo -->
                <div class="flex flex-col items-center">
                    <div class="flex gap-2">
                        <div class={`w-4 h-4 rounded-full shadow-[0_0_15px_rgba(34,197,94,0.3)] ${cliente.fin_status === 'clean' ? 'bg-green-500 animate-pulse' : 'bg-gray-800'}`}></div>
                        <div class={`w-4 h-4 rounded-full shadow-[0_0_15px_rgba(234,179,8,0.3)] ${cliente.fin_status === 'partial' ? 'bg-yellow-500 animate-pulse' : 'bg-gray-800'}`}></div>
                        <div class={`w-4 h-4 rounded-full shadow-[0_0_15px_rgba(239,68,68,0.3)] ${cliente.fin_status === 'debt' ? 'bg-red-500 animate-pulse' : 'bg-gray-800'}`}></div>
                    </div>
                    <p class={`text-sm font-black uppercase tracking-tighter mt-4 ${
                        cliente.fin_status === 'clean' ? 'text-green-500' : 
                        cliente.fin_status === 'partial' ? 'text-yellow-500' : 'text-red-500'
                    }`}>
                        {cliente.fin_status === 'clean' ? 'Cuenta al Día' : 
                         cliente.fin_status === 'partial' ? 'Pago Parcial Pendiente' : 'Pendiente de Pago'}
                    </p>
                </div>

                <!-- Monto y Vencimiento -->
                <div class="md:col-span-2 border-t md:border-t-0 md:border-l border-white/10 pt-6 md:pt-0 md:pl-8 space-y-4">
                    <div class="flex justify-between items-end">
                        <div>
                            <p class="text-xs text-gray-500 uppercase font-black tracking-widest mb-1">Saldo a Pagar</p>
                            <p class={`text-4xl font-extrabold tracking-tighter ${cliente.debt_amount > 0 ? 'text-white' : 'text-gray-600'}`}>
                                ${Number(cliente.debt_amount || 0).toLocaleString()}
                            </p>
                        </div>
                        {cliente.due_date && (
                            <div class="text-right">
                                <p class="text-xs text-gray-500 uppercase font-black tracking-widest mb-1">Vencimiento</p>
                                <p class="text-amber-500 font-bold">{new Date(cliente.due_date).toLocaleDateString()}</p>
                            </div>
                        )}
                    </div>
                    
                    {cliente.fin_status !== 'clean' && (
                        <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-4 flex items-center gap-4">
                            <i class="fas fa-exclamation-triangle text-red-500"></i>
                            <p class="text-xs text-red-200/80 leading-relaxed font-medium">
                                Esta cuenta ha sido confirmada por tu vendedor. Por favor, regulariza tu situación antes de la fecha límite para evitar interrupciones en el servicio.
                            </p>
                        </div>
                    )}
                </div>
            </div>
        </div>

        <!-- Pedidos Recientes -->
        <h2 class="text-xl font-bold text-white mt-10 mb-4">Seguimiento de mis Pedidos</h2>
        
        {pedidos.length > 0 ? (
            <div class="bg-[#1a1a1a] border border-gray-800 rounded-xl overflow-hidden shadow-lg">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-white/5 text-gray-400 text-xs uppercase font-bold">
                                <th class="px-6 py-4">Fecha</th>
                                <th class="px-6 py-4">Código / Tracking</th>
                                <th class="px-6 py-4">Total</th>
                                <th class="px-6 py-4 text-center">Estado</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            {pedidos.map(p => (
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="px-6 py-4 text-sm">{new Date(p.created_at).toLocaleDateString()}</td>
                                    <td class="px-6 py-4 text-sm font-mono text-primary">{p.tracking_code || '---'}</td>
                                    <td class="px-6 py-4 text-sm font-bold ">${p.total_amount}</td>
                                    <td class="px-6 py-4 text-center">
                                        <span class={`px-3 py-1 rounded-full text-[10px] font-bold uppercase ${
                                            p.status === 'pending' ? 'bg-yellow-500/10 text-yellow-500' :
                                            p.status === 'processing' ? 'bg-blue-500/10 text-blue-500' :
                                            p.status === 'cut' ? 'bg-purple-500/10 text-purple-500' :
                                            'bg-green-500/10 text-green-500'
                                        }`}>
                                            {p.status}
                                        </span>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
        ) : (
            <div class="bg-[#1a1a1a] border border-dashed border-gray-800 rounded-xl p-12 text-center text-gray-500">
                <i class="fas fa-box-open text-4xl mb-4 opacity-20"></i>
                <p>Aún no tienes pedidos registrados.</p>
            </div>
        )}

        <!-- Account Settings / Delete -->
        <div class="pt-20 border-t border-white/5 flex flex-col items-center">
            <button class="text-gray-600 hover:text-red-500 text-xs transition-colors flex items-center gap-2" id="deleteAccount">
                <i class="fas fa-trash-alt"></i> Eliminar mi cuenta y datos personales
            </button>
        </div>

    </main>

    <BottomNav />

    <script is:inline>
        document.getElementById('deleteAccount').addEventListener('click', async () => {
            if (confirm('¿Estás seguro que deseas eliminar tu cuenta? Esta acción no se puede deshacer y perderás todos tus puntos acumulados.')) {
                const res = await fetch('/api/cliente/delete-account', { method: 'POST' });
                if (res.ok) {
                    alert('Cuenta eliminada con éxito.');
                    window.location.href = '/';
                } else {
                    alert('Error al intentar eliminar la cuenta.');
                }
            }
        });
    </script>
</body>
</html>
