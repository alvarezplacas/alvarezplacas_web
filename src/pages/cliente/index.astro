---
import '../../styles/global.css';

const { title = "Mi Cuenta | Alvarez Placas" } = Astro.props;

// Mock data del Cliente (Sesión activa)
const cliente = {
    nombre: "Carpintería Los Álamos",
    puntos: 12,
    pedidosMes: 3,
    diasInactivo: 15,
};

// Pedidos Mock
const pedidos = [
    { id: "PED-1025", fecha: "25 Feb 2026", estado: "En Proceso", total: "$125,000", items: "3 Placas + Cortes" },
    { id: "PED-0980", fecha: "10 Feb 2026", estado: "Entregado", total: "$85,000", items: "2 Placas Faplac" },
    { id: "PED-0850", fecha: "02 Ene 2026", estado: "Entregado", total: "$210,000", items: "5 Placas + Tapacantos + Envío" },
];
---
<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <!-- Google Fonts & FontAwesome -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="bg-[#111111] text-gray-200 font-sans antialiased pb-20 md:pb-0">

    <!-- Header Móvil/App-like -->
    <header class="bg-[#1a1a1a] border-b border-gray-800 sticky top-0 z-50">
        <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
            <a href="/" class="text-xl font-bold tracking-tight text-white">
                ALVAREZ<span class="text-primary">PLACAS</span>
            </a>
            <div class="flex items-center gap-3">
                <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 border border-primary/30 mr-2">
                    <span class="text-primary font-bold">{cliente.puntos}</span>
                    <i class="fas fa-star text-yellow-500 text-xs"></i>
                </div>
                <!-- Avatar -->
                <div class="w-9 h-9 rounded-full bg-gray-700 flex items-center justify-center font-bold text-white shadow-[0_0_10px_rgba(255,255,255,0.1)]">
                    {cliente.nombre.charAt(0)}
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-5xl mx-auto p-4 sm:p-6 lg:p-8 space-y-6">

        <!-- Welcome Banner con SCORING -->
        <div class="bg-gradient-to-br from-primary/20 via-[#1a1a1a] to-[#111111] border border-primary/30 rounded-2xl p-6 relative overflow-hidden shadow-lg">
            <div class="absolute right-0 top-0 w-32 h-32 bg-primary/20 blur-[50px] pointer-events-none"></div>
            
            <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">¡Hola, {cliente.nombre}! 👋</h1>
                    <p class="text-gray-400">Gracias por elegirnos. Aquí puedes gestionar todos tus proyectos.</p>
                </div>
                
                <div class="bg-black/40 backdrop-blur-sm border border-gray-700 rounded-xl p-4 flex items-center gap-4 shrink-0">
                    <div class="w-14 h-14 rounded-full bg-gradient-to-tr from-yellow-600 to-yellow-400 flex items-center justify-center text-white text-2xl shadow-[0_0_15px_rgba(234,179,8,0.4)]">
                        <i class="fas fa-star"></i>
                    </div>
                    <div>
                        <p class="text-sm text-gray-400 font-semibold uppercase">Tus Puntos</p>
                        <p class="text-3xl font-extrabold text-white">{cliente.puntos}</p>
                    </div>
                </div>
            </div>
            
            <!-- Barra de inactividad (Progress Bar) -->
            <div class="relative z-10 mt-6 pt-6 border-t border-white/10">
                <div class="flex justify-between items-end mb-2">
                    <p class="text-sm font-medium text-gray-300">Actividad de la cuenta (90 días max.)</p>
                    <p class="text-xs text-green-400 font-bold"><i class="fas fa-check-circle"></i> Cuenta Segura</p>
                </div>
                <!-- Progress visual (15/90 dias inactivo -> aprox 16% consumido) -->
                <div class="w-full h-2 bg-gray-800 rounded-full overflow-hidden">
                    <div class="h-full bg-green-500 rounded-full" style="width: 84%"></div>
                </div>
                <p class="text-xs text-gray-500 mt-2">Último pedido hace {cliente.diasInactivo} días. Mantente por debajo de los 90 días para conservar tus {cliente.puntos} puntos y participar de los sorteos.</p>
            </div>
        </div>

        <!-- Botones de Herramientas Rápidas -->
        <h2 class="text-xl font-bold text-white mt-8 mb-4">Herramientas Digitales</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            
            <a href="/herramientas/optimizador" class="bg-[#1a1a1a] border border-gray-800 hover:border-primary/50 transition-colors rounded-xl p-5 flex flex-col items-center justify-center text-center group cursor-pointer h-full">
                <div class="w-14 h-14 rounded-full bg-blue-500/10 text-blue-500 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 group-hover:bg-blue-500/20 transition-all">
                    <i class="fas fa-cut"></i>
                </div>
                <h3 class="font-bold text-white mb-1">Optimizador de Corte</h3>
                <p class="text-xs text-gray-400">Ingresá tus medidas y armá tu pedido completo al instante.</p>
            </a>

            <a href="/herramientas/match-board" class="bg-[#1a1a1a] border border-gray-800 hover:border-primary/50 transition-colors rounded-xl p-5 flex flex-col items-center justify-center text-center group cursor-pointer h-full">
                <div class="w-14 h-14 rounded-full bg-purple-500/10 text-purple-400 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 group-hover:bg-purple-500/20 transition-all">
                    <i class="fas fa-layer-group"></i>
                </div>
                <h3 class="font-bold text-white mb-1">Match-Board</h3>
                <p class="text-xs text-gray-400">Creá un PDF premium de combinaciones para enviarle a tu cliente.</p>
            </a>

            <a href="/herramientas/calculadora" class="bg-[#1a1a1a] border border-gray-800 hover:border-primary/50 transition-colors rounded-xl p-5 flex flex-col items-center justify-center text-center group cursor-pointer h-full">
                <div class="w-14 h-14 rounded-full bg-green-500/10 text-green-500 flex items-center justify-center text-2xl mb-4 group-hover:scale-110 group-hover:bg-green-500/20 transition-all">
                    <i class="fas fa-calculator"></i>
                </div>
                <h3 class="font-bold text-white mb-1">Calculadora Cúbica</h3>
                <p class="text-xs text-gray-400">Calculá cuántas placas precisás al 85% de eficiencia.</p>
            </a>
        </div>

        <!-- Tabla de "Mis Pedidos" -->
        <h2 class="text-xl font-bold text-white mt-10 mb-4">Mis Pedidos Recientes (Tracking)</h2>
        <div class="bg-[#1a1a1a] border border-gray-800 rounded-xl overflow-hidden shadow-lg">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-black/40 border-b border-gray-800 text-xs uppercase tracking-wider text-gray-500">
                            <th class="p-4 font-semibold">ID / Fecha</th>
                            <th class="p-4 font-semibold">Detalle del Pedido</th>
                            <th class="p-4 font-semibold text-center">Estado</th>
                            <th class="p-4 font-semibold text-right">Total</th>
                            <th class="p-4 font-semibold text-right">Acción</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-800/50">
                        {pedidos.map(p => (
                            <tr class="hover:bg-white/5 transition-colors group">
                                <td class="p-4">
                                    <p class="text-white font-bold">{p.id}</p>
                                    <p class="text-xs text-gray-500 mt-0.5">{p.fecha}</p>
                                </td>
                                <td class="p-4 text-sm text-gray-300">
                                    {p.items}
                                </td>
                                <td class="p-4 text-center">
                                    {p.estado === 'En Proceso' ? (
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-yellow-500/10 text-yellow-500 border border-yellow-500/20">
                                            <i class="fas fa-cog fa-spin"></i> {p.estado}
                                        </span>
                                    ) : (
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-green-500/10 text-green-500 border border-green-500/20">
                                            <i class="fas fa-check"></i> {p.estado}
                                        </span>
                                    )}
                                </td>
                                <td class="p-4 text-right text-white font-bold">
                                    {p.total}
                                </td>
                                <td class="p-4 text-right">
                                    <button class="w-8 h-8 rounded bg-gray-800 hover:bg-primary text-gray-300 hover:text-white inline-flex items-center justify-center transition-colors">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
            <div class="p-4 border-t border-gray-800 text-center">
                <a href="#" class="text-sm font-semibold text-primary hover:text-primary-light transition-colors">
                    Ver Historial Completo
                </a>
            </div>
        </div>

    </main>

    <!-- Mobile Bottom App Nav (Igual que en vista pública) -->
    <nav class="md:hidden fixed bottom-0 w-full z-[100] bg-black/90 backdrop-blur-lg border-t border-white/10 pb-[env(safe-area-inset-bottom)]">
        <div class="flex justify-around items-center h-16 px-2 text-[10px] font-semibold uppercase tracking-wider">
            <a href="/" class="flex flex-col items-center justify-center w-full h-full text-gray-400 hover:text-white">
                <i class="fas fa-home text-xl mb-1"></i> Inicio
            </a>
            <a href="/catalogo" class="flex flex-col items-center justify-center w-full h-full text-gray-400 hover:text-white relative">
                <div class="absolute -top-3 bg-[#1a1a1a] border border-gray-700 w-12 h-12 rounded-full flex items-center justify-center shadow-lg">
                    <i class="fas fa-search text-gray-400 text-lg"></i>
                </div>
                <span class="mt-6">Catálogo</span>
            </a>
            <a href="/cliente" class="flex flex-col items-center justify-center w-full h-full text-primary relative">
                <i class="fas fa-user text-xl mb-1"></i> Perfil
            </a>
        </div>
    </nav>
</body>
</html>
