---
import '@styles/global.css';
import { createDirectus, rest, readItems, readItem } from '@directus/sdk';

const getEnv = () => {
    if (typeof import.meta !== 'undefined' && (import.meta as any).env) return (import.meta as any).env;
    return process.env;
};

const env = getEnv();
const DIRECTUS_URL = env.DIRECTUS_URL || 'https://admin.alvarezplacas.com.ar';
const directus = createDirectus(DIRECTUS_URL).with(rest());

const { title = "Mi Cuenta | Alvarez Placas" } = Astro.props;

// Strict session check
const userCookie = Astro.cookies.get('client_session')?.value;
if (!userCookie) {
    return Astro.redirect('/login');
}

// En Directus, el ID suele ser UUID o ID incremental. Asumimos el cookie es el ID.
const userId = userCookie;

let cliente = null;
let pedidos = [];

try {
    // Buscar cliente por ID en Directus
    // Asumimos relación con vendedores se llama 'vendedor_asignado' (m2o)
    cliente = await directus.request(readItem('clientes', userId, {
        fields: ['*', { vendedor_asignado: ['Nombre', 'Whatsapp'] }]
    } as any));

    // Buscar pedidos del cliente
    pedidos = await directus.request(readItems('pedidos', {
        filter: { cliente_id: { _eq: userId } },
        sort: ['-fecha_pedido']
    } as any));

} catch (e) {
    console.error('Error fetching client from Directus:', e);
}

// If session is invalid or user not found, clear and redirect
if (!cliente) {
    Astro.cookies.delete('client_session', { path: '/' });
    return Astro.redirect('/login');
}

// Map Directus fields to template compatibility
const templateData = {
    ...cliente,
    seller_name: cliente.vendedor_asignado?.Nombre || 'Sin asignar',
    seller_phone: cliente.vendedor_asignado?.Whatsapp || '',
    full_name: cliente.nombre_empresa || cliente.nombre,
    points: cliente.puntaje || 0,
    debt_amount: cliente.debt_amount || 0,
    fin_status: cliente.fin_status || 'clean',
    client_number: cliente.id
};

const processedPedidos = (pedidos || []).map((p: any) => ({
    ...p,
    created_at: p.fecha_pedido,
    total_amount: p.total,
    tracking_code: p.tracking_id,
    status: p.status
}));
---
<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="bg-[#0a0a0a] text-gray-200 font-sans antialiased pb-20 md:pb-0">

    <div class="flex min-h-screen">
        <!-- Sidebar - Only visible on MD+ -->
        <aside class="hidden md:flex flex-col w-72 bg-[#141414] border-r border-white/5 sticky top-0 h-screen">
            <div class="p-8 border-b border-white/5">
                <a href="/" class="text-xl font-black tracking-tighter text-white">
                    ALVAREZ<span class="text-primary font-bold">PLACAS</span>
                </a>
            </div>

            <nav class="flex-grow p-4 space-y-1 overflow-y-auto">
                <div class="px-4 py-2 text-[10px] font-black text-gray-500 uppercase tracking-widest">General</div>
                <a href="/cliente" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-primary text-white font-bold transition-all shadow-lg shadow-primary/20">
                    <i class="fas fa-th-large"></i> Mi Resumen
                </a>

                <div class="px-4 py-2 mt-6 text-[10px] font-black text-gray-500 uppercase tracking-widest">Herramientas Exclusive</div>
                <p class="px-4 text-[10px] text-gray-600 mb-2 leading-tight">
                    Beneficio exclusivo para nuestros clientes registrados.
                </p>
                
                <a href="/presupuestador" class="flex items-center justify-between px-4 py-3 rounded-xl hover:bg-white/5 text-gray-400 hover:text-white transition-all group">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-paper-plane"></i> Envío de Cortes
                    </div>
                    <i class="fas fa-chevron-right text-[8px] opacity-0 group-hover:opacity-100 transition-all"></i>
                </a>

                <a href="/cliente/creador-presupuestos" class="flex items-center justify-between px-4 py-3 rounded-xl hover:bg-white/5 text-gray-400 hover:text-white transition-all group">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-file-pdf"></i> Creador de Presupuestos
                    </div>
                    <i class="fas fa-chevron-right text-[8px] opacity-0 group-hover:opacity-100 transition-all"></i>
                </a>

                <a href="/herramientas/calculadora" class="flex items-center justify-between px-4 py-3 rounded-xl hover:bg-white/5 text-gray-400 hover:text-white transition-all group">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-cube"></i> Calculadora Cúbica
                    </div>
                    <i class="fas fa-chevron-right text-[8px] opacity-0 group-hover:opacity-100 transition-all"></i>
                </a>

                <div class="flex items-center justify-between px-4 py-3 rounded-xl text-gray-600 cursor-not-allowed">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-palette"></i> Match Color
                    </div>
                    <span class="text-[8px] bg-white/5 px-2 py-0.5 rounded uppercase">Próximamente</span>
                </div>

                <div class="flex items-center justify-between px-4 py-3 rounded-xl text-gray-600 cursor-not-allowed">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-layer-group"></i> Optimizador de Corte
                    </div>
                    <span class="text-[8px] bg-white/5 px-2 py-0.5 rounded uppercase">Próximamente</span>
                </div>

                <div class="px-4 py-2 mt-6 text-[10px] font-black text-gray-500 uppercase tracking-widest">Soporte</div>
                <a href={`https://wa.me/549${templateData.seller_phone}`} target="_blank" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-white/5 text-gray-400 hover:text-white transition-all">
                    <i class="fab fa-whatsapp"></i> Mi Vendedor
                </a>
                
                <div class="mt-auto pt-6">
                    <a href="/api/auth/logout" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-red-500/10 text-gray-500 hover:text-red-500 transition-all text-sm">
                        <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
                    </a>
                </div>
            </nav>

            <div class="p-6 bg-black/20 border-t border-white/5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold uppercase">
                        {templateData.full_name?.charAt(0)}
                    </div>
                    <div class="overflow-hidden">
                        <p class="text-xs font-bold text-white truncate">{templateData.full_name}</p>
                        <p class="text-[10px] text-gray-500 truncate lowercase">{templateData.email}</p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-grow">
            <!-- Mobile Header -->
            <header class="md:hidden bg-[#141414] border-b border-white/5 px-6 h-16 flex items-center justify-between sticky top-0 z-50">
                <a href="/" class="text-lg font-black tracking-tighter text-white">
                    ALVAREZ<span class="text-primary">PLACAS</span>
                </a>
                <div class="px-3 py-1 bg-white/5 rounded-lg border border-white/10 text-[10px] text-gray-500">
                    ID: {templateData.client_number}
                </div>
            </header>

            <div class="p-4 sm:p-8 lg:p-12 max-w-6xl mx-auto space-y-8">
                
                <!-- Welcome Banner -->
                <section class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <div class="lg:col-span-2 bg-gradient-to-br from-primary/10 via-[#1a1a1a] to-[#111111] border border-white/5 rounded-[2.5rem] p-8 sm:p-10 relative overflow-hidden shadow-2xl">
                        <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/20 rounded-full blur-[100px] pointer-events-none"></div>
                        <div class="relative z-10">
                            <h1 class="text-3xl sm:text-4xl font-black text-white mb-4 tracking-tight">
                                ¡Hola, {templateData.full_name?.split(' ')[0]}!
                            </h1>
                            <p class="text-gray-400 text-lg max-w-md leading-relaxed">
                                Bienvenido a tu panel exclusivo. Aquí podrás gestionar tus pedidos, puntos y usar nuestras herramientas profesionales.
                            </p>
                        </div>
                    </div>

                    <div class="bg-[#1a1a1a] border border-white/5 rounded-[2.5rem] p-8 flex flex-col justify-center items-center text-center shadow-xl">
                        <div class="w-20 h-20 rounded-3xl bg-primary/20 text-primary flex items-center justify-center text-3xl mb-4 transform rotate-3 shadow-lg shadow-primary/10">
                            <i class="fas fa-award"></i>
                        </div>
                        <p class="text-xs text-gray-500 font-black uppercase tracking-[0.2em] mb-1">Puntos Alvarez</p>
                        <p class="text-5xl font-black text-white tracking-tighter">{templateData.points}</p>
                    </div>
                </section>

                <!-- Herramientas Grid (Strategic for Mobile) -->
                <section class="space-y-4">
                    <div class="flex items-center justify-between px-2">
                        <h2 class="text-lg font-black text-white uppercase tracking-tighter flex items-center gap-3">
                            Mis Herramientas <span class="text-[10px] text-gray-500 font-normal normal-case">Exclusivo Clientes</span>
                        </h2>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                        <!-- Envío de Cortes (Ex Presupuestador) -->
                        <a href="/presupuestador" class="bg-[#141414] border border-white/5 p-6 rounded-[2rem] flex flex-col items-center text-center hover:bg-white/5 transition-all group shadow-xl">
                            <div class="w-12 h-12 rounded-2xl bg-primary/10 text-primary flex items-center justify-center text-xl mb-3 group-hover:scale-110 transition-transform">
                                <i class="fas fa-paper-plane"></i>
                            </div>
                            <span class="text-[10px] font-bold text-white uppercase tracking-tighter leading-tight">Envío de<br/>Cortes</span>
                        </a>

                        <!-- Creador de Presupuestos (PDF Tool) -->
                        <a href="/cliente/creador-presupuestos" class="bg-[#141414] border border-white/5 p-6 rounded-[2rem] flex flex-col items-center text-center hover:bg-white/5 transition-all group shadow-xl relative overflow-hidden">
                            <div class="absolute inset-0 bg-blue-500/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <div class="w-12 h-12 rounded-2xl bg-blue-500/10 text-blue-500 flex items-center justify-center text-xl mb-3 group-hover:scale-110 transition-transform relative z-10">
                                <i class="fas fa-file-pdf"></i>
                            </div>
                            <span class="text-[10px] font-bold text-white uppercase tracking-tighter leading-tight relative z-10">Creador de<br/>Presupuestos</span>
                        </a>

                        <!-- Calculadora Cúbica -->
                        <a href="/herramientas/calculadora" class="bg-[#141414] border border-white/5 p-6 rounded-[2rem] flex flex-col items-center text-center hover:bg-white/5 transition-all group shadow-xl">
                            <div class="w-12 h-12 rounded-2xl bg-green-500/10 text-green-500 flex items-center justify-center text-xl mb-3 group-hover:scale-110 transition-transform">
                                <i class="fas fa-cube"></i>
                            </div>
                            <span class="text-[10px] font-bold text-white uppercase tracking-tighter leading-tight">Calculadora<br/>Cúbica</span>
                        </a>

                        <div class="bg-[#141414] border border-white/5 p-6 rounded-[2rem] flex flex-col items-center text-center opacity-30 cursor-not-allowed shadow-xl relative overflow-hidden group">
                            <div class="w-12 h-12 rounded-2xl bg-gray-500/10 text-gray-500 flex items-center justify-center text-xl mb-3">
                                <i class="fas fa-palette"></i>
                            </div>
                            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-tighter">Match <br/>Color</span>
                        </div>

                        <div class="bg-[#141414] border border-white/5 p-6 rounded-[2rem] flex flex-col items-center text-center opacity-30 cursor-not-allowed shadow-xl relative overflow-hidden group">
                            <div class="w-12 h-12 rounded-2xl bg-gray-500/10 text-gray-500 flex items-center justify-center text-xl mb-3">
                                <i class="fas fa-layer-group"></i>
                            </div>
                            <span class="text-[10px] font-bold text-gray-500 uppercase tracking-tighter">Optimizador <br/>de Corte</span>
                        </div>
                    </div>
                </section>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Informe Financiero -->
                    <div class="bg-[#141414] border border-white/5 rounded-[2.5rem] p-8 space-y-6">
                        <div class="flex items-center justify-between">
                            <h2 class="text-lg font-bold text-white uppercase tracking-tighter">Situación Financiera</h2>
                            <div class="flex gap-1.5">
                                <div class={`w-2.5 h-2.5 rounded-full ${templateData.fin_status === 'clean' ? 'bg-green-500 shadow-[0_0_10px_rgba(34,197,94,0.5)]' : 'bg-gray-800'}`}></div>
                                <div class={`w-2.5 h-2.5 rounded-full ${templateData.fin_status === 'partial' ? 'bg-yellow-500 shadow-[0_0_10px_rgba(234,179,8,0.5)]' : 'bg-gray-800'}`}></div>
                                <div class={`w-2.5 h-2.5 rounded-full ${templateData.fin_status === 'debt' ? 'bg-red-500 shadow-[0_0_10px_rgba(239,68,68,0.5)]' : 'bg-gray-800'}`}></div>
                            </div>
                        </div>

                        <div class="space-y-1">
                            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">Saldo Pendiente</p>
                            <p class={`text-4xl font-black tracking-tighter ${templateData.debt_amount > 0 ? 'text-white' : 'text-gray-700'}`}>
                                ${Number(templateData.debt_amount || 0).toLocaleString()}
                            </p>
                        </div>

                        <div class={`px-4 py-3 rounded-2xl text-[11px] font-bold ${
                            templateData.fin_status === 'clean' ? 'bg-green-500/10 text-green-500 border border-green-500/20' : 
                            'bg-red-500/10 text-red-500 border border-red-500/20'
                        }`}>
                            <i class="fas fa-info-circle mr-2"></i>
                            {templateData.fin_status === 'clean' ? 'Tu cuenta se encuentra al día.' : 'Tienes pagos pendientes de regularizar.'}
                        </div>
                    </div>

                    <!-- Vendedor Mobile/Quick Access -->
                    <div class="bg-[#141414] border border-white/5 rounded-[2.5rem] p-8 flex flex-col justify-between">
                        <div class="flex items-start justify-between">
                            <div>
                                <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest mb-1">Vendedor Asignado</p>
                                <h3 class="text-xl font-bold text-white">{templateData.seller_name}</h3>
                            </div>
                            <div class="w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center text-gray-400">
                                <i class="fas fa-user-tie"></i>
                            </div>
                        </div>
                        
                        <div class="pt-6">
                            <a href={`https://wa.me/549${templateData.seller_phone}`} class="w-full bg-[#25D366] hover:bg-[#128C7E] text-[#0a0a0a] font-black py-4 rounded-2xl flex items-center justify-center gap-3 transition-all uppercase text-xs tracking-widest">
                                <i class="fab fa-whatsapp text-lg"></i> Consultar por WhatsApp
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Pedidos Section -->
                <section class="space-y-4">
                    <div class="flex items-center justify-between px-2">
                        <h2 class="text-xl font-black text-white uppercase tracking-tighter flex items-center gap-3">
                            Mis Pedidos <span class="bg-white/5 px-2 py-0.5 rounded text-xs text-gray-500 font-normal">{pedidos.length}</span>
                        </h2>
                    </div>

                    {processedPedidos.length > 0 ? (
                        <div class="bg-[#141414] border border-white/5 rounded-[2.5rem] overflow-hidden shadow-2xl">
                            <div class="overflow-x-auto">
                                <table class="w-full text-left">
                                    <thead>
                                        <tr class="bg-white/2 text-[10px] font-black text-gray-500 uppercase tracking-widest">
                                            <th class="px-8 py-6">Fecha</th>
                                            <th class="px-8 py-6">Num. Pedido</th>
                                            <th class="px-8 py-6">Importe</th>
                                            <th class="px-8 py-6">Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-white/5">
                                        {processedPedidos.map((p: any) => (
                                            <tr class="hover:bg-white/2 transition-colors">
                                                <td class="px-8 py-6 text-sm text-gray-400">{new Date(p.created_at).toLocaleDateString()}</td>
                                                <td class="px-8 py-6 text-sm font-mono text-primary font-bold">{p.tracking_code || '---'}</td>
                                                <td class="px-8 py-6 text-sm font-black text-white">${Number(p.total_amount).toLocaleString()}</td>
                                                <td class="px-8 py-6">
                                                    <span class={`px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-wider border ${
                                                        p.status === 'pending' ? 'bg-yellow-500/10 text-yellow-500 border-yellow-500/20' :
                                                        p.status === 'processing' ? 'bg-blue-500/10 text-blue-500 border-blue-500/20' :
                                                        p.status === 'cut' ? 'bg-purple-500/10 text-purple-500 border-purple-500/20' :
                                                        'bg-green-500/10 text-green-500 border-green-500/20'
                                                    }`}>
                                                        {p.status}
                                                    </span>
                                                </td>
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    ) : (
                        <div class="bg-[#141414] border border-dashed border-white/10 rounded-[2.5rem] p-20 text-center">
                            <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-700">
                                <i class="fas fa-shopping-bag text-3xl"></i>
                            </div>
                            <h3 class="text-white font-bold mb-1">Sin movimientos aún</h3>
                            <p class="text-gray-500 text-sm">Tus pedidos aparecerán aquí una vez que los realices.</p>
                        </div>
                    )}
                </section>

                <!-- Danger Zone -->
                <div class="pt-20 border-t border-white/5 flex justify-center">
                    <button class="text-gray-600 hover:text-red-500 text-[10px] font-bold uppercase tracking-widest transition-colors flex items-center gap-2" id="deleteAccount">
                        <i class="fas fa-trash-alt text-[8px]"></i> Gestionar privacidad de mi cuenta
                    </button>
                </div>
            </div>
        </main>
    </div>

    <BottomNav />

    <script is:inline>
        document.getElementById('deleteAccount').addEventListener('click', async () => {
            if (confirm('¿Deseas solicitar la eliminación de tus datos? Esta acción requiere confirmación con tu vendedor.')) {
                alert('Solicitud enviada. Tu vendedor se pondrá en contacto pronto.');
            }
        });
    </script>
</body>
</html>
