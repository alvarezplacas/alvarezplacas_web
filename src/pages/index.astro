---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Hero from '@components/Hero.astro';
---

<Layout title="Alvarez Placas - Proveedor para Profesionales de la Madera y Diseño">
	
	<!-- 0. Main Navigation Header -->
	<Header />

	<!-- 1. Hero Carousel (con Quick Nav y Live Status Card) -->
	<Hero />

	<!-- 2. Features / Services (Optimizador, Pedidos Online, Descargas) -->
	<section class="features-services">
		<!-- TODO: Implement Features -->
	</section>

	<!-- 3. Promotional Products (Ofertas Imperdibles) -->
	<section class="promotional-products">
		<!-- TODO: Implement Offers -->
	</section>

	<!-- 4. Magazine / News (Novedades y Tendencias) -->
	<section class="magazine-news">
		<!-- TODO: Implement News -->
	</section>

	<!-- 5. Virtual Tour (Recorré Nuestro Local) -->
	<section class="virtual-tour">
		<!-- TODO: Implement 360 Viewer -->
	</section>

	<!-- 6. Client Projects (Proyectos de Clientes) -->
	<section class="client-projects">
		<!-- TODO: Implement Projects Carousel -->
	</section>

	<!-- 7. Google Reviews (Opiniones en Google) -->
	<section class="google-reviews">
		<!-- TODO: Implement Reviews -->
	</section>

    <!-- 8. Club de Clientes Section -->
    <section class="py-20 bg-gradient-to-br from-jet-black to-[#111111] relative overflow-hidden">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2"></div>
        
        <div class="max-w-6xl mx-auto px-4 relative z-10">
            <div class="bg-[#1a1a1a] border border-white/5 rounded-[2rem] p-8 md:p-16 flex flex-col md:flex-row items-center gap-12 shadow-2xl">
                <div class="flex-1 text-center md:text-left">
                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold uppercase mb-6 tracking-widest">
                        <i class="fas fa-crown"></i> Beneficio Exclusivo
                    </div>
                    <h2 class="text-4xl md:text-6xl font-extrabold text-white mb-6 leading-tight">
                        Únete al <br/><span class="text-primary italic">Club de Clientes</span>
                    </h2>
                    <p class="text-gray-400 text-lg mb-8 max-w-xl leading-relaxed">
                        Si eres profesional del diseño o la madera, accede a un panel exclusivo para seguir tus pedidos, sumar puntos por cada compra y recibir atención personalizada.
                    </p>
                    <div class="flex flex-col sm:flex-row items-center gap-4 justify-center md:justify-start">
                        <a href="/cliente/registro" class="w-full sm:w-auto px-8 py-4 bg-primary hover:bg-primary-dark text-white font-bold rounded-xl transition-all shadow-lg shadow-primary/20 flex items-center justify-center gap-2">
                            Registrarme ahora <i class="fas fa-arrow-right"></i>
                        </a>
                        <a href="/login" class="w-full sm:w-auto px-8 py-4 bg-white/5 hover:bg-white/10 text-white font-bold rounded-xl border border-white/10 transition-all flex items-center justify-center gap-2">
                            Ya tengo cuenta <i class="fas fa-sign-in-alt"></i>
                        </a>
                    </div>
                </div>
                
                <div class="flex-1 relative order-first md:order-last">
                    <div class="relative z-10 bg-gradient-to-tr from-primary to-orange-500 p-1 rounded-3xl rotate-3 hover:rotate-0 transition-transform duration-500 shadow-2xl">
                        <div class="bg-[#0a0a0a] rounded-[1.4rem] p-6">
                            <div class="flex items-center gap-4 mb-6">
                                <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                                    <i class="fas fa-user-circle text-2xl"></i>
                                </div>
                                <div>
                                    <div class="h-3 w-32 bg-white/10 rounded-full mb-2"></div>
                                    <div class="h-2 w-20 bg-white/5 rounded-full"></div>
                                </div>
                            </div>
                            <div class="space-y-4">
                                <div class="bg-white/5 h-20 rounded-xl p-4 flex items-center justify-between">
                                    <div class="space-y-2">
                                        <div class="h-2 w-24 bg-white/10 rounded-full"></div>
                                        <div class="h-2 w-16 bg-white/5 rounded-full"></div>
                                    </div>
                                    <div class="w-10 h-10 rounded-lg bg-green-500/20 text-green-500 flex items-center justify-center">
                                        <i class="fas fa-check"></i>
                                    </div>
                                </div>
                                <div class="bg-white/5 h-12 rounded-xl p-3 flex items-center gap-3">
                                    <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center text-[10px] text-primary">
                                        <i class="fas fa-star"></i>
                                    </div>
                                    <div class="h-2 w-32 bg-white/10 rounded-full"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Decorative elements -->
                    <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-primary rounded-full mix-blend-screen filter blur-xl opacity-30 animate-pulse"></div>
                    <div class="absolute -top-6 -left-6 w-32 h-32 bg-blue-500 rounded-full mix-blend-screen filter blur-xl opacity-20 animate-pulse"></div>
                </div>
            </div>
        </div>
    </section>

</Layout>
