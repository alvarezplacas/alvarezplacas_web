---
import AdminLayout from '@layouts/AdminLayout.astro';
import StatCard from '@features/dashboard/components/StatCard.astro';
import OrderList from '@features/dashboard/components/OrderList.astro';
import { Order } from '@domain/order.js';
import { query } from '@lib/db.js';

// Fetch real stats from DB
const statsResult = await Promise.all([
    query("SELECT COUNT(*) FROM orders WHERE created_at >= NOW() - INTERVAL '1 day'"),
    query("SELECT COUNT(*) FROM budgets WHERE created_at >= NOW() - INTERVAL '1 day'"),
    query("SELECT COUNT(*) FROM orders WHERE status IN ('Pendiente', 'En proceso')"),
    query("SELECT COUNT(*) FROM users WHERE role = 'client'"),
    query(`
        SELECT o.*, u.full_name as cliente_name 
        FROM orders o 
        LEFT JOIN users u ON o.client_id = u.id 
        ORDER BY o.created_at DESC 
        LIMIT 5
    `)
]);

const newOrdersCount = parseInt(statsResult[0].rows[0]?.count || '0');
const budgetsCount = parseInt(statsResult[1].rows[0]?.count || '0');
const pendingCutsCount = parseInt(statsResult[2].rows[0]?.count || '0');
const activeClientsCount = parseInt(statsResult[3].rows[0]?.count || '0');

// Map DB orders to the format expected by OrderList
const recentOrders = statsResult[4].rows.map(row => ({
    id: row.id.toString(),
    cliente: row.cliente_name || 'Consumidor Final',
    status: row.status,
    logistica: row.logistics
}));
---

<AdminLayout title="Dashboard General">
    
    <!-- Welcome Header -->
    <div class="mb-8">
        <h2 class="text-3xl font-bold text-white mb-2">Bienvenido, Javier 👋</h2>
        <p class="text-gray-400">Aquí tienes un resumen rápido de lo que está sucediendo en <span class="text-primary font-semibold">Alvarez Placas</span> hoy.</p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <StatCard 
            label="Nuevos Pedidos" 
            value={newOrdersCount.toString()} 
            icon="fa-shopping-cart" 
            color="primary" 
            trend={{ value: 'Real', isUp: true, label: 'datos en vivo' }}
        />
        <StatCard 
            label="Presupuestos" 
            value={budgetsCount.toString()}
            icon="fa-calculator" 
            color="blue" 
            trend={{ value: 'Real', isUp: true, label: 'datos en vivo' }}
        />
        <StatCard 
            label="Cortes Pendientes" 
            value={pendingCutsCount.toString()}
            icon="fa-cut" 
            color="purple" 
            trend={{ value: 'Filtro', isUp: false, label: 'pendientes/proceso' }}
        />
        <StatCard 
            label="Clientes Activos" 
            value={activeClientsCount.toString()}
            icon="fa-users" 
            color="green" 
            trend={{ value: 'Total', isUp: true, label: 'en club' }}
        />
    </div>

    <!-- Quick Actions & Recent Activity -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Quick Actions (Left, 2 cols width on large screens) -->
        <div class="lg:col-span-2 space-y-6">
            
            <div class="bg-[#1a1a1a] border border-gray-800 rounded-xl p-6 shadow-lg">
                <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                    <i class="fas fa-bolt text-yellow-500"></i> Accesos Rápidos
                </h3>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <a href="/admin/catalogo" class="flex items-center gap-4 p-4 rounded-lg bg-white/5 hover:bg-white/10 border border-transparent hover:border-gray-600 transition-all group">
                        <div class="w-10 h-10 rounded-full bg-primary/20 text-primary flex items-center justify-center group-hover:scale-110 transition-transform">
                            <i class="fas fa-file-excel"></i>
                        </div>
                        <div>
                            <h4 class="text-white font-semibold">Subir Catálogo</h4>
                            <p class="text-xs text-gray-400">Actualizar precios y placas</p>
                        </div>
                    </a>
                    
                    <a href="#" class="flex items-center gap-4 p-4 rounded-lg bg-white/5 hover:bg-white/10 border border-transparent hover:border-gray-600 transition-all group">
                        <div class="w-10 h-10 rounded-full bg-blue-500/20 text-blue-400 flex items-center justify-center group-hover:scale-110 transition-transform">
                            <i class="fas fa-search-dollar"></i>
                        </div>
                        <div>
                            <h4 class="text-white font-semibold">Revisar Presupuestos</h4>
                            <p class="text-xs text-gray-400">Ver pedidos pendientes</p>
                        </div>
                    </a>

                    <a href="#" class="flex items-center gap-4 p-4 rounded-lg bg-white/5 hover:bg-white/10 border border-transparent hover:border-gray-600 transition-all group">
                        <div class="w-10 h-10 rounded-full bg-green-500/20 text-green-400 flex items-center justify-center group-hover:scale-110 transition-transform">
                            <i class="fas fa-user-plus"></i>
                        </div>
                        <div>
                            <h4 class="text-white font-semibold">Nuevo Cliente</h4>
                            <p class="text-xs text-gray-400">Registro manual</p>
                        </div>
                    </a>

                    <a href="#" class="flex items-center gap-4 p-4 rounded-lg bg-white/5 hover:bg-white/10 border border-transparent hover:border-gray-600 transition-all group">
                        <div class="w-10 h-10 rounded-full bg-purple-500/20 text-purple-400 flex items-center justify-center group-hover:scale-110 transition-transform">
                            <i class="fas fa-bullhorn"></i>
                        </div>
                        <div>
                            <h4 class="text-white font-semibold">Anuncio Global</h4>
                            <p class="text-xs text-gray-400">Notificar a carpinteros</p>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Configuración Global -->
            <div class="bg-[#1a1a1a] border border-gray-800 rounded-xl p-6 shadow-lg">
                <h3 class="text-lg font-bold text-white mb-6 flex items-center gap-2">
                    <i class="fas fa-cogs text-blue-500"></i> Configuración del Catálogo
                </h3>
                
                <div class="space-y-4">
                    <div class="flex items-center justify-between p-4 rounded-lg bg-white/5 border border-gray-800">
                        <div>
                            <h4 class="text-white font-semibold italic text-primary">MODO MANTENIMIENTO</h4>
                            <p class="text-xs text-gray-400">Si se activa, los clientes verán la página de "Estamos Actualizando".</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="maintToggle" class="sr-only peer">
                            <div class="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary shadow-[0_0_15px_rgba(255,255,0,0.2)]"></div>
                        </label>
                    </div>

                    <div class="flex items-center justify-between p-4 rounded-lg bg-white/5 border border-gray-800">
                        <div>
                            <h4 class="text-white font-semibold">Mostrar Precios al Cliente</h4>
                            <p class="text-xs text-gray-400">Si se desactiva, el cliente verá "Consultar" en lugar del precio.</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="priceToggle" class="sr-only peer">
                            <div class="w-11 h-6 bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                        </label>
                    </div>
                </div>
            </div>

            <!-- TODO: Add Chart widget here later -->

        </div>

        <!-- Recent Activity Sidebar (Right, 1 col width) -->
        <OrderList orders={recentOrders} />
    </div>

    <script>
        const priceToggle = document.getElementById('priceToggle');
        const maintToggle = document.getElementById('maintToggle');
        
        // Cargar estado inicial desde el servidor
        async function loadSettings() {
            try {
                const res = await fetch('/api/settings');
                const settings = await res.json();
                
                if (priceToggle) priceToggle.checked = settings.show_prices !== 'false';
                if (maintToggle) maintToggle.checked = settings.maintenance_mode === 'true';
            } catch (err) {
                console.error('Error cargando ajustes:', err);
            }
        }

        async function updateSetting(key, value) {
            try {
                await fetch('/api/settings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ key, value: String(value) })
                });
            } catch (err) {
                console.error('Error actualizando ajuste:', err);
                alert('No se pudo guardar el cambio en el servidor.');
            }
        }
        
        if (priceToggle) {
            priceToggle.addEventListener('change', (e) => updateSetting('show_prices', e.target.checked));
        }

        if (maintToggle) {
            maintToggle.addEventListener('change', (e) => {
                updateSetting('maintenance_mode', e.target.checked);
            });
        }

        loadSettings();
    </script>
    </div>

</AdminLayout>
