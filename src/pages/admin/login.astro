---
import Layout from '@layouts/Layout.astro';

let error = '';

if (Astro.request.method === 'POST') {
    const data = await Astro.request.formData();
    const user = data.get('user');
    const pass = data.get('password');

    const isAdmin = (user === 'alvarezjavierh@gmail.com' || user === 'Javier' || user === 'javier') && pass === 'Tecno121212';

    if (isAdmin) {
        Astro.cookies.set('admin_session', 'authenticated_javier', { path: '/', httpOnly: true });
        return Astro.redirect('/admin');
    } else {
        error = 'Usuario o contraseña incorrectos';
    }
}
---

<Layout title="Admin Login - Alvarez Placas">
    <div class="min-h-screen flex items-center justify-center bg-[#0a0a0a] px-4">
        <div class="max-w-md w-full bg-[#1a1a1a] border border-gray-800 p-8 rounded-3xl shadow-2xl">
            <div class="text-center mb-8">
                <i class="fas fa-lock text-primary text-4xl mb-4"></i>
                <h1 class="text-2xl font-bold text-white uppercase tracking-tighter">Acceso Administrativo</h1>
                <p class="text-gray-400 text-sm">Ingrese sus credenciales para continuar</p>
            </div>

            <form method="POST" class="space-y-6">
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-2 ml-1">Usuario</label>
                    <input type="text" name="user" required class="w-full bg-black/50 border border-gray-700 rounded-xl px-4 py-3 text-white outline-none focus:border-primary transition-all" placeholder="Nombre de usuario" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-2 ml-1">Contraseña</label>
                    <input type="password" name="password" required class="w-full bg-black/50 border border-gray-700 rounded-xl px-4 py-3 text-white outline-none focus:border-primary transition-all" placeholder="••••••••" />
                </div>

                {error && <p class="text-red-500 text-xs font-bold text-center italic">{error}</p>}

                <button type="submit" class="w-full py-4 bg-primary hover:bg-primary-dark text-black font-black rounded-xl uppercase tracking-widest transition-all shadow-[0_0_20px_rgba(255,40,0,0.2)]">
                    Ingresar
                </button>
            </form>
        </div>
    </div>
</Layout>
