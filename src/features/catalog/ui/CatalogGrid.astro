---
import CatalogItem from '../components/CatalogItem.astro';
import CatalogFilters from '../components/CatalogFilters.astro';
import { createDirectus, rest, readItems } from '@directus/sdk';

const getEnv = () => {
    if (typeof import.meta !== 'undefined' && import.meta.env) return import.meta.env;
    return process.env;
};

const env = getEnv();
const DIRECTUS_URL = env.DIRECTUS_URL || 'https://admin.alvarezplacas.com.ar';
const directus = createDirectus(DIRECTUS_URL).with(rest());

let initialItems = [];
let showPrices = true;

try {
  // 1. Obtener Ajustes de Sitio
  const settings = await directus.request(readItems('site_settings', {
    filter: { key: { _eq: 'show_prices' } },
    limit: 1
  }));
  if (settings && settings.length > 0) {
    showPrices = settings[0].value !== 'false';
  }

  // 2. Obtener Catálogo Completo
  const productos = await directus.request(readItems('productos', {
    limit: -1,
    fields: ['*','marca_id.nombre','categoria_id.nombre','linea_id.nombre'],
    filter: { status: { _eq: 'published' } }
  }));

  initialItems = (productos || []).map(prod => {
    const marca = prod.marca_id?.nombre || "Varios";
    const linea = prod.linea_id?.nombre || "Estándar";
    const categoria = prod.categoria_id?.nombre || "General";
    
    // Imagen Jerárquica: /Placas/Marca/Linea/Nombre.avif
    const imagePath = `/Placas/${marca}/${linea}/${prod.nombre}.avif`;

    // Formato de Precio
    let priceFormatted = "Consultar";
    if (prod.precio) {
       const p = parseFloat(prod.precio);
       if (!isNaN(p)) {
         priceFormatted = `$${p.toLocaleString('es-AR', {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
       }
    }

    return {
      id: prod.id,
      original: prod.nombre,
      brand: marca,
      category: categoria,
      name: prod.nombre,
      specs: prod.atributos ? Object.values(prod.atributos).filter(Boolean) : [],
      price: priceFormatted,
      code: prod.sku || `SKU-${prod.id}`,
      imagen: imagePath,
      localMatch: true, // Asumimos true para que intente cargar .avif
      status: "Directus",
      tags: prod.tags || []
    };
  });
} catch (e) {
  console.error("Error fetching catalog from Directus SDK:", e);
}

// Preparar marcas y categorías para filtros
const marcasRaw = [...new Set(initialItems.map((item) => item.brand))].filter(m => m && m !== "Varios");
const categoriasRaw = [...new Set(initialItems.map((item) => item.category))].filter(c => c);

const marcas = ["Todos", ...marcasRaw.sort()];
const categorias = ["Todas", ...categoriasRaw.sort()];

// Construir mapa de Marcas por Categoría
const brandsByCategory = {};
categoriasRaw.forEach(cat => {
  brandsByCategory[cat] = [...new Set(initialItems.filter(i => i.category === cat).map(i => i.brand))].filter(b => b && b !== "Varios").sort();
});
brandsByCategory["Todas"] = marcasRaw.sort();
---


<section class="max-w-7xl mx-auto px-4 py-12 relative">
  <div class="text-center mb-12">
    <h2 class="text-3xl md:text-5xl font-bold text-white mb-4">
      Catálogo <span class="text-primary">Unificado</span>
    </h2>
    <p class="text-gray-400">Todo lo que necesitás en un solo lugar. Placas, Herrajes, Químicos y Herramientas.</p>
  </div>

  <CatalogFilters 
    marcas={marcas} 
    categorias={categorias} 
    brandsByCategory={brandsByCategory} 
    totalProducts={initialItems.length}
  />

  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6" id="catalogGrid">
    {initialItems.map((item) => (
      <CatalogItem placa={item} showPrices={showPrices} />
    ))}
  </div>

  {initialItems.length === 0 && (
    <div class="text-center py-24 bg-[#151515] rounded-3xl border border-dashed border-gray-800" id="noResults">
      <i class="fas fa-search text-5xl text-gray-700 mb-6"></i>
      <h3 class="text-xl font-bold text-white mb-2">No se encontraron productos</h3>
      <p class="text-gray-500">Estamos actualizando el catálogo. Por favor, intenta de nuevo en unos minutos.</p>
    </div>
  )}

  <!-- Modal Desktop (Horizontal Layout) -->
  <div id="productModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 sm:p-6 opacity-0 transition-opacity duration-300">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm modal-backdrop close-modal"></div>
    
    <!-- Modal Content (Horizontal Card) -->
    <div class="bg-[#1a1a1a] rounded-2xl overflow-hidden shadow-2xl shadow-primary/20 w-full max-w-5xl relative z-10 flex flex-col md:flex-row max-h-[90vh] transform scale-95 transition-transform duration-300" id="modalCard">
      
      <!-- Close Button -->
      <button class="absolute top-4 right-4 z-30 p-2 bg-black/50 hover:bg-primary text-white rounded-full backdrop-blur-md transition-colors close-modal outline-none">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>

      <!-- Left Side: Large Image -->
      <div class="w-full md:w-3/5 bg-[#0a2e2e] relative min-h-[300px] md:min-h-0">
        <img id="modalImage" src="" alt="Placa" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute top-4 left-4 z-20">
          <span id="modalMarcaBadge" class="bg-primary text-white text-xs font-bold px-3 py-1.5 rounded uppercase tracking-wider shadow-lg"></span>
        </div>
      </div>

      <!-- Right Side: Details & Actions -->
      <div class="w-full md:w-2/5 p-8 flex flex-col bg-[#1a1a1a] md:border-l border-gray-800 overflow-y-auto custom-scrollbar">
        <div class="mb-8">
          <h2 id="modalNombre" class="text-3xl md:text-4xl font-bold text-white mb-2 leading-tight"></h2>
        </div>

        <div class="space-y-4 mb-8 flex-grow">
          <!-- Detalles dinámicos -->
          <div class="flex flex-col border-b border-gray-800 pb-3">
            <span class="text-gray-500 text-xs font-semibold uppercase tracking-wider mb-1">Código</span>
            <span id="modalCodigo" class="text-white font-medium text-lg"></span>
          </div>
          <div class="flex flex-col border-b border-gray-800 pb-3">
            <span class="text-gray-500 text-xs font-semibold uppercase tracking-wider mb-1">Línea</span>
            <span id="modalLinea" class="text-white font-medium text-lg"></span>
          </div>
          <div class="flex flex-col border-b border-gray-800 pb-3">
            <span class="text-gray-500 text-xs font-semibold uppercase tracking-wider mb-1">Acabado</span>
            <span id="modalAcabado" class="text-white font-medium text-lg capitalize"></span>
          </div>
          <div class="flex flex-col pb-3">
            <span class="text-gray-500 text-xs font-semibold uppercase tracking-wider mb-1">Color</span>
            <span id="modalColor" class="text-white font-medium text-lg capitalize"></span>
          </div>
        </div>

        <!-- Botones de Acción -->
        <div class="flex flex-col gap-4 mt-auto">
          <a id="modalWhatsAppBtn" href="#" target="_blank" class="w-full bg-[#25D366] hover:bg-[#1ebd5a] text-white font-bold py-4 px-6 rounded-xl flex items-center justify-center gap-3 transition-colors shadow-lg">
            <i class="fab fa-whatsapp text-xl"></i>
            Consultar Presupuesto
          </a>
          <button id="modalSmartMatchBtn" class="w-full bg-primary hover:bg-primary-light text-white font-bold py-4 px-6 rounded-xl flex items-center justify-center gap-3 transition-colors shadow-lg shadow-primary/20">
            <i class="fas fa-magic"></i>
            Sugerir Combinación
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initCatalog } from './catalog-logic.js';
  
  // Inicialización para Astro (View Transitions friendly)
  document.addEventListener('astro:page-load', () => {
    initCatalog();
  });

  // Fallback para carga inicial sin transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCatalog);
  } else {
    initCatalog();
  }
</script>
